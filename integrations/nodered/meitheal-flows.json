    ],
    "x": 180,
    "y": 440,
    "wires": [["meitheal-debug-test"]]
  },
  {
    "id": "meitheal-debug-test",
    "type": "debug",
    "z": "meitheal-tab",
    "name": "Debug: Test Event ✓",
    "active": true,
    "tosidebar": true,
    "console": false,
    "tostatus": true,
    "complete": "payload",
    "targetType": "msg",
    "statusVal": "payload.title",
    "statusType": "auto",
    "x": 460,
    "y": 440,
    "wires": []
  }
