      "id": 4,
      "title": "Auth Failure Breakdown",
      "type": "piechart",
      "targets": [
        {
          "expr": "sum by (route) (count_over_time({service=\"meitheal\", domain=\"integrations\", component=\"vikunja-compat\"} |= \"compat.request.completed\" | json | err_code = \"auth_failed\" [1h]))",
          "legendFormat": "{{route}}"
        }
      ]
