      "id": 1,
      "title": "Compat Request Rate (5m)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate({service=\"meitheal\", domain=\"integrations\", component=\"vikunja-compat\"} |= \"compat.request.completed\" | json | status >= 0 [5m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "meitheal-loki" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "Compat Error Rate (5m)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate({service=\"meitheal\", domain=\"integrations\", component=\"vikunja-compat\"} |= \"compat.request.completed\" | json | status >= 400 [5m])) by (route, err_code)",
          "legendFormat": "{{route}} [{{err_code}}]"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "meitheal-loki" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 5 },
      "id": 3,
      "title": "Compat P95 Latency (ms)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "quantile_over_time(0.95, {service=\"meitheal\", domain=\"integrations\", component=\"vikunja-compat\"} |= \"compat.request.completed\" | json | unwrap duration_ms [5m]) by (route)",
          "legendFormat": "p95 {{route}}"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "meitheal-loki" },
      "fieldConfig": { "defaults": {} },
