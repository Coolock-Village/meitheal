# Meitheal Devcontainer — Default Environment
# These values are used by docker-compose.yml. Override locally by creating
# a .env.local file (gitignored) or setting env vars in your shell.

# Timezone (used by Grocy and Node-RED)
TZ=Europe/Dublin

# Grocy default credentials (linuxserver image default)
# Change these after first login at http://localhost:9192
# Default: admin / admin

# Node-RED credential encryption secret
NODE_RED_CREDENTIAL_SECRET=dev-secret

# Compose project name (keeps volumes/networks namespaced)
COMPOSE_PROJECT_NAME=meitheal-dev
