---
import { t } from "../../i18n/translations";
import type { Locale } from "../../lib/locale";
import HelpTooltip from "../ui/HelpTooltip.astro";
import EntitySelector from "../ui/EntitySelector.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<div id="tab-integrations" class="tab-pane" style="display: none;">
  <div class="integrations-layout">
    <div class="integrations-header">
      <div>
        <h2 class="integrations-title">
          {t("settings.integrations_title", locale)}
        </h2>
        <p class="integrations-subtitle">
          {t("settings.integrations_subtitle", locale)}
        </p>
      </div>
    </div>

    <!-- ═══════ Home Assistant ═══════ -->
    <div class="integration-card" id="integration-ha">
      <button
        type="button"
        class="integration-card__header"
        aria-expanded="false"
        aria-controls="integration-ha-body"
      >
        <div class="integration-card__title-row">
          <span class="integration-card__icon">🏠</span>
          <div class="integration-card__title-info">
            <strong>Home Assistant</strong>
            <span class="integration-card__desc"
              >Connection and integration settings</span
            >
          </div>
        </div>
        <div class="integration-card__header-right">
          <button
            type="button"
            class="info-btn"
            data-explainer="ha"
            aria-label="What is Home Assistant integration?"
            onclick="event.stopPropagation()">ℹ️</button
          >
          <span class="badge badge-pending" id="ha-connection-badge"
            >Checking…</span
          >
          <span class="integration-card__chevron">▸</span>
        </div>
      </button>

      <div
        class="integration-card__body"
        id="integration-ha-body"
        aria-hidden="true"
      >
        <!-- Connection Status Display -->
        <div id="ha-connection-status" class="ha-status-row">
          <div class="ha-status-row__left">
            <div
              class="ha-status-indicator ha-status-indicator--checking"
              id="ha-indicator"
            >
              <span class="ha-status-indicator__dot"></span>
            </div>
            <div class="ha-status-row__info">
              <span class="ha-status-row__mode" id="ha-mode-label"
                >Detecting connection…</span
              >
              <span class="ha-status-row__detail" id="ha-detail-label"></span>
            </div>
          </div>
        </div>

        <!-- HA Info Panel — shown when connected -->
        <div id="ha-info-panel" class="ha-info-panel" style="display: none;">
          <div class="ha-info-grid">
            <div class="ha-info-item">
              <span class="ha-info-item__label">Version</span>
              <span class="ha-info-item__value" id="ha-info-version">—</span>
            </div>
            <div class="ha-info-item">
              <span class="ha-info-item__label">Location</span>
              <span class="ha-info-item__value" id="ha-info-location">—</span>
            </div>
            <div class="ha-info-item">
              <span class="ha-info-item__label">Timezone</span>
              <span class="ha-info-item__value" id="ha-info-timezone">—</span>
            </div>
            <div class="ha-info-item">
              <span class="ha-info-item__label">Mode</span>
              <span class="ha-info-item__value" id="ha-info-mode">—</span>
            </div>
          </div>
        </div>

        <!-- Test Connection -->
        <div class="integration-card__config" style="margin-top: 8px;">
          <div class="integration-card__actions">
            <button type="button" class="btn btn-ghost" id="test-connection">
              Test Connection
            </button>
          </div>
          <div id="ha-status" class="ha-test-result"></div>
        </div>

        <!-- Advanced / Standalone Mode -->
        <details class="ha-advanced-section" id="ha-advanced-section">
          <summary class="ha-advanced-toggle">
            <span>⚙ Advanced — Standalone Mode</span>
            <small>Only needed if running outside Home Assistant</small>
          </summary>
          <form id="ha-form" class="ha-advanced-form">
            <div class="form-group">
              <label class="form-label" for="ha-url">HA URL</label>
              <input
                type="url"
                class="form-input"
                id="ha-url"
                placeholder="http://homeassistant.local:8123"
                pattern="https?://.*"
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="ha-token">
                Long-Lived Access Token
              </label>
              <input
                type="password"
                class="form-input"
                id="ha-token"
                placeholder="••••••••"
              />
              <small style="color: var(--text-muted); font-size: 12px;">
                Generate in HA → Profile → Long-Lived Access Tokens
              </small>
            </div>
            <div style="display: flex; gap: 8px;">
              <button type="submit" class="btn btn-primary" id="save-ha">
                💾 Save
              </button>
            </div>
          </form>
        </details>
      </div>
    </div>

    <!-- ═══════ Calendar Sync ═══════ -->
    <div class="integration-card" id="integration-calendar">
      <button
        type="button"
        class="integration-card__header"
        aria-expanded="false"
        aria-controls="integration-calendar-body"
      >
        <div class="integration-card__title-row">
          <span class="integration-card__icon">📅</span>
          <div class="integration-card__title-info">
            <strong>Calendar Sync</strong>
            <span class="integration-card__desc"
              >Bidirectional sync with HA calendars</span
            >
          </div>
        </div>
        <div class="integration-card__header-right">
          <button
            type="button"
            class="info-btn"
            data-explainer="calendar"
            aria-label="What is Calendar Sync?"
            onclick="event.stopPropagation()">ℹ️</button
          >
          <span class="badge badge-pending" id="cal-status">Checking…</span>
          <span class="integration-card__chevron">▸</span>
        </div>
      </button>

      <div
        class="integration-card__body"
        id="integration-calendar-body"
        aria-hidden="true"
      >
        <!-- HA auto-sync info callout -->
        <div
          id="cal-auto-info"
          class="integration-callout integration-callout--success"
          style="display: none;"
        >
          <strong>✓ Automatic sync active</strong>
          <span id="cal-auto-entity" class="mono-text"></span>
          <div class="integration-callout__detail">
            Running as an HA addon — Meitheal automatically detects your
            calendar entities and syncs events bidirectionally (past 7 days →
            next 30 days).
          </div>
        </div>

        <!-- Detected HA calendar entities -->
        <div id="cal-entities-list" style="display: none; margin-bottom: 12px;">
          <label class="form-label" style="font-size: 12px; margin-bottom: 6px;"
            >Detected Calendar Entities</label
          >
          <div id="cal-entities-container" class="entity-list-container"></div>
        </div>

        <div class="integration-card__config">
          <div class="form-group">
            <div class="form-label-row">
              <label class="form-label" for="cal-entity">Calendar Entity</label>
              <HelpTooltip
                text="The HA calendar entity Meitheal syncs tasks with. Calendar events become tasks, and tasks with due dates appear as calendar events. Meitheal creates this entity automatically when running as an addon."
                href="https://www.home-assistant.io/integrations/calendar/"
                id="help-cal-entity"
              />
            </div>
            <!-- Dropdown populated by JS from detected entities -->
            <select class="form-select" id="cal-entity">
              <option value="" disabled selected>Loading entities…</option>
            </select>
            <input
              type="text"
              class="form-input"
              id="cal-entity-manual"
              placeholder="calendar.meitheal_tasks"
              style="display: none; margin-top: 6px;"
            />
          </div>

          <!-- External CalDAV — collapsible -->
          <details class="caldav-section">
            <summary class="caldav-toggle">
              <span>📡 External Calendar (CalDAV)</span>
              <small
                >For Nextcloud, Radicale, Baikal — not needed for HA calendars</small
              >
            </summary>
            <div class="form-group" style="margin-top: 10px;">
              <div class="form-label-row">
                <label class="form-label" for="caldav-url">CalDAV URL</label>
                <HelpTooltip
                  text="For direct CalDAV sync with external calendar servers like Nextcloud, Radicale, or Baikal. Leave blank to use HA's built-in calendar integration only. When set, Meitheal will sync directly with your CalDAV server in addition to HA."
                  id="help-caldav"
                />
              </div>
              <input
                type="url"
                class="form-input"
                id="caldav-url"
                placeholder="https://your-server.com/dav/calendars/"
              />
            </div>
          </details>

          <div class="integration-card__actions">
            <button type="button" class="btn btn-primary" id="save-cal"
              >Save Calendar Settings</button
            >
            <button type="button" class="btn btn-ghost" id="test-cal"
              >Sync Now</button
            >
            <span id="cal-sync-result" class="integration-card__result"></span>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════ Todo Sync ═══════ -->
    <div class="integration-card" id="integration-todo">
      <button
        type="button"
        class="integration-card__header"
        aria-expanded="false"
        aria-controls="integration-todo-body"
      >
        <div class="integration-card__title-row">
          <span class="integration-card__icon">✅</span>
          <div class="integration-card__title-info">
            <strong>Todo Sync</strong>
            <span class="integration-card__desc"
              >Bridge HA todo lists with Meitheal</span
            >
          </div>
        </div>
        <div class="integration-card__header-right">
          <button
            type="button"
            class="info-btn"
            data-explainer="todo"
            aria-label="What is Todo Sync?"
            onclick="event.stopPropagation()">ℹ️</button
          >
          <span class="badge badge-pending" id="todo-status">Disabled</span>
          <span class="integration-card__chevron">▸</span>
        </div>
      </button>

      <div
        class="integration-card__body"
        id="integration-todo-body"
        aria-hidden="true"
      >
        <!-- Bridge purpose explainer -->
        <div
          class="integration-callout integration-callout--info"
          style="margin-bottom: 12px;"
        >
          <strong>🔗 HA Bridge</strong>
          <div class="integration-callout__detail">
            Bridges Home Assistant's built-in todo lists with Meitheal. Enable
            this so your HA dashboards and automations that use <code
              >todo.*</code
            > entities stay in sync with tasks managed here.
          </div>
        </div>
        <!-- HA auto-detect callout -->
        <div
          id="todo-auto-info"
          class="integration-callout integration-callout--success"
          style="display: none;"
        >
          <strong>✓ Todo list(s) detected</strong>
          <div id="todo-auto-entities" class="integration-callout__detail">
          </div>
        </div>

        <!-- Detected HA todo entities -->
        <div
          id="todo-entities-list"
          style="display: none; margin-bottom: 12px;"
        >
          <label class="form-label" style="font-size: 12px; margin-bottom: 6px;"
            >Detected Todo Entities</label
          >
          <div id="todo-entities-container" class="entity-list-container"></div>
        </div>

        <div class="integration-card__config">
          <div class="form-group">
            <div class="form-label-row">
              <label class="form-label" for="todo-enabled"
                >Enable Todo Sync</label
              >
              <HelpTooltip
                text="When enabled, Meitheal syncs tasks with your HA todo lists in real-time via WebSocket. Disabled by default to save power — enable only for lists you actively use."
                id="help-todo-enabled"
              />
            </div>
            <div style="display: flex; align-items: center; gap: 10px;">
              <label class="toggle-label">
                <input
                  type="checkbox"
                  id="todo-enabled"
                  aria-label="Enable or disable todo list sync"
                />
                <span class="toggle-slider"></span>
              </label>
              <span
                id="todo-enabled-label"
                style="font-size: 13px; color: var(--text-secondary);"
                >Off — sync disabled to save power</span
              >
            </div>
          </div>

          <div class="form-group">
            <div class="form-label-row">
              <label class="form-label" for="todo-entity">Todo Entity</label>
              <HelpTooltip
                text="The HA todo list entity to sync with. Each todo entity represents a list (e.g., shopping_list, chores). Meitheal will keep this list in sync bidirectionally."
                href="https://www.home-assistant.io/integrations/todo/"
                id="help-todo-entity"
              />
            </div>
            <EntitySelector
              domain="todo"
              id="todo-entity"
              placeholder="todo.shopping_list"
              helpText="Select from detected entities, or enter a custom entity ID."
            />
          </div>

          <div class="form-group">
            <div class="form-label-row">
              <label class="form-label" for="todo-sync-direction"
                >Sync Direction</label
              >
              <HelpTooltip
                text="Bidirectional keeps both Meitheal and HA in sync — changes in either place propagate. Inbound-only imports from HA without pushing back, which saves power and avoids write conflicts."
                id="help-todo-direction"
              />
            </div>
            <select class="form-select" id="todo-sync-direction">
              <option value="inbound">Import HA → Meitheal</option>
              <option value="outbound">Export Meitheal → HA</option>
              <option value="bidirectional" selected>Bidirectional sync</option>
            </select>
          </div>

          <div class="integration-card__actions">
            <button type="button" class="btn btn-primary" id="save-todo"
              >Save Todo Settings</button
            >
            <button type="button" class="btn btn-ghost" id="sync-todo"
              >Sync Now</button
            >
            <span id="todo-sync-result" class="integration-card__result"></span>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════ Grocy ═══════ -->
    <div class="integration-card" id="integration-grocy">
      <button
        type="button"
        class="integration-card__header"
        aria-expanded="false"
        aria-controls="integration-grocy-body"
      >
        <div class="integration-card__title-row">
          <span class="integration-card__icon">🛒</span>
          <div class="integration-card__title-info">
            <strong>Grocy</strong>
            <span class="integration-card__desc"
              >Household inventory & chore management</span
            >
          </div>
        </div>
        <div class="integration-card__header-right">
          <button
            type="button"
            class="info-btn"
            data-explainer="grocy"
            aria-label="What is Grocy integration?"
            onclick="event.stopPropagation()">ℹ️</button
          >
          <span class="badge badge-disabled" id="grocy-status"
            >Not configured</span
          >
          <span class="integration-card__chevron">▸</span>
        </div>
      </button>

      <div
        class="integration-card__body"
        id="integration-grocy-body"
        aria-hidden="true"
      >
        <!-- Grocy auto-detect callout -->
        <div
          id="grocy-auto-info"
          class="integration-callout integration-callout--success"
          style="display: none;"
          aria-live="polite"
        >
          <strong>✓ Grocy detected via HA</strong>
          <div class="integration-callout__detail">
            Grocy addon found — URL auto-populated from HA ingress. No
            additional setup needed.
          </div>
        </div>

        <div class="integration-card__config">
          <div class="form-group" id="grocy-url-group">
            <div class="form-label-row">
              <label class="form-label" for="grocy-url">Grocy URL</label>
              <HelpTooltip
                text="The URL of your Grocy instance. If running Grocy as a Home Assistant add-on, it's typically available at http://homeassistant.local:9192 or via the HA ingress proxy."
                id="help-grocy-url"
              />
            </div>
            <input
              type="url"
              class="form-input"
              id="grocy-url"
              placeholder="http://homeassistant.local:9192"
            />
          </div>
          <div class="form-group" id="grocy-key-group">
            <div class="form-label-row">
              <label class="form-label" for="grocy-key">API Key</label>
              <HelpTooltip
                text="Generate a Grocy API key in Grocy → Settings → API Keys → Add. This key allows Meitheal to read and write chores and tasks."
                id="help-grocy-key"
              />
            </div>
            <input
              type="password"
              class="form-input"
              id="grocy-key"
              placeholder="••••••••"
            />
          </div>
          <!-- Custom config toggle for auto-detected installs -->
          <button
            type="button"
            class="btn btn-ghost"
            id="grocy-custom-toggle"
            style="display: none; font-size: 12px; padding: 4px 8px; align-self: flex-start;"
          >
            ⚙ Custom configuration
          </button>
          <div class="form-group">
            <div class="form-label-row">
              <label class="form-label" for="grocy-sync-mode">Sync Mode</label>
              <HelpTooltip
                text="Controls how data flows between Grocy and Meitheal. Import pulls chores/products into tasks, Export pushes completed tasks to Grocy, and Bidirectional keeps both systems in sync."
                id="help-grocy-sync"
              />
            </div>
            <select class="form-select" id="grocy-sync-mode">
              <option value="import">Import Grocy → Meitheal</option>
              <option value="export">Export Meitheal → Grocy</option>
              <option value="bidirectional">Bidirectional sync</option>
            </select>
          </div>
          <div class="integration-card__actions">
            <button type="button" class="btn btn-primary" id="save-grocy"
              >Save Grocy Settings</button
            >
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════ n8n / Node-RED ═══════ -->
    <div class="integration-card" id="integration-n8n">
      <button
        type="button"
        class="integration-card__header"
        aria-expanded="false"
        aria-controls="integration-n8n-body"
      >
        <div class="integration-card__title-row">
          <span class="integration-card__icon">⚙</span>
          <div class="integration-card__title-info">
            <strong>n8n / Node-RED</strong>
            <span class="integration-card__desc"
              >Automation workflow triggers</span
            >
          </div>
        </div>
        <div class="integration-card__header-right">
          <button
            type="button"
            class="info-btn"
            data-explainer="n8n"
            aria-label="What is n8n / Node-RED integration?"
            onclick="event.stopPropagation()">ℹ️</button
          >
          <span class="badge badge-disabled" id="n8n-status"
            >Not configured</span
          >
          <span class="integration-card__chevron">▸</span>
        </div>
      </button>

      <div
        class="integration-card__body"
        id="integration-n8n-body"
        aria-hidden="true"
      >
        <!-- HA addon auto-detect callout -->
        <div
          id="n8n-auto-info"
          class="integration-callout integration-callout--success"
          style="display: none;"
        >
          <strong>✓ Automation addon detected</strong>
          <div class="integration-callout__detail" id="n8n-auto-detail">
            Events are sent/received automatically via WebSocket — no additional
            webhook configuration needed.
          </div>
        </div>

        <!-- Mode toggle: HA Addon vs Standalone -->
        <div class="n8n-mode-toggle" style="margin-bottom: 12px;">
          <label class="form-label" style="margin-bottom: 6px;"
            >Integration Mode</label
          >
          <div class="mode-tabs">
            <button
              type="button"
              class="mode-tab mode-tab--active"
              id="n8n-mode-auto"
              data-mode="auto"
            >
              🏠 HA Addon (auto)
            </button>
            <button
              type="button"
              class="mode-tab"
              id="n8n-mode-standalone"
              data-mode="standalone"
            >
              🌐 Standalone
            </button>
          </div>
        </div>

        <!-- HA Addon mode content -->
        <div
          id="n8n-auto-content"
          class="integration-card__config"
          aria-live="polite"
        >
          <div class="integration-callout integration-callout--info">
            <strong>🔗 Automatic via WebSocket</strong>
            <div class="integration-callout__detail">
              Node-RED and n8n addons communicate with Meitheal automatically
              through the HA WebSocket. Select which events to broadcast below.
            </div>
          </div>
          <div
            id="n8n-auto-detect-info"
            class="integration-callout integration-callout--success"
            style="display: none;"
            aria-live="polite"
          >
            <strong>✓ Node-RED detected via HA</strong>
            <div class="integration-callout__detail">
              Node-RED addon found and connected automatically.
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Trigger Events</label>
            <div class="event-checkbox-grid">
              <label class="event-checkbox">
                <input
                  type="checkbox"
                  class="n8n-event"
                  value="task.created"
                  checked
                /> Created
              </label>
              <label class="event-checkbox">
                <input
                  type="checkbox"
                  class="n8n-event"
                  value="task.updated"
                  checked
                /> Updated
              </label>
              <label class="event-checkbox">
                <input
                  type="checkbox"
                  class="n8n-event"
                  value="task.completed"
                  checked
                /> Completed
              </label>
              <label class="event-checkbox">
                <input type="checkbox" class="n8n-event" value="task.deleted" /> Deleted
              </label>
            </div>
          </div>
          <div class="integration-card__actions">
            <button type="button" class="btn btn-primary" id="save-n8n"
              >Save n8n Settings</button
            >
          </div>
        </div>

        <!-- Standalone mode content -->
        <div
          id="n8n-standalone-content"
          class="integration-card__config"
          style="display: none;"
        >
          <div class="form-group">
            <div class="form-label-row">
              <label class="form-label" for="n8n-webhook-url">Webhook URL</label
              >
              <HelpTooltip
                text="The webhook URL from your n8n or Node-RED flow. Meitheal will POST a JSON payload to this URL whenever selected task events occur."
                id="help-n8n-url"
              />
            </div>
            <input
              type="url"
              class="form-input"
              id="n8n-webhook-url"
              placeholder="https://n8n.example.com/webhook/meitheal"
            />
          </div>
          <div class="form-group">
            <div class="form-label-row">
              <label class="form-label" for="n8n-api-key"
                >API Key (optional)</label
              >
              <HelpTooltip
                text="If your n8n/Node-RED instance requires authentication, enter the API key here. This is used in the Authorization header for webhook requests."
                id="help-n8n-apikey"
              />
            </div>
            <input
              type="password"
              class="form-input"
              id="n8n-api-key"
              placeholder="••••••••"
            />
          </div>
          <div class="form-group">
            <div class="form-label-row">
              <label class="form-label" for="n8n-secret"
                >Signing Secret (optional)</label
              >
              <HelpTooltip
                text="HMAC-SHA256 secret for signing webhook payloads. Verify the X-Meitheal-Signature header on your receiving end."
                id="help-n8n-secret"
              />
            </div>
            <input
              type="password"
              class="form-input"
              id="n8n-secret"
              placeholder="••••••••"
            />
          </div>
          <div class="form-group">
            <label class="form-label">Trigger Events</label>
            <div class="event-checkbox-grid">
              <label class="event-checkbox">
                <input
                  type="checkbox"
                  class="n8n-event-standalone"
                  value="task.created"
                  checked
                /> Created
              </label>
              <label class="event-checkbox">
                <input
                  type="checkbox"
                  class="n8n-event-standalone"
                  value="task.updated"
                  checked
                /> Updated
              </label>
              <label class="event-checkbox">
                <input
                  type="checkbox"
                  class="n8n-event-standalone"
                  value="task.completed"
                  checked
                /> Completed
              </label>
              <label class="event-checkbox">
                <input
                  type="checkbox"
                  class="n8n-event-standalone"
                  value="task.deleted"
                /> Deleted
              </label>
            </div>
          </div>
          <div class="integration-card__actions">
            <button
              type="button"
