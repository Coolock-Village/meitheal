<script>
  /**
   * Integration Card Collapse/Expand
   *
   * Handles the accordion-like behavior of integration cards.
   * Cards with configured integrations auto-expand on load.
   */
  function initIntegrationCards() {
    document.querySelectorAll(".integration-card__header").forEach((header) => {
      const btn = header as HTMLButtonElement;
      if (btn.dataset.cardInit) return;
      btn.dataset.cardInit = "true";

      function toggleCard() {
        const bodyId = btn.getAttribute("aria-controls");
        if (!bodyId) return;
        const body = document.getElementById(bodyId);
        if (!body) return;

        const isExpanded = btn.getAttribute("aria-expanded") === "true";
        btn.setAttribute("aria-expanded", String(!isExpanded));
        body.setAttribute("aria-hidden", String(isExpanded));
      }

      btn.addEventListener("click", toggleCard);

      // Keyboard: Enter and Space toggle
      btn.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          toggleCard();
        }
      });
    });
  }

  /**
   * Programmatically expand an integration card by its body ID.
   * Called from settings.astro restore functions when a card has config.
   */
  (window as any).expandIntegrationCard = function (bodyId: string) {
    const body = document.getElementById(bodyId);
    const header = document.querySelector(
      `[aria-controls="${bodyId}"]`,
    ) as HTMLButtonElement | null;
    if (body && header) {
      header.setAttribute("aria-expanded", "true");
      body.setAttribute("aria-hidden", "false");
    }
  };

  initIntegrationCards();
  document.addEventListener("astro:page-load", initIntegrationCards);

  /**
   * HA Connection Status Detection
   *
   * Auto-detects HA connection on page load. Updates status indicator,
   * info panel, and badge. Auto-expands the HA card when connected.
   *
   * Bounded context: integrations / ha-connection
   */
  async function initHAConnectionStatus() {
    const indicator = document.getElementById("ha-indicator");
    const modeLabel = document.getElementById("ha-mode-label");
    const detailLabel = document.getElementById("ha-detail-label");
    const badge = document.getElementById("ha-connection-badge");
    const infoPanel = document.getElementById("ha-info-panel");
    if (!indicator || !modeLabel || !badge) return;
    if (indicator.dataset.haInit) return;
    indicator.dataset.haInit = "true";

    try {
      const res = await fetch("/api/ha/connection");
      const data = (await res.json()) as Record<string, unknown>;

      if (data.connected) {
        indicator.className =
          "ha-status-indicator ha-status-indicator--connected";
        modeLabel!.textContent = `✓ Connected as HA Addon`;
        if (detailLabel) detailLabel.textContent = `HA ${data.version}`;
        badge!.textContent = "Connected";
        badge!.className = "badge badge-active";

        if (infoPanel) {
          infoPanel.style.display = "block";
          const setVal = (id: string, val: unknown) => {
            const el = document.getElementById(id);
            if (el) el.textContent = String(val ?? "—");
          };
          setVal("ha-info-version", data.version);
          setVal("ha-info-location", data.location_name);
          setVal("ha-info-timezone", data.time_zone);
          setVal("ha-info-mode", data.mode);
        }

        // Auto-expand HA card when connected
        if ((window as any).expandIntegrationCard) {
          (window as any).expandIntegrationCard("integration-ha-body");
        }
      } else {
        indicator.className = "ha-status-indicator";
        modeLabel!.textContent = "Not connected";
        if (detailLabel)
          detailLabel.textContent = String(data.mode ?? "Standalone");
        badge!.textContent = "Disconnected";
        badge!.className = "badge badge-pending";
      }
    } catch {
      indicator.className = "ha-status-indicator";
      modeLabel!.textContent = "Connection check failed";
      badge!.textContent = "Error";
      badge!.className = "badge badge-error";
    }
  }

  initHAConnectionStatus();
  document.addEventListener("astro:page-load", initHAConnectionStatus);

  /**
   * Integration Explainer Dialog
   *
   * Opens a native <dialog> with explainer content for each integration.
   * Content is defined inline to keep it colocated with the component.
   */
  const EXPLAINER_CONTENT: Record<string, { title: string; body: string }> = {
    ha: {
      title: "🏠 Home Assistant",
      body: `<p>Meitheal connects to Home Assistant via <strong>WebSocket</strong>, allowing it to consume and provide data automatically.</p>
             <p>When running as an HA addon, no configuration is needed — the connection is established through the Supervisor API with a built-in token.</p>
             <p>For standalone installs, enter your HA URL and a Long-Lived Access Token in the Advanced section.</p>`,
    },
    calendar: {
      title: "📅 Calendar Sync",
      body: `<p>Bidirectional sync between Meitheal tasks and HA calendar events. Tasks with due dates appear as calendar events, and calendar events become tasks.</p>
             <p>When connected to HA, select a calendar entity from the dropdown — Meitheal auto-detects available calendars. For external servers (Nextcloud, Radicale, Baikal), expand the CalDAV section.</p>
             <p>Sync window: past 7 days → next 30 days.</p>`,
    },
    todo: {
      title: "✅ Todo Sync",
      body: `<p>Bridges Home Assistant's built-in todo lists (<code>todo.*</code> entities) with Meitheal.</p>
             <p>This ensures your HA dashboards, automations, and voice assistants that use <code>todo.*</code> entities stay in sync with tasks managed here.</p>
             <p>Enable only for lists you actively use — disabled by default to save power.</p>`,
    },
    grocy: {
      title: "🛒 Grocy",
      body: `<p>Grocy is a household inventory and chore management system. This integration syncs Grocy chores and products with Meitheal tasks.</p>
             <p>When Grocy is running as an HA addon, Meitheal auto-detects it and fills in the URL automatically. For standalone Grocy servers, enter the URL and API key manually.</p>
             <p>Generate an API key in Grocy → Settings → API Keys.</p>`,
    },
    n8n: {
      title: "⚙ n8n / Node-RED",
      body: `<p>Trigger automation workflows when task events occur (created, updated, completed, deleted).</p>
             <p><strong>HA Addon mode:</strong> Node-RED and n8n addons communicate automatically through the HA WebSocket — no webhook URL needed.</p>
             <p><strong>Standalone mode:</strong> Enter the webhook URL from your n8n/Node-RED flow, plus optional API key and signing secret for authentication.</p>`,
    },
    webhooks: {
      title: "🔔 Webhooks",
      body: `<p>Generic outgoing HTTP webhooks that send task event payloads to any URL you specify (e.g., Zapier, IFTTT, custom APIs).</p>
             <p>Each event is POSTed as JSON with an optional HMAC-SHA256 signature for verification.</p>
             <p><strong>Not the same as Agents & AI</strong> — webhooks are for data pipelines and automations. For AI agent protocols (A2A, MCP, WebMCP), use the Agents & AI tab.</p>`,
    },
  };

  function initExplainerDialog() {
    const dialog = document.getElementById(
      "integration-explainer-dialog",
    ) as HTMLDialogElement | null;
    const titleEl = document.getElementById("explainer-title");
    const bodyEl = document.getElementById("explainer-body");
    const closeBtn = dialog?.querySelector(".explainer-dialog__close");
    if (!dialog || !titleEl || !bodyEl) return;
    if (dialog.dataset.explainerInit) return;
    dialog.dataset.explainerInit = "true";

    // Open on info button click
    document.querySelectorAll(".info-btn[data-explainer]").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        const key = (btn as HTMLElement).dataset.explainer || "";
        const content = EXPLAINER_CONTENT[key];
        if (!content) return;
        titleEl.textContent = content.title;
        bodyEl.innerHTML = content.body;
        dialog.showModal();
      });
    });

    // Close button
    closeBtn?.addEventListener("click", () => dialog.close());

    // Close on backdrop click
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });
  }

  initExplainerDialog();
  document.addEventListener("astro:page-load", initExplainerDialog);

  /**
   * n8n / Node-RED Mode Toggle
   *
   * Switches between HA Addon (auto) and Standalone modes.
   */
  function initN8nModeToggle() {
    const autoBtn = document.getElementById("n8n-mode-auto");
    const standaloneBtn = document.getElementById("n8n-mode-standalone");
    const autoContent = document.getElementById("n8n-auto-content");
    const standaloneContent = document.getElementById("n8n-standalone-content");
    if (!autoBtn || !standaloneBtn || !autoContent || !standaloneContent)
      return;
    if (autoBtn.dataset.modeInit) return;
    autoBtn.dataset.modeInit = "true";

    function setMode(mode: string) {
      if (mode === "auto") {
        autoBtn!.classList.add("mode-tab--active");
        standaloneBtn!.classList.remove("mode-tab--active");
        autoContent!.style.display = "";
        standaloneContent!.style.display = "none";
      } else {
        standaloneBtn!.classList.add("mode-tab--active");
        autoBtn!.classList.remove("mode-tab--active");
        autoContent!.style.display = "none";
        standaloneContent!.style.display = "";
      }
      try {
        localStorage.setItem("meitheal:n8n-mode", mode);
      } catch {}
    }

    // Restore persisted mode
    try {
      const saved = localStorage.getItem("meitheal:n8n-mode");
      if (saved === "standalone") setMode("standalone");
    } catch {}

    autoBtn.addEventListener("click", () => setMode("auto"));
    standaloneBtn.addEventListener("click", () => setMode("standalone"));
  }

  initN8nModeToggle();
  document.addEventListener("astro:page-load", initN8nModeToggle);

  /**
   * Calendar Entity Dropdown Population
   *
   * Populates the cal-entity <select> with detected HA calendar entities.
   * Adds a "Custom entity…" option that reveals the manual input.
   */
  function initCalendarDropdown() {
    const select = document.getElementById(
      "cal-entity",
    ) as HTMLSelectElement | null;
    const manual = document.getElementById(
      "cal-entity-manual",
    ) as HTMLInputElement | null;
    if (!select || !manual) return;
    if (select.dataset.calInit) return;
    select.dataset.calInit = "true";

    // When select changes, show/hide manual input
    select.addEventListener("change", () => {
      if (select.value === "__custom__") {
        manual.style.display = "";
        manual.focus();
      } else {
        manual.style.display = "none";
        manual.value = "";
      }
    });

    // Populate from API
    (async () => {
      try {
        const res = await fetch("/api/ha/calendars");
        if (!res.ok) throw new Error("API error");
        const data = (await res.json()) as {
          calendars?: { entity_id: string; friendly_name: string }[];
          sync?: { entityId: string | null };
        };

        const calendars = data.calendars ?? [];
        const activeEntity = data.sync?.entityId ?? "";

        // Clear loading option
        select.innerHTML = "";

        if (calendars.length === 0) {
          select.innerHTML =
            '<option value="" disabled selected>No calendars detected</option>';
        } else {
          // Default option
          select.innerHTML =
            '<option value="" disabled>Select a calendar…</option>';
          for (const cal of calendars) {
            const opt = document.createElement("option");
            opt.value = cal.entity_id;
            opt.textContent = `${cal.friendly_name} (${cal.entity_id})`;
            if (cal.entity_id === activeEntity) opt.selected = true;
            select.appendChild(opt);
          }
          // Auto-select if only one and nothing pre-selected
          if (calendars.length === 1 && !activeEntity) {
            select.selectedIndex = 1;
          }
        }

        // Add custom option
        const customOpt = document.createElement("option");
        customOpt.value = "__custom__";
        customOpt.textContent = "Custom entity…";
        select.appendChild(customOpt);
      } catch {
        select.innerHTML =
          '<option value="" disabled selected>Could not load calendars</option>';
        // Add custom option as fallback
        const customOpt = document.createElement("option");
        customOpt.value = "__custom__";
        customOpt.textContent = "Custom entity…";
        select.appendChild(customOpt);
        manual.style.display = "";
      }
    })();
  }

  initCalendarDropdown();
  document.addEventListener("astro:page-load", initCalendarDropdown);

  /**
   * Grocy Auto-Detection
   *
   * Checks if Grocy addon is available via HA Supervisor API.
   * Auto-fills URL when detected, hides manual fields.
   * Addon slug: a0d7b954_grocy (hassio-addons repository)
   */
  async function initGrocyAutoDetect() {
    const autoInfo = document.getElementById("grocy-auto-info");
    const urlGroup = document.getElementById("grocy-url-group");
    const keyGroup = document.getElementById("grocy-key-group");
    const urlInput = document.getElementById(
      "grocy-url",
    ) as HTMLInputElement | null;
    const customToggle = document.getElementById("grocy-custom-toggle");
    const statusEl = document.getElementById("grocy-status");
    if (!autoInfo || !urlGroup || !keyGroup || !urlInput) return;
    if (autoInfo.dataset.grocyInit) return;
    autoInfo.dataset.grocyInit = "true";

    try {
      // Check HA connection first
      const haRes = await fetch("/api/ha/connection");
      const haData = (await haRes.json()) as { connected?: boolean };
      if (!haData.connected) return; // Not connected to HA, skip auto-detect

      // Check if Grocy addon is installed via addons API
      const addonsRes = await fetch("/api/ha/addons");
      if (!addonsRes.ok) return;
      const addonsData = (await addonsRes.json()) as {
        addons?: {
          slug: string;
          name: string;
          state: string;
          ingress_url?: string;
        }[];
      };

      const grocy = addonsData.addons?.find((a) => a.slug.includes("grocy"));
      if (grocy) {
        // Auto-detected!
        autoInfo.style.display = "block";
        urlGroup.style.display = "none";
        keyGroup.style.display = "none";
        if (customToggle) customToggle.style.display = "";

        // Auto-fill URL from ingress
        if (grocy.ingress_url) {
          urlInput.value = grocy.ingress_url;
        }

        // Update badge
        if (statusEl) {
          statusEl.textContent = "Auto-detected";
          statusEl.className = "badge badge-active";
        }

        // Custom toggle handler
        customToggle?.addEventListener("click", () => {
          urlGroup.style.display = "";
          keyGroup.style.display = "";
          customToggle.style.display = "none";
        });
      }
    } catch {
      console.warn("[Meitheal] Grocy auto-detect failed");
    }
  }

  initGrocyAutoDetect();
  document.addEventListener("astro:page-load", initGrocyAutoDetect);

  /**
   * Node-RED Auto-Detection
   *
   * Checks if Node-RED addon is available via HA Supervisor API.
   * Addon slug: a0d7b954_nodered (hassio-addons repository)
   * Reference: https://github.com/hassio-addons/app-node-red
   */
  async function initNodeRedAutoDetect() {
    const callout = document.getElementById("n8n-auto-detect-info");
    const statusEl = document.getElementById("n8n-status");
    if (!callout) return;
    if (callout.dataset.nrInit) return;
    callout.dataset.nrInit = "true";

    try {
      const haRes = await fetch("/api/ha/connection");
      const haData = (await haRes.json()) as { connected?: boolean };
      if (!haData.connected) return;

      const addonsRes = await fetch("/api/ha/addons");
      if (!addonsRes.ok) return;
      const addonsData = (await addonsRes.json()) as {
        addons?: { slug: string; name: string; state: string }[];
      };

      const nodeRed = addonsData.addons?.find(
        (a) =>
          a.slug.includes("nodered") ||
          a.slug.includes("node_red") ||
          a.slug.includes("node-red"),
      );
      const n8n = addonsData.addons?.find((a) => a.slug.includes("n8n"));

      if (nodeRed || n8n) {
        callout.style.display = "block";
        const name = nodeRed ? "Node-RED" : "n8n";
        const strongEl = callout.querySelector("strong");
        const detailEl = callout.querySelector(".integration-callout__detail");
        if (strongEl) strongEl.textContent = `✓ ${name} detected via HA`;
        if (detailEl)
          detailEl.textContent = `${name} addon found and connected automatically.`;

        if (statusEl) {
          statusEl.textContent = "Auto-detected";
          statusEl.className = "badge badge-active";
        }
      }
    } catch {
      console.warn("[Meitheal] Node-RED/n8n auto-detect failed");
    }
  }

  initNodeRedAutoDetect();
  document.addEventListener("astro:page-load", initNodeRedAutoDetect);

  /**
   * Callout Jump Links
   *
   * Handles click on [data-tab] links to switch settings tabs.
   */
  function initCalloutLinks() {
    document.querySelectorAll(".callout-link[data-tab]").forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const tabId = (link as HTMLElement).dataset.tab;
        if (!tabId) return;
        // Find the corresponding tab button and click it
        const tabBtn = document.querySelector(
          `[data-settings-tab="${tabId}"]`,
        ) as HTMLElement | null;
        if (tabBtn) {
          tabBtn.click();
          tabBtn.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    });
  }

  initCalloutLinks();
  document.addEventListener("astro:page-load", initCalloutLinks);
</script>
