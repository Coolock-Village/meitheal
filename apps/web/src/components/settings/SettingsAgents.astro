---
import { t } from "../../i18n/translations";
import type { Locale } from "../../lib/locale";

/**
 * SettingsAgents — AI provider and agent protocol configuration.
 *
 * Phase 58: Added HA Conversation Agent picker at top.
 *
 * @domain settings
 * @bounded-context agents
 */

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<div id="tab-agents" class="tab-pane" style="display: none;">
  <div class="settings-grid">
    <div class="card" style="grid-column: 1 / -1;">
      <div class="card-header">
        <div>
          <div class="card-title">Agents & AI</div>
          <div class="card-subtitle">
            Configure Home Assistant conversation agents, external AI providers,
            and agent-to-agent protocols.
          </div>
        </div>
      </div>

      <!-- HA Conversation Agent (PRIMARY — top of page) -->
      <div class="integration-section">
        <div class="integration-header">
          <div>
            <strong>🏠 HA Conversation Agent</strong>
            <div class="integration-desc">
              Select which Home Assistant conversation agent powers the "Ask
              Assistant" chat (✦ button). This connects to HA's built-in Assist
              pipeline or any configured LLM agent (Google AI, OpenAI, Ollama).
            </div>
          </div>
          <span class="badge badge-active" id="ha-agent-status">Default</span>
        </div>
        <div class="integration-config">
          <div class="form-group">
            <label class="form-label" for="ha-agent-select-settings"
              >Conversation Agent</label
            >
            <select class="form-select" id="ha-agent-select-settings">
              <option value="" selected>Default (built-in Assist)</option>
            </select>
            <small
              style="color: var(--text-muted); font-size: 11px; margin-top: 4px; display: block;"
            >
              Agents are registered in HA → Settings → Voice Assistants. Add
              Google Generative AI, OpenAI, or Ollama integrations to see more
              options here.
            </small>
          </div>
          <div
            class="form-group"
            style="display: flex; gap: 8px; align-items: center;"
          >
            <button
              type="button"
              class="btn btn-primary"
              id="save-ha-agent"
              style="font-size: 13px;">Save Agent Setting</button
            >
            <button
              type="button"
              class="btn btn-ghost"
              id="test-ha-agent"
              style="font-size: 13px;">Test</button
            >
            <span
              id="ha-agent-test-result"
              style="font-size: 12px; color: var(--text-muted);"></span>
          </div>
        </div>
      </div>

      <hr style="border-color: var(--border); margin: 16px 0;" />

      <!-- External AI Provider (secondary) -->
      <div class="integration-section">
        <div class="integration-header">
          <div>
            <strong>🤖 External AI Provider</strong>
            <div class="integration-desc">
              Configure which external AI service the "Ask AI" button sends
              tasks to (separate from HA Assist). Generates a pre-filled prompt
              with task context for analysis.
            </div>
          </div>
          <span class="badge badge-active" id="ext-ai-badge">ChatGPT</span>
        </div>
        <div class="integration-config">
          <div class="form-group">
            <label class="form-label" for="ai-provider">Provider</label>
            <select class="form-select" id="ai-provider">
              <option value="chatgpt" selected>ChatGPT</option>
              <option value="claude">Claude</option>
              <option value="gemini">Google Gemini</option>
              <option value="ollama">Ollama (local)</option>
              <option value="ha_llm">Home Assistant (LLM)</option>
              <option value="custom">Custom URL</option>
            </select>
          </div>
          <div
            class="form-group"
            id="ai-custom-url-group"
            style="display: none;"
          >
            <label class="form-label" for="ai-custom-url">Custom API URL</label>
            <input
              type="url"
              class="form-input"
              id="ai-custom-url"
              placeholder="http://localhost:11434/api/chat"
            />
          </div>
          <button
            type="button"
            class="btn btn-primary"
            id="save-ai"
            style="font-size: 13px;">Save AI Settings</button
          >
        </div>
      </div>

      <hr style="border-color: var(--border); margin: 16px 0;" />

      <!-- Agent Protocols -->
      <div class="integration-section">
        <div class="integration-header">
          <div>
            <strong>🔗 Agent Protocols</strong>
            <div class="integration-desc">
              Expose Meitheal tools to AI agents via A2A, WebMCP, and MCP
              protocols. Enable agent-to-agent collaboration, browser agent
              tools, and tool discovery.
            </div>
          </div>
          <span class="badge badge-active" id="agent-protocols-status"
            >Active</span
          >
        </div>
        <div class="integration-config">
          <!-- A2A -->
          <div
            class="form-group"
            style="padding-bottom: 16px; border-bottom: 1px solid var(--border);"
          >
            <div
              style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;"
            >
              <label class="toggle-label">
                <input type="checkbox" id="agent-a2a-enabled" checked />
                <span class="toggle-slider"></span>
              </label>
              <div>
                <strong style="font-size: 14px;">A2A (Agent-to-Agent)</strong>
                <div
                  style="color: var(--text-muted); font-size: 12px; margin-top: 2px;"
                >
                  Serve an Agent Card at <code
                    >/.well-known/agent-card.json</code
                  > so other AI agents can discover and delegate tasks to Meitheal.
                  <a
                    href="/api/a2a/agent-card"
                    target="_blank"
                    rel="noopener noreferrer"
                    style="color: var(--accent);">View Agent Card →</a
                  >
                </div>
              </div>
            </div>
          </div>

          <!-- WebMCP -->
          <div
            class="form-group"
            style="padding-top: 16px; padding-bottom: 16px; border-bottom: 1px solid var(--border);"
          >
            <div
              style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;"
            >
              <label class="toggle-label">
                <input type="checkbox" id="agent-webmcp-enabled" />
                <span class="toggle-slider"></span>
              </label>
              <div>
                <strong style="font-size: 14px;">WebMCP (Browser Agent)</strong>
                <span
                  style="font-size: 10px; padding: 2px 6px; background: var(--accent); color: #fff; border-radius: 4px; margin-left: 6px; vertical-align: middle;"
                  >Experimental</span
                >
                <div
                  style="color: var(--text-muted); font-size: 12px; margin-top: 2px;"
                >
                  Register Meitheal tools with your browser's AI assistant
                  (Chrome EPP). Allows browser agents to create tasks, search,
                  and navigate boards.
                </div>
              </div>
            </div>
          </div>

          <!-- MCP Discovery -->
          <div class="form-group" style="padding-top: 16px;">
            <div
              style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;"
            >
              <label class="toggle-label">
                <input type="checkbox" id="agent-mcp-enabled" checked />
                <span class="toggle-slider"></span>
              </label>
              <div>
                <strong style="font-size: 14px;">MCP Discovery</strong>
                <div
                  style="color: var(--text-muted); font-size: 12px; margin-top: 2px;"
                >
                  Serve tool definitions at <code>/.well-known/mcp.json</code> for
                  MCP-compatible clients.
                  <a
                    href="/.well-known/mcp.json"
                    target="_blank"
                    rel="noopener noreferrer"
                    style="color: var(--accent);">View MCP manifest →</a
                  >
                </div>
              </div>
            </div>
          </div>

          <button
            class="btn btn-primary"
            id="save-agent-protocols"
            style="font-size: 13px;">Save Agent Protocol Settings</button
          >
        </div>
      </div>
    </div>
  </div>
  <!-- /settings-grid (agents) -->
</div>

<script>
  import { showToast } from "@lib/toast";

  // ── HA Conversation Agent picker ──
  const haAgentSelect = document.getElementById(
    "ha-agent-select-settings",
  ) as HTMLSelectElement;
  const haAgentStatus = document.getElementById("ha-agent-status");
  const saveHaAgentBtn = document.getElementById("save-ha-agent");
  const testHaAgentBtn = document.getElementById("test-ha-agent");
  const testResult = document.getElementById("ha-agent-test-result");

  // Load agents on tab show
  async function loadHAAgents() {
    try {
      const res = await fetch("/api/ha/agents");
      if (res.ok) {
        const data = await res.json();
        if (data.agents?.length > 0) {
          haAgentSelect.innerHTML =
            '<option value="">Default (built-in Assist)</option>';
          for (const agent of data.agents) {
            const opt = document.createElement("option");
            opt.value = agent.id;
            opt.textContent = agent.name;
            haAgentSelect.appendChild(opt);
          }
        }
      }
    } catch {
      // HA not connected — keep default
    }

    // Restore saved preference
    try {
      const res = await fetch("/api/settings?key=ha-assist-agent");
      if (res.ok) {
        const data = await res.json();
        if (data?.value) {
          haAgentSelect.value = data.value;
          updateAgentBadge();
        }
      }
    } catch {
      /* ignore */
    }
  }

  function updateAgentBadge() {
    if (haAgentStatus) {
      const selected = haAgentSelect.options[haAgentSelect.selectedIndex];
      haAgentStatus.textContent = selected?.text || "Default";
    }
  }

  haAgentSelect?.addEventListener("change", updateAgentBadge);

  saveHaAgentBtn?.addEventListener("click", async () => {
    try {
      await fetch("/api/settings", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          key: "ha-assist-agent",
          value: haAgentSelect.value,
        }),
      });
      showToast("Agent setting saved.", "success");
      updateAgentBadge();
    } catch {
      showToast("Failed to save agent setting.", "error");
    }
  });

  testHaAgentBtn?.addEventListener("click", async () => {
    if (testResult) testResult.textContent = "Testing…";
    try {
      const body: Record<string, string> = { text: "Hello" };
      if (haAgentSelect.value) body.agent_id = haAgentSelect.value;

      const res = await fetch("/api/ha/assist", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });

      if (res.ok) {
        const data = await res.json();
        if (testResult) testResult.textContent = `✅ "${data.speech}"`;
        setTimeout(() => {
          if (testResult) testResult.textContent = "";
        }, 5000);
      } else {
        if (testResult) testResult.textContent = "❌ Agent unavailable";
      }
    } catch {
      if (testResult) testResult.textContent = "❌ Connection failed";
    }
  });

  // ── External AI Provider ──
  const extBadge = document.getElementById("ext-ai-badge");
  const aiProvider = document.getElementById(
    "ai-provider",
  ) as HTMLSelectElement;
  const customUrlGroup = document.getElementById("ai-custom-url-group");

  aiProvider?.addEventListener("change", () => {
    // Persist provider choice for Ask AI handler
    localStorage.setItem("meitheal-ai-provider", aiProvider.value);
    if (customUrlGroup) {
      customUrlGroup.style.display =
        aiProvider.value === "custom" || aiProvider.value === "ollama"
          ? ""
          : "none";
    }
    if (extBadge) {
      const names: Record<string, string> = {
        chatgpt: "ChatGPT",
        claude: "Claude",
        gemini: "Gemini",
        ollama: "Ollama",
        ha_llm: "HA LLM",
        custom: "Custom",
      };
      extBadge.textContent = names[aiProvider.value] || aiProvider.value;
    }
  });

  // Init: Load agents when the tab is shown
  const tabAgents = document.getElementById("tab-agents");
  if (tabAgents) {
    const observer = new MutationObserver(() => {
      if (tabAgents.style.display !== "none") {
        loadHAAgents();
        observer.disconnect();
      }
    });
    observer.observe(tabAgents, {
      attributes: true,
      attributeFilter: ["style"],
    });
  }
</script>
