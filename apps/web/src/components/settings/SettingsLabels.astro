---
/**
 * SettingsLabels — Label management panel in Settings
 *
 * @domain labels
 * @bounded-context labels
 *
 * Lists all labels with inline edit/delete, plus create-new form.
 * All operations use /api/labels and /api/labels/[id] endpoints.
 */
import { t } from "../../i18n/translations"
import type { Locale } from "../../lib/locale"

interface Props {
  locale: Locale
}

const { locale } = Astro.props
---

<div class="tab-pane" id="tab-labels" role="tabpanel" aria-labelledby="tab-btn-labels" style="display: none;" aria-hidden="true">
  <div class="card" style="margin-bottom: 16px;">
    <div class="card-header" style="padding: 12px 16px;">
      <div>
        <div class="card-title" style="font-size: 14px;">🏷️ Manage Labels</div>
        <div class="card-subtitle" style="font-size: 12px;">
          Create, edit, and remove labels used to categorize tasks
        </div>
      </div>
    </div>

    {/* Create new label form */}
    <div style="padding: 12px 16px; border-bottom: 1px solid var(--border);">
      <form id="create-label-form" style="display: flex; gap: 8px; align-items: center;">
        <input
          type="text"
          id="new-label-title"
          class="form-input"
          placeholder="Label name"
          maxlength="100"
          required
          style="flex: 1; font-size: 13px;"
        />
        <input
          type="color"
          id="new-label-color"
          value="#6366f1"
          title="Label color"
          style="width: 36px; height: 32px; padding: 2px; border: 1px solid var(--border); border-radius: 6px; cursor: pointer;"
        />
        <button type="submit" class="btn btn-primary" style="font-size: 13px; white-space: nowrap;">
          + Create
        </button>
      </form>
    </div>

    {/* Label list */}
    <div id="labels-list" style="padding: 0;">
      <div style="padding: 24px; text-align: center; color: var(--text-muted); font-size: 13px;">
        Loading labels...
      </div>
    </div>
  </div>
</div>

<script>
  import { showToast } from "@lib/toast"

  type LabelData = { id: number; title: string; hex_color: string }

  const listEl = document.getElementById("labels-list")
  const form = document.getElementById("create-label-form") as HTMLFormElement
  const titleInput = document.getElementById("new-label-title") as HTMLInputElement
  const colorInput = document.getElementById("new-label-color") as HTMLInputElement

  let labels: LabelData[] = []

  async function loadLabels() {
    try {
      const res = await fetch("/api/labels")
      if (res.ok) {
        const data = await res.json()
        labels = Array.isArray(data) ? data : data.labels || []
      }
    } catch { /* offline */ }
    renderLabels()
  }

  function renderLabels() {
    if (!listEl) return

    if (labels.length === 0) {
      listEl.innerHTML = `
        <div style="padding: 24px; text-align: center; color: var(--text-muted); font-size: 13px;">
          No labels yet. Create one above!
        </div>
      `
      return
    }

    listEl.innerHTML = labels
      .map(
        (l) => `
      <div class="label-settings-row" data-id="${l.id}" style="display: flex; align-items: center; gap: 8px; padding: 8px 16px; border-bottom: 1px solid var(--border);">
        <input
          type="color"
          class="label-color-edit"
          data-id="${l.id}"
          value="${l.hex_color.startsWith('#') ? l.hex_color : '#' + l.hex_color}"
          title="Change color"
          style="width: 28px; height: 28px; padding: 1px; border: 1px solid var(--border); border-radius: 6px; cursor: pointer;"
        />
        <span
          class="label-badge"
          style="background: ${l.hex_color.startsWith('#') ? l.hex_color : '#' + l.hex_color}20; color: ${l.hex_color.startsWith('#') ? l.hex_color : '#' + l.hex_color}; border: 1px solid ${l.hex_color.startsWith('#') ? l.hex_color : '#' + l.hex_color}40; flex-shrink: 0;"
        >
          ${l.title}
        </span>
        <input
          type="text"
          class="form-input label-title-edit"
          data-id="${l.id}"
          value="${l.title.replace(/"/g, '&quot;')}"
          maxlength="100"
          style="flex: 1; font-size: 13px; max-width: 240px;"
        />
        <button
          type="button"
          class="btn btn-ghost label-delete-btn"
          data-id="${l.id}"
          title="Delete label"
          style="color: var(--danger); font-size: 16px; padding: 4px 8px;"
        >×</button>
      </div>
    `,
      )
      .join("")

    // Bind edit handlers
    listEl.querySelectorAll<HTMLInputElement>(".label-title-edit").forEach(
      (input) => {
        let timeout: ReturnType<typeof setTimeout> | null = null
        input.addEventListener("input", () => {
          if (timeout) clearTimeout(timeout)
          timeout = setTimeout(async () => {
            const id = input.dataset.id
            const title = input.value.trim()
            if (!id || !title) return
            try {
              await fetch(`/api/labels/${id}`, {
                method: "PUT",
                headers: { "content-type": "application/json" },
                body: JSON.stringify({ title }),
              })
              const label = labels.find((l) => l.id === Number(id))
              if (label) label.title = title
              renderLabels()
            } catch { /* silent */ }
          }, 500)
        })
      },
    )

    listEl.querySelectorAll<HTMLInputElement>(".label-color-edit").forEach(
      (input) => {
        input.addEventListener("change", async () => {
          const id = input.dataset.id
          const hexColor = input.value
          if (!id) return
          try {
            await fetch(`/api/labels/${id}`, {
              method: "PUT",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ hex_color: hexColor }),
            })
            const label = labels.find((l) => l.id === Number(id))
            if (label) label.hex_color = hexColor
            renderLabels()
          } catch { /* silent */ }
        })
      },
    )

    listEl.querySelectorAll<HTMLButtonElement>(".label-delete-btn").forEach(
      (btn) => {
        btn.addEventListener("click", async () => {
          const id = btn.dataset.id
          if (!id) return
          if (!confirm(`Delete label? This will remove it from all tasks.`)) return
          try {
            const res = await fetch(`/api/labels/${id}`, { method: "DELETE" })
            if (res.ok) {
              labels = labels.filter((l) => l.id !== Number(id))
              renderLabels()
              showToast("Label deleted", "success")
            } else {
              showToast("Failed to delete label", "error")
            }
          } catch {
            showToast("Network error", "error")
          }
        })
      },
    )
  }

  // Create label
  form?.addEventListener("submit", async (e) => {
    e.preventDefault()
    const title = titleInput.value.trim()
    const hexColor = colorInput.value
    if (!title) return

    try {
      const res = await fetch("/api/labels", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ title, hex_color: hexColor }),
      })
      if (res.ok) {
        const label = await res.json()
        labels.push(label)
        renderLabels()
        titleInput.value = ""
        showToast("Label created", "success")
      } else {
        const err = await res.json().catch(() => ({}))
        showToast(err.error || "Failed to create label", "error")
      }
    } catch {
      showToast("Network error", "error")
    }
  })

  // Load on tab activation
  const tabBtn = document.getElementById("tab-btn-labels")
  tabBtn?.addEventListener("click", () => {
    if (labels.length === 0) loadLabels()
  })

  // Also load if tab is already active (deep link)
  const pane = document.getElementById("tab-labels")
  if (pane && pane.style.display !== "none") {
    loadLabels()
  }
</script>
