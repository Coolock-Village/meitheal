---
import { t } from "../../i18n/translations";
import type { Locale } from "../../lib/locale";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<div
  id="tab-general"
  class="tab-pane active"
  role="tabpanel"
  aria-labelledby="tab-btn-general"
  style="display: block;"
>
  <div class="settings-grid">
    <!-- Sidebar Config -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Sidebar Configuration</div>
          <div class="card-subtitle">
            Configure visibility, order, and custom labels for navigation items.
          </div>
        </div>
      </div>
      <div style="padding: 16px;">
        <div
          id="sidebar-item-list"
          style="display: flex; flex-direction: column; gap: 8px;"
        >
          <!-- Populated by JS -->
        </div>
        <div
          style="margin-top: 16px; border-top: 1px solid var(--border); padding-top: 16px;"
        >
          <div style="margin-bottom: 8px; font-weight: 500;">Custom Links</div>
          <div
            id="custom-links-list"
            style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 12px;"
          >
          </div>
          <button type="button" class="btn btn-ghost" id="add-custom-link-btn"
            >+ Add Custom Link</button
          >
        </div>
        <div style="display: flex; gap: 8px; margin-top: 16px;">
          <button
            type="button"
            class="btn btn-primary"
            id="save-sidebar"
            style="font-size: 13px;">Save Sidebar Config</button
          >
          <button
            type="button"
            class="btn btn-ghost"
            id="reset-sidebar"
            style="font-size: 13px;">Reset to Default</button
          >
        </div>
      </div>
    </div>

    <!-- Custom Fields -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">
            {t("settings.custom_fields_title", locale)}
          </div>
          <div class="card-subtitle">
            {t("settings.custom_fields_subtitle", locale)}
          </div>
        </div>
        <button type="button" class="btn btn-ghost" id="add-custom-field"
          >+ Add Field</button
        >
      </div>
      <div id="custom-fields-list">
        <div class="custom-field-row">
          <input
            type="text"
            class="form-input"
            placeholder="Field name"
            value="sprint"
            disabled
          />
          <select class="form-select" disabled>
            <option value="text" selected>Text</option>
            <option value="number">Number</option>
            <option value="select">Select</option>
            <option value="date">Date</option>
            <option value="checkbox">Checkbox</option>
          </select>
          <span style="color: var(--text-muted); font-size: 12px;"
            >Built-in</span
          >
        </div>
        <div class="custom-field-row">
          <input
            type="text"
            class="form-input"
            placeholder="Field name"
            value="story_points"
            disabled
          />
          <select class="form-select" disabled>
            <option value="number" selected>Number</option>
          </select>
          <span style="color: var(--text-muted); font-size: 12px;"
            >Built-in</span
          >
        </div>
      </div>
    </div>

    <!-- Strategic Lenses — Contextual Mapping -->
    <div class="card" style="position: relative;">
      <div class="card-header">
        <div>
          <div
            class="card-title"
            style="display: flex; align-items: center; gap: 8px;"
          >
            Strategic Lenses
            <button
              type="button"
              id="strategic-lenses-help-btn"
              style="display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; border-radius: 50%; border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-muted); font-size: 12px; cursor: pointer; transition: all 150ms ease; flex-shrink: 0;"
              title="What are Strategic Lenses?">?</button
            >
          </div>
          <div class="card-subtitle">
            Map evaluation frameworks contextually by Task Type.
          </div>
        </div>
      </div>

      <!-- Helper Popup -->
      <div
        id="strategic-lenses-help-popup"
        style="display: none; position: absolute; top: 64px; left: 0; right: 0; z-index: 20; padding: 16px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; box-shadow: 0 8px 32px rgba(0,0,0,0.4); max-height: 70vh; overflow-y: auto;"
      >
        <div
          style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px;"
        >
          <div>
            <strong style="font-size: 15px; color: var(--text-primary);"
              >What are Strategic Lenses?</strong
            >
            <p
              style="font-size: 13px; color: var(--text-secondary); margin: 4px 0 0; line-height: 1.5;"
            >
              Strategic Lenses let you evaluate tasks through proven frameworks.
              Assign different lenses to task types (Epic, Story, Task, Doc) to
              automatically score priority, impact, and domain fit when creating
              or reviewing work.
            </p>
          </div>
          <button
            type="button"
            id="strategic-lenses-help-close"
            style="color: var(--text-muted); background: none; border: none; font-size: 18px; cursor: pointer; padding: 0 4px; line-height: 1;"
            >×</button
          >
        </div>

        <div style="display: flex; flex-direction: column; gap: 10px;">
          <!-- RICE -->
          <div
            style="padding: 10px 12px; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 8px;"
          >
            <div
              style="display: flex; justify-content: space-between; align-items: center;"
            >
              <strong style="font-size: 13px;">🎯 RICE</strong>
              <a
                href="https://www.intercom.com/blog/rice-simple-prioritization-for-product-managers/"
                target="_blank"
                rel="noopener noreferrer"
                style="font-size: 11px; color: var(--accent); text-decoration: none;"
                >Intercom Blog →</a
              >
            </div>
            <p
              style="font-size: 12px; color: var(--text-muted); margin: 4px 0 0; line-height: 1.5;"
            >
              <strong>Reach × Impact × Confidence ÷ Effort</strong>.
              Prioritization framework from Intercom. Scores tasks by how many
              people they affect, how much they move the needle, how confident
              you are, and how much work they take.
            </p>
          </div>

          <!-- DRICE -->
          <div
            style="padding: 10px 12px; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 8px;"
          >
            <div
              style="display: flex; justify-content: space-between; align-items: center;"
            >
              <strong style="font-size: 13px;">🔗 DRICE</strong>
              <a
                href="https://www.lennysnewsletter.com/p/introducing-drice-a-modern-prioritization"
                target="_blank"
                rel="noopener noreferrer"
                style="font-size: 11px; color: var(--accent); text-decoration: none;"
                >Lenny's Newsletter →</a
              >
            </div>
            <p
              style="font-size: 12px; color: var(--text-muted); margin: 4px 0 0; line-height: 1.5;"
            >
              Extended RICE that factors in <strong>dependency weight</strong> — how
              many other tasks are blocked by this one. Higher dependency = higher
              urgency multiplier.
            </p>
          </div>

          <!-- DDD -->
          <div
            style="padding: 10px 12px; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 8px;"
          >
            <div
              style="display: flex; justify-content: space-between; align-items: center;"
            >
              <strong style="font-size: 13px;">🏗️ DDD</strong>
              <span style="display: flex; gap: 8px;">
                <a
                  href="https://martinfowler.com/bliki/DomainDrivenDesign.html"
                  target="_blank"
                  rel="noopener noreferrer"
                  style="font-size: 11px; color: var(--accent); text-decoration: none;"
                  >Fowler →</a
                >
                <a
                  href="https://www.geeksforgeeks.org/system-design/domain-driven-design-ddd/"
                  target="_blank"
                  rel="noopener noreferrer"
                  style="font-size: 11px; color: var(--accent); text-decoration: none;"
                  >Guide →</a
                >
              </span>
            </div>
            <p
              style="font-size: 12px; color: var(--text-muted); margin: 4px 0 0; line-height: 1.5;"
            >
              <strong>Domain-Driven Design</strong>. Evaluates tasks through
              bounded context alignment, ubiquitous language adherence, and
              strategic/tactical pattern fit. Best for architectural decisions
              and Epics.
            </p>
          </div>

          <!-- HEART -->
          <div
            style="padding: 10px 12px; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 8px;"
          >
            <div
              style="display: flex; justify-content: space-between; align-items: center;"
            >
              <strong style="font-size: 13px;">💚 HEART</strong>
              <a
                href="https://www.heartframework.com/"
                target="_blank"
                rel="noopener noreferrer"
                style="font-size: 11px; color: var(--accent); text-decoration: none;"
                >heartframework.com →</a
              >
            </div>
            <p
              style="font-size: 12px; color: var(--text-muted); margin: 4px 0 0; line-height: 1.5;"
            >
              <strong
                >Happiness, Engagement, Adoption, Retention, Task success</strong
              >. Google's UX metrics framework. Evaluates features against 5
              user-centered dimensions for holistic UX impact scoring.
            </p>
          </div>

          <!-- KCS -->
          <div
            style="padding: 10px 12px; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 8px;"
          >
            <div
              style="display: flex; justify-content: space-between; align-items: center;"
            >
              <strong style="font-size: 13px;">📚 KCS</strong>
              <a
                href="https://library.serviceinnovation.org/KCS"
                target="_blank"
                rel="noopener noreferrer"
                style="font-size: 11px; color: var(--accent); text-decoration: none;"
                >Service Innovation →</a
              >
            </div>
            <p
              style="font-size: 12px; color: var(--text-muted); margin: 4px 0 0; line-height: 1.5;"
            >
              <strong>Knowledge-Centered Service</strong>. Consortium for
              Service Innovation methodology. Evaluates documentation tasks: is
              knowledge captured at creation, reusable, and continuously
              improved?
            </p>
          </div>
        </div>

        <div
          style="margin-top: 12px; padding-top: 10px; border-top: 1px solid var(--border); font-size: 12px; color: var(--text-muted); line-height: 1.6;"
        >
          <strong style="color: var(--text-secondary);">How it works:</strong> Select
          which frameworks apply to each task type below. When you open a task, click
          <strong>⚖️ Add Strategic Lens</strong> in the detail sidebar to evaluate
          it. Sliders and inputs are generated from the framework's YAML schema. Use
          🤖 <strong>Auto-Score</strong> to generate an AI prompt.
        </div>
      </div>
      <div
        style="display: flex; flex-direction: column; gap: 12px; margin-top: 16px;"
      >
        <div
          style="display: flex; align-items: center; justify-content: space-between; padding: 12px; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-secondary);"
        >
          <div>
            <strong style="display: block; font-size: 14px;">🎯 Epic</strong>
            <span style="font-size: 12px; color: var(--text-muted);"
              >High-level initiatives</span
            >
          </div>
          <select
            class="form-select framework-mapping-select"
            data-task-type="epic"
            multiple
            style="height: 80px; max-width: 260px;"
          >
            <option value="ddd">DDD (Domain-Driven Design)</option>
            <option value="rice">RICE (Priority Math)</option>
            <option value="drice">DRICE (Deps + RICE)</option>
            <option value="heart">HEART (UX Matrix)</option>
            <option value="kcs">KCS (Knowledge Workflow)</option>
          </select>
        </div>

        <div
          style="display: flex; align-items: center; justify-content: space-between; padding: 12px; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-secondary);"
        >
          <div>
            <strong style="display: block; font-size: 14px;">📖 Story</strong>
            <span style="font-size: 12px; color: var(--text-muted);"
              >User-facing features</span
            >
          </div>
          <select
            class="form-select framework-mapping-select"
            data-task-type="story"
            multiple
            style="height: 80px; max-width: 260px;"
          >
            <option value="rice">RICE (Priority Math)</option>
            <option value="drice">DRICE (Deps + RICE)</option>
            <option value="ddd">DDD (Domain-Driven Design)</option>
            <option value="heart">HEART (UX Matrix)</option>
            <option value="kcs">KCS (Knowledge Workflow)</option>
          </select>
        </div>

        <div
          style="display: flex; align-items: center; justify-content: space-between; padding: 12px; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-secondary);"
        >
          <div>
            <strong style="display: block; font-size: 14px;">✅ Task</strong>
            <span style="font-size: 12px; color: var(--text-muted);"
              >Standard work items</span
            >
          </div>
          <select
            class="form-select framework-mapping-select"
            data-task-type="task"
            multiple
            style="height: 80px; max-width: 260px;"
          >
            <option value="heart">HEART (UX Matrix)</option>
            <option value="rice">RICE (Priority Math)</option>
            <option value="drice">DRICE (Deps + RICE)</option>
            <option value="ddd">DDD (Domain-Driven Design)</option>
            <option value="kcs">KCS (Knowledge Workflow)</option>
          </select>
        </div>

        <div
          style="display: flex; align-items: center; justify-content: space-between; padding: 12px; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-secondary);"
        >
          <div>
            <strong style="display: block; font-size: 14px;"
              >📝 Documentation</strong
            >
            <span style="font-size: 12px; color: var(--text-muted);"
              >Knowledge articles</span
            >
          </div>
          <select
            class="form-select framework-mapping-select"
            data-task-type="documentation"
            multiple
            style="height: 80px; max-width: 260px;"
          >
            <option value="kcs">KCS (Knowledge Workflow)</option>
            <option value="heart">HEART (UX Matrix)</option>
            <option value="rice">RICE (Priority Math)</option>
            <option value="drice">DRICE (Deps + RICE)</option>
            <option value="ddd">DDD (Domain-Driven Design)</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Users & Assignment -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">👤 Users & Assignment</div>
          <div class="card-subtitle">
            Manage task assignees. Home Assistant users are discovered
            automatically. Add custom users for non-HA household members.
          </div>
        </div>
      </div>
      <div
        style="padding: 16px; display: flex; flex-direction: column; gap: 16px;"
      >
        <!-- Default Assignee -->
        <div>
          <label
            for="default-assignee-select"
            style="font-weight: 600; font-size: 13px; display: block; margin-bottom: 6px;"
            >Default Assignee</label
          >
          <div style="display: flex; gap: 8px; align-items: center;">
            <select
              id="default-assignee-select"
              class="form-select"
              style="flex: 1; max-width: 300px;"
              aria-label="Default task assignee"
            >
              <option value="">None (unassigned)</option>
            </select>
            <button
              type="button"
              class="btn btn-primary"
              id="save-default-assignee"
              style="font-size: 13px;">Save</button
            >
          </div>
          <p
            style="font-size: 11px; color: var(--text-muted); margin-top: 4px;"
          >
            New tasks will be assigned to this user by default.
          </p>
        </div>

        <!-- Discovered Users -->
        <div>
          <div style="font-weight: 600; font-size: 13px; margin-bottom: 6px;">
            Discovered Users
          </div>
          <div
            id="discovered-users-list"
            style="display: flex; flex-direction: column; gap: 4px;"
          >
            <span
              style="color: var(--text-muted); font-size: 12px; font-style: italic;"
              >Loading…</span
            >
          </div>
        </div>

        <!-- Custom Users -->
        <div style="border-top: 1px solid var(--border); padding-top: 16px;">
          <div
            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;"
          >
            <div style="font-weight: 600; font-size: 13px;">Custom Users</div>
          </div>
          <div
            id="custom-users-list"
            style="display: flex; flex-direction: column; gap: 6px;"
          >
          </div>
          <div style="display: flex; gap: 8px; margin-top: 10px;">
            <input
              type="text"
              id="new-custom-user-name"
              class="form-input"
              placeholder="Name (e.g. Emma)"
              style="flex: 1; max-width: 200px;"
              aria-label="New custom user name"
            />
            <button
              type="button"
              class="btn btn-ghost"
              id="add-custom-user-btn"
              style="font-size: 13px;">+ Add User</button
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const btn = document.getElementById("strategic-lenses-help-btn");
    const popup = document.getElementById("strategic-lenses-help-popup");
    const closeBtn = document.getElementById("strategic-lenses-help-close");
    if (!btn || !popup) return;

    function openPopup() {
      popup.style.display = "block";
      btn.style.background = "var(--accent)";
      btn.style.color = "#fff";
      btn.style.borderColor = "var(--accent)";
      btn.setAttribute("aria-expanded", "true");
    }

    function closePopup() {
      popup.style.display = "none";
      btn.style.background = "var(--bg-secondary)";
      btn.style.color = "var(--text-muted)";
      btn.style.borderColor = "var(--border)";
      btn.setAttribute("aria-expanded", "false");
      btn.focus();
    }

    btn.setAttribute("aria-expanded", "false");
    btn.setAttribute("aria-haspopup", "true");
    btn.addEventListener("click", function () {
      popup.style.display !== "none" ? closePopup() : openPopup();
    });

    closeBtn?.addEventListener("click", closePopup);

    // Escape key closes popup
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && popup.style.display !== "none") {
        closePopup();
      }
    });

    // Click outside closes popup
    document.addEventListener("click", function (e) {
      if (
        popup.style.display !== "none" &&
        !popup.contains(e.target) &&
        e.target !== btn
      ) {
        closePopup();
      }
    });
  })();
</script>

<script is:inline>
  (function () {
    var bp = window.__ingress_path || "";

    /** Create a styled element without innerHTML */
    function makeEl(tag, styles, text) {
      var el = document.createElement(tag);
      if (styles) el.style.cssText = styles;
      if (text !== undefined) el.textContent = text;
      return el;
    }

    /** Build an avatar initials badge (safe — textContent only) */
    function makeAvatar(name, bg) {
      var initials = (name || "??").slice(0, 2).toUpperCase();
      var el = makeEl(
        "span",
        "display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 28px; border-radius: 50%; color: #fff; font-size: 11px; font-weight: 700; background: " +
          (bg || "var(--accent)"),
        initials,
      );
      return el;
    }

    function initUsersCard() {
      var select = document.getElementById("default-assignee-select");
      var discoveredList = document.getElementById("discovered-users-list");
      var customList = document.getElementById("custom-users-list");
      if (!select) return;

      Promise.all([
        fetch(bp + "/api/users").then(function (r) {
          return r.ok ? r.json() : { users: [] };
        }),
        fetch(bp + "/api/users/default")
          .then(function (r) {
            return r.ok ? r.json() : {};
          })
          .catch(function () {
            return {};
          }),
        fetch(bp + "/api/users/custom")
          .then(function (r) {
            return r.ok ? r.json() : { users: [] };
          })
          .catch(function () {
            return { users: [] };
          }),
      ])
        .then(function (results) {
          var allUsers = results[0].users || [];
          var defaultData = results[1];
          var customUsers = results[2].users || [];

          // Populate default-assignee dropdown (safe: option textContent)
          select.innerHTML = "";
          var noneOpt = document.createElement("option");
          noneOpt.value = "";
          noneOpt.textContent = "None (unassigned)";
          select.appendChild(noneOpt);

          allUsers.forEach(function (u) {
            var opt = document.createElement("option");
            opt.value = u.id;
            opt.textContent =
              (u.display_name || u.name || u.id) +
              (u.source === "ha" ? " (HA)" : " (Custom)");
            select.appendChild(opt);
          });
          if (defaultData.default_assignee) {
            select.value = defaultData.default_assignee;
          }

          // Discovered (HA) users list — safe DOM only
          var haUsers = allUsers.filter(function (u) {
            return u.source === "home_assistant";
          });
          if (discoveredList) {
            discoveredList.innerHTML = "";
            if (haUsers.length === 0) {
              discoveredList.appendChild(
                makeEl(
                  "span",
                  "color: var(--text-muted); font-size: 12px; font-style: italic;",
                  "No HA users found (standalone mode?)",
                ),
              );
            } else {
              haUsers.forEach(function (u) {
                var row = makeEl(
                  "div",
                  "display: flex; align-items: center; gap: 8px; padding: 6px 10px; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 6px;",
                );
                row.appendChild(
                  makeAvatar(u.display_name || u.name, "var(--accent)"),
                );
                row.appendChild(
                  makeEl(
                    "span",
                    "font-size: 13px; font-weight: 500;",
                    u.display_name || u.name || u.id,
                  ),
                );
                row.appendChild(
                  makeEl(
                    "span",
                    "font-size: 11px; color: var(--text-muted); font-family: monospace;",
                    u.id,
                  ),
                );
                discoveredList.appendChild(row);
              });
            }
          }

          renderCustomUsers(customUsers);
        })
        .catch(function (err) {
          console.error("[Settings] Users load error:", err);
          if (discoveredList) {
            discoveredList.innerHTML = "";
            discoveredList.appendChild(
              makeEl(
                "span",
                "color: var(--danger); font-size: 12px;",
                "Failed to load users",
              ),
            );
          }
        });

      function renderCustomUsers(users) {
        if (!customList) return;
        customList.innerHTML = "";
        if (users.length === 0) {
          customList.appendChild(
            makeEl(
              "span",
              "color: var(--text-muted); font-size: 12px; font-style: italic;",
              "No custom users added yet",
            ),
          );
          return;
        }
        users.forEach(function (u) {
          var row = makeEl(
            "div",
            "display: flex; align-items: center; gap: 8px; padding: 6px 10px; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 6px;",
          );
          row.appendChild(
            makeAvatar(u.display_name || u.name, "var(--warning, #f59e0b)"),
          );
          row.appendChild(
            makeEl(
              "span",
              "font-size: 13px; font-weight: 500; flex: 1;",
              u.display_name || u.name || u.id,
            ),
          );

          var delBtn = document.createElement("button");
          delBtn.type = "button";
          delBtn.className = "btn-icon text-danger";
          delBtn.style.cssText = "font-size: 16px; cursor: pointer;";
          delBtn.textContent = "×";
          delBtn.title = "Remove user";
          delBtn.setAttribute(
            "aria-label",
            "Remove " + (u.display_name || u.name || "user"),
          );
          delBtn.setAttribute("data-user-id", u.id);
          delBtn.addEventListener("click", function () {
            fetch(bp + "/api/users/custom?id=" + encodeURIComponent(u.id), {
              method: "DELETE",
            })
              .then(function () {
                initUsersCard();
              })
              .catch(function (err) {
                console.error("Delete custom user error:", err);
              });
          });
          row.appendChild(delBtn);

          customList.appendChild(row);
        });
      }

      // Save default assignee
      document
        .getElementById("save-default-assignee")
        ?.addEventListener("click", function () {
          var val = select.value;
          fetch(bp + "/api/users/default", {
            method: "PUT",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ user_id: val || null }),
          })
            .then(function () {
              if (typeof window.showToast === "function")
                window.showToast("Default assignee saved");
            })
            .catch(function (err) {
              console.error("Save default assignee error:", err);
            });
        });

      // Add custom user
      document
        .getElementById("add-custom-user-btn")
        ?.addEventListener("click", function () {
          var input = document.getElementById("new-custom-user-name");
          var name = (input?.value || "").trim();
          if (!name) {
            input?.focus();
            return;
          }
          fetch(bp + "/api/users/custom", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ name: name }),
          })
            .then(function (res) {
              if (res.ok) {
                input.value = "";
                initUsersCard();
              }
            })
            .catch(function (err) {
              console.error("Add custom user error:", err);
            });
        });
    }

    initUsersCard();
    document.addEventListener("astro:page-load", initUsersCard);
  })();
</script>
