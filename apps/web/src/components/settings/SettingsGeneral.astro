---
import { t } from "../../i18n/translations";
import type { Locale } from "../../lib/locale";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<div id="tab-general" class="tab-pane active" style="display: block;">
  <div class="settings-grid">
    <!-- HA Connection — Auto-Detect Status -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">{t("settings.ha_title", locale)}</div>
          <div class="card-subtitle">{t("settings.ha_subtitle", locale)}</div>
        </div>
      </div>

      <!-- Connection Status Display — populated by JS -->
      <div id="ha-connection-status" class="ha-status-card">
        <div class="ha-status-card__indicator">
          <div
            class="ha-status-indicator ha-status-indicator--checking"
            id="ha-indicator"
          >
            <span class="ha-status-indicator__dot"></span>
          </div>
          <div class="ha-status-card__info">
            <span class="ha-status-card__mode" id="ha-mode-label"
              >Detecting connection…</span
            >
            <span class="ha-status-card__detail" id="ha-detail-label"></span>
          </div>
        </div>
        <span class="badge badge-pending" id="ha-connection-badge"
          >Checking…</span
        >
      </div>

      <!-- HA Info Panel — shown when connected -->
      <div id="ha-info-panel" class="ha-info-panel" style="display: none;">
        <div class="ha-info-grid">
          <div class="ha-info-item">
            <span class="ha-info-item__label">Version</span>
            <span class="ha-info-item__value" id="ha-info-version">—</span>
          </div>
          <div class="ha-info-item">
            <span class="ha-info-item__label">Location</span>
            <span class="ha-info-item__value" id="ha-info-location">—</span>
          </div>
          <div class="ha-info-item">
            <span class="ha-info-item__label">Timezone</span>
            <span class="ha-info-item__value" id="ha-info-timezone">—</span>
          </div>
          <div class="ha-info-item">
            <span class="ha-info-item__label">Mode</span>
            <span class="ha-info-item__value" id="ha-info-mode">—</span>
          </div>
        </div>
      </div>

      <!-- Test Connection Button -->
      <div style="display: flex; gap: 8px; margin-top: 12px;">
        <button type="button" class="btn btn-ghost" id="test-connection">
          Test Connection
        </button>
      </div>
      <div id="ha-status" style="margin-top: 8px;"></div>

      <!-- Advanced / Standalone Mode — collapsed by default -->
      <details class="ha-advanced-section" id="ha-advanced-section">
        <summary class="ha-advanced-toggle">
          <span>⚙ Advanced — Standalone Mode</span>
          <small>Only needed if running outside Home Assistant</small>
        </summary>
        <form id="ha-form" class="ha-advanced-form">
          <div class="form-group">
            <label class="form-label" for="ha-url">HA URL</label>
            <input
              type="url"
              class="form-input"
              id="ha-url"
              placeholder="http://homeassistant.local:8123"
              pattern="https?://.*"
            />
          </div>
          <div class="form-group">
            <label class="form-label" for="ha-token">
              Long-Lived Access Token
            </label>
            <input
              type="password"
              class="form-input"
              id="ha-token"
              placeholder="••••••••"
            />
            <small style="color: var(--text-muted); font-size: 12px;">
              Generate in HA → Profile → Long-Lived Access Tokens
            </small>
          </div>
          <div style="display: flex; gap: 8px;">
            <button type="submit" class="btn btn-primary" id="save-ha">
              💾 Save
            </button>
          </div>
        </form>
      </details>
    </div>

    <!-- PWA / Offline Status — auto-detected from secure context -->
    <div class="card" id="pwa-status-card">
      <div class="card-header">
        <div>
          <div class="card-title">Progressive Web App</div>
          <div class="card-subtitle">
            Offline support, install-to-homescreen, and push notifications.
          </div>
        </div>
      </div>
      <div id="pwa-status-body" class="pwa-status-body">
        <!-- Populated by JS based on window.isSecureContext -->
        <div class="pwa-status-row" id="pwa-status-row">
          <div class="pwa-status-indicator" id="pwa-indicator">
            <span class="pwa-status-dot"></span>
          </div>
          <div class="pwa-status-info">
            <span class="pwa-status-label" id="pwa-status-label"
              >Checking...</span
            >
            <span class="pwa-status-detail" id="pwa-status-detail"></span>
          </div>
          <span class="badge badge-pending" id="pwa-badge">Checking</span>
        </div>
        <!-- HTTPS hint — shown only when insecure -->
        <div id="pwa-https-hint" class="pwa-https-hint" style="display: none;">
          <div class="pwa-https-hint__icon">🔒</div>
          <div class="pwa-https-hint__content">
            <strong>HTTPS required for full PWA support</strong>
            <p>
              Service workers, install prompts, and offline caching require a
              secure connection. Most Home Assistant setups support this:
            </p>
            <ul>
              <li><strong>Nabu Casa</strong> — HTTPS included automatically</li>
              <li>
                <strong>DuckDNS + Let's Encrypt</strong> — free SSL via HA addon
              </li>
              <li>
                <strong>Reverse proxy</strong> — Nginx Proxy Manager, Caddy, Traefik
              </li>
            </ul>
            <p style="margin-bottom: 0;">
              The app works fully without HTTPS — you just won't get offline
              support or the install prompt.
            </p>
          </div>
          <button
            type="button"
            class="pwa-https-hint__dismiss"
            id="pwa-hint-dismiss"
            aria-label="Dismiss"
            title="Dismiss this hint">✕</button
          >
        </div>
      </div>
    </div>

    <!-- Sidebar Config -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Sidebar Configuration</div>
          <div class="card-subtitle">
            Configure visibility, order, and custom labels for navigation items.
          </div>
        </div>
      </div>
      <div style="padding: 16px;">
        <div
          id="sidebar-item-list"
          style="display: flex; flex-direction: column; gap: 8px;"
        >
          <!-- Populated by JS -->
        </div>
        <div
          style="margin-top: 16px; border-top: 1px solid var(--border); padding-top: 16px;"
        >
          <div style="margin-bottom: 8px; font-weight: 500;">Custom Links</div>
          <div
            id="custom-links-list"
            style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 12px;"
          >
          </div>
          <button type="button" class="btn btn-ghost" id="add-custom-link-btn"
            >+ Add Custom Link</button
          >
        </div>
        <div style="display: flex; gap: 8px; margin-top: 16px;">
          <button
            type="button"
            class="btn btn-primary"
            id="save-sidebar"
            style="font-size: 13px;">Save Sidebar Config</button
          >
          <button
            type="button"
            class="btn btn-ghost"
            id="reset-sidebar"
            style="font-size: 13px;">Reset to Default</button
          >
        </div>
      </div>
    </div>

    <!-- Custom Fields -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">
            {t("settings.custom_fields_title", locale)}
          </div>
          <div class="card-subtitle">
            {t("settings.custom_fields_subtitle", locale)}
          </div>
        </div>
        <button type="button" class="btn btn-ghost" id="add-custom-field"
          >+ Add Field</button
        >
      </div>
      <div id="custom-fields-list">
        <div class="custom-field-row">
          <input
            type="text"
            class="form-input"
            placeholder="Field name"
            value="sprint"
            disabled
          />
          <select class="form-select" disabled>
            <option value="text" selected>Text</option>
            <option value="number">Number</option>
            <option value="select">Select</option>
            <option value="date">Date</option>
            <option value="checkbox">Checkbox</option>
          </select>
          <span style="color: var(--text-muted); font-size: 12px;"
            >Built-in</span
          >
        </div>
        <div class="custom-field-row">
          <input
            type="text"
            class="form-input"
            placeholder="Field name"
            value="story_points"
            disabled
          />
          <select class="form-select" disabled>
            <option value="number" selected>Number</option>
          </select>
          <span style="color: var(--text-muted); font-size: 12px;"
            >Built-in</span
          >
        </div>
      </div>
    </div>

    <!-- Strategic Lenses — Contextual Mapping -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Strategic Lenses</div>
          <div class="card-subtitle">
            Map evaluation frameworks contextually by Task Type.
          </div>
        </div>
      </div>
      <div
        style="display: flex; flex-direction: column; gap: 12px; margin-top: 16px;"
      >
        <div
          style="display: flex; align-items: center; justify-content: space-between; padding: 12px; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-secondary);"
        >
          <div>
            <strong style="display: block; font-size: 14px;">🎯 Epic</strong>
            <span style="font-size: 12px; color: var(--text-muted);"
              >High-level initiatives</span
            >
          </div>
          <select
            class="form-select framework-mapping-select"
            data-task-type="epic"
            multiple
            style="height: 80px; max-width: 260px;"
          >
            <option value="ddd">DDD (Domain-Driven Design)</option>
            <option value="rice">RICE (Priority Math)</option>
            <option value="drice">DRICE (Deps + RICE)</option>
            <option value="heart">HEART (UX Matrix)</option>
            <option value="kcs">KCS (Knowledge Workflow)</option>
          </select>
        </div>

        <div
          style="display: flex; align-items: center; justify-content: space-between; padding: 12px; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-secondary);"
        >
          <div>
            <strong style="display: block; font-size: 14px;">📖 Story</strong>
            <span style="font-size: 12px; color: var(--text-muted);"
              >User-facing features</span
            >
          </div>
          <select
            class="form-select framework-mapping-select"
            data-task-type="story"
            multiple
            style="height: 80px; max-width: 260px;"
          >
            <option value="rice">RICE (Priority Math)</option>
            <option value="drice">DRICE (Deps + RICE)</option>
            <option value="ddd">DDD (Domain-Driven Design)</option>
            <option value="heart">HEART (UX Matrix)</option>
            <option value="kcs">KCS (Knowledge Workflow)</option>
          </select>
        </div>

        <div
          style="display: flex; align-items: center; justify-content: space-between; padding: 12px; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-secondary);"
        >
          <div>
            <strong style="display: block; font-size: 14px;">✅ Task</strong>
            <span style="font-size: 12px; color: var(--text-muted);"
              >Standard work items</span
            >
          </div>
          <select
            class="form-select framework-mapping-select"
            data-task-type="task"
            multiple
            style="height: 80px; max-width: 260px;"
          >
            <option value="heart">HEART (UX Matrix)</option>
            <option value="rice">RICE (Priority Math)</option>
            <option value="drice">DRICE (Deps + RICE)</option>
            <option value="ddd">DDD (Domain-Driven Design)</option>
            <option value="kcs">KCS (Knowledge Workflow)</option>
          </select>
        </div>

        <div
          style="display: flex; align-items: center; justify-content: space-between; padding: 12px; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-secondary);"
        >
          <div>
            <strong style="display: block; font-size: 14px;"
              >📝 Documentation</strong
            >
            <span style="font-size: 12px; color: var(--text-muted);"
              >Knowledge articles</span
            >
          </div>
          <select
            class="form-select framework-mapping-select"
            data-task-type="documentation"
            multiple
            style="height: 80px; max-width: 260px;"
          >
            <option value="kcs">KCS (Knowledge Workflow)</option>
            <option value="heart">HEART (UX Matrix)</option>
            <option value="rice">RICE (Priority Math)</option>
            <option value="drice">DRICE (Deps + RICE)</option>
            <option value="ddd">DDD (Domain-Driven Design)</option>
          </select>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* ── HA Connection Status Card ── */
  .ha-status-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 8px;
    margin-bottom: 8px;
  }

  .ha-status-card__indicator {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ha-status-indicator {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    position: relative;
    flex-shrink: 0;
  }

  .ha-status-indicator__dot {
    display: block;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--text-muted);
    transition: background 300ms ease;
  }

  .ha-status-indicator--checking .ha-status-indicator__dot {
    background: var(--text-muted);
    animation: pulse-dim 1.5s ease-in-out infinite;
  }

  .ha-status-indicator--connected .ha-status-indicator__dot {
    background: var(--accent);
    box-shadow: 0 0 8px rgba(16, 185, 129, 0.4);
  }

  .ha-status-indicator--disconnected .ha-status-indicator__dot {
    background: var(--danger);
    box-shadow: 0 0 8px rgba(239, 68, 68, 0.3);
  }

  @keyframes pulse-dim {
    0%,
    100% {
      opacity: 0.4;
    }
    50% {
      opacity: 1;
    }
  }

  .ha-status-card__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ha-status-card__mode {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
  }

  .ha-status-card__detail {
    font-size: 12px;
    color: var(--text-muted);
    font-family: "JetBrains Mono", monospace;
  }

  /* ── HA Info Panel ── */
  .ha-info-panel {
    margin-top: 8px;
    padding: 12px 16px;
    background: rgba(16, 185, 129, 0.06);
    border: 1px solid rgba(16, 185, 129, 0.15);
    border-radius: 8px;
  }

  .ha-info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px 24px;
  }

  .ha-info-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ha-info-item__label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-muted);
    font-weight: 500;
  }

  .ha-info-item__value {
    font-size: 13px;
    color: var(--text-primary);
    font-family: "JetBrains Mono", monospace;
  }

  /* ── Advanced / Standalone Section ── */
  .ha-advanced-section {
    margin-top: 12px;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .ha-advanced-toggle {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 16px;
    cursor: pointer;
    font-size: 13px;
    color: var(--text-secondary);
    background: var(--bg-secondary);
    user-select: none;
    list-style: none;
  }

  .ha-advanced-toggle::-webkit-details-marker {
    display: none;
  }

  .ha-advanced-toggle::before {
    content: "▸";
    margin-right: 8px;
    transition: transform 150ms ease;
    font-size: 10px;
  }

  .ha-advanced-section[open] .ha-advanced-toggle::before {
    transform: rotate(90deg);
  }

  .ha-advanced-toggle small {
    font-size: 11px;
    color: var(--text-muted);
    font-style: italic;
  }

  .ha-advanced-form {
    padding: 16px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ── PWA Status Card ── */
  .pwa-status-body {
    padding: 0 16px 16px;
  }

  .pwa-status-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 8px;
  }

  .pwa-status-indicator {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-right: 12px;
  }

  .pwa-status-dot {
    display: block;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--text-muted);
    transition: background 300ms ease;
  }

  .pwa-status--active .pwa-status-dot {
    background: var(--accent);
    box-shadow: 0 0 8px rgba(16, 185, 129, 0.4);
  }

  .pwa-status--unavailable .pwa-status-dot {
    background: var(--warning, #f59e0b);
    box-shadow: 0 0 8px rgba(245, 158, 11, 0.3);
  }

  .pwa-status-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }

  .pwa-status-label {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
  }

  .pwa-status-detail {
    font-size: 12px;
    color: var(--text-muted);
    font-family: "JetBrains Mono", monospace;
  }

  .pwa-https-hint {
    display: flex;
    gap: 12px;
    margin-top: 12px;
    padding: 16px;
    background: rgba(245, 158, 11, 0.06);
    border: 1px solid rgba(245, 158, 11, 0.2);
    border-radius: 8px;
    position: relative;
  }

  .pwa-https-hint__icon {
    font-size: 24px;
    flex-shrink: 0;
    line-height: 1;
  }

  .pwa-https-hint__content {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .pwa-https-hint__content strong {
    display: block;
    font-size: 14px;
    color: var(--text-primary);
    margin-bottom: 6px;
  }

  .pwa-https-hint__content p {
    margin: 6px 0;
  }

  .pwa-https-hint__content ul {
    margin: 8px 0;
    padding-left: 18px;
    list-style: disc;
  }

  .pwa-https-hint__content li {
    margin-bottom: 4px;
  }

  .pwa-https-hint__dismiss {
    position: absolute;
    top: 8px;
    right: 8px;
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 16px;
    padding: 4px 8px;
    line-height: 1;
    border-radius: 4px;
    transition: background 150ms ease;
  }

  .pwa-https-hint__dismiss:hover {
    background: rgba(255, 255, 255, 0.08);
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .ha-info-grid {
      grid-template-columns: 1fr;
    }
    .ha-advanced-toggle {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
    }
  }
</style>

<script>
  /**
   * HA Connection Auto-Detect — Client-Side
   *
   * Fetches /api/ha/connection on load and populates the connection
   * status card with auto-detected HA info.
   */
  function initHAConnectionStatus() {
    const indicator = document.getElementById("ha-indicator");
    const modeLabel = document.getElementById("ha-mode-label");
    const detailLabel = document.getElementById("ha-detail-label");
    const badge = document.getElementById("ha-connection-badge");
    const infoPanel = document.getElementById("ha-info-panel");
    const advancedSection = document.getElementById("ha-advanced-section");
    if (!indicator || !modeLabel || !badge) return;
    if (indicator.dataset.haInit) return;
    indicator.dataset.haInit = "true";

    async function detectConnection() {
      try {
        const res = await fetch("/api/ha/connection");
        if (!res.ok) throw new Error("API error");
        const data = (await res.json()) as {
          connected: boolean;
          version?: string;
          mode?: string;
          location_name?: string;
          time_zone?: string;
          components?: string[];
          message?: string;
        };

        indicator!.className = "ha-status-indicator";

        if (data.connected) {
          indicator!.classList.add("ha-status-indicator--connected");
          modeLabel!.textContent =
            data.mode === "ha-addon"
              ? "✓ Connected as HA Addon"
              : "✓ Connected (standalone)";
          if (detailLabel)
            detailLabel.textContent = `HA ${data.version || "unknown"}`;
          badge!.textContent = "Connected";
          badge!.className = "badge badge-active";

          // Show info panel
          if (infoPanel) {
            infoPanel.style.display = "block";
            const versionEl = document.getElementById("ha-info-version");
            const locationEl = document.getElementById("ha-info-location");
            const timezoneEl = document.getElementById("ha-info-timezone");
            const modeEl = document.getElementById("ha-info-mode");
            if (versionEl) versionEl.textContent = data.version || "—";
            if (locationEl) locationEl.textContent = data.location_name || "—";
            if (timezoneEl) timezoneEl.textContent = data.time_zone || "—";
            if (modeEl)
              modeEl.textContent =
                data.mode === "ha-addon" ? "Addon (Supervisor)" : "Standalone";
          }

          // Hide advanced section when auto-connected as addon
          if (data.mode === "ha-addon" && advancedSection) {
            advancedSection.style.display = "none";
          }
        } else {
          indicator!.classList.add("ha-status-indicator--disconnected");
          modeLabel!.textContent =
            data.mode === "standalone"
              ? "Standalone mode — configure below"
              : `Not connected — ${data.message || "check configuration"}`;
          if (detailLabel) detailLabel.textContent = data.message || "";
          badge!.textContent = "Disconnected";
          badge!.className = "badge badge-pending";

          // Show advanced section in standalone mode
          if (advancedSection) {
            advancedSection.style.display = "block";
            (advancedSection as HTMLDetailsElement).open = true;
          }
        }
      } catch {
        indicator!.className =
          "ha-status-indicator ha-status-indicator--disconnected";
        modeLabel!.textContent = "Connection check failed";
        badge!.textContent = "Error";
        badge!.className = "badge badge-pending";

        // Show advanced section as fallback
        if (advancedSection) {
          advancedSection.style.display = "block";
        }
      }
    }

    detectConnection();
  }

  initHAConnectionStatus();
  document.addEventListener("astro:page-load", initHAConnectionStatus);

  /**
   * PWA Status Detection — Client-Side
   *
   * Checks window.isSecureContext and navigator.serviceWorker to determine
   * whether PWA features (SW, install prompt, push) are available.
   * Shows actionable HTTPS guidance for insecure contexts.
   *
   * Bounded context: offline / settings
   */
  function initPwaStatus() {
    const indicator = document.getElementById("pwa-indicator");
    const label = document.getElementById("pwa-status-label");
    const detail = document.getElementById("pwa-status-detail");
    const badge = document.getElementById("pwa-badge");
    const hint = document.getElementById("pwa-https-hint");
    const dismissBtn = document.getElementById("pwa-hint-dismiss");
    if (!indicator || !label || !badge) return;
    if (indicator.dataset.pwaInit) return;
    indicator.dataset.pwaInit = "true";

    const isSecure = window.isSecureContext;
    const hasSw = "serviceWorker" in navigator;
    const supported = isSecure && hasSw;

    if (supported) {
      // Check if SW is actually registered
      navigator.serviceWorker
        .getRegistration()
        .then((reg) => {
          indicator!.className = "pwa-status-indicator pwa-status--active";
          if (reg) {
            label!.textContent = "✓ Service worker active";
            if (detail) detail.textContent = `Scope: ${reg.scope}`;
            badge!.textContent = "Active";
            badge!.className = "badge badge-active";
          } else {
            label!.textContent = "✓ PWA supported — awaiting first cache";
            if (detail)
              detail.textContent = "Service worker will register shortly";
            badge!.textContent = "Ready";
            badge!.className = "badge badge-active";
          }
        })
        .catch(() => {
          indicator!.className = "pwa-status-indicator pwa-status--active";
          label!.textContent = "✓ PWA supported";
          badge!.textContent = "Ready";
          badge!.className = "badge badge-active";
        });
    } else {
      indicator!.className = "pwa-status-indicator pwa-status--unavailable";
      if (!isSecure) {
        label!.textContent = "Requires HTTPS";
        if (detail)
          detail.textContent =
            window.location.protocol + "//" + window.location.host;
        badge!.textContent = "HTTP only";
        badge!.className = "badge badge-pending";

        // Show hint unless dismissed
        if (hint && !localStorage.getItem("meitheal_pwa_hint_dismissed")) {
          hint.style.display = "flex";
        }
      } else {
        label!.textContent = "Not supported in this browser";
        badge!.textContent = "Unavailable";
        badge!.className = "badge badge-pending";
      }
    }

    // Dismiss button
    if (dismissBtn && hint) {
      dismissBtn.addEventListener("click", () => {
        hint.style.display = "none";
        localStorage.setItem("meitheal_pwa_hint_dismissed", "1");
      });
    }
  }

  initPwaStatus();
  document.addEventListener("astro:page-load", initPwaStatus);
</script>
