---
import { t } from "../../i18n/translations";
import type { Locale } from "../../lib/locale";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

// Dynamic version — injected at build time from meitheal-hub/config.yaml via
// vite.define in astro.config.mjs. Runtime env var takes precedence (Docker).
declare const __MEITHEAL_VERSION__: string;
const version =
  import.meta.env.MEITHEAL_VERSION ||
  process.env.MEITHEAL_VERSION ||
  (typeof __MEITHEAL_VERSION__ !== "undefined"
    ? __MEITHEAL_VERSION__
    : "0.0.0-dev");
---

<div
  id="tab-system"
  class="tab-pane"
  role="tabpanel"
  aria-labelledby="tab-btn-system"
  style="display: none;"
  aria-hidden="true"
>
  <div class="settings-grid">
    <!-- Keyboard Shortcuts -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">
            {t("settings.shortcuts_title", locale)}
          </div>
          <div class="card-subtitle">
            {t("settings.shortcuts_subtitle", locale)}
          </div>
        </div>
      </div>
      <div class="shortcut-grid">
        <div class="shortcut-row">
          <kbd>n</kbd><span>{t("settings.shortcut_new_task", locale)}</span>
        </div>
        <div class="shortcut-row">
          <kbd>/</kbd><span>{t("settings.shortcut_search", locale)}</span>
        </div>
        <div class="shortcut-row">
          <kbd>Ctrl</kbd> + <kbd>B</kbd><span>Toggle sidebar</span>
        </div>
        <div class="shortcut-row">
          <kbd>Ctrl</kbd> + <kbd>K</kbd><span>Command palette</span>
        </div>
        <div class="shortcut-row">
          <kbd>l</kbd><span>{t("settings.shortcut_list", locale)}</span>
        </div>
        <div class="shortcut-row">
          <kbd>k</kbd><span>{t("settings.shortcut_kanban", locale)}</span>
        </div>
        <div class="shortcut-row">
          <kbd>t</kbd><span>{t("settings.shortcut_table", locale)}</span>
        </div>
        <div class="shortcut-row">
          <kbd>y</kbd><span>{t("settings.shortcut_today", locale)}</span>
        </div>
        <div class="shortcut-row">
          <kbd>u</kbd><span>{t("settings.shortcut_upcoming", locale)}</span>
        </div>
        <div class="shortcut-row">
          <kbd>c</kbd><span>{t("settings.shortcut_calendar", locale)}</span>
        </div>
        <div class="shortcut-row">
          <kbd>Esc</kbd><span>{t("settings.shortcut_close", locale)}</span>
        </div>
        <div class="shortcut-row">
          <kbd>?</kbd><span>{t("settings.shortcut_help", locale)}</span>
        </div>
      </div>
    </div>

    <!-- Language & Appearance -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">{t("settings.language_title", locale)}</div>
          <div class="card-subtitle">
            {t("settings.language_subtitle", locale)}
          </div>
        </div>
      </div>
      <div class="form-group" style="margin-top: 12px;">
        <label class="form-label" for="locale-select">Display Language</label>
        <select
          class="form-select"
          id="locale-select"
          style="max-width: 240px;"
        >
          <option value="en">English</option>
          <option value="ga">Gaeilge</option>
        </select>
      </div>
      <div class="form-group" style="margin-top: 12px;">
        <label class="form-label" for="theme-select">🎨 Theme</label>
        <select class="form-select" id="theme-select" style="max-width: 240px;">
          <option value="dark">Dark</option>
          <option value="light">Light</option>
          <option value="auto">Auto (System)</option>
          <option value="custom">Custom</option>
        </select>
      </div>

      <!-- Accent Color -->
      <div class="form-group" style="margin-top: 12px;">
        <label class="form-label">🎨 Accent Color</label>
        <div
          style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;"
        >
          <button
            type="button"
            class="accent-swatch"
            data-color="#6366F1"
            title="Indigo (Default)"
            style="background: #6366F1;"></button>
          <button
            type="button"
            class="accent-swatch"
            data-color="#14b8a6"
            title="Teal"
            style="background: #14b8a6;"></button>
          <button
            type="button"
            class="accent-swatch"
            data-color="#3b82f6"
            title="Blue"
            style="background: #3b82f6;"></button>
          <button
            type="button"
            class="accent-swatch"
            data-color="#8b5cf6"
            title="Violet"
            style="background: #8b5cf6;"></button>
          <button
            type="button"
            class="accent-swatch"
            data-color="#ec4899"
            title="Pink"
            style="background: #ec4899;"></button>
          <button
            type="button"
            class="accent-swatch"
            data-color="#f59e0b"
            title="Amber"
            style="background: #f59e0b;"></button>
          <button
            type="button"
            class="accent-swatch"
            data-color="#ef4444"
            title="Red"
            style="background: #ef4444;"></button>
          <input
            type="color"
            id="accent-color-custom"
            title="Custom color"
            style="width: 28px; height: 28px; border: 2px solid var(--border); border-radius: 50%; padding: 0; cursor: pointer; background: transparent;"
          />
          <button
            type="button"
            id="accent-reset"
            class="btn btn-ghost"
            style="font-size: 11px; padding: 4px 8px;">Reset</button
          >
        </div>
        <small
          style="color: var(--text-muted); font-size: 11px; margin-top: 4px; display: block;"
          >Changes apply immediately across all pages.</small
        >
      </div>
      <div
        id="custom-theme-section"
        class="form-group"
        style="margin-top: 12px; display: none;"
      >
        <div
          id="custom-theme-empty"
          style="display: flex; align-items: center; gap: 8px;"
        >
          <label
            class="btn btn-secondary"
            style="cursor: pointer; margin: 0; padding: 6px 16px; display: inline-flex; align-items: center; gap: 6px;"
          >
            🎨 Import CSS Theme
            <input
              type="file"
              id="custom-theme-input"
              accept=".css"
              style="display: none;"
            />
          </label>
          <small style="color: var(--text-muted); font-size: 11px;"
            >Max 50KB · .css only · 1 theme</small
          >
        </div>
        <div
          id="custom-theme-loaded"
          style="display: none; align-items: center; gap: 8px; margin-top: 8px; padding: 8px 12px; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius-sm);"
        >
          <span style="font-size: 14px;">🎨</span>
          <a
            id="custom-theme-filename"
            href="#"
            style="flex: 1; font-size: 13px; font-weight: 500; color: var(--accent); cursor: pointer;"
          ></a>
          <button
            type="button"
            id="custom-theme-delete"
            class="btn-icon"
            style="color: var(--danger); font-size: 14px; padding: 2px 6px;"
            title="Remove custom theme"
            aria-label="Remove custom theme">×</button
          >
        </div>
      </div>
      <div class="form-group" style="margin-top: 12px;">
        <label class="form-label" for="timezone-select">Timezone</label>
        <select
          class="form-select"
          id="timezone-select"
          style="max-width: 300px;"
        >
          <option value="Europe/Dublin">Europe/Dublin</option>
          <option value="Europe/London">Europe/London</option>
          <option value="Europe/Berlin">Europe/Berlin</option>
          <option value="Europe/Paris">Europe/Paris</option>
          <option value="America/New_York">America/New_York</option>
          <option value="America/Chicago">America/Chicago</option>
          <option value="America/Denver">America/Denver</option>
          <option value="America/Los_Angeles">America/Los_Angeles</option>
          <option value="Asia/Tokyo">Asia/Tokyo</option>
          <option value="Asia/Shanghai">Asia/Shanghai</option>
          <option value="Australia/Sydney">Australia/Sydney</option>
          <option value="UTC">UTC</option>
        </select>
      </div>
      <div class="form-group" style="margin-top: 12px;">
        <label class="form-label" for="week-start-select">Week Starts On</label>
        <select
          class="form-select"
          id="week-start-select"
          style="max-width: 240px;"
        >
          <option value="monday">Monday</option>
          <option value="sunday">Sunday</option>
          <option value="saturday">Saturday</option>
        </select>
      </div>
      <div class="form-group" style="margin-top: 12px;">
        <label class="form-label" for="date-format-select"
          >Date Display Format</label
        >
        <select
          class="form-select"
          id="date-format-select"
          style="max-width: 300px;"
        >
          <option value="relative">Relative (e.g. "2 days ago")</option>
          <option value="absolute-iso">Absolute ISO (2026-03-01)</option>
          <option value="absolute-eu">Absolute EU (01/03/2026)</option>
          <option value="absolute-us">Absolute US (03/01/2026)</option>
        </select>
      </div>
    </div>

    <!-- Data Portability -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">{t("settings.data_title", locale)}</div>
          <div class="card-subtitle">
            {t("settings.data_subtitle", locale)}
          </div>
        </div>
      </div>
      <div class="form-group" style="margin-top: 12px;">
        <label class="form-label" style="margin-bottom: 8px;"
          >Export Tasks</label
        >
        <div style="display: flex; gap: 8px;">
          <a
            href="#"
            class="btn btn-primary"
            id="export-json-btn"
            style="flex: 1; text-align: center; text-decoration: none;"
            >📥 Download JSON</a
          >
          <a
            href="/api/export/tasks.csv"
            download
            class="btn btn-secondary"
            id="export-csv-btn"
            style="flex: 1; text-align: center; text-decoration: none;"
            >📊 Download CSV</a
          >
          <button
            type="button"
            class="btn btn-secondary"
            id="export-db-btn"
            style="flex: 1; text-align: center;">🗄️ Raw DB</button
          >
        </div>
        <small
          style="color: var(--text-muted); font-size: 11px; display: block; margin-top: 6px;"
        >
          Export your tasks to JSON/CSV, or download the entire raw SQLite
          database file for full local-first data sovereignty.
        </small>
      </div>

      <div
        class="form-group"
        style="margin-top: 16px; border-top: 1px solid var(--border-color); padding-top: 16px;"
      >
        <label class="form-label" style="margin-bottom: 8px;"
          >Settings Configuration</label
        >
        <div style="display: flex; gap: 8px;">
          <a
            href="/api/export/settings.json"
            download
            class="btn btn-secondary"
            id="export-settings-btn"
            style="flex: 1; text-align: center; text-decoration: none;"
            >⚙️ Export Config</a
          >
          <label
            class="btn btn-secondary"
            style="flex: 1; text-align: center; cursor: pointer; margin: 0; padding: 6px 16px; display: inline-flex; justify-content: center; align-items: center;"
          >
            🔄 Import Config
            <input
              type="file"
              id="import-settings-input"
              accept=".json"
              style="display: none;"
            />
          </label>
        </div>
        <small
          style="color: var(--text-muted); font-size: 11px; display: block; margin-top: 6px;"
        >
          Backup or restore your tokens, shortcuts, UI layouts, and active
          integrations. Restoring will trigger a page reload.
        </small>
      </div>
    </div>

    <!-- About -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">{t("settings.about_title", locale)}</div>
          <div class="card-subtitle">
            {t("settings.about_subtitle", locale)}
          </div>
        </div>
      </div>
      <div
        style="font-size: 13px; color: var(--text-secondary); line-height: 1.8;"
      >
        <p>
          <a
            href="https://en.wiktionary.org/wiki/meitheal"
            target="_blank"
            rel="noopener noreferrer"
            style="color: var(--accent); font-weight: 600; text-decoration: underline; text-underline-offset: 3px;"
            >Meitheal</a
          >
          (IPA: /ˈmɛhəl/) — from Irish: a cooperative work party where neighbours
          come together to help with farming, harvesting, or building. The tradition
          reflects a core principle: <em>work shared is work halved</em>.
        </p>
        <p>
          A Home Assistant-native, Astro-first task and life management engine —
          built for people who think in systems.
        </p>
        <p style="margin-top: 8px;">
          Version: <code>{version}</code>
        </p>
        <div
          id="pwa-status-compact"
          class="pwa-compact-row"
          style="margin-top: 8px;"
        >
          <div
            style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;"
          >
            <span
              class="pwa-compact-dot"
              id="pwa-compact-dot"
              role="status"
              aria-label="PWA status indicator"></span>
            <span
              style="font-size: 13px; color: var(--text-secondary);"
              id="pwa-compact-label">PWA: Checking...</span
            >
            <span
              class="badge badge-pending"
              id="pwa-compact-badge"
              style="font-size: 11px;">Checking</span
            >
            <span
              id="pwa-compact-version"
              style="font-size: 11px; color: var(--text-muted); font-family: 'JetBrains Mono', monospace; display: none;"
            ></span>
            <a
              href="#"
              id="pwa-install-settings-btn"
              class="pwa-subtle-link"
              style="display: none;">install</a
            >
            <a
              href="#"
              id="pwa-update-settings-btn"
              class="pwa-subtle-link"
              style="display: none;">update available</a
            >
            <span
              id="pwa-installed-badge"
              class="badge badge-active"
              style="font-size: 11px; display: none;">✓ Installed</span
            >
            <span class="pwa-link-separator" aria-hidden="true">·</span>
            <a
              href="#"
              id="pwa-popout-btn"
              class="pwa-subtle-link"
              title="Open in a standalone browser tab (required for install prompt)"
              >open in browser ↗</a
            >
            <span class="pwa-link-separator" aria-hidden="true">·</span>
            <a href="#" id="pwa-uninstall-btn" class="pwa-subtle-link"
              >uninstall</a
            >
          </div>
          <!-- Uninstall instructions (hidden by default) -->
          <div
            id="pwa-uninstall-info"
            style="display: none; margin-top: 6px; font-size: 12px; color: var(--text-muted); line-height: 1.6; padding: 8px 12px; background: var(--bg-secondary); border-radius: 8px;"
          >
            <strong style="color: var(--text-secondary);"
              >How to uninstall:</strong
            ><br />
            <strong>Chrome/Edge:</strong> Open the installed app → ⋮ menu → "Uninstall
            Meitheal"<br />
            <strong>Safari:</strong> Long-press the icon on your home screen → Remove<br
            />
            <strong>Firefox:</strong> Not applicable (does not support PWA install)<br
            />
            <small style="margin-top: 4px; display: block;"
              >Your data is safe — uninstalling the PWA only removes the
              shortcut and cached shell.</small
            >
          </div>
          <details
            id="pwa-compact-details"
            style="display: none; margin-top: 6px;"
          >
            <summary
              style="font-size: 12px; color: var(--accent); cursor: pointer; list-style: none;"
            >
              Why is PWA unavailable?
            </summary>
            <div
              style="margin-top: 6px; font-size: 12px; color: var(--text-muted); line-height: 1.6; padding: 8px 12px; background: var(--bg-secondary); border-radius: 8px;"
            >
              PWA features (offline support, install prompt) require HTTPS.
              Options:
              <strong>Nabu Casa</strong> (automatic), <strong
                >DuckDNS + Let's Encrypt</strong
              > (free), or a <strong>reverse proxy</strong>. The app works fully
              without HTTPS.
            </div>
          </details>
          <!-- PWA Troubleshooting -->
          <details id="pwa-troubleshoot" style="margin-top: 6px;">
            <summary
              class="pwa-subtle-link"
              style="list-style: none; cursor: pointer; display: inline;"
              >troubleshooting</summary
            >
            <div class="pwa-troubleshoot-panel">
              <p
                style="margin: 0 0 8px; font-size: 12px; color: var(--text-muted);"
              >
                If the app is behaving unexpectedly, these self-help actions may
                resolve it.
              </p>
              <div style="display: flex; gap: 6px; flex-wrap: wrap;">
                <button
                  type="button"
                  id="pwa-clear-cache-btn"
                  class="btn btn-ghost pwa-troubleshoot-btn"
                  >🗑 Clear Cache</button
                >
                <button
                  type="button"
                  id="pwa-force-update-btn"
                  class="btn btn-ghost pwa-troubleshoot-btn"
                  >🔄 Force SW Update</button
                >
                <button
                  type="button"
                  id="pwa-clear-offline-btn"
                  class="btn btn-ghost pwa-troubleshoot-btn"
                  >📴 Clear Offline Data</button
                >
              </div>
              <div
                style="display: flex; gap: 6px; flex-wrap: wrap; margin-top: 6px;"
              >
                <button
                  type="button"
                  id="pwa-push-notif-btn"
                  class="btn btn-ghost pwa-troubleshoot-btn"
                  >🔔 Push Notifications</button
                >
                <button
                  type="button"
                  id="pwa-reset-hints-btn"
                  class="btn btn-ghost pwa-troubleshoot-btn"
                  >🔁 Reset All Hints</button
                >
              </div>
              <div
                id="pwa-troubleshoot-result"
                style="display: none; margin-top: 6px; font-size: 11px; padding: 6px 10px; border-radius: 6px; background: var(--bg-secondary); border: 1px solid var(--border);"
              >
              </div>
            </div>
          </details>
        </div>
      </div>
      <div
        style="margin-top: 16px; padding-top: 12px; border-top: 1px solid var(--border); display: flex; gap: 12px; flex-wrap: wrap;"
      >
        <a
          href="https://github.com/Coolock-Village/meitheal/issues/new/choose"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-secondary"
          style="font-size: 12px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px;"
          >🐛 Report an Issue</a
        >
        <a
          href="https://github.com/Coolock-Village/meitheal/discussions"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-secondary"
          style="font-size: 12px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px;"
          >💬 Discussions</a
        >
        <a
          href="https://github.com/Coolock-Village/meitheal"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-secondary"
          style="font-size: 12px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px;"
          >⭐ Star on GitHub</a
        >
      </div>
    </div>

    <!-- Help & Support -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Help & Support</div>
          <div class="card-subtitle">
            Documentation, guides, and community resources.
          </div>
        </div>
      </div>
      <div
        style="font-size: 13px; color: var(--text-secondary); line-height: 1.8;"
      >
        <details open>
          <summary
            style="font-weight: 600; font-size: 14px; cursor: pointer; color: var(--text-primary); list-style: none; display: flex; align-items: center; gap: 6px;"
          >
            📖 Getting Started
          </summary>
          <div
            style="margin-top: 8px; padding: 12px; background: var(--bg-secondary); border-radius: 8px; border: 1px solid var(--border);"
          >
            <p style="margin: 0 0 8px 0;">
              <strong>Meitheal</strong> is a local-first task and life management
              engine built for Home Assistant. Your data lives on your device. No
              cloud required.
            </p>
            <ul style="margin: 0; padding-left: 20px; line-height: 2;">
              <li>
                Create tasks with <kbd
                  style="font-size: 11px; padding: 1px 6px; background: var(--bg-primary); border: 1px solid var(--border); border-radius: 4px;"
                  >n</kbd
                > or the + button
              </li>
              <li>Switch views: Kanban, Table, Calendar, Today, Upcoming</li>
              <li>Drag and drop to reorder, prioritize, and schedule</li>
              <li>
                Configure integrations (Calendar, Todo, Grocy) in the
                Integrations tab
              </li>
              <li>All data is exportable as JSON, CSV, or raw SQLite</li>
            </ul>
          </div>
        </details>
        <details style="margin-top: 12px;">
          <summary
            style="font-weight: 600; font-size: 14px; cursor: pointer; color: var(--text-primary); list-style: none; display: flex; align-items: center; gap: 6px;"
          >
            🏗️ Architecture
          </summary>
          <div
            style="margin-top: 8px; padding: 12px; background: var(--bg-secondary); border-radius: 8px; border: 1px solid var(--border);"
          >
            <p style="margin: 0 0 8px 0;">Meitheal is built with:</p>
            <ul style="margin: 0; padding-left: 20px; line-height: 2;">
              <li><strong>Astro</strong> for SSR and static generation</li>
              <li>
                <strong>SQLite</strong> (better-sqlite3) for local-first persistence
              </li>
              <li>
                <strong>Home Assistant WebSocket API</strong> for calendar and todo
                sync
              </li>
              <li>
                <strong>Service Worker</strong> for offline caching (requires HTTPS)
              </li>
              <li>
                <strong>Domain-Driven Design</strong> with bounded contexts per feature
              </li>
            </ul>
          </div>
        </details>
      </div>
      <div
        style="margin-top: 16px; padding-top: 12px; border-top: 1px solid var(--border); display: flex; gap: 12px; flex-wrap: wrap;"
      >
        <a
          href="https://github.com/Coolock-Village/meitheal#readme"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-secondary"
          style="font-size: 12px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px;"
          >📄 Full README</a
        >
        <a
          href="https://github.com/Coolock-Village/meitheal/wiki"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-secondary"
          style="font-size: 12px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px;"
          >📚 Wiki</a
        >
        <a
          href="https://github.com/Coolock-Village/meitheal/blob/main/CHANGELOG.md"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-secondary"
          style="font-size: 12px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px;"
          >📋 Changelog</a
        >
      </div>
    </div>

    <!-- Danger Zone -->
    <div class="card" style="border-color: var(--danger); border-width: 2px;">
      <div class="card-header">
        <div>
          <div class="card-title" style="color: var(--danger);">
            {t("settings.danger_title", locale)}
          </div>
          <div class="card-subtitle">
            {t("settings.danger_subtitle", locale)}
          </div>
        </div>
      </div>
      <div style="display: flex; gap: 8px; flex-wrap: wrap;">
        <button
          class="btn"
          id="purge-tasks"
          style="border-color: var(--danger); color: var(--danger);"
          >🗑 Purge All Tasks</button
        >
        <button
          class="btn"
          id="reset-settings"
          style="border-color: var(--danger); color: var(--danger);"
          >🔄 Reset Settings</button
        >
      </div>
    </div>
  </div>
</div>

<style is:inline>
  /* Keyboard Shortcuts — is:inline survives ClientRouter DOM swaps */
  .shortcut-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }
  .shortcut-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--border);
    font-size: 13px;
    color: var(--text-secondary);
  }
  .shortcut-row:nth-child(odd) {
    background: rgba(255, 255, 255, 0.02);
  }
  .shortcut-row:last-child,
  .shortcut-row:nth-last-child(2):nth-child(odd) {
    border-bottom: none;
  }
  kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 28px;
    height: 26px;
    padding: 0 8px;
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-primary);
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-bottom-width: 2px;
    border-radius: 6px;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.2);
    white-space: nowrap;
  }
  .pwa-compact-row {
    padding: 8px 0;
    border-top: 1px solid var(--border);
  }
  .pwa-compact-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--text-muted);
    transition:
      background 300ms ease,
      box-shadow 300ms ease;
  }
  .pwa-compact-dot--active {
    background: var(--accent);
    box-shadow: 0 0 6px rgba(99, 102, 241, 0.4);
  }
  .pwa-compact-dot--unavailable {
    background: #f59e0b;
  }
  .pwa-subtle-link {
    font-size: 11px;
    color: var(--text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    cursor: pointer;
    transition: color 0.15s ease;
    background: none;
    border: none;
    padding: 0;
    font-family: inherit;
  }
  .pwa-subtle-link:hover {
    color: var(--accent);
  }
  .pwa-link-separator {
    font-size: 11px;
    color: var(--text-muted);
    opacity: 0.4;
    user-select: none;
  }
  .pwa-troubleshoot-panel {
    margin-top: 8px;
    padding: 10px 12px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 8px;
  }
  .pwa-troubleshoot-btn {
    font-size: 11px !important;
    padding: 4px 10px !important;
  }

  /* Accent color swatches */
  .accent-swatch {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
    transition: all 0.2s;
    padding: 0;
  }
  .accent-swatch:hover {
    transform: scale(1.15);
  }
  .accent-swatch.active {
    border-color: var(--text-primary);
    box-shadow:
      0 0 0 2px var(--bg-secondary),
      0 0 0 4px currentColor;
  }
</style>

<script>
  function initPwaCompact() {
    const dot = document.getElementById("pwa-compact-dot");
    const label = document.getElementById("pwa-compact-label");
    const badge = document.getElementById("pwa-compact-badge");
    const details = document.getElementById("pwa-compact-details");
    const versionEl = document.getElementById("pwa-compact-version");
    const installBtn = document.getElementById("pwa-install-settings-btn");
    const updateBtn = document.getElementById("pwa-update-settings-btn");
    const installedBadge = document.getElementById("pwa-installed-badge");
    if (!dot || !label || !badge) return;
    if (dot.dataset.pwaInit) return;
    dot.dataset.pwaInit = "true";

    const isSecure = window.isSecureContext;
    const hasSW = "serviceWorker" in navigator;

    if (isSecure && hasSW) {
      dot.className = "pwa-compact-dot pwa-compact-dot--active";
      label.textContent = "PWA: Active";
      badge.textContent = "Active";
      badge.className = "badge badge-active";
      badge.style.fontSize = "11px";

      // Query SW version
      if (navigator.serviceWorker.controller && versionEl) {
        navigator.serviceWorker.addEventListener("message", (e) => {
          if (e.data?.type === "VERSION") {
            versionEl.textContent = `SW v${e.data.version}`;
            versionEl.style.display = "";
          }
        });
        navigator.serviceWorker.controller.postMessage({ type: "GET_VERSION" });
      }

      // Check for waiting SW (update available)
      navigator.serviceWorker.ready.then((reg) => {
        if (reg.waiting && updateBtn) {
          updateBtn.style.display = "";
          updateBtn.addEventListener("click", (e) => {
            e.preventDefault();
            reg.waiting?.postMessage({ type: "SKIP_WAITING" });
            window.location.reload();
          });
        }
      });
    } else {
      dot.className = "pwa-compact-dot pwa-compact-dot--unavailable";
      label.textContent = "PWA: Requires HTTPS";
      badge.textContent = "HTTP only";
      badge.className = "badge badge-pending";
      badge.style.fontSize = "11px";
      if (details) details.style.display = "block";
    }

    // Install button — show when install prompt available
    if (installBtn) {
      const showInstallBtn = () => {
        if (window.__pwa_install_prompt) {
          installBtn.style.display = "";
        }
      };
      showInstallBtn();
      window.addEventListener("meitheal-pwa-installable", showInstallBtn);

      installBtn.addEventListener("click", async (e) => {
        e.preventDefault();
        const prompt = window.__pwa_install_prompt;
        if (!prompt) return;
        try {
          await prompt.prompt();
          const result = await prompt.userChoice;
          if (result.outcome === "accepted") {
            installBtn.style.display = "none";
            if (installedBadge) installedBadge.style.display = "";
          }
        } catch {
          /* prompt can only be called once */
        }
        window.__pwa_install_prompt = null;
      });
    }

    // Listen for installed event (window-level, guarded to prevent accumulation)
    if (!(window as any).__pwaCompactListenersBound) {
      (window as any).__pwaCompactListenersBound = true;
      window.addEventListener("meitheal-pwa-installed", () => {
        const ib = document.getElementById("pwa-install-settings-btn");
        const iBadge = document.getElementById("pwa-installed-badge");
        if (ib) ib.style.display = "none";
        if (iBadge) iBadge.style.display = "";
      });
    }
  }

  initPwaCompact();
  document.addEventListener("astro:page-load", initPwaCompact);

  // ── Pop out to browser (escape HA iframe for PWA install) ──
  function initPwaPopout() {
    const popoutBtn = document.getElementById("pwa-popout-btn");
    const uninstallBtn = document.getElementById("pwa-uninstall-btn");
    const uninstallInfo = document.getElementById("pwa-uninstall-info");
    if (!popoutBtn || popoutBtn.dataset.popoutInit) return;
    popoutBtn.dataset.popoutInit = "true";

    popoutBtn?.addEventListener("click", (e) => {
      e.preventDefault();
      // Construct the full top-level URL for the app
      // If inside HA ingress iframe, we need the parent origin + ingress path
      const ingressPath = window.__ingress_path || "";
      let targetUrl: string;

      if (ingressPath) {
        // We're in HA ingress — build the parent-frame URL
        // The iframe src is just "/" but the real URL is origin + ingressPath + "/"
        try {
          const parentOrigin =
            window.top?.location?.origin || window.location.origin;
          targetUrl = parentOrigin + ingressPath + "/settings#system";
        } catch {
          // Cross-origin: can't read parent origin, use referrer or HA default
          const referrer = document.referrer;
          if (referrer) {
            const refUrl = new URL(referrer);
            targetUrl = refUrl.origin + ingressPath + "/settings#system";
          } else {
            // Last resort: just use the ingress path relative
            targetUrl = ingressPath + "/settings#system";
          }
        }
      } else {
        // Standalone mode — same origin
        targetUrl = window.location.origin + "/settings#system";
      }

      window.open(targetUrl, "_blank", "noopener");
    });

    uninstallBtn?.addEventListener("click", (e) => {
      e.preventDefault();
      if (uninstallInfo) {
        const showing = uninstallInfo.style.display !== "none";
        uninstallInfo.style.display = showing ? "none" : "block";
      }
    });
  }

  initPwaPopout();
  document.addEventListener("astro:page-load", initPwaPopout);

  // ── PWA Troubleshooting Actions ──
  function showTroubleshootResult(msg: string, ok = true) {
    const el = document.getElementById("pwa-troubleshoot-result");
    if (!el) return;
    el.textContent = msg;
    el.style.display = "block";
    el.style.color = ok ? "var(--accent)" : "var(--danger)";
    setTimeout(() => {
      el.style.display = "none";
    }, 4000);
  }

  function initPwaTroubleshooting() {
    const clearCacheBtn = document.getElementById("pwa-clear-cache-btn");
    const forceUpdateBtn = document.getElementById("pwa-force-update-btn");
    const clearOfflineBtn = document.getElementById("pwa-clear-offline-btn");
    if (!clearCacheBtn || clearCacheBtn.dataset.troubleshootInit) return;
    clearCacheBtn.dataset.troubleshootInit = "true";

    clearCacheBtn?.addEventListener("click", async () => {
      try {
        const names = await caches.keys();
        await Promise.all(names.map((n) => caches.delete(n)));
        showTroubleshootResult(
          `✓ Cleared ${names.length} cache(s). Reload to re-populate.`,
        );
      } catch (err) {
        showTroubleshootResult("✗ Failed to clear caches.", false);
      }
    });

    forceUpdateBtn?.addEventListener("click", async () => {
      try {
        if (!("serviceWorker" in navigator)) {
          showTroubleshootResult("Service workers not available.", false);
          return;
        }
        const reg = await navigator.serviceWorker.getRegistration();
        if (reg) {
          await reg.update();
          if (reg.waiting) {
            reg.waiting.postMessage({ type: "SKIP_WAITING" });
          }
          showTroubleshootResult("✓ SW update triggered. Reloading...");
          setTimeout(() => window.location.reload(), 800);
        } else {
          showTroubleshootResult("No service worker registered.", false);
        }
      } catch (err) {
        showTroubleshootResult("✗ SW update failed.", false);
      }
    });

    clearOfflineBtn?.addEventListener("click", async () => {
      try {
        // Clear all known IDB databases
        const dbNames = [
          "meitheal-offline",
          "meitheal-tasks",
          "meitheal-sync",
          "task_attachments",
        ];
        let deleted = 0;
        for (const name of dbNames) {
          try {
            const req = indexedDB.deleteDatabase(name);
            await new Promise<void>((resolve, reject) => {
              req.onsuccess = () => {
                deleted++;
                resolve();
              };
              req.onerror = () => reject(req.error);
              req.onblocked = () => resolve(); // may be blocked if other tabs open
            });
          } catch {
            /* skip individual failures */
          }
        }
        // Clear sync-related localStorage keys
        [
          "meitheal-sync-queue",
          "meitheal-last-sync",
          "meitheal-offline-tasks",
        ].forEach((k) => {
          try {
            localStorage.removeItem(k);
          } catch { /* non-fatal */ }
        });
        showTroubleshootResult(
          `✓ Cleared ${deleted} offline database(s) and sync state.`,
        );
      } catch (err) {
        showTroubleshootResult("✗ Failed to clear offline data.", false);
      }
    });
    // Push notification opt-in
    const pushBtn = document.getElementById("pwa-push-notif-btn");
    pushBtn?.addEventListener("click", async () => {
      if (!("Notification" in window)) {
        showTroubleshootResult(
          "Notifications not supported in this browser.",
          false,
        );
        return;
      }
      const current = Notification.permission;
      if (current === "granted") {
        showTroubleshootResult("✓ Push notifications already enabled.");
        return;
      }
      if (current === "denied") {
        showTroubleshootResult(
          "✗ Notifications blocked. Reset in browser settings → Site permissions.",
          false,
        );
        return;
      }
      try {
        const result = await Notification.requestPermission();
        if (result === "granted") {
          showTroubleshootResult("✓ Push notifications enabled!");
          // Send a test notification
          new Notification("Meitheal", {
            body: "Push notifications are now active.",
            icon: "/icons/icon-192.png",
          });
        } else {
          showTroubleshootResult(
            "Notifications dismissed. You can enable later in browser settings.",
            false,
          );
        }
      } catch {
        showTroubleshootResult(
          "✗ Failed to request notification permission.",
          false,
        );
      }
    });

    // Reset all onboarding hints
    const resetHintsBtn = document.getElementById("pwa-reset-hints-btn");
    resetHintsBtn?.addEventListener("click", () => {
      const keys = [
        "meitheal-pwa-dismissed",
        "meitheal_shortcut_hint_dismissed",
      ];
      let cleared = 0;
      keys.forEach((k) => {
        if (localStorage.getItem(k) !== null) {
          localStorage.removeItem(k);
          cleared++;
        }
      });
      showTroubleshootResult(
        cleared > 0
          ? `✓ Reset ${cleared} hint(s). They'll reappear on next page load.`
          : "No dismissed hints to reset.",
      );
    });
  }

  initPwaTroubleshooting();
  document.addEventListener("astro:page-load", initPwaTroubleshooting);

  // Accent color picker
  function initAccentColor() {
    const swatches =
      document.querySelectorAll<HTMLButtonElement>(".accent-swatch");
    const customPicker = document.getElementById(
      "accent-color-custom",
    ) as HTMLInputElement | null;
    const resetBtn = document.getElementById("accent-reset");
    if (!swatches.length) return;
    if ((swatches[0] as HTMLElement).dataset.accentInit) return;
    (swatches[0] as HTMLElement).dataset.accentInit = "true";

    const current = localStorage.getItem("meitheal-accent-color") || "#6366F1";

    function applyAccent(color: string) {
      const root = document.documentElement.style;
      root.setProperty("--accent", color);
      root.setProperty(
        "--accent-hover",
        `color-mix(in srgb, ${color} 85%, #000)`,
      );
      root.setProperty(
        "--accent-light",
        `color-mix(in srgb, ${color} 12%, transparent)`,
      );
      root.setProperty("--border-focus", color);
      localStorage.setItem("meitheal-accent-color", color);
      highlightActive(color);
    }

    function highlightActive(color: string) {
      swatches.forEach((s) => {
        s.classList.toggle("active", s.dataset.color === color);
      });
      if (customPicker) customPicker.value = color;
    }

    highlightActive(current);

    swatches.forEach((s) => {
      s.addEventListener("click", () => {
        if (s.dataset.color) applyAccent(s.dataset.color);
      });
    });

    customPicker?.addEventListener("input", (e) => {
      applyAccent((e.target as HTMLInputElement).value);
    });

    resetBtn?.addEventListener("click", () => {
      localStorage.removeItem("meitheal-accent-color");
      document.documentElement.style.removeProperty("--accent");
      document.documentElement.style.removeProperty("--accent-hover");
      document.documentElement.style.removeProperty("--accent-light");
      document.documentElement.style.removeProperty("--border-focus");
      highlightActive("#6366F1");
    });
  }

  initAccentColor();
  document.addEventListener("astro:page-load", initAccentColor);
</script>
