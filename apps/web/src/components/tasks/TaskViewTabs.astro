---
import { t } from "../../i18n/translations";
import type { Locale } from "../../lib/locale";

interface Props {
  activeView: "list" | "board" | "table" | "calendar" | "gantt";
}

const { activeView } = Astro.props;
const cookieLocale = Astro.cookies.get("meitheal-locale")?.value;
const locale: Locale = cookieLocale === "ga" ? "ga" : "en";

// Rebuild current search params to preserve filters when switching views
const currentParams = new URL(Astro.request.url).searchParams;
const queryString = currentParams.toString()
  ? `?${currentParams.toString()}`
  : "";
---

<div class="task-view-tabs px-6">
  <a
    href={`/tasks${queryString}`}
    class={`view-tab ${activeView === "list" ? "active" : ""}`}
  >
    <span class="mr-2">☰</span>
    {t("tasks.list_view", locale)}
  </a>
  <a
    href={`/kanban${queryString}`}
    class={`view-tab ${activeView === "board" ? "active" : ""}`}
  >
    <span class="mr-2">▦</span> Kanban Board
  </a>
  <a
    href={`/table${queryString}`}
    class={`view-tab ${activeView === "table" ? "active" : ""}`}
  >
    <span class="mr-2">⊞</span> Table View
  </a>
  <a
    href={`/calendar${queryString}`}
    class={`view-tab ${activeView === "calendar" ? "active" : ""}`}
  >
    <span class="mr-2">🗓️</span> Calendar
  </a>
  <a
    href={`/gantt${queryString}`}
    class={`view-tab ${activeView === "gantt" ? "active" : ""}`}
  >
    <span class="mr-2">📊</span> Gantt
  </a>
</div>

<style>
  .task-view-tabs {
    display: flex;
    gap: 24px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 24px;
    background: var(--bg-primary);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    white-space: nowrap;
    scrollbar-width: none;
  }
  .task-view-tabs::-webkit-scrollbar {
    display: none;
  }
  .view-tab {
    padding: 12px 4px;
    color: var(--text-muted);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
    margin-bottom: -1px; /* Overlap border */
    display: inline-flex;
    align-items: center;
  }
  .view-tab:hover {
    color: var(--text-primary);
    border-bottom-color: var(--text-muted);
  }
  .view-tab.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
</style>
