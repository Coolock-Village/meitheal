---
import { t } from "../../i18n/translations";
import type { Locale } from "../../lib/locale";
import LabelPicker from "../ui/LabelPicker.astro";

const cookieLocale = Astro.cookies.get("meitheal-locale")?.value;
const locale: Locale = cookieLocale === "ga" ? "ga" : "en";
---

<div
  id="new-task-overlay"
  class="modal-overlay z-[200]"
  style="display:none;position:fixed;"
>
  <div class="modal-content max-w-lg w-full p-6 animate-slide-in">
    <div
      class="modal-header flex items-center justify-between mb-4 border-b border-border pb-3"
    >
      <h2 class="text-xl font-bold text-text-primary" id="new-task-title">
        {t("tasks.new_task", locale)}
      </h2>
      <button
        type="button"
        class="btn-icon text-xl text-text-muted hover:text-text-primary"
        id="close-new-task-modal"
        aria-label="Close">✕</button
      >
    </div>

    <form id="new-task-form" class="space-y-4">
      <div class="form-group">
        <label for="new-task-title-input" class="form-label"
          >{t("tasks.title_label", locale)}
          <span class="text-accent">*</span></label
        >
        <input
          type="text"
          class="form-input bg-bg-input"
          id="new-task-title-input"
          placeholder="What needs to be done? (Use #tags or 'today')"
          required
          autofocus
          autocapitalize="sentences"
        />
      </div>

      <div class="form-group">
        <label for="new-task-desc-input" class="form-label">Description</label>
        <textarea
          class="form-input bg-bg-input resize-y min-h-[80px]"
          id="new-task-desc-input"
          placeholder="Optional description (Markdown supported)"></textarea>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div class="form-group">
          <label for="new-task-priority" class="form-label"
            >{t("tasks.priority_label", locale)}</label
          >
          <select class="form-select bg-bg-input" id="new-task-priority">
            <option value="1">Urgent (1)</option>
            <option value="2">High (2)</option>
            <option value="3" selected>Medium (3)</option>
            <option value="4">Low (4)</option>
          </select>
        </div>
        <div class="form-group">
          <label for="new-task-status" class="form-label"
            >{t("tasks.status_label", locale)}</label
          >
          <select class="form-select bg-bg-input" id="new-task-status">
            <option value="backlog">Backlog</option>
            <option value="pending" selected>Pending</option>
            <option value="active">Active</option>
            <option value="complete">Complete</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="new-task-labels" class="form-label">Labels</label>
        <LabelPicker id="new-task-label-picker" name="labels" />
      </div>

      <div class="form-group">
        <label for="new-task-assigned-to" class="form-label">Assign To</label>
        <select class="form-select bg-bg-input" id="new-task-assigned-to">
          <option value="">Unassigned</option>
        </select>
        <p
          class="text-xs text-text-muted mt-1"
          id="new-task-assignee-hint"
          style="display:none"
        >
          Tip: Use @name in the title to auto-assign
        </p>
      </div>

      <!-- Recurrence Picker (Phase 1: REC-02) -->
      <div class="form-group">
        <label for="new-task-recurrence" class="form-label">Recurrence</label>
        <select class="form-select bg-bg-input" id="new-task-recurrence">
          <option value="">None (one-time)</option>
          <option value="FREQ=DAILY">Every day</option>
          <option value="FREQ=WEEKLY">Every week</option>
          <option value="FREQ=WEEKLY;BYDAY=MO,TU,WE,TH,FR">Every weekday</option>
          <option value="FREQ=MONTHLY">Every month</option>
          <option value="FREQ=YEARLY">Every year</option>
          <option value="FREQ=WEEKLY;INTERVAL=2">Every 2 weeks</option>
        </select>
      </div>

      <!-- Checklist (Phase 1: CHK-01) -->
      <div class="form-group">
        <label class="form-label">Checklist</label>
        <div id="new-task-checklist-items" class="space-y-1"></div>
        <button type="button" id="new-task-add-checklist" class="text-xs text-accent hover:text-accent-hover mt-1 flex items-center gap-1">
          <span>➕</span> Add checklist item
        </button>
      </div>

      <div
        class="modal-actions pt-4 border-t border-border flex justify-end gap-3 mt-6"
      >
        <button type="button" class="btn btn-ghost" id="cancel-new-task"
          >{t("tasks.cancel", locale)}</button
        >
        <button
          type="submit"
          class="btn btn-primary shadow-lg shadow-accent/20"
          id="submit-new-task-btn">Create Task</button
        >
      </div>
    </form>
  </div>
</div>

<script>
  import { showToast } from "@lib/toast";

  // Handle smart task extraction mapping
  const nextWeekday = (day: number) => {
    const d = new Date();
    const diff = (day - d.getDay() + 7) % 7 || 7;
    d.setDate(d.getDate() + diff);
    return d;
  };

  const overlay = document.getElementById("new-task-overlay");
  const closeBtn = document.getElementById("close-new-task-modal");
  const cancelBtn = document.getElementById("cancel-new-task");
  const form = document.getElementById("new-task-form") as HTMLFormElement;

  // Checklist item management (CHK-01)
  const checklistContainer = document.getElementById("new-task-checklist-items");
  const addChecklistBtn = document.getElementById("new-task-add-checklist");

  function addChecklistRow(value = "") {
    if (!checklistContainer) return;
    const row = document.createElement("div");
    row.className = "flex items-center gap-1";
    const input = document.createElement("input");
    input.type = "text";
    input.className = "form-input text-sm py-1 flex-1 bg-bg-input";
    input.placeholder = "Checklist item...";
    input.value = value;
    const removeBtn = document.createElement("button");
    removeBtn.type = "button";
    removeBtn.className = "text-text-muted hover:text-red-400 text-sm px-1";
    removeBtn.textContent = "✕";
    removeBtn.addEventListener("click", () => row.remove());
    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") { e.preventDefault(); addChecklistRow(); }
      if (e.key === "Escape" && !input.value.trim()) row.remove();
    });
    row.appendChild(input);
    row.appendChild(removeBtn);
    checklistContainer.appendChild(row);
    setTimeout(() => input.focus(), 10);
  }

  addChecklistBtn?.addEventListener("click", () => addChecklistRow());

  function closeNewTaskModal() {
    overlay?.classList.remove("open");
    if (overlay) {
      overlay.style.display = "none";
    }
    form?.reset();
    // Clear dynamic checklist rows
    if (checklistContainer) checklistContainer.innerHTML = "";
  }

  closeBtn?.addEventListener("click", closeNewTaskModal);
  cancelBtn?.addEventListener("click", closeNewTaskModal);
  overlay?.addEventListener("click", (e) => {
    if (e.target === overlay) closeNewTaskModal();
  });

  // Expose global open method
  window.openNewTaskModal = () => {
    // If the detail panel is open, close it to avoid dual modal
    document.getElementById("task-detail-panel")?.classList.remove("open");
    document.getElementById("task-detail-overlay")?.classList.add("hidden");

    form?.reset();
    overlay?.classList.add("open");
    if (overlay) {
      overlay.style.display = "flex";
      overlay.style.position = "fixed";
    }
    // Load user list for assignment dropdown
    loadAssigneeDropdown();
    setTimeout(() => {
      document.getElementById("new-task-title-input")?.focus();
    }, 50);
  };

  // Fetch users and populate the Assign To dropdown
  async function loadAssigneeDropdown() {
    const select = document.getElementById(
      "new-task-assigned-to",
    ) as HTMLSelectElement;
    const hint = document.getElementById("new-task-assignee-hint");
    if (!select) return;

    // Reset to just "Unassigned"
    select.innerHTML = '<option value="">Unassigned</option>';

    try {
      const res = await fetch((window.__ingress_path || "") + "/api/users");
      if (!res.ok) return;
      const data = await res.json();
      const users = data.users || [];

      if (users.length === 0) {
        // No users discovered — hide dropdown, show link to settings
        select.parentElement!.style.display = "none";
        return;
      }

      select.parentElement!.style.display = "";
      if (hint) hint.style.display = users.length > 1 ? "" : "none";

      for (const user of users) {
        const opt = document.createElement("option");
        opt.value = user.id;
        opt.textContent =
          user.name + (user.source === "home_assistant" ? " (HA)" : "");
        select.appendChild(opt);
      }

      // Auto-select default assignee if set
      if (data.default_assignee) {
        select.value = data.default_assignee;
      }

      // Single-user auto-select
      if (users.length === 1 && !data.default_assignee) {
        select.value = users[0].id;
      }

      // Store users for @mention matching
      (window as any).__meitheal_users = users;
    } catch {
      // Standalone/offline — leave just "Unassigned"
    }
  }

  // Backlog mode: hide backlog option when disabled
  (async function hideBacklogIfDisabled() {
    try {
      const res = await fetch(
        (window.__ingress_path || "") + "/api/settings?key=backlog_mode",
      );
      if (!res.ok) return;
      const data = await res.json();
      if (data.value === "disabled") {
        const statusSelect = document.getElementById(
          "new-task-status",
        ) as HTMLSelectElement;
        if (statusSelect) {
          const backlogOpt = statusSelect.querySelector(
            'option[value="backlog"]',
          );
          if (backlogOpt) backlogOpt.remove();
        }
      }
    } catch {
      /* offline — keep all options */
    }
  })();

  // Use event delegation on document.body to catch all create-task-btn clicks
  // without cloning DOM nodes (which breaks other scripts' references).
  document.body.addEventListener("click", (e) => {
    const target = (e.target as HTMLElement).closest("#create-task-btn");
    if (target) {
      e.preventDefault();
      window.openNewTaskModal?.();
    }
  });

  // Form Submission
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const titleInput = document.getElementById(
      "new-task-title-input",
    ) as HTMLInputElement;
    let title = titleInput.value.trim();
    if (!title) return;

    const submitBtn = document.getElementById(
      "submit-new-task-btn",
    ) as HTMLButtonElement;
    const originalText = submitBtn.textContent || "Create Task";
    submitBtn.disabled = true;
    submitBtn.textContent = "Creating...";

    try {
      const extractedLabels: string[] = [];
      let extractedDue: string | null = null;

      // Extract #tags
      title = title
        .replace(/#(\w+)/g, (_match, label) => {
          extractedLabels.push(label);
          return "";
        })
        .trim();

      // Extract date semantics
      const dateKeywords: Record<string, () => Date> = {
        today: () => new Date(),
        tomorrow: () => {
          const d = new Date();
          d.setDate(d.getDate() + 1);
          return d;
        },
        "next week": () => {
          const d = new Date();
          d.setDate(d.getDate() + 7);
          return d;
        },
        monday: () => nextWeekday(1),
        tuesday: () => nextWeekday(2),
        wednesday: () => nextWeekday(3),
        thursday: () => nextWeekday(4),
        friday: () => nextWeekday(5),
      };

      for (const [kw, getDate] of Object.entries(dateKeywords)) {
        const regex = new RegExp(`\\b${kw}\\b`, "i");
        if (regex.test(title)) {
          extractedDue = getDate().toISOString().slice(0, 16);
          title = title.replace(regex, "").trim();
          break;
        }
      }

      const labelPickerValue = document.getElementById(
        "new-task-label-picker-value",
      ) as HTMLInputElement | null
      const manualLabels: string[] = labelPickerValue
        ? JSON.parse(labelPickerValue.value || "[]")
        : []

      const allLabels = [...new Set([...manualLabels, ...extractedLabels])];
      let finalTitle = title || titleInput.value.trim();

      // Extract @mentions for assignment
      let assignedTo =
        (document.getElementById("new-task-assigned-to") as HTMLSelectElement)
          ?.value || "";
      const users = (window as any).__meitheal_users || [];
      finalTitle = finalTitle
        .replace(/@(\w+)/g, (_match: string, mention: string) => {
          if (!assignedTo) {
            const found = users.find((u: any) =>
              u.name.toLowerCase().startsWith(mention.toLowerCase()),
            );
            if (found) assignedTo = found.id;
          }
          return "";
        })
        .trim();
      if (!finalTitle) finalTitle = titleInput.value.trim();

      // Collect checklist items
      const checklistItems: {text: string, done: boolean}[] = [];
      document.querySelectorAll('#new-task-checklist-items input[type="text"]').forEach((inp) => {
        const text = (inp as HTMLInputElement).value.trim();
        if (text) checklistItems.push({ text, done: false });
      });

      const body: Record<string, unknown> = {
        title: finalTitle,
        description: (
          document.getElementById("new-task-desc-input") as HTMLTextAreaElement
        ).value.trim(),
        priority: parseInt(
          (document.getElementById("new-task-priority") as HTMLSelectElement)
            .value,
          10,
        ),
        status: (
          document.getElementById("new-task-status") as HTMLSelectElement
        ).value,
        labels: JSON.stringify(allLabels),
        due_date: extractedDue,
        assigned_to: assignedTo || null,
        recurrence_rule: (document.getElementById("new-task-recurrence") as HTMLSelectElement)?.value || null,
        checklists: checklistItems.length > 0 ? JSON.stringify(checklistItems) : null,
      };

      const res = await fetch((window.__ingress_path || "") + "/api/tasks", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(body),
      });

      if (res.ok) {
        showToast("Task created successfully", "success");
        closeNewTaskModal();
        window.location.reload();
      } else {
        showToast("Failed to create task", "error");
      }
    } catch (err) {
      console.error(err);
      showToast("Network error creating task", "error");
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
