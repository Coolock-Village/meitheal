---
import Icon from "../ui/Icon.astro";

export interface Props {
  navItems: {
    key: string;
    label: string;
    isActive: boolean;
    href: string;
    icon: string;
    showBadge?: boolean;
  }[];
  taskCounts: {
    total: number;
    active: number;
    pending: number;
  };
}
const { navItems, taskCounts } = Astro.props;

/** Check if a URL is external (absolute http/https) */
function isExternal(href: string): boolean {
  return /^https?:\/\//i.test(href);
}
---

<ul
  class="nav-list flex-1 flex flex-col gap-1 list-none m-0 p-0 overflow-y-auto w-full"
>
  {
    navItems.map((item) => {
      const external = isExternal(item.href);
      return (
        <li>
          <a
            href={item.href}
            class={`nav-link ${item.isActive ? "active" : ""} ${external ? "nav-link--external" : ""}`}
            data-page={item.key}
            aria-label={`${item.label}${external ? " (opens in new tab)" : ""}`}
            {...(external
              ? {
                  target: "_top",
                  rel: "noopener noreferrer",
                  "data-external": "true",
                }
              : {})}
          >
            <span class="nav-icon">
              <Icon name={item.icon as any} />
            </span>
            {item.label}
            {external && (
              <span
                class="nav-external-icon"
                aria-hidden="true"
                title="Opens in new tab"
              >
                ↗
              </span>
            )}
            {item.showBadge && (
              <span
                class="nav-badge"
                id={`nav-count-${item.key}`}
                aria-hidden="true"
              >
                {taskCounts.total}
              </span>
            )}
          </a>
        </li>
      );
    })
  }
</ul>

<style>
  .nav-external-icon {
    margin-left: auto;
    font-size: 11px;
    opacity: 0.5;
    transition: opacity 150ms ease;
  }
  .nav-link--external:hover .nav-external-icon {
    opacity: 1;
  }
</style>

<script>
  // Active nav link — reusable for View Transitions
  function updateActiveNavLink() {
    const currentPath = window.location.pathname;
    document.querySelectorAll(".sidebar .nav-link").forEach((link) => {
      link.classList.remove("active");
      if (
        link.getAttribute("href") === currentPath ||
        (currentPath === "/" && link.getAttribute("data-page") === "dashboard")
      ) {
        link.classList.add("active");
      }
    });
  }
  updateActiveNavLink();

  // Re-run after View Transitions swap
  document.addEventListener("astro:after-swap", updateActiveNavLink);

  /**
   * External link handler — ensures custom sidebar links pointing to
   * external URLs (http/https) always open in a new browser tab,
   * even when Meitheal runs inside HA's ingress iframe.
   *
   * X-Frame-Options on most external sites (e.g. Google) blocks loading
   * them inside an iframe. Using window.open() guarantees a new tab
   * regardless of iframe sandbox restrictions.
   */
  function attachExternalLinkHandlers() {
    document
      .querySelectorAll('.sidebar .nav-link[data-external="true"]')
      .forEach((link) => {
        link.addEventListener("click", (e) => {
          e.preventDefault();
          const href = (link as HTMLAnchorElement).href;
          // Use window.open for guaranteed new-tab behavior in iframe contexts
          // Falls back to top-level navigation if popups are blocked
          const win = window.open(href, "_blank", "noopener,noreferrer");
          if (!win) {
            // Popup blocked — navigate the top-level window instead
            try {
              window.top!.location.href = href;
            } catch {
              // Cross-origin top — last resort, navigate current frame
              window.location.href = href;
            }
          }
        });
      });
  }
  attachExternalLinkHandlers();
  document.addEventListener("astro:after-swap", attachExternalLinkHandlers);
</script>
