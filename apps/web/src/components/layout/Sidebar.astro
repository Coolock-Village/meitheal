---
import { t } from "../../i18n/translations";
import type { Locale } from "../../lib/locale";
import Icon from "../ui/Icon.astro";
import SidebarNavList from "./SidebarNavList.astro";
import SidebarBoardSwitcher from "./SidebarBoardSwitcher.astro";
import SidebarFooter from "./SidebarFooter.astro";
import {
  ensureSchema,
  getPersistenceClient,
} from "@domains/tasks/persistence/store";

const currentPath = Astro.url.pathname;
export interface Props {
  locale?: Locale;
  taskCounts?: { total: number; active: number; pending: number };
}
const {
  locale = Astro.cookies.get("meitheal-locale")?.value === "ga" ? "ga" : "en",
  taskCounts = { total: 0, active: 0, pending: 0 },
} = Astro.props;

/** Default nav item definitions */
interface NavItemDef {
  href: string;
  i18nKey: string;
  icon: string;
  matchExact?: boolean;
  showBadge?: boolean;
}

const NAV_ITEMS: Record<string, NavItemDef> = {
  dashboard: {
    href: "/",
    i18nKey: "nav.dashboard",
    icon: "dashboard",
    matchExact: true,
  },
  kanban: {
    href: "/kanban",
    i18nKey: "nav.kanban",
    icon: "kanban",
    matchExact: true,
  },
  tasks: {
    href: "/tasks",
    i18nKey: "nav.tasks",
    icon: "tasks",
    showBadge: true,
  },
  table: { href: "/table", i18nKey: "nav.table", icon: "table" },
  today: { href: "/today", i18nKey: "nav.today", icon: "today" },
  upcoming: { href: "/upcoming", i18nKey: "nav.upcoming", icon: "upcoming" },
  calendar: { href: "/calendar", i18nKey: "nav.calendar", icon: "calendar" },
};

type NavKey = string;
const DEFAULT_ORDER: NavKey[] = [
  "dashboard",
  "kanban",
  "tasks",
  "today",
  "upcoming",
  "calendar",
];

interface CustomNavItem {
  id: string;
  href: string;
  icon: string;
  label: string;
}

/** Sidebar configuration from settings DB */
interface SidebarConfig {
  /** Visibility toggles (legacy format preserved) */
  [key: string]: unknown;
  /** Display order — array of nav keys */
  order?: string[];
  /** Custom labels per nav key */
  labels?: Record<string, string>;
  /** Custom dynamically added nav items */
  customItems?: CustomNavItem[];
}

let sidebarConfig: SidebarConfig = {
  dashboard: true,
  kanban: true,
  tasks: true,
  table: true,
  today: true,
  upcoming: true,
  calendar: true,
};

try {
  await ensureSchema();
  const c = getPersistenceClient();
  const res = await c.execute(
    "SELECT value FROM settings WHERE key = 'sidebar_config'",
  );
  if (res.rows.length > 0) {
    let parsed = JSON.parse(String(res.rows[0]?.value));
    // Handle double-encoded JSON (API stores JSON.stringify'd values)
    if (typeof parsed === "string") {
      try {
        parsed = JSON.parse(parsed);
      } catch {
        /* not double-encoded */
      }
    }
    if (parsed && typeof parsed === "object") {
      sidebarConfig = { ...sidebarConfig, ...parsed };
    }
  }
} catch (e) {
  console.error("[Sidebar.astro] Failed to load sidebar_config:", e);
  // DB fallback — use defaults
}

/** Inject custom items into NAV_ITEMS before processing */
if (Array.isArray(sidebarConfig.customItems)) {
  sidebarConfig.customItems.forEach((c) => {
    if (c.id && c.href) {
      NAV_ITEMS[c.id] = {
        href: c.href,
        i18nKey: "",
        icon: c.icon || "link",
        matchExact: false, // Default matching
      };
      if (!sidebarConfig.labels) sidebarConfig.labels = {};
      sidebarConfig.labels[c.id] = c.label || c.id;
    }
  });
}

/** Build ordered, filtered nav item list */
const rawOrder: NavKey[] =
  Array.isArray(sidebarConfig.order) && sidebarConfig.order.length > 0
    ? (sidebarConfig.order as string[]).filter((k: string) => k in NAV_ITEMS)
    : [];
// Fall back to defaults if saved order is empty / invalid, then append any missing defaults
const order: NavKey[] = rawOrder.length > 0 ? rawOrder : [...DEFAULT_ORDER];
DEFAULT_ORDER.forEach((k) => {
  if (!order.includes(k)) order.push(k);
});
// Append custom items that were injected into NAV_ITEMS but aren't in the order yet
Object.keys(NAV_ITEMS).forEach((k) => {
  if (!order.includes(k)) order.push(k);
});

const labels: Record<string, string> =
  (sidebarConfig.labels as Record<string, string>) ?? {};

const navItems = order
  .filter((key) => sidebarConfig[key] !== false && key in NAV_ITEMS)
  .map((key) => {
    const def = NAV_ITEMS[key]!;
    const label = labels[key] || t(def.i18nKey, locale);
    const isActive = def.matchExact
      ? currentPath === def.href
      : currentPath.startsWith(def.href);
    return { key, label, isActive, ...def };
  });
---

<nav
  class="sidebar hidden md:flex"
  id="sidebar"
  role="navigation"
  aria-label="Main Navigation"
>
  <div class="sidebar-header pb-4 mb-0 border-b border-border/50">
    <a
      href="/"
      class="sidebar-brand text-xl font-bold tracking-tight text-text-primary hover:text-accent transition-colors flex items-center gap-2 no-underline"
      aria-label="Meitheal Home"
      title="Ag Obair le Chéile — Working Together"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 100 100"
        width="24"
        height="24"
        aria-hidden="true"
        style="flex-shrink:0"
      >
        <rect width="100" height="100" rx="22" fill="#0F172A"></rect>
        <path
          d="M25 65 L50 30 L75 65"
          fill="none"
          stroke="#6366F1"
          stroke-width="6"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
        <path
          d="M35 65 L65 65"
          fill="none"
          stroke="#334155"
          stroke-width="4"
          stroke-dasharray="4 4"
          stroke-linecap="round"></path>
        <path
          d="M50 35 L50 65"
          fill="none"
          stroke="#334155"
          stroke-width="4"
          stroke-dasharray="4 4"
          stroke-linecap="round"></path>
        <circle cx="50" cy="30" r="7" fill="#F59E0B"></circle>
        <circle cx="25" cy="65" r="7" fill="#6366F1"></circle>
        <circle cx="75" cy="65" r="7" fill="#6366F1"></circle>
      </svg> Meitheal
    </a>
    <span
      class="sidebar-ipa"
      aria-hidden="true"
      style="display:block;font-size:10px;font-style:italic;color:var(--text-muted);opacity:0.55;letter-spacing:0.3px;padding-left:2.25rem;margin-top:1px;line-height:1;user-select:none"
      >/ˈmʲɛhəlˠ/</span
    >
    <span
      class="sidebar-tooltip"
      aria-hidden="true"
      style="display:none;position:absolute;left:0.5rem;top:calc(100% + 2px);white-space:nowrap;font-size:10px;font-weight:400;font-style:italic;color:var(--text-muted);background:var(--bg-card);border:1px solid var(--border);border-radius:6px;padding:3px 8px;pointer-events:none;z-index:50;box-shadow:0 2px 8px rgba(0,0,0,0.15)"
      >Ag Obair le Chéile&ensp;·&ensp;Working Together</span
    >
  </div>

  <div class="sidebar-scroll">
    <SidebarNavList navItems={navItems} taskCounts={taskCounts} />
    <SidebarBoardSwitcher locale={locale} />
  </div>

  <SidebarFooter locale={locale} />
</nav>

<style>
  .sidebar {
    @apply flex flex-col h-full bg-bg-secondary/90 backdrop-blur-md border-r border-border transition-transform duration-300 w-[240px] fixed z-40 p-4;
    overflow: hidden;
  }

  .sidebar-scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    min-height: 0;
    padding-top: 8px;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  .sidebar-scroll::-webkit-scrollbar {
    width: 4px;
  }
  .sidebar-scroll::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 4px;
  }

  .sidebar-header {
    @apply mb-6 px-2;
    position: relative;
  }

  .sidebar-ipa {
    display: block;
    font-size: 10px;
    font-style: italic;
    color: var(--text-muted);
    opacity: 0.55;
    letter-spacing: 0.3px;
    padding-left: 2.25rem;
    margin-top: 1px;
    line-height: 1;
    user-select: none;
    font-family: "Noto Sans", system-ui, sans-serif;
  }

  .sidebar-tooltip {
    display: none;
    position: absolute;
    left: 0.5rem;
    top: calc(100% + 2px);
    white-space: nowrap;
    font-size: 10px;
    font-weight: 400;
    font-style: italic;
    color: var(--text-muted);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 3px 8px;
    pointer-events: none;
    z-index: 50;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .sidebar-header:hover .sidebar-tooltip {
    display: block !important;
    animation: tooltip-fade-in 200ms ease forwards;
  }

  @keyframes tooltip-fade-in {
    from {
      opacity: 0;
      transform: translateY(-2px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Expose these styles globally for the sub-components to use cleanly without duplicate scopes */
  :global(.sidebar .nav-links) {
    @apply flex flex-col gap-1 list-none p-0 m-0 mb-6;
  }

  :global(.sidebar .nav-link) {
    @apply flex items-center justify-start px-3 py-2 rounded-md text-sm font-medium text-text-secondary transition-all no-underline;
  }

  :global(.sidebar .nav-link:hover) {
    @apply bg-bg-hover text-text-primary translate-x-1;
  }

  :global(.sidebar .nav-link.active) {
    @apply bg-accent/10 text-accent;
  }

  :global(.sidebar .nav-link.active .nav-icon) {
    @apply text-accent;
  }

  :global(.sidebar .nav-icon) {
    @apply flex items-center justify-center w-6 h-6 mr-3 text-text-muted transition-colors;
  }

  :global(.sidebar .nav-badge) {
    @apply ml-auto bg-bg-primary text-text-muted text-[10px] font-bold px-2 py-0.5 rounded-full border border-border/50 min-w-[20px] text-center;
  }

  /* --- Mobile sidebar --- */
  @media (max-width: 768px) {
    .sidebar {
      display: flex !important;
      transform: translateX(-100%);
      transition: transform 250ms ease;
    }

    .sidebar.open {
      transform: translateX(0);
      box-shadow: 4px 0 24px rgba(0, 0, 0, 0.4);
    }

    .sidebar.open::after {
      content: "";
      position: fixed;
      top: 0;
      left: 240px;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.5);
    }
  }
</style>
