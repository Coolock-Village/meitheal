---
import { t } from "../../i18n/translations";
import type { Locale } from "../../lib/locale";

interface Props {
  locale: Locale;
  taskCounts: { total: number; active: number; pending: number };
}

const { locale, taskCounts } = Astro.props;
---

<nav
  class="sidebar"
  id="sidebar"
  role="navigation"
  aria-label="Main navigation"
>
  <div class="sidebar-header">
    <div class="logo">
      <span class="logo-icon">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-6 h-6 text-accent"
          ><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"
          ></path></svg
        >
      </span>
      <span class="logo-text">Meitheal</span>
    </div>
  </div>
  <ul class="nav-links">
    <li>
      <a
        href="/"
        class="nav-link"
        data-page="dashboard"
        aria-label={t("nav.dashboard", locale)}
      >
        <span class="nav-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect width="18" height="18" x="3" y="3" rx="2"></rect><path
              d="M3 9h18M9 21V9"></path></svg
          >
        </span>
        {t("nav.dashboard", locale)}
      </a>
    </li>
    <li>
      <a
        href="/tasks"
        class="nav-link"
        data-page="tasks"
        aria-label={`Tasks (${taskCounts.total} total)`}
      >
        <span class="nav-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="m9 11 3 3L22 4"></path><path
              d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
            ></path></svg
          >
        </span>
        {t("nav.tasks", locale)}
        <span class="nav-badge" aria-label={`${taskCounts.total} tasks`}
          >{taskCounts.total}</span
        >
      </a>
    </li>
    <li>
      <a
        href="/kanban"
        class="nav-link"
        data-page="kanban"
        aria-label={`Kanban board (${taskCounts.active} active)`}
      >
        <span class="nav-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect width="18" height="18" x="3" y="3" rx="2"></rect><path
              d="M8 3v18M16 3v18"></path></svg
          >
        </span>
        {t("nav.kanban", locale)}
        <span class="nav-badge" aria-label={`${taskCounts.active} active tasks`}
          >{taskCounts.active}</span
        >
      </a>
    </li>
    <li>
      <a
        href="/table"
        class="nav-link"
        data-page="table"
        aria-label={t("nav.table", locale)}
      >
        <span class="nav-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M12 3v18"></path><rect
              width="18"
              height="18"
              x="3"
              y="3"
              rx="2"></rect><path d="M3 9h18"></path><path d="M3 15h18"
            ></path></svg
          >
        </span>
        {t("nav.table", locale)}
      </a>
    </li>
    <li>
      <a
        href="/today"
        class="nav-link"
        data-page="today"
        aria-label={t("nav.today", locale)}
      >
        <span class="nav-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"
            ></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"
            ></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"
            ></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"
            ></path><path d="m19.07 4.93-1.41 1.41"></path></svg
          >
        </span>
        {t("nav.today", locale)}
      </a>
    </li>
    <li>
      <a
        href="/upcoming"
        class="nav-link"
        data-page="upcoming"
        aria-label={t("nav.upcoming", locale)}
      >
        <span class="nav-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M8 2v4"></path><path d="M16 2v4"></path><rect
              width="18"
              height="18"
              x="3"
              y="4"
              rx="2"></rect><path d="M3 10h18"></path><path d="m9 16 2 2 4-4"
            ></path></svg
          >
        </span>
        {t("nav.upcoming", locale)}
      </a>
    </li>
    <li>
      <a
        href="/calendar"
        class="nav-link"
        data-page="calendar"
        aria-label={t("nav.calendar", locale)}
      >
        <span class="nav-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M8 2v4"></path><path d="M16 2v4"></path><rect
              width="18"
              height="18"
              x="3"
              y="4"
              rx="2"></rect><path d="M3 10h18"></path><path d="M8 14h.01"
            ></path><path d="M12 14h.01"></path><path d="M16 14h.01"
            ></path><path d="M8 18h.01"></path><path d="M12 18h.01"></path><path
              d="M16 18h.01"></path></svg
          >
        </span>
        {t("nav.calendar", locale)}
      </a>
    </li>
    <li>
      <a
        href="/settings"
        class="nav-link"
        data-page="settings"
        aria-label={t("nav.settings", locale)}
      >
        <span class="nav-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"
            ></path><circle cx="12" cy="12" r="3"></circle></svg
          >
        </span>
        {t("nav.settings", locale)}
      </a>
    </li>
  </ul>
  <div
    class="board-switcher"
    id="board-switcher"
    role="region"
    aria-label="Board selector"
  >
    <div class="board-switcher-label">{t("sidebar.board", locale)}</div>
    <div class="relative w-full">
      <select
        class="board-select appearance-none w-full bg-bg-primary border border-border rounded-md py-2 pl-3 pr-8 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
        id="board-select"
        aria-label="Select active board"
      >
        <option value="default">📋 {t("sidebar.default_board", locale)}</option>
      </select>
      <div
        class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-text-muted"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg
        >
      </div>
    </div>
    <button
      class="board-add-btn mt-2 w-full bg-bg-primary hover:bg-bg-hover border border-border rounded-md py-1.5 text-sm font-medium transition-colors flex items-center justify-center gap-2"
      id="add-board-btn"
      title={t("sidebar.create_board", locale)}
      aria-label={t("sidebar.create_board", locale)}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M5 12h14"></path><path d="M12 5v14"></path></svg
      >
      New Board
    </button>
  </div>
  <div class="sidebar-footer mt-auto pt-4 border-t border-border/50">
    <div
      class="status-indicator text-xs text-text-muted flex items-center gap-2"
      id="connection-status"
      role="status"
      aria-live="polite"
    >
      <span
        class="status-dot w-2 h-2 rounded-full bg-gray-400"
        aria-hidden="true"></span>
      <span class="status-text">{t("status.checking", locale)}</span>
    </div>
  </div>
</nav>

<style>
  .sidebar {
    @apply flex flex-col h-full bg-bg-secondary/90 backdrop-blur-md border-r border-border overflow-y-auto transition-transform duration-300 w-[240px] fixed z-40 p-4;
  }

  .sidebar-header {
    @apply mb-6 px-2;
  }

  .logo {
    @apply flex items-center gap-3 font-semibold text-xl tracking-tight text-text-primary;
  }

  .nav-links {
    @apply flex flex-col gap-1 list-none p-0 m-0 mb-6;
  }

  .nav-link {
    @apply flex items-center justify-between px-3 py-2 rounded-md text-sm font-medium text-text-secondary transition-all no-underline;
  }

  .nav-link:hover {
    @apply bg-bg-hover text-text-primary translate-x-1;
  }

  .nav-link.active {
    @apply bg-accent/10 text-accent;
  }

  .nav-link.active .nav-icon {
    @apply text-accent;
  }

  .nav-icon {
    @apply flex items-center justify-center w-6 h-6 mr-3 text-text-muted transition-colors;
  }

  .nav-badge {
    @apply ml-auto bg-bg-primary text-text-muted text-[10px] font-bold px-2 py-0.5 rounded-full border border-border/50 min-w-[20px] text-center;
  }

  .board-switcher {
    @apply flex flex-col gap-2 p-3 bg-bg-primary/50 rounded-lg border border-border/50 mt-auto mb-4;
  }

  .board-switcher-label {
    @apply text-xs uppercase tracking-wider font-semibold text-text-muted;
  }
</style>

<script>
  // Connection status check
  async function checkHealth() {
    const indicator = document.getElementById("connection-status");
    if (!indicator) return;
    const dot = indicator.querySelector(".status-dot");
    const text = indicator.querySelector(".status-text");
    try {
      const res = await fetch("/api/health");
      const data = await res.json();
      if (data.status === "ok") {
        dot?.classList.add("bg-green-500");
        dot?.classList.remove("bg-gray-400", "bg-red-500");
        if (text) text.textContent = "Connected";
      } else {
        dot?.classList.add("bg-red-500");
        dot?.classList.remove("bg-gray-400", "bg-green-500");
        if (text) text.textContent = "DB Offline";
      }
    } catch {
      dot?.classList.add("bg-gray-400");
      dot?.classList.remove("bg-green-500", "bg-red-500");
      if (text) text.textContent = "Disconnected";
    }
  }
  checkHealth();
  setInterval(checkHealth, 30000);

  // Active nav link
  const currentPath = window.location.pathname;
  document.querySelectorAll(".sidebar .nav-link").forEach((link) => {
    if (
      link.getAttribute("href") === currentPath ||
      (currentPath === "/" && link.getAttribute("data-page") === "dashboard")
    ) {
      link.classList.add("active");
    }
  });

  // Board Switcher
  (async function initBoardSwitcher() {
    const select = document.getElementById(
      "board-select",
    ) as HTMLSelectElement | null;
    const addBtn = document.getElementById("add-board-btn");
    if (!select) return;

    // Load boards from API
    try {
      const res = await fetch("/api/boards");
      if (res.ok) {
        const data = await res.json();
        const boards = data.boards ?? [];
        select.innerHTML = "";
        // "All Boards" option first
        const allOpt = document.createElement("option");
        allOpt.value = "all";
        allOpt.textContent = "🗂 All Boards";
        select.appendChild(allOpt);
        boards.forEach((b: { id: string; title: string; icon: string }) => {
          const opt = document.createElement("option");
          opt.value = b.id;
          opt.textContent = `${b.icon} ${b.title}`;
          select.appendChild(opt);
        });
      }
    } catch {
      /* fallback to default option */
    }

    // Restore active board from localStorage
    const saved = localStorage.getItem("meitheal_active_board") ?? "all";
    if (select.querySelector(`option[value="${saved}"]`)) {
      select.value = saved;
    }

    // Expose active board globally for page scripts
    (window as any).__activeBoard = select.value;

    // Apply board filter to visible items
    function applyBoardFilter() {
      const board = select!.value;
      (window as any).__activeBoard = board;
      // Filter task items (tasks page)
      document.querySelectorAll(".task-item[data-board]").forEach((el) => {
        const item = el as HTMLElement;
        item.style.display =
          board === "all" || item.dataset.board === board ? "" : "none";
      });
      // Filter kanban cards
      document.querySelectorAll(".kanban-card[data-board]").forEach((el) => {
        const card = el as HTMLElement;
        card.style.display =
          board === "all" || card.dataset.board === board ? "" : "none";
      });
      // Filter table rows
      document
        .querySelectorAll("#task-table tbody tr[data-board]")
        .forEach((el) => {
          const row = el as HTMLElement;
          row.style.display =
            board === "all" || row.dataset.board === board ? "" : "none";
        });
    }

    // Apply on load
    applyBoardFilter();

    // Switch board → save + filter
    select.addEventListener("change", () => {
      localStorage.setItem("meitheal_active_board", select.value);
      applyBoardFilter();
    });

    // Add new board
    addBtn?.addEventListener("click", async () => {
      const title = prompt("Board name:");
      if (!title?.trim()) return;
      try {
        const res = await fetch("/api/boards", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ title: title.trim() }),
        });
        if (res.ok) {
          const board = await res.json();
          localStorage.setItem("meitheal_active_board", board.id);
          window.location.reload();
        }
      } catch {
        /* ignore */
      }
    });
  })();
</script>
