---
import { t } from "../../i18n/translations";
import type { Locale } from "../../lib/locale";
import Icon from "../ui/Icon.astro";
import {
  ensureSchema,
  getPersistenceClient,
} from "@domains/tasks/persistence/store";

const currentPath = Astro.url.pathname;
export interface Props {
  locale?: Locale;
  taskCounts?: { total: number; active: number; pending: number };
}
const {
  locale = Astro.cookies.get("meitheal-locale")?.value === "ga" ? "ga" : "en",
  taskCounts = { total: 0, active: 0, pending: 0 },
} = Astro.props;

/** Default nav item definitions */
interface NavItemDef {
  href: string;
  i18nKey: string;
  icon: string;
  matchExact?: boolean;
  showBadge?: boolean;
}

const NAV_ITEMS: Record<string, NavItemDef> = {
  dashboard: {
    href: "/",
    i18nKey: "nav.dashboard",
    icon: "dashboard",
    matchExact: true,
  },
  kanban: {
    href: "/kanban",
    i18nKey: "nav.kanban",
    icon: "kanban",
    matchExact: true,
  },
  tasks: {
    href: "/tasks",
    i18nKey: "nav.tasks",
    icon: "tasks",
    showBadge: true,
  },
  table: { href: "/table", i18nKey: "nav.table", icon: "table" },
  today: { href: "/today", i18nKey: "nav.today", icon: "today" },
  upcoming: { href: "/upcoming", i18nKey: "nav.upcoming", icon: "upcoming" },
  calendar: { href: "/calendar", i18nKey: "nav.calendar", icon: "calendar" },
};

type NavKey = string;
const DEFAULT_ORDER: NavKey[] = [
  "dashboard",
  "kanban",
  "tasks",
  "table",
  "today",
  "upcoming",
  "calendar",
];

interface CustomNavItem {
  id: string;
  href: string;
  icon: string;
  label: string;
}

/** Sidebar configuration from settings DB */
interface SidebarConfig {
  /** Visibility toggles (legacy format preserved) */
  [key: string]: unknown;
  /** Display order — array of nav keys */
  order?: string[];
  /** Custom labels per nav key */
  labels?: Record<string, string>;
  /** Custom dynamically added nav items */
  customItems?: CustomNavItem[];
}

let sidebarConfig: SidebarConfig = {
  dashboard: true,
  kanban: true,
  tasks: true,
  table: true,
  today: true,
  upcoming: true,
  calendar: true,
};

try {
  await ensureSchema();
  const c = getPersistenceClient();
  const res = await c.execute(
    "SELECT value FROM settings WHERE key = 'sidebar_config'",
  );
  if (res.rows.length > 0) {
    let parsed = JSON.parse(String(res.rows[0]?.value));
    // Handle double-encoded JSON (API stores JSON.stringify'd values)
    if (typeof parsed === "string") {
      try {
        parsed = JSON.parse(parsed);
      } catch {
        /* not double-encoded */
      }
    }
    if (parsed && typeof parsed === "object") {
      sidebarConfig = { ...sidebarConfig, ...parsed };
    }
  }
} catch (e) {
  console.error("[Sidebar.astro] Failed to load sidebar_config:", e);
  // DB fallback — use defaults
}

/** Inject custom items into NAV_ITEMS before processing */
if (Array.isArray(sidebarConfig.customItems)) {
  sidebarConfig.customItems.forEach((c) => {
    if (c.id && c.href) {
      NAV_ITEMS[c.id] = {
        href: c.href,
        i18nKey: "",
        icon: c.icon || "link",
        matchExact: false, // Default matching
      };
      if (!sidebarConfig.labels) sidebarConfig.labels = {};
      sidebarConfig.labels[c.id] = c.label || c.id;
    }
  });
}

/** Build ordered, filtered nav item list */
const rawOrder: NavKey[] =
  Array.isArray(sidebarConfig.order) && sidebarConfig.order.length > 0
    ? (sidebarConfig.order as string[]).filter((k: string) => k in NAV_ITEMS)
    : [];
// Fall back to defaults if saved order is empty / invalid, then append any missing defaults
const order: NavKey[] = rawOrder.length > 0 ? rawOrder : [...DEFAULT_ORDER];
DEFAULT_ORDER.forEach((k) => {
  if (!order.includes(k)) order.push(k);
});

const labels: Record<string, string> =
  (sidebarConfig.labels as Record<string, string>) ?? {};

const navItems = order
  .filter((key) => sidebarConfig[key] !== false && key in NAV_ITEMS)
  .map((key) => {
    const def = NAV_ITEMS[key]!;
    const label = labels[key] || t(def.i18nKey, locale);
    const isActive = def.matchExact
      ? currentPath === def.href
      : currentPath.startsWith(def.href);
    return { key, label, isActive, ...def };
  });
---

<nav
  class="sidebar hidden md:flex"
  id="sidebar"
  role="navigation"
  aria-label="Main Navigation"
>
  <div class="sidebar-header pb-4 mb-4 border-b border-border/50">
    <a
      href="/"
      class="text-xl font-bold tracking-tight text-text-primary hover:text-accent transition-colors flex items-center gap-2 no-underline"
      aria-label="Meitheal Home"
    >
      <span class="text-2xl" aria-hidden="true">☘️</span> Meitheal
    </a>
  </div>
  <ul
    class="nav-list flex-1 flex flex-col gap-1 list-none m-0 p-0 overflow-y-auto w-full"
  >
    {
      navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class={`nav-link ${item.isActive ? "active" : ""}`}
            data-page={item.key}
            aria-label={item.label}
          >
            <span class="nav-icon">
              <Icon name={item.icon as any} />
            </span>
            {item.label}
            {item.showBadge && (
              <span
                class="nav-badge"
                id={`nav-count-${item.key}`}
                aria-hidden="true"
              >
                {taskCounts.active}
              </span>
            )}
          </a>
        </li>
      ))
    }
  </ul>
  <div
    class="board-switcher"
    id="board-switcher"
    role="region"
    aria-label="Board selector"
  >
    <div class="board-switcher-label">{t("sidebar.board", locale)}</div>
    <div class="relative w-full">
      <select
        class="board-select appearance-none w-full bg-bg-primary border border-border rounded-md py-2 pl-3 pr-8 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
        id="board-select"
        aria-label="Select active board"
      >
        <option value="default">📋 {t("sidebar.default_board", locale)}</option>
      </select>
      <div
        class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-text-muted"
      >
        <Icon name="chevron-down" size={16} />
      </div>
    </div>
    <button
      class="board-add-btn mt-2 w-full bg-bg-primary hover:bg-bg-hover border border-border rounded-md py-1.5 text-sm font-medium transition-colors flex items-center justify-center gap-2"
      id="add-board-btn"
      title={t("sidebar.create_board", locale)}
      aria-label={t("sidebar.create_board", locale)}
    >
      <Icon name="plus" size={16} />
      New Board
    </button>
  </div>
  <div
    class="sidebar-footer mt-auto pt-4 border-t border-border/50 flex flex-col gap-2"
  >
    <div
      class="status-indicator text-xs text-text-muted flex items-center gap-2 px-3 pb-2"
      id="connection-status"
      role="status"
      aria-live="polite"
    >
      <span
        class="status-dot w-2 h-2 rounded-full bg-gray-400"
        aria-hidden="true"></span>
      <span class="status-text">{t("status.checking", locale)}</span>
    </div>

    <a
      href="/settings"
      class="nav-link w-full"
      data-page="settings"
      aria-label={t("nav.settings", locale)}
    >
      <span class="nav-icon">
        <Icon name="settings" />
      </span>
      {t("nav.settings", locale)}
    </a>
  </div>
</nav>

<style>
  .sidebar {
    @apply flex flex-col h-full bg-bg-secondary/90 backdrop-blur-md border-r border-border overflow-y-auto transition-transform duration-300 w-[240px] fixed z-40 p-4;
  }

  .sidebar-header {
    @apply mb-6 px-2;
  }

  .logo {
    @apply flex items-center gap-3 font-semibold text-xl tracking-tight text-text-primary;
  }

  .nav-links {
    @apply flex flex-col gap-1 list-none p-0 m-0 mb-6;
  }

  .nav-link {
    @apply flex items-center justify-start px-3 py-2 rounded-md text-sm font-medium text-text-secondary transition-all no-underline;
  }

  .nav-link:hover {
    @apply bg-bg-hover text-text-primary translate-x-1;
  }

  .nav-link.active {
    @apply bg-accent/10 text-accent;
  }

  .nav-link.active .nav-icon {
    @apply text-accent;
  }

  .nav-icon {
    @apply flex items-center justify-center w-6 h-6 mr-3 text-text-muted transition-colors;
  }

  .nav-badge {
    @apply ml-auto bg-bg-primary text-text-muted text-[10px] font-bold px-2 py-0.5 rounded-full border border-border/50 min-w-[20px] text-center;
  }

  .board-switcher {
    @apply flex flex-col gap-2 p-3 bg-bg-primary/50 rounded-lg border border-border/50 mt-auto mb-4;
  }

  .board-switcher-label {
    @apply text-xs uppercase tracking-wider font-semibold text-text-muted;
  }
</style>

<script>
  // Connection status check
  async function checkHealth() {
    const indicator = document.getElementById("connection-status");
    if (!indicator) return;
    const dot = indicator.querySelector(".status-dot");
    const text = indicator.querySelector(".status-text");
    try {
      const res = await fetch("/api/health");
      const data = await res.json();
      if (data.status === "ok") {
        dot?.classList.add("bg-green-500");
        dot?.classList.remove("bg-gray-400", "bg-red-500");
        if (text) text.textContent = "Connected";
      } else {
        dot?.classList.add("bg-red-500");
        dot?.classList.remove("bg-gray-400", "bg-green-500");
        if (text) text.textContent = "DB Offline";
      }
    } catch {
      dot?.classList.add("bg-gray-400");
      dot?.classList.remove("bg-green-500", "bg-red-500");
      if (text) text.textContent = "Disconnected";
    }
  }
  checkHealth();
  setInterval(checkHealth, 30000);

  // Active nav link
  const currentPath = window.location.pathname;
  document.querySelectorAll(".sidebar .nav-link").forEach((link) => {
    if (
      link.getAttribute("href") === currentPath ||
      (currentPath === "/" && link.getAttribute("data-page") === "dashboard")
    ) {
      link.classList.add("active");
    }
  });

  // Board Switcher
  (async function initBoardSwitcher() {
    const select = document.getElementById(
      "board-select",
    ) as HTMLSelectElement | null;
    const addBtn = document.getElementById("add-board-btn");
    if (!select) return;

    // Load boards from API
    try {
      const res = await fetch("/api/boards");
      if (res.ok) {
        const data = await res.json();
        const boards = data.boards ?? [];
        select.innerHTML = "";
        // "All Boards" option first
        const allOpt = document.createElement("option");
        allOpt.value = "all";
        allOpt.textContent = "🗂 All Boards";
        select.appendChild(allOpt);
        boards.forEach((b: { id: string; title: string; icon: string }) => {
          const opt = document.createElement("option");
          opt.value = b.id;
          opt.textContent = `${b.icon} ${b.title}`;
          select.appendChild(opt);
        });
      }
    } catch {
      /* fallback to default option */
    }

    // Restore active board from localStorage
    const saved = localStorage.getItem("meitheal_active_board") ?? "all";
    if (select.querySelector(`option[value="${saved}"]`)) {
      select.value = saved;
    }

    // Expose active board globally for page scripts
    (window as any).__activeBoard = select.value;

    // Apply board filter to visible items
    function applyBoardFilter() {
      const board = select!.value;
      (window as any).__activeBoard = board;
      // Filter task items (tasks page)
      document.querySelectorAll(".task-item[data-board]").forEach((el) => {
        const item = el as HTMLElement;
        item.style.display =
          board === "all" || item.dataset.board === board ? "" : "none";
      });
      // Filter kanban cards
      document.querySelectorAll(".kanban-card[data-board]").forEach((el) => {
        const card = el as HTMLElement;
        card.style.display =
          board === "all" || card.dataset.board === board ? "" : "none";
      });
      // Filter table rows
      document
        .querySelectorAll("#task-table tbody tr[data-board]")
        .forEach((el) => {
          const row = el as HTMLElement;
          row.style.display =
            board === "all" || row.dataset.board === board ? "" : "none";
        });
    }

    // Apply on load
    applyBoardFilter();

    // Switch board → save + filter
    select.addEventListener("change", () => {
      localStorage.setItem("meitheal_active_board", select.value);
      applyBoardFilter();
    });

    // Add new board
    addBtn?.addEventListener("click", async () => {
      const title = prompt("Board name:");
      if (!title?.trim()) return;
      try {
        const res = await fetch("/api/boards", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ title: title.trim() }),
        });
        if (res.ok) {
          const board = await res.json();
          localStorage.setItem("meitheal_active_board", board.id);
          window.location.reload();
        }
      } catch {
        /* ignore */
      }
    });
  })();
</script>
