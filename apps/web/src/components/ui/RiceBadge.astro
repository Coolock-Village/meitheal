---
interface Props {
  rice: number | null | undefined;
}

const { rice } = Astro.props;

if (rice === null || rice === undefined || isNaN(rice)) {
  return;
}

const riceClass = rice >= 50 ? "rice-high" : rice >= 20 ? "rice-med" : "rice-low";
---
<span class={`rice-badge ${riceClass}`}>
  {rice}
</span>
