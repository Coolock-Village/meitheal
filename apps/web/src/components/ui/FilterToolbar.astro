---
/**
 * FilterToolbar — Shared filter bar for table, kanban, and future views
 *
 * @domain tasks
 * @bounded-context tasks/ui
 *
 * Renders a configurable filter toolbar with:
 * - Type toggle buttons (Epic/Story/Task)
 * - Board filter selector (populated client-side from /api/boards)
 * - Group-by selector
 * - Status, Priority, RICE, User select filters (opt-in per view)
 * - Label filter bar (lazy-loaded)
 * - Clear all button
 *
 * Emits `meitheal:filter-change` CustomEvent whenever any filter changes.
 * Each view's controller (table-controller.ts, kanban inline script) listens
 * for this event to apply filtering.
 *
 * Usage:
 *   <FilterToolbar view="table" showSearch showGroupBy showStatusFilter showPriorityFilter showRICEFilter showUserFilter />
 *   <FilterToolbar view="kanban" showGroupBy />
 */
import { t } from "../../i18n/translations"
import type { Locale } from "../../lib/locale"
import LabelFilterBar from "./LabelFilterBar.astro"

interface Props {
  /** View context — controls ID prefixing and default visibility */
  view: "table" | "kanban"
  /** Show search input */
  showSearch?: boolean
  /** Show group-by selector */
  showGroupBy?: boolean
  /** Show status filter select */
  showStatusFilter?: boolean
  /** Show priority filter select */
  showPriorityFilter?: boolean
  /** Show RICE filter select */
  showRICEFilter?: boolean
  /** Show user filter select */
  showUserFilter?: boolean
  /** Show user filter pills (kanban-style) */
  showUserPills?: boolean
  /** Group-by options override */
  groupByOptions?: { value: string; label: string }[]
  /** Additional CSS class */
  class?: string
}

const {
  view,
  showSearch = view === "table",
  showGroupBy = true,
  showStatusFilter = view === "table",
  showPriorityFilter = view === "table",
  showRICEFilter = view === "table",
  showUserFilter = view === "table",
  showUserPills = view === "kanban",
  groupByOptions,
  class: className,
} = Astro.props

// Resolve locale from cookie (same pattern as pages)
const cookieLocale = Astro.cookies.get("meitheal-locale")?.value
const locale: Locale = cookieLocale === "ga" ? "ga" : "en"

const prefix = view === "table" ? "table" : "kanban"

const defaultGroupByOptions = view === "table"
  ? [
      { value: "none", label: "No Grouping" },
      { value: "type", label: "Group by Type" },
      { value: "priority", label: "Group by Priority" },
      { value: "board", label: "Group by Board" },
      { value: "assignee", label: "Group by Assignee" },
      { value: "status", label: "Group by Status" },
      { value: "rice", label: "Group by RICE" },
    ]
  : [
      { value: "none", label: t("kanban.group_none", locale) },
      { value: "type", label: t("kanban.group_type", locale) },
      { value: "board", label: t("kanban.group_board", locale) },
      { value: "priority", label: t("kanban.group_priority", locale) },
    ]

const groupOptions = groupByOptions ?? defaultGroupByOptions
---

<div
  class:list={["filter-toolbar", `filter-toolbar--${view}`, className]}
  id={`${prefix}-filter-bar`}
  role="toolbar"
  aria-label="Filter tasks"
>
  {/* Search input (table only by default) */}
  {showSearch && (
    <input
      type="text"
      class="form-input filter-toolbar__search"
      id={`${prefix}-search`}
      placeholder={t("table.filter_placeholder", locale)}
      aria-label="Filter by text"
    />
  )}

  {/* Type toggle buttons — shared across views */}
  <div class="filter-toolbar__type-toggles" id={`${prefix}-type-toggles`}>
    <button
      type="button"
      class="filter-toolbar__type-btn active"
      data-type="epic"
      aria-pressed="true"
      title="Toggle Epics"
    >
      <span class="filter-toolbar__type-dot filter-toolbar__type-dot--epic"></span>
      Epic
    </button>
    <button
      type="button"
      class="filter-toolbar__type-btn active"
      data-type="story"
      aria-pressed="true"
      title="Toggle Stories"
    >
      <span class="filter-toolbar__type-dot filter-toolbar__type-dot--story"></span>
      Story
    </button>
    <button
      type="button"
      class="filter-toolbar__type-btn active"
      data-type="task"
      aria-pressed="true"
      title="Toggle Tasks"
    >
      <span class="filter-toolbar__type-dot filter-toolbar__type-dot--task"></span>
      Task
    </button>
  </div>

  {/* User filter pills (kanban-style) */}
  {showUserPills && (
    <div
      class="filter-toolbar__user-pills"
      id={`${prefix}-user-filters`}
      role="group"
      aria-label="Filter by assignee"
    >
      <button type="button" class="filter-toolbar__user-btn active" data-user="all" title="Show all users">
        👥 All
      </button>
      <button type="button" class="filter-toolbar__user-btn" data-user="unassigned" title="Unassigned tasks">
        ∅
      </button>
      {/* Dynamic user pills populated by JS */}
    </div>
  )}

  {/* Status filter (table-style select) */}
  {showStatusFilter && (
    <select class="form-select filter-toolbar__select" id={`${prefix}-filter-status`} aria-label="Filter by status">
      <option value="">{t("tasks.all_statuses", locale)}</option>
      <option value="pending">{t("task_status.pending", locale)}</option>
      <option value="active">{t("task_status.active", locale)}</option>
      <option value="complete">{t("task_status.complete", locale)}</option>
      <option value="overdue">{t("tasks.overdue", locale)}</option>
    </select>
  )}

  {/* Priority filter */}
  {showPriorityFilter && (
    <select class="form-select filter-toolbar__select" id={`${prefix}-filter-priority`} aria-label="Filter by priority">
      <option value="">{t("tasks.all_priorities", locale)}</option>
      <option value="1">{t("priority.critical", locale)}</option>
      <option value="2">{t("priority.high", locale)}</option>
      <option value="3">{t("priority.medium", locale)}</option>
      <option value="4">{t("priority.low", locale)}</option>
      <option value="5">{t("priority.minimal", locale)}</option>
    </select>
  )}

  {/* RICE filter */}
  {showRICEFilter && (
    <select class="form-select filter-toolbar__select" id={`${prefix}-filter-rice`} aria-label="Filter by RICE score">
      <option value="">{t("tasks.all_rice", locale)}</option>
      <option value="high">{t("tasks.rice_high", locale)}</option>
      <option value="medium">{t("tasks.rice_medium", locale)}</option>
      <option value="low">{t("tasks.rice_low", locale)}</option>
    </select>
  )}

  {/* User filter select (table-style) */}
  {showUserFilter && (
    <select class="form-select filter-toolbar__select" id={`${prefix}-filter-user`} aria-label="Filter by assigned user">
      <option value="">{t("tasks.all_users", locale)}</option>
      <option value="__unassigned__">Unassigned</option>
    </select>
  )}

  {/* Board filter — populated client-side from /api/boards */}
  <select class="form-select filter-toolbar__select" id={`${prefix}-filter-board`} aria-label="Filter by board">
    <option value="">All Boards</option>
  </select>

  {/* Group-by selector */}
  {showGroupBy && (
    <select class="form-select filter-toolbar__select" id={`${prefix}-group-by`} aria-label="Group tasks by">
      {groupOptions.map((opt) => (
        <option value={opt.value}>{opt.label}</option>
      ))}
    </select>
  )}

  {/* Clear all button */}
  <button
    type="button"
    class="filter-toolbar__clear"
    id={`${prefix}-clear-filters`}
    title="Clear all filters"
    aria-label="Clear all active filters"
  >
    {t("tasks.clear_filters", locale)}
  </button>

  {/* Advanced Filter Toggle */}
  <button
    type="button"
    class="filter-toolbar__advanced-toggle"
    id={`${prefix}-advanced-toggle`}
    title="Advanced Filters"
    aria-label="Toggle advanced filters"
    aria-expanded="false"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sliders-horizontal"><line x1="21" x2="14" y1="4" y2="4"/><line x1="10" x2="3" y1="4" y2="4"/><line x1="21" x2="12" y1="12" y2="12"/><line x1="8" x2="3" y1="12" y2="12"/><line x1="21" x2="16" y1="20" y2="20"/><line x1="12" x2="3" y1="20" y2="20"/><line x1="14" x2="14" y1="2" y2="6"/><line x1="8" x2="8" y1="10" y2="14"/><line x1="16" x2="16" y1="18" y2="22"/></svg>
  </button>

  {/* Advanced Filter Builder Dropdown (Hidden by default) */}
<div class="filter-toolbar__advanced-panel hidden" id={`${prefix}-advanced-panel`} role="region" aria-label="Advanced Filter Builder">
  <div class="advanced-panel__header">
    <h4 class="text-sm font-semibold text-text">Advanced Filters</h4>
    <button type="button" class="btn-icon" id={`${prefix}-advanced-close`} aria-label="Close advanced filters">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
  </div>
  
  <div class="advanced-panel__body" id={`${prefix}-advanced-conditions-container`}>
    <!-- Conditions rendered here by JS -->
    <div class="advanced-panel__empty-state text-sm text-text-muted italic py-2">
      No advanced rules applied. Add a condition to start filtering.
    </div>
  </div>

  <div class="advanced-panel__footer mt-3 pt-3 border-t border-border flex justify-between items-center gap-2">
    <div class="flex gap-2">
      <button type="button" class="btn btn-outline text-xs py-1" id={`${prefix}-advanced-add-condition`}>
        + Add Condition
      </button>
      <button type="button" class="btn btn-outline text-xs py-1" id={`${prefix}-advanced-add-group`}>
        + Add Group
      </button>
    </div>
    <div class="flex gap-2">
      <button type="button" class="btn text-xs py-1 text-text-muted hover:text-text" id={`${prefix}-advanced-clear`}>
        Clear Rules
      </button>
      <button type="button" class="btn btn-primary text-xs py-1" id={`${prefix}-advanced-apply`}>
        Apply Rules
      </button>
    </div>
  </div>
</div>

</div>

{/* Label filter bar — separate row below main toolbar */}
<LabelFilterBar id={`${prefix}-label-filter`} />

<script>
  import { isTaskVisible } from "../../lib/filter-state"

  // Expose for Kanban's inline scripts which can't do module imports easily
  ;(window as any).__isTaskVisible = isTaskVisible

  /**
   * FilterToolbar client-side controller
   *
   * Binds all filter controls and emits a unified `meitheal:filter-change`
   * CustomEvent whenever any filter value changes. Views listen for this event.
   */
  function initFilterToolbar(toolbar: HTMLElement) {
    const prefix = toolbar.id.startsWith("table") ? "table" : "kanban"

    // Gather all controls
    const search = toolbar.querySelector<HTMLInputElement>(`#${prefix}-search`)
    const statusSel = toolbar.querySelector<HTMLSelectElement>(`#${prefix}-filter-status`)
    const prioritySel = toolbar.querySelector<HTMLSelectElement>(`#${prefix}-filter-priority`)
    const riceSel = toolbar.querySelector<HTMLSelectElement>(`#${prefix}-filter-rice`)
    const userSel = toolbar.querySelector<HTMLSelectElement>(`#${prefix}-filter-user`)
    const boardSel = toolbar.querySelector<HTMLSelectElement>(`#${prefix}-filter-board`)
    const groupBySel = toolbar.querySelector<HTMLSelectElement>(`#${prefix}-group-by`)
    const clearBtn = toolbar.querySelector<HTMLButtonElement>(`#${prefix}-clear-filters`)
    const typeToggles = toolbar.querySelectorAll<HTMLButtonElement>(".filter-toolbar__type-btn")
    const userPills = toolbar.querySelectorAll<HTMLButtonElement>(".filter-toolbar__user-btn")

    // Advanced Filter controls
    const advToggleBtn = toolbar.querySelector<HTMLButtonElement>(`#${prefix}-advanced-toggle`)
    const advPanel = toolbar.querySelector<HTMLElement>(`#${prefix}-advanced-panel`)
    const advCloseBtn = toolbar.querySelector<HTMLButtonElement>(`#${prefix}-advanced-close`)
    const advAddCondBtn = toolbar.querySelector<HTMLButtonElement>(`#${prefix}-advanced-add-condition`)
    const advAddGroupBtn = toolbar.querySelector<HTMLButtonElement>(`#${prefix}-advanced-add-group`)
    const advClearBtn = toolbar.querySelector<HTMLButtonElement>(`#${prefix}-advanced-clear`)
    const advApplyBtn = toolbar.querySelector<HTMLButtonElement>(`#${prefix}-advanced-apply`)
    const advContainer = toolbar.querySelector<HTMLElement>(`#${prefix}-advanced-conditions-container`)

    // Internal state for advanced filters
    let advancedFilterState: any = null

    // Field definition for dropdowns
    const fields = [
      { id: "title", label: "Task Title" },
      { id: "status", label: "Status" },
      { id: "priority", label: "Priority" },
      { id: "rice", label: "RICE Score" },
      { id: "type", label: "Task Type" },
      { id: "assigned", label: "Assignee" },
      { id: "labels", label: "Labels" },
      { id: "board", label: "Board ID" },
    ]

    const operators = [
      { id: "equals", label: "Equals" },
      { id: "notEquals", label: "Does not equal" },
      { id: "contains", label: "Contains" },
      { id: "notContains", label: "Does not contain" },
      { id: "greaterThan", label: "Greater than" },
      { id: "lessThan", label: "Less than" },
      { id: "isEmpty", label: "Is empty" },
      { id: "isNotEmpty", label: "Is not empty" },
    ]

    function renderAdvancedConditionRow() {
      const row = document.createElement("div")
      row.className = "advanced-filter-row"
      row.dataset.type = "condition"

      const fieldSel = document.createElement("select")
      fieldSel.className = "adv-field"
      fields.forEach(f => {
        const opt = document.createElement("option")
        opt.value = f.id
        opt.textContent = f.label
        fieldSel.appendChild(opt)
      })

      const opSel = document.createElement("select")
      opSel.className = "adv-op"
      operators.forEach(o => {
        const opt = document.createElement("option")
        opt.value = o.id
        opt.textContent = o.label
        opSel.appendChild(opt)
      })

      const valInput = document.createElement("input")
      valInput.className = "adv-val"
      valInput.type = "text"
      valInput.placeholder = "Value..."

      // Hide value input for empty/not-empty operators
      opSel.addEventListener("change", () => {
        if (opSel.value === "isEmpty" || opSel.value === "isNotEmpty") {
          valInput.style.display = "none"
        } else {
          valInput.style.display = ""
        }
      })

      const removeBtn = document.createElement("button")
      removeBtn.type = "button"
      removeBtn.className = "btn-icon text-text-muted hover:text-red-500"
      removeBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>`
      removeBtn.addEventListener("click", () => {
        row.remove()
        checkEmptyState()
      })

      row.append(fieldSel, opSel, valInput, removeBtn)
      return row
    }

    function checkEmptyState() {
      if (!advContainer) return
      const emptyState = advContainer.querySelector(".advanced-panel__empty-state")
      const hasRows = advContainer.querySelectorAll(".advanced-filter-row").length > 0
      if (emptyState) {
        (emptyState as HTMLElement).style.display = hasRows ? "none" : "block"
      }
    }

    // Toggle Advanced Panel
    advToggleBtn?.addEventListener("click", () => {
      const isExpanded = advToggleBtn.getAttribute("aria-expanded") === "true"
      advToggleBtn.setAttribute("aria-expanded", String(!isExpanded))
      advPanel?.classList.toggle("hidden")
    })

    advCloseBtn?.addEventListener("click", () => {
      advToggleBtn?.setAttribute("aria-expanded", "false")
      advPanel?.classList.add("hidden")
    })

    // Click outside to close advanced panel
    document.addEventListener("click", (e) => {
      if (!advPanel?.classList.contains("hidden") && advToggleBtn && advPanel) {
        if (!advPanel.contains(e.target as Node) && !advToggleBtn.contains(e.target as Node)) {
          advToggleBtn.setAttribute("aria-expanded", "false")
          advPanel.classList.add("hidden")
        }
      }
    })

    // Advanced Panel Actions
    advAddCondBtn?.addEventListener("click", () => {
      if (!advContainer) return
      const emptyState = advContainer.querySelector(".advanced-panel__empty-state")
      if (emptyState) (emptyState as HTMLElement).style.display = "none"
      
      const row = renderAdvancedConditionRow()
      advContainer.appendChild(row)
    })

    advClearBtn?.addEventListener("click", () => {
      if (!advContainer) return
      const rows = advContainer.querySelectorAll(".advanced-filter-row")
      rows.forEach(r => r.remove())
      checkEmptyState()
      advancedFilterState = null
      emitChange()
    })

    advApplyBtn?.addEventListener("click", () => {
      if (!advContainer) return
      const rows = advContainer.querySelectorAll(".advanced-filter-row")
      if (rows.length === 0) {
        advancedFilterState = null
      } else {
        // Build the root AND group from the flat list of conditions for now
        // (Full recursive group UI can be added later, starting with a flat AND block)
        const conditions = Array.from(rows).map(row => {
          const field = row.querySelector<HTMLSelectElement>(".adv-field")?.value ?? ""
          const operator = row.querySelector<HTMLSelectElement>(".adv-op")?.value ?? "equals"
          const value = row.querySelector<HTMLInputElement>(".adv-val")?.value ?? ""
          return { id: Math.random().toString(36).substring(7), field, operator, value }
        })
        advancedFilterState = {
          id: "root",
          logic: "AND",
          conditions
        }
      }
      
      // Visual feedback on toggle button
      if (advancedFilterState && advancedFilterState.conditions.length > 0) {
        advToggleBtn?.classList.add("text-accent")
      } else {
        advToggleBtn?.classList.remove("text-accent")
      }

      advToggleBtn?.setAttribute("aria-expanded", "false")
      advPanel?.classList.add("hidden")
      emitChange()
    })

    function gatherState() {
      // Collect active types
      const activeTypes: string[] = []
      typeToggles.forEach((btn) => {
        if (btn.classList.contains("active") && btn.dataset.type) {
          activeTypes.push(btn.dataset.type)
        }
      })

      // Collect active users (pill mode)
      let activeUser = ""
      if (userPills.length > 0) {
        const activeUserBtn = toolbar.querySelector<HTMLButtonElement>(".filter-toolbar__user-btn.active:not([data-user='all'])")
        activeUser = activeUserBtn?.dataset.user ?? ""
      } else {
        activeUser = userSel?.value ?? ""
      }

      return {
        search: search?.value ?? "",
        status: statusSel?.value ?? "",
        priority: prioritySel?.value ?? "",
        rice: riceSel?.value ?? "",
        user: activeUser,
        board: boardSel?.value ?? "",
        groupBy: groupBySel?.value ?? "none",
        types: activeTypes.length === typeToggles.length ? [] : activeTypes,
        advancedFilter: advancedFilterState,
      }
    }

    function emitChange() {
      const state = gatherState()
      document.dispatchEvent(
        new CustomEvent("meitheal:filter-change", {
          detail: { ...state, view: prefix },
        })
      )
    }

    // Debounce for search
    let searchTimer: ReturnType<typeof setTimeout>
    search?.addEventListener("input", () => {
      clearTimeout(searchTimer)
      searchTimer = setTimeout(emitChange, 150)
    })

    // Select change listeners
    ;[statusSel, prioritySel, riceSel, userSel, boardSel, groupBySel].forEach((sel) => {
      sel?.addEventListener("change", emitChange)
    })

    // Type toggle listeners
    typeToggles.forEach((btn) => {
      btn.addEventListener("click", () => {
        btn.classList.toggle("active")
        btn.setAttribute("aria-pressed", String(btn.classList.contains("active")))
        emitChange()
      })
    })

    // User pill listeners (kanban)
    userPills.forEach((btn) => {
      btn.addEventListener("click", () => {
        const user = btn.dataset.user
        if (user === "all") {
          userPills.forEach((b) => {
            b.classList.remove("active")
          })
          btn.classList.add("active")
        } else {
          toolbar.querySelector<HTMLButtonElement>(".filter-toolbar__user-btn[data-user='all']")?.classList.remove("active")
          btn.classList.toggle("active")
          // If none active, re-activate "all"
          const anyActive = toolbar.querySelector<HTMLButtonElement>(".filter-toolbar__user-btn.active:not([data-user='all'])")
          if (!anyActive) {
            toolbar.querySelector<HTMLButtonElement>(".filter-toolbar__user-btn[data-user='all']")?.classList.add("active")
          }
        }
        emitChange()
      })
    })

    // Clear all button
    clearBtn?.addEventListener("click", () => {
      if (search) search.value = ""
      ;[statusSel, prioritySel, riceSel, userSel, boardSel].forEach((sel) => {
        if (sel) sel.value = ""
      })
      if (groupBySel) groupBySel.value = "none"
      typeToggles.forEach((btn) => {
        btn.classList.add("active")
        btn.setAttribute("aria-pressed", "true")
      })
      userPills.forEach((btn) => {
        btn.classList.remove("active")
      })
      toolbar.querySelector<HTMLButtonElement>(".filter-toolbar__user-btn[data-user='all']")?.classList.add("active")
      
      // Clear advanced filters too
      if (advContainer) {
        const rows = advContainer.querySelectorAll(".advanced-filter-row")
        rows.forEach(r => r.remove())
        checkEmptyState()
      }
      advancedFilterState = null
      advToggleBtn?.classList.remove("text-accent")

      emitChange()
    })

    // Load boards into board selector (idempotent via DOM attribute)
    async function loadBoards() {
      if (!boardSel || boardSel.dataset.populated) return
      boardSel.dataset.populated = "true"
      
      try {
        const res = await fetch("/api/boards")
        if (!res.ok) return
        const data = await res.json()
        const boards: { id: string; title: string; icon?: string }[] = data.boards || []
        
        boards.forEach((b) => {
          const opt = document.createElement("option")
          opt.value = b.id
          opt.textContent = `${b.icon ?? "📋"} ${b.title}`
          boardSel.appendChild(opt)
        })
      } catch { /* offline fallback */ }
    }

    loadBoards()
  }

  // Initialize toolbars
  function bootToolbars() {
    document.querySelectorAll<HTMLElement>(".filter-toolbar").forEach((toolbar) => {
      // Guard: don't re-initialize if already done
      if (toolbar.dataset.initialized) return
      toolbar.dataset.initialized = "true"
      initFilterToolbar(toolbar)
    })
  }

  // Use both events but rely on data-initialized + data-populated for idempotency
  document.addEventListener("DOMContentLoaded", bootToolbars)
  document.addEventListener("astro:page-load", bootToolbars)
</script>

