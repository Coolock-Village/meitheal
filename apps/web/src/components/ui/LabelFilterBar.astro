---
/**
 * LabelFilterBar — Interactive label filter component
 *
 * @domain labels
 * @bounded-context labels
 *
 * Renders a row of toggleable label chips that filter tasks by label.
 * Fetches available labels from /api/labels on first interaction.
 * Emits 'meitheal:label-filter' custom events when selection changes.
 *
 * Uses existing `.label-filter` CSS classes from `_labels.css`.
 *
 * @prop activeLabels - Currently active label filter names
 * @prop id - Element ID for targeting
 */
interface Props {
  activeLabels?: string[]
  id?: string
}

const {
  activeLabels = [],
  id = "label-filter-bar",
} = Astro.props
---

<div class="label-filter" id={id} data-active={JSON.stringify(activeLabels)}>
  <span
    class={`label-filter__chip ${activeLabels.length === 0 ? "label-filter__chip--active" : ""}`}
    data-label="__all__"
    role="button"
    tabindex="0"
    aria-pressed={activeLabels.length === 0 ? "true" : "false"}
  >
    All
  </span>
  {/* Dynamic label chips populated by client JS */}
</div>

<script>
  type LabelData = { id: number; title: string; hex_color: string }

  document.querySelectorAll<HTMLElement>(".label-filter").forEach((bar) => {
    let allLabels: LabelData[] = []
    let activeLabels: string[] = JSON.parse(bar.dataset.active || "[]")
    let loaded = false

    async function loadLabels() {
      if (loaded) return
      try {
        const res = await fetch("/api/labels")
        if (res.ok) {
          const data = await res.json()
          allLabels = Array.isArray(data) ? data : data.labels || []
          loaded = true
          renderChips()
        }
      } catch { /* offline fallback */ }
    }

    function renderChips() {
      // Keep "All" chip, add label chips
      const allChip = bar.querySelector<HTMLElement>("[data-label='__all__']")
      // Remove existing dynamic chips
      bar.querySelectorAll<HTMLElement>("[data-label]:not([data-label='__all__'])").forEach((c) => c.remove())

      for (const label of allLabels) {
        const chip = document.createElement("span")
        chip.className = `label-filter__chip${activeLabels.includes(label.title) ? " label-filter__chip--active" : ""}`
        chip.dataset.label = label.title
        chip.setAttribute("role", "button")
        chip.setAttribute("tabindex", "0")
        chip.setAttribute("aria-pressed", activeLabels.includes(label.title) ? "true" : "false")

        // Color dot
        const dot = document.createElement("span")
        dot.className = "label-picker__dot"
        dot.style.background = label.hex_color.startsWith("#") ? label.hex_color : `#${label.hex_color}`
        chip.appendChild(dot)

        chip.appendChild(document.createTextNode(label.title))
        bar.appendChild(chip)

        chip.addEventListener("click", () => toggleLabel(label.title))
        chip.addEventListener("keydown", (e) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault()
            toggleLabel(label.title)
          }
        })
      }

      // Update "All" chip state
      if (allChip) {
        const isAll = activeLabels.length === 0
        allChip.classList.toggle("label-filter__chip--active", isAll)
        allChip.setAttribute("aria-pressed", String(isAll))
      }
    }

    function toggleLabel(name: string) {
      if (name === "__all__") {
        activeLabels = []
      } else {
        const idx = activeLabels.indexOf(name)
        if (idx >= 0) {
          activeLabels.splice(idx, 1)
        } else {
          activeLabels.push(name)
        }
      }

      renderChips()
      emitFilterEvent()
    }

    function emitFilterEvent() {
      document.dispatchEvent(
        new CustomEvent("meitheal:label-filter", {
          detail: { labels: [...activeLabels] },
        }),
      )
    }

    // "All" chip click handler
    const allChip = bar.querySelector<HTMLElement>("[data-label='__all__']")
    allChip?.addEventListener("click", () => toggleLabel("__all__"))
    allChip?.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault()
        toggleLabel("__all__")
      }
    })

    // Load labels on interaction or immediately if visible
    if (typeof IntersectionObserver !== "undefined") {
      const observer = new IntersectionObserver(
        (entries) => {
          if (entries[0]?.isIntersecting) {
            loadLabels()
            observer.disconnect()
          }
        },
        { threshold: 0.1 },
      )
      observer.observe(bar)
    } else {
      loadLabels()
    }
  })
</script>
