---
import { t } from "../../i18n/translations";
import type { Locale } from "../../lib/locale";

interface Props {
  status: string;
}

const { status } = Astro.props;

// i18n: resolve locale from cookie
const cookieLocale = Astro.cookies.get("meitheal-locale")?.value;
const locale: Locale = cookieLocale === "ga" ? "ga" : "en";

const isDone = status === "complete" || status === "done";
const statusLabels: Record<string, string> = {
  pending: t("task_status.pending", locale),
  active: t("task_status.active", locale),
  in_progress: t("task_status.active", locale),
  complete: t("task_status.complete", locale),
  done: t("task_status.complete", locale),
  todo: t("task_status.pending", locale),
};

const label = statusLabels[status] ?? status;
const badgeClass = isDone ? "done" : status;
---
<span class={`task-badge badge-${badgeClass}`}>
  {label}
</span>
