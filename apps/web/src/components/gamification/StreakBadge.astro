---
/**
 * StreakBadge — Displays current completion streak in sidebar/dashboard
 *
 * @domain gamification
 * @bounded-context gamification
 *
 * Server-side rendered badge showing current streak count with fire emoji.
 * Fetches stats from the gamification domain at build/request time.
 *
 * @prop streak - Current streak count
 * @prop compact - Use compact sizing for sidebar
 */
interface Props {
  streak: number
  compact?: boolean
}

const { streak, compact = false } = Astro.props
---

{streak > 0 && (
  <div
    class={`streak-badge ${compact ? "streak-badge--compact" : ""}`}
    title={`${streak} day${streak !== 1 ? "s" : ""} streak`}
    aria-label={`${streak} day completion streak`}
  >
    <span class="streak-badge__icon">🔥</span>
    <span class="streak-badge__count">{streak}</span>
    {!compact && <span class="streak-badge__label">day streak</span>}
  </div>
)}

<style>
  .streak-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 600;
    background: linear-gradient(135deg, hsl(38 92% 50% / 0.15), hsl(15 85% 55% / 0.15));
    color: hsl(38 92% 45%);
    border: 1px solid hsl(38 92% 50% / 0.2);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    cursor: default;
  }

  .streak-badge:hover {
    transform: scale(1.05);
    box-shadow: 0 2px 8px hsl(38 92% 50% / 0.15);
  }

  .streak-badge--compact {
    padding: 0.125rem 0.375rem;
    font-size: 0.75rem;
    gap: 0.125rem;
  }

  .streak-badge__icon {
    font-size: 1em;
    line-height: 1;
  }

  .streak-badge__count {
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  .streak-badge__label {
    font-weight: 400;
    opacity: 0.8;
    font-size: 0.75em;
  }

  [data-theme="dark"] .streak-badge {
    background: linear-gradient(135deg, hsl(38 70% 30% / 0.3), hsl(15 70% 35% / 0.3));
    color: hsl(38 85% 65%);
    border-color: hsl(38 70% 50% / 0.25);
  }

  @media (prefers-reduced-motion: reduce) {
    .streak-badge {
      transition: none;
    }
    .streak-badge:hover {
      transform: none;
    }
  }
</style>
