---
import "../styles/global.css";
import Confetti from "../components/gamification/Confetti.astro";
import PomodoroTimer from "../components/pomodoro/PomodoroTimer.astro";
import { getFeatureFlags } from "../lib/feature-flags";
import { ViewTransitions } from "astro:transitions";
import { t } from "../i18n/translations";
import type { Locale } from "../lib/locale";
import Sidebar from "../components/layout/Sidebar.astro";
import TopNavigation from "../components/layout/TopNavigation.astro";
import StrategicEvaluator from "../components/tasks/StrategicEvaluator.astro";
import NewTaskModal from "../components/tasks/NewTaskModal.astro";
import AskAssistModal from "../components/ha/AskAssistModal.astro";
import PwaInstallBanner from "../components/pwa/PwaInstallBanner.astro";

import dtEn from "../i18n/en.json";
import dtGa from "../i18n/ga.json";

// i18n: resolve locale from cookie for SSR
const cookieLocale = Astro.cookies.get("meitheal-locale")?.value;
const locale: Locale = cookieLocale === "ga" ? "ga" : "en";

// Feature flags — read from settings DB (SSR)
const featureFlags = await getFeatureFlags();
const featureFlagsJson = JSON.stringify(featureFlags);

const {
  timezone = "Europe/Dublin",
  weekStart = "monday",
  dateFormat = "relative",
  ingressPath,
  behindIngress = false,
} = Astro.locals;

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Meitheal",
  description = "The cooperative task and life engine for your home.",
} = Astro.props;

// OA-607: Sidebar task count badges (SSR)
let taskCounts = { total: 0, active: 0, pending: 0 };
try {
  const { ensureSchema, getPersistenceClient } =
    await import("@domains/tasks/persistence/store");
  await ensureSchema();
  const client = getPersistenceClient();
  const result = await client.execute(
    "SELECT status, COUNT(*) as cnt FROM tasks GROUP BY status",
  );
  for (const row of result.rows) {
    const r = row as Record<string, unknown>;
    const s = String(r.status);
    const c = Number(r.cnt);
    taskCounts.total += c;
    if (s === "active") taskCounts.active += c;
    if (s === "pending" || s === "backlog") taskCounts.pending += c;
  }
} catch {
  /* DB not available */
}

// Security headers are set by middleware.ts — no duplicates here.
// IMPORTANT: Do NOT set Strict-Transport-Security or upgrade-insecure-requests
// in HA ingress environments — the addon serves HTTP internally.
Astro.response.headers.set("X-Content-Type-Options", "nosniff");
---

<!doctype html>
<html lang={locale} dir="ltr">
  <head>
    <!-- Ingress-aware fetch: prefix /api/ paths with HA ingress path -->
    <script is:inline>
      (function () {
        var ip = window.__ingress_path;
        var _f = window.fetch;
        window.fetch = function (input, init) {
          // Ensure ingress session cookie is always sent
          if (!init) init = {};
          if (ip) {
            if (!init.credentials) init.credentials = "include";
            if (typeof input === "string" && input.startsWith("/")) {
              // Guard: don't prefix if URL already contains the ingress path
              if (!input.startsWith(ip + "/") && input !== ip) {
                input = ip + input;
              }
            } else if (input instanceof Request && input.url) {
              var u = new URL(input.url);
              if (u.pathname.startsWith("/") && u.origin === location.origin) {
                // Guard: don't prefix if path already contains the ingress path
                if (!u.pathname.startsWith(ip + "/") && u.pathname !== ip) {
                  input = new Request(ip + u.pathname + u.search, input);
                }
              }
            }
          }
          return _f.call(this, input, init).then(function (response) {
            // Stale ingress token: HA Supervisor returns 403 when the
            // addon restarted and got a new ingress token. Auto-reload
            // to fetch the new token from the server-rendered HTML.
            if (response.status === 403 && ip) {
              var reloadKey = "meitheal-ingress-reload";
              var lastReload = sessionStorage.getItem(reloadKey);
              var now = Date.now();
              // Guard: don't reload more than once per 10 seconds
              if (!lastReload || now - Number(lastReload) > 10000) {
                sessionStorage.setItem(reloadKey, String(now));
                var tc = document.querySelector(".toast-container");
                if (tc) {
                  var t = document.createElement("div");
                  t.className = "toast warning";
                  t.textContent = "🔄 Session expired. Reloading...";
                  t.setAttribute("role", "alert");
                  tc.appendChild(t);
                }
                setTimeout(function () {
                  window.location.reload();
                }, 800);
              }
            }
            // Conflict detection (Persona #14): show toast on 409
            if (response.status === 409) {
              var tc = document.querySelector(".toast-container");
              if (tc) {
                var toast = document.createElement("div");
                toast.className = "toast warning";
                toast.textContent =
                  "⚠ Task was modified by another session. Refresh to see latest.";
                toast.setAttribute("role", "alert");
                tc.appendChild(toast);
                setTimeout(function () {
                  toast.remove();
                }, 6000);
              }
              // Announce for screen readers via aria-live
              var live = document.getElementById("sync-announcer");
              if (live)
                live.textContent =
                  "Conflict detected: task was modified elsewhere.";
            }
            return response;
          });
        };
      })();
    </script>

    <!-- Ingress state persistence: restore last route after iframe recreation -->
    <!-- Runs pre-paint so the user never sees a flash of the wrong page -->
    <script is:inline>
      (function () {
        if (!window.__ingress_path) return;
        if (window.location.pathname !== "/") return;
        try {
          var raw = sessionStorage.getItem("meitheal-navigation-state");
          if (!raw) return;
          var state = JSON.parse(raw);
          if (
            typeof state.path !== "string" ||
            typeof state.timestamp !== "number"
          )
            return;
          // Only restore if saved within the last 60 seconds
          if (Date.now() - state.timestamp > 60000) {
            sessionStorage.removeItem("meitheal-navigation-state");
            return;
          }
          // Don't redirect to root (no-op)
          if (state.path === "/") return;
          // Redirect to saved path — prepend ingress path for proper routing
          var target = window.__ingress_path + state.path;
          // Save scroll position to restore after redirect
          if (state.scrollY) {
            sessionStorage.setItem(
              "meitheal-restore-scroll",
              String(state.scrollY),
            );
          }
          window.location.replace(target);
        } catch (e) {
          // sessionStorage unavailable or parse error — silently continue
        }
      })();
    </script>

    <!-- Theme init — runs before paint to prevent flash -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem("meitheal-theme") || "dark";
        // Always set data-theme explicitly for all states (including dark)
        // Previous code relied on :root fallthrough for dark, which caused
        // theme inconsistency when components used [data-theme="dark"] selector
        if (t === "custom") {
          document.documentElement.setAttribute("data-theme", "dark");
          var css = localStorage.getItem("meitheal-custom-theme-css");
          if (css) {
            var s = document.createElement("style");
            s.id = "meitheal-custom-theme";
            s.textContent = css;
            document.head.appendChild(s);
          }
        } else {
          document.documentElement.setAttribute("data-theme", t);
        }
      })();
    </script>

    <!-- HA theme passthrough: bridge parent frame CSS vars into Meitheal -->
    <script is:inline>
      (function () {
        if (!window.__ingress_path) return;
        try {
          var parent = window.parent;
          if (!parent || parent === window) return;
          var parentStyles = getComputedStyle(parent.document.documentElement);
          // Map HA theme vars → Meitheal vars
          var mapping = {
            "--primary-color": "--accent",
            "--accent-color": "--accent",
            "--primary-text-color": "--text-primary",
            "--primary-background-color": "--bg-primary",
            "--secondary-background-color": "--bg-secondary",
            "--divider-color": "--border",
          };
          var root = document.documentElement.style;
          var applied = 0;
          for (var haVar in mapping) {
            var val = parentStyles.getPropertyValue(haVar).trim();
            if (val) {
              root.setProperty(mapping[haVar], val);
              applied++;
            }
          }
          if (applied > 0) {
            document.documentElement.setAttribute("data-ha-theme", "inherited");
          }
        } catch (e) {
          // Cross-origin restriction — can't read parent frame vars
        }
      })();
    </script>

    <!-- User accent color: restore from localStorage before paint -->
    <script is:inline>
      (function () {
        var accent = localStorage.getItem("meitheal-accent-color");
        if (!accent) return;
        var root = document.documentElement.style;
        root.setProperty("--accent", accent);
        // P3-3: Set fallback values first (for WebViews without color-mix support)
        root.setProperty("--accent-hover", accent);
        root.setProperty("--accent-light", accent);
        // Compute hover (darken 10%) — overrides fallback on supporting browsers
        try {
          root.setProperty(
            "--accent-hover",
            "color-mix(in srgb, " + accent + " 85%, #000)",
          );
          root.setProperty(
            "--accent-light",
            "color-mix(in srgb, " + accent + " 12%, transparent)",
          );
        } catch (e) {
          // Older WebViews — fallback values already set above
        }
        root.setProperty("--border-focus", accent);
      })();
    </script>

    <!-- Page transition loading indicator (CSS-only) -->
    <style is:inline>
      @keyframes meitheal-loading-slide {
        0% {
          transform: translateX(-100%);
        }
        50% {
          transform: translateX(0%);
        }
        100% {
          transform: translateX(100%);
        }
      }
      .meitheal-loading-bar {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
        z-index: 9999;
        background: var(--accent, #6366f1);
        transform: translateX(-100%);
        animation: meitheal-loading-slide 1.2s ease-in-out infinite;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.2s;
      }
      html.is-loading .meitheal-loading-bar {
        opacity: 1;
      }
    </style>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <link
      rel="manifest"
      href="/manifest.webmanifest"
      crossorigin="use-credentials"
    />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <meta name="theme-color" content="#0f172a" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
    />
    <!-- Inter font self-hosted via @fontsource-variable/inter (imported in global.css) -->
    {!behindIngress && <ViewTransitions fallback="swap" />}
    <!-- Inject localization and settings maps into the window for client-scripts like toast.ts -->
    <script
      is:inline
      define:vars={{ locale, dtEn, dtGa, timezone, weekStart, dateFormat }}
    >
      window.mSettings = { timezone, weekStart, dateFormat };
      window.mI18n = {
        locale,
        get: function (key) {
          const dict = locale === "ga" ? dtGa : dtEn;
          const parts = key.split(".");
          let val = dict;
          for (const p of parts) {
            if (!val || typeof val !== "object") return key;
            val = val[p];
          }
          return typeof val === "string" ? val : key;
        },
      };
    </script>
  </head>
  <body>
    <!-- Page transition loading indicator -->
    <div class="meitheal-loading-bar" aria-hidden="true"></div>

    <!-- Wire Astro view transitions to loading bar -->
    <script is:inline>
      document.addEventListener("astro:before-preparation", function () {
        document.documentElement.classList.add("is-loading");
      });
      document.addEventListener("astro:after-swap", function () {
        document.documentElement.classList.remove("is-loading");
      });
      document.addEventListener("astro:page-load", function () {
        document.documentElement.classList.remove("is-loading");
      });
    </script>

    <!-- Sidebar collapse: restore state immediately to avoid FOUC -->
    <script is:inline>
      (function () {
        // HA ingress detection
        if (window.__ingress_path && document.body) {
          document.body.classList.add("ha-ingress");
        }
        // Restore sidebar collapsed state from localStorage
        if (localStorage.getItem("meitheal_sidebar_collapsed") === "true") {
          document.body.classList.add("sidebar-collapsed");
        }
      })();
    </script>
    <!-- Ingress URL sync: DISABLED — removed to prevent potential HA panel routing interference -->

    <a href="#main-content" class="skip-to-content"
      >{t("nav.skip_to_content", locale)}</a
    >
    <div transition:persist="sidebar">
      <Sidebar locale={locale} taskCounts={taskCounts} />
    </div>

    <!-- Sidebar toggle pill (appears on hover, always visible when collapsed) -->
    <button
      type="button"
      class="sidebar-toggle"
      id="sidebar-toggle-btn"
      aria-label="Toggle sidebar (Ctrl+B)"
      title="Toggle sidebar (Ctrl+B)"
    >
      <svg
        width="10"
        height="14"
        viewBox="0 0 10 14"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M8 1L2 7L8 13"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </button>

    <div class="main-content">
      <TopNavigation locale={locale}>
        <Fragment slot="page-title"><slot name="page-title" /></Fragment>
        <Fragment slot="actions"><slot name="actions" /></Fragment>
      </TopNavigation>
      <main
        class="content"
        role="main"
        id="main-content"
        style="padding: 0 24px 24px;"
      >
        <slot />
      </main>
    </div>

    <!-- Sidebar toggle logic: click + keyboard shortcut -->
    <script is:inline>
      (function () {
        var btn = document.getElementById("sidebar-toggle-btn");
        function toggleSidebar() {
          var collapsed = document.body.classList.toggle("sidebar-collapsed");
          localStorage.setItem("meitheal_sidebar_collapsed", String(collapsed));
          // Rotate chevron: points left when expanded (to collapse), right when collapsed (to expand)
          if (btn) {
            btn.querySelector("svg").style.transform = collapsed
              ? "rotate(180deg)"
              : "";
          }
        }
        // Initialise chevron rotation on load
        if (btn && document.body.classList.contains("sidebar-collapsed")) {
          btn.querySelector("svg").style.transform = "rotate(180deg)";
        }
        // Click handler
        if (btn) btn.addEventListener("click", toggleSidebar);
        // Keyboard shortcut: Ctrl+B / Cmd+B
        document.addEventListener("keydown", function (e) {
          if ((e.ctrlKey || e.metaKey) && e.key === "b") {
            // Don't hijack Ctrl+B (bold) when user is editing text
            var tag = (e.target || {}).tagName || "";
            var editable = (e.target || {}).contentEditable === "true";
            if (["INPUT", "TEXTAREA", "SELECT"].indexOf(tag) !== -1 || editable) return;
            e.preventDefault();
            toggleSidebar();
          }
        });
      })();
    </script>

    <!-- Task Detail Slide-out Panel -->
    <div
      id="task-detail-overlay"
      class="fixed inset-0 bg-black/60 z-50 hidden"
      role="dialog"
      aria-modal="true"
      aria-label="Task detail"
    >
      <div
        id="task-detail-panel"
        class="absolute right-0 top-0 h-full w-full max-w-4xl bg-bg-secondary border-l border-border shadow-2xl overflow-y-auto animate-slide-in"
      >
        <div class="px-6 lg:px-8 pt-6 pb-2">
          <a
            href="#"
            id="td-parent"
            class="text-xs text-info hidden hover:underline items-center gap-1 mb-1"
          ></a>
          <div
            class="flex items-center justify-between pb-2 border-b border-border"
          >
            <div class="flex items-center gap-4 w-full mr-32">
              <span
                id="td-priority-dot"
                class="td-priority-dot text-xl"
                title="Priority">●</span
              >
              <input
                id="td-title"
                class="form-input bg-transparent border border-transparent hover:border-border hover:bg-bg-hover focus:bg-bg-input focus:border-border focus:ring-1 focus:ring-accent text-2xl font-bold px-2 py-1 -ml-2 rounded transition-colors leading-tight"
                placeholder="Task title"
              />
              <span
                id="td-id"
                class="hidden"
                style="font-size:12px;font-family:'JetBrains Mono',monospace;color:var(--accent);background:rgba(99,102,241,0.1);border:1px solid rgba(99,102,241,0.2);padding:4px 10px;border-radius:6px;white-space:nowrap;cursor:help;flex-shrink:0;"
                title="Task ID"></span>
            </div>
            <button
              type="button"
              id="td-close"
              class="btn-secondary px-3 py-1.5 text-sm"
              aria-label="Close detail">✕</button
            >
          </div>
          <!-- Progress bar -->
          <div id="td-progress-bar-container" class="td-progress-bar-container">
            <div
              id="td-progress-bar-fill"
              class="td-progress-bar-fill"
              style="width: 0%"
            >
            </div>
          </div>
          <!-- Due date -->
          <div id="td-due-row" class="td-due-row hidden">
            <span class="text-[10px] text-text-muted uppercase tracking-wider"
              >Due</span
            >
            <span
              id="td-due-display"
              class="text-xs text-text-muted font-medium"></span>
          </div>

          <div class="flex flex-col lg:flex-row min-h-0">
            <!-- Left: Content -->
            <div class="flex-1 min-w-0 px-6 lg:px-8 py-6 space-y-8 overflow-y-auto">
              <!-- Status + Board -->
              <div class="flex items-center gap-3">
                <select id="td-status" class="inline-select">
                  <option value="backlog">Backlog</option>
                  <option value="pending">Pending</option>
                  <option value="active">Active</option>
                  <option value="complete">Complete</option>
                </select>
                <select
                  id="td-task-type"
                  class="inline-select"
                  title="Work item type"
                >
                  <option value="task">✅ Task</option>
                  <option value="story">📖 Story</option>
                  <option value="epic">🎯 Epic</option>
                </select>
                <select id="td-board" class="inline-select" title="Board"
                ></select>
              </div>

              <!-- Description (Markdown Editor) -->
              <div class="mb-5">
                <div class="flex items-center justify-between mb-3">
                  <label
                    class="text-sm text-text-muted font-semibold uppercase tracking-wider block"
                  >
                    Description
                  </label>
                  <div class="flex gap-2">
                    <button
                      id="td-desc-edit-btn"
                      class="btn btn-ghost text-xs px-2 py-1 bg-[var(--bg-hover)]"
                      type="button">Edit</button
                    >
                    <button
                      id="td-desc-preview-btn"
                      class="btn btn-ghost text-xs px-2 py-1"
                      type="button">Preview</button
                    >
                  </div>
                </div>
                <div id="td-desc-edit-container">
                  <textarea
                    id="td-description"
                    class="form-input min-h-[160px] resize-y text-base w-full"
                    placeholder="Add a description (Markdown supported)..."
                  ></textarea>
                </div>
                <div
                  id="td-desc-preview-container"
                  class="hidden min-h-[160px] p-4 bg-[var(--bg-input)] border border-border rounded-md text-base mt-2 text-[var(--text-primary)]"
                  style="max-width: 100%;"
                >
                  <div
                    class="prose prose-sm dark:prose-invert max-w-none break-words"
                    id="td-desc-preview"
                  >
                  </div>
                </div>
              </div>

              <!-- Checklists (Phase 31) -->
              <div>
                <label
                  class="text-xs text-text-muted font-semibold uppercase tracking-wide mb-2 flex items-center justify-between"
                >
                  <span>Checklists</span>
                  <button
                    type="button"
                    id="td-add-checklist-item"
                    class="text-xs text-accent hover:text-accent-hover transition-colors"
                    >+ Add Item</button
                  >
                </label>
                <div id="td-checklists" class="space-y-1"></div>
                <div
                  id="td-checklist-progress"
                  class="text-[10px] text-text-muted mt-1"
                  style="display:none;"
                >
                  <span id="td-checklist-done">0</span>/<span
                    id="td-checklist-total">0</span
                  > complete
                </div>
              </div>

              <!-- Recurrence (Phase 31) -->
              <div>
                <label
                  class="text-xs text-text-muted font-semibold uppercase tracking-wide mb-2 block"
                  >Recurrence</label
                >
                <div class="flex items-center gap-2">
                  <select
                    id="td-recurrence"
                    class="inline-select flex-1"
                    title="Recurrence pattern"
                  >
                    <option value="">None</option>
                    <option value="FREQ=DAILY">Every day</option>
                    <option value="FREQ=WEEKLY">Every week</option>
                    <option value="FREQ=WEEKLY;BYDAY=MO,TU,WE,TH,FR"
                      >Every weekday</option
                    >
                    <option value="FREQ=MONTHLY">Every month</option>
                    <option value="FREQ=YEARLY">Every year</option>
                    <option value="FREQ=WEEKLY;INTERVAL=2">Every 2 weeks</option
                    >
                  </select>
                  <span
                    id="td-recurrence-desc"
                    class="text-[10px] text-text-muted"></span>
                </div>
              </div>

              <!-- Ticket Linking (Parent / Children) -->
              <div>
                <label
                  class="text-xs text-text-muted font-semibold uppercase tracking-wide mb-2 block"
                  >Linked Tickets</label
                >
                <div class="space-y-2">
                  <div class="flex items-center gap-2">
                    <span class="text-xs text-text-muted w-14">Parent:</span>
                    <div
                      id="td-link-parent-display"
                      class="flex-1 flex items-center gap-1"
                    >
                      <span class="text-xs text-text-muted italic">None</span>
                    </div>
                  </div>
                  <div class="relative">
                    <input
                      id="td-link-parent-search"
                      class="form-input text-sm py-1.5"
                      placeholder="Search for parent (Epic/Story)..."
                      autocomplete="off"
                    />
                    <div
                      id="td-link-parent-results"
                      class="absolute z-10 left-0 right-0 bg-bg-card border border-border rounded-md shadow-lg max-h-40 overflow-y-auto"
                      style="display:none;"
                    >
                    </div>
                  </div>
                  <div>
                    <span class="text-xs text-text-muted">Children:</span>
                    <div id="td-link-children" class="space-y-1 mt-1"></div>
                    <!-- Subtask progress bar (Phase 1: SUB-03) -->
                    <div id="td-subtask-progress" class="hidden mt-2">
                      <div class="flex items-center justify-between text-[10px] text-text-muted mb-0.5">
                        <span>Subtask progress</span>
                        <span id="td-subtask-progress-label">0/0</span>
                      </div>
                      <div class="w-full h-1.5 bg-bg-input rounded-full overflow-hidden">
                        <div id="td-subtask-progress-bar" class="h-full bg-accent rounded-full transition-all duration-300" style="width:0%"></div>
                      </div>
                    </div>
                    <!-- Add subtask inline form (Phase 1: SUB-02) -->
                    <div id="td-add-subtask" class="mt-2">
                      <button type="button" id="td-add-subtask-btn" class="text-xs text-accent hover:text-accent-hover flex items-center gap-1">
                        <span>➕</span> Add subtask
                      </button>
                      <div id="td-add-subtask-form" class="hidden mt-1 gap-1">
                        <input
                          id="td-add-subtask-input"
                          class="form-input text-sm py-1 flex-1"
                          placeholder="Subtask title..."
                          autocomplete="off"
                        />
                        <button type="button" id="td-add-subtask-submit" class="btn-primary text-xs px-2 py-1">Add</button>
                        <button type="button" id="td-add-subtask-cancel" class="btn-secondary text-xs px-2 py-1">✕</button>
                      </div>
                    </div>
                  </div>

                  <!-- Related Links (Jira-style issue linking) -->
                  <div
                    class="mt-3 pt-3"
