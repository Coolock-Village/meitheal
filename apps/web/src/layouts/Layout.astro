---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Meitheal",
  description = "The cooperative task and life engine for your home.",
} = Astro.props;

// OA-607: Sidebar task count badges (SSR)
let taskCounts = { total: 0, active: 0, pending: 0 };
try {
  const { ensureSchema, getPersistenceClient } =
    await import("@domains/tasks/persistence/store");
  await ensureSchema();
  const client = getPersistenceClient();
  const result = await client.execute(
    "SELECT status, COUNT(*) as cnt FROM tasks GROUP BY status",
  );
  for (const row of result.rows) {
    const r = row as Record<string, unknown>;
    const s = String(r.status);
    const c = Number(r.cnt);
    taskCounts.total += c;
    if (s === "active" || s === "in_progress") taskCounts.active += c;
    if (s === "pending" || s === "todo") taskCounts.pending += c;
  }
} catch {
  /* DB not available */
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#1a1a2e" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <nav
      class="sidebar"
      id="sidebar"
      role="navigation"
      aria-label="Main navigation"
    >
      <div class="sidebar-header">
        <div class="logo">
          <span class="logo-icon">☘</span>
          <span class="logo-text">Meitheal</span>
        </div>
      </div>
      <ul class="nav-links">
        <li>
          <a
            href="/"
            class="nav-link"
            data-page="dashboard"
            aria-label="Dashboard"><span class="nav-icon">📊</span> Dashboard</a
          >
        </li>
        <li>
          <a
            href="/tasks"
            class="nav-link"
            data-page="tasks"
            aria-label={`Tasks (${taskCounts.total} total)`}
            ><span class="nav-icon">✅</span> Tasks <span
              class="nav-badge"
              aria-label={`${taskCounts.total} tasks`}>{taskCounts.total}</span
            ></a
          >
        </li>
        <li>
          <a
            href="/kanban"
            class="nav-link"
            data-page="kanban"
            aria-label={`Kanban board (${taskCounts.active} active)`}
            ><span class="nav-icon">▦</span> Kanban <span
              class="nav-badge"
              aria-label={`${taskCounts.active} active tasks`}
              >{taskCounts.active}</span
            ></a
          >
        </li>
        <li>
          <a
            href="/table"
            class="nav-link"
            data-page="table"
            aria-label="Table view"><span class="nav-icon">⊞</span> Table</a
          >
        </li>
        <li>
          <a
            href="/settings"
            class="nav-link"
            data-page="settings"
            aria-label="Settings"><span class="nav-icon">⚙</span> Settings</a
          >
        </li>
      </ul>
      <div
        class="board-switcher"
        id="board-switcher"
        role="region"
        aria-label="Board selector"
      >
        <div class="board-switcher-label">Board</div>
        <select
          class="board-select"
          id="board-select"
          aria-label="Select active board"
        >
          <option value="default">📋 Default</option>
        </select>
        <button
          class="board-add-btn"
          id="add-board-btn"
          title="Create new board"
          aria-label="Create new board">+</button
        >
      </div>
      <div class="sidebar-footer">
        <div
          class="status-indicator"
          id="connection-status"
          role="status"
          aria-live="polite"
        >
          <span class="status-dot" aria-hidden="true"></span>
          <span class="status-text">Checking...</span>
        </div>
      </div>
    </nav>
    <div class="main-content">
      <header class="topbar">
        <button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu"
          >☰</button
        >
        <h1 class="page-title"><slot name="page-title" /></h1>
        <div class="search-container" id="search-container">
          <input
            type="search"
            class="search-input"
            id="global-search"
            placeholder="Search tasks..."
            aria-label="Search tasks"
            autocomplete="off"
          />
          <div
            class="search-results"
            id="search-results"
            style="display: none;"
          >
          </div>
        </div>
        <div class="topbar-actions">
          <slot name="actions" />
        </div>
      </header>
      <main class="content" role="main" id="main-content">
        <slot />
      </main>
    </div>

    <!-- Task Detail Slide-out Panel -->
    <div
      id="task-detail-overlay"
      class="fixed inset-0 bg-black/60 z-50 hidden"
      role="dialog"
      aria-modal="true"
      aria-label="Task detail"
    >
      <div
        id="task-detail-panel"
        class="absolute right-0 top-0 h-full w-full max-w-3xl bg-bg-secondary border-l border-border shadow-lg overflow-y-auto animate-slide-in"
      >
        <div class="px-6 pt-4">
          <a href="#" id="td-parent" class="text-xs text-info hidden hover:underline flex items-center gap-1 mb-1"></a>
          <div class="flex items-center justify-between pb-4 border-b border-border">
            <div class="flex items-center gap-3 w-full">
              <span id="td-id" class="text-xs text-text-muted">#</span>
              <input
                id="td-title"
              class="form-input bg-transparent border-none text-lg font-bold p-0 focus:ring-0"
              placeholder="Task title"
            />
          </div>
          <button
            id="td-close"
            class="btn-secondary px-3 py-1.5 text-sm"
            aria-label="Close detail">✕</button
          >
        </div>

        <div class="flex flex-col lg:flex-row">
          <!-- Left: Content -->
          <div class="flex-1 p-6 space-y-6">
            <!-- Status + Board -->
            <div class="flex items-center gap-3">
              <select id="td-status" class="inline-select">
                <option value="pending">Pending</option>
                <option value="active">Active</option>
                <option value="in_progress">In Progress</option>
                <option value="done">Done</option>
              </select>
              <select
                id="td-task-type"
                class="inline-select"
                title="Work item type"
              >
                <option value="task">✅ Task</option>
                <option value="story">📖 Story</option>
                <option value="epic">🎯 Epic</option>
              </select>
              <span id="td-board" class="text-xs text-text-muted"></span>
            </div>

            <!-- Description -->
            <div>
              <label
                class="text-xs text-text-muted font-semibold uppercase tracking-wide mb-2 block"
                >Description</label
              >
              <textarea
                id="td-description"
                class="form-input min-h-[120px] resize-y"
                placeholder="Add a description..."></textarea>
            </div>

            <!-- Labels (interactive) -->
            <div>
              <label
                class="text-xs text-text-muted font-semibold uppercase tracking-wide mb-2 block"
                >Labels</label
              >
              <div id="td-labels" class="flex flex-wrap gap-1 mb-2"></div>
              <input
                id="td-label-input"
                class="form-input text-sm py-1.5"
                placeholder="Type a label and press Enter..."
              />
            </div>

            <!-- Custom Fields (interactive) -->
            <div>
              <label
                class="text-xs text-text-muted font-semibold uppercase tracking-wide mb-2 block"
                >Custom Fields</label
              >
              <div id="td-custom-fields" class="space-y-2"></div>
              <button
                id="td-add-cf"
                type="button"
                class="text-xs text-accent hover:text-accent-hover mt-2 transition-colors"
                >+ Add Field</button
              >
            </div>

            <!-- Comments -->
            <div>
              <label
                class="text-xs text-text-muted font-semibold uppercase tracking-wide mb-2 block"
                >Comments</label
              >
              <div id="td-comments" class="space-y-3 mb-4"></div>
              <div class="flex gap-2">
                <input
                  id="td-comment-input"
                  class="form-input flex-1"
                  placeholder="Add a comment..."
                />
                <button id="td-comment-submit" class="btn-primary px-4"
                  >Comment</button
                >
              </div>
            </div>
          </div>

          <!-- Right: Action Sidebar -->
          <div
            class="w-full lg:w-64 border-t lg:border-t-0 lg:border-l border-border p-4 space-y-3"
          >
            <div class="space-y-1">
              <button
                id="td-toggle-done"
                class="w-full text-left px-3 py-2 text-sm rounded-md hover:bg-bg-hover transition-colors"
                >✓ Mark as Done</button
              >
              <button
                id="td-toggle-favorite"
                class="w-full text-left px-3 py-2 text-sm rounded-md hover:bg-bg-hover transition-colors"
                >⭐ Add to Favorites</button
              >
            </div>

            <div class="border-t border-border pt-3">
              <span
                class="text-[10px] uppercase tracking-wide text-text-muted font-semibold"
                >Organization</span
              >
              <div class="mt-2 space-y-2">
                <div>
                  <label class="text-xs text-text-secondary block mb-1"
                    >Priority</label
                  >
                  <select id="td-priority" class="inline-select w-full">
                    <option value="1">1 — Lowest</option>
                    <option value="2">2 — Low</option>
                    <option value="3">3 — Medium</option>
                    <option value="4">4 — High</option>
                    <option value="5">5 — Highest</option>
                  </select>
                </div>
                <div>
                  <label class="text-xs text-text-secondary block mb-1"
                    >Progress</label
                  >
                  <div class="flex items-center gap-2">
                    <input
                      id="td-progress"
                      type="range"
                      min="0"
                      max="100"
                      value="0"
                      class="flex-1 accent-accent"
                    />
                    <span
                      id="td-progress-value"
                      class="text-xs text-text-muted w-8 text-right">0%</span
                    >
                  </div>
                </div>
                <div>
                  <label class="text-xs text-text-secondary block mb-1"
                    >Color</label
                  >
                  <input
                    id="td-color"
                    type="color"
                    value="#10b981"
                    class="w-8 h-8 rounded cursor-pointer border-none"
                  />
                </div>
              </div>
            </div>

            <div class="border-t border-border pt-3">
              <span
                class="text-[10px] uppercase tracking-wide text-text-muted font-semibold"
                >Date & Time</span
              >
              <div class="mt-2 space-y-2">
                <div>
                  <label class="text-xs text-text-secondary block mb-1"
                    >Due Date</label
                  >
                  <input
                    id="td-due-date"
                    type="date"
                    class="form-input text-sm py-1.5"
                  />
                </div>
                <div>
                  <label class="text-xs text-text-secondary block mb-1"
                    >Start Date</label
                  >
                  <input
                    id="td-start-date"
                    type="date"
                    class="form-input text-sm py-1.5"
                  />
                </div>
                <div>
                  <label class="text-xs text-text-secondary block mb-1"
                    >End Date</label
                  >
                  <input
                    id="td-end-date"
                    type="date"
                    class="form-input text-sm py-1.5"
                  />
                </div>
              </div>
            </div>

            <div class="border-t border-border pt-3">
              <span id="td-rice" class="text-xs text-text-muted"></span>
            </div>

            <div class="border-t border-border pt-3 space-y-2">
              <button
                id="td-ask-ai"
                class="w-full text-left px-3 py-2 text-sm text-primary rounded-md hover:bg-primary/10 transition-colors"
                >🤖 Ask AI</button
              >
              <button
                id="td-delete"
                class="w-full text-left px-3 py-2 text-sm text-danger rounded-md hover:bg-danger/10 transition-colors"
                >🗑 Delete</button
              >
            </div>

            <div class="text-[10px] text-text-muted mt-4">
              <div id="td-created"></div>
              <div id="td-updated"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Command Palette -->
    <div
      id="command-palette-overlay"
      class="fixed inset-0 bg-black/60 z-[60] hidden"
      role="dialog"
      aria-modal="true"
      aria-label="Command palette"
    >
      <div class="flex justify-center pt-[15vh]">
        <div
          id="command-palette"
          class="w-full max-w-lg bg-bg-card border border-border rounded-xl shadow-lg overflow-hidden animate-fade-in"
        >
          <div class="px-4 py-3 border-b border-border">
            <input
              id="cp-search"
              type="text"
              class="w-full bg-transparent text-text-primary text-lg outline-none"
              placeholder="Type a command or search..."
              autocomplete="off"
            />
            <p class="text-[10px] text-text-muted mt-1">
              Search tasks, or use quick actions
            </p>
          </div>
          <div id="cp-results" class="max-h-[50vh] overflow-y-auto">
            <div
              class="px-3 py-1.5 text-[10px] uppercase tracking-wide text-text-muted font-semibold"
            >
              Commands
            </div>
            <div
              class="cp-item px-4 py-2.5 cursor-pointer hover:bg-bg-hover text-sm text-text-primary"
              data-action="new-task"
            >
              New task
            </div>
            <div
              class="cp-item px-4 py-2.5 cursor-pointer hover:bg-bg-hover text-sm text-text-primary"
              data-action="new-board"
            >
              New board
            </div>
            <div id="cp-tasks-section" class="hidden">
              <div
                class="px-3 py-1.5 text-[10px] uppercase tracking-wide text-text-muted font-semibold"
              >
                Tasks
              </div>
              <div id="cp-tasks"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script>
      // Connection status check
      async function checkHealth() {
        const indicator = document.getElementById("connection-status");
        if (!indicator) return;
        const dot = indicator.querySelector(".status-dot");
        const text = indicator.querySelector(".status-text");
        try {
          const res = await fetch("/api/health");
          const data = await res.json();
          if (data.status === "ok") {
            dot?.classList.add("online");
            dot?.classList.remove("offline");
            if (text) text.textContent = "Connected";
          } else {
            dot?.classList.remove("online");
            dot?.classList.add("offline");
            if (text) text.textContent = "DB Offline";
          }
        } catch {
          dot?.classList.remove("online");
          dot?.classList.add("offline");
          if (text) text.textContent = "Disconnected";
        }
      }
      checkHealth();
      setInterval(checkHealth, 30000);

      // Mobile menu toggle
      document.getElementById("menu-toggle")?.addEventListener("click", () => {
        document.getElementById("sidebar")?.classList.toggle("open");
      });

      // Active nav link
      const currentPath = window.location.pathname;
      document.querySelectorAll(".nav-link").forEach((link) => {
        if (
          link.getAttribute("href") === currentPath ||
          (currentPath === "/" &&
            link.getAttribute("data-page") === "dashboard")
        ) {
          link.classList.add("active");
        }
      });

      // Global search
      const searchInput = document.getElementById(
        "global-search",
      ) as HTMLInputElement;
      const searchResults = document.getElementById("search-results")!;
      let searchTimeout: ReturnType<typeof setTimeout> | null = null;

      searchInput?.addEventListener("input", () => {
        const q = searchInput.value.trim();
        if (searchTimeout) clearTimeout(searchTimeout);
        if (!q) {
          searchResults.style.display = "none";
          return;
        }
        searchTimeout = setTimeout(async () => {
          try {
            const res = await fetch(
              `/api/tasks?q=${encodeURIComponent(q)}&limit=8`,
            );
            const data = (await res.json()) as {
              tasks: Array<Record<string, unknown>>;
              total: number;
            };
            if (data.tasks.length === 0) {
              searchResults.innerHTML =
                '<div class="search-empty">No tasks found</div>';
            } else {
              searchResults.innerHTML = data.tasks
                .map(
                  (t) =>
                    `<div class="search-item" data-task-id="${String(t.id ?? "")}" style="cursor:pointer;">
                  <strong>${String(t.title ?? "")}</strong>
                  <span class="search-meta">${String(t.status ?? "pending")} · P${t.priority ?? 3}</span>
                </div>`,
                )
                .join("");
            }
            searchResults.style.display = "block";
          } catch {
            searchResults.style.display = "none";
          }
        }, 300);
      });

      // Close search on click outside
      document.addEventListener("click", (e) => {
        if (!(e.target as Element)?.closest("#search-container")) {
          searchResults.style.display = "none";
        }
      });

      // "/" to focus search, Escape to blur, "n" for new task
      document.addEventListener("keydown", (e) => {
        const tag = (e.target as HTMLElement)?.tagName;
        const isEditing =
          ["INPUT", "TEXTAREA", "SELECT"].includes(tag) ||
          (e.target as HTMLElement)?.contentEditable === "true";

        if (e.key === "Escape") {
          // Close overlays in priority order: task detail > command palette > search > sidebar
          const taskOverlay = document.getElementById("task-detail-overlay");
          const cpOverlay = document.getElementById("command-palette-overlay");
          const shortcutModal = document.getElementById("shortcut-modal");
          const sidebar = document.getElementById("sidebar");

          if (shortcutModal && !shortcutModal.classList.contains("hidden")) {
            shortcutModal.classList.add("hidden");
            return;
          }
          if (taskOverlay && !taskOverlay.classList.contains("hidden")) {
            taskOverlay.classList.add("hidden");
            return;
          }
          if (cpOverlay && !cpOverlay.classList.contains("hidden")) {
            cpOverlay.classList.add("hidden");
            return;
          }
          if (document.activeElement === searchInput) {
            searchInput?.blur();
            searchResults.style.display = "none";
            return;
          }
          if (sidebar?.classList.contains("open")) {
            sidebar.classList.remove("open");
            return;
          }
        }

        if (isEditing) return;

        if (e.key === "/") {
          e.preventDefault();
          searchInput?.focus();
        }
        if (e.key === "n") {
          e.preventDefault();
          // If on tasks page, click the create button; otherwise navigate
          const createBtn = document.getElementById("create-task-btn");
          if (createBtn) {
            createBtn.click();
          } else {
            window.location.href = "/tasks";
          }
        }
        if (e.key === "k") {
          window.location.href = "/kanban";
        }
        if (e.key === "t") {
          window.location.href = "/table";
        }
        if (e.key === "d") {
          window.location.href = "/";
        }
        if (e.key === "?") {
          e.preventDefault();
          const modal = document.getElementById("shortcut-modal");
          if (modal) modal.classList.toggle("hidden");
        }

        // --- Focus Trap Logic ---
        const taskOverlay = document.getElementById("task-detail-overlay");
        const cpOverlay = document.getElementById("command-palette-overlay");
        const shortcutModal = document.getElementById("shortcut-modal");
        
        // Find which overlay is active (priority order)
        let activeOverlay: HTMLElement | null = null;
        if (shortcutModal && !shortcutModal.classList.contains("hidden")) activeOverlay = shortcutModal;
        else if (taskOverlay && !taskOverlay.classList.contains("hidden")) activeOverlay = taskOverlay;
        else if (cpOverlay && !cpOverlay.classList.contains("hidden")) activeOverlay = cpOverlay;

        if (activeOverlay && e.key === "Tab") {
          const focusableElements = activeOverlay.querySelectorAll('a[href], button, textarea, input, select, [tabindex]:not([tabindex="-1"])');
          const firstElement = focusableElements[0] as HTMLElement;
          const lastElement = focusableElements[focusableElements.length - 1] as HTMLElement;

          if (e.shiftKey) { // Shift + Tab
            if (document.activeElement === firstElement) {
              lastElement?.focus();
              e.preventDefault();
            }
          } else { // Tab
            if (document.activeElement === lastElement) {
              firstElement?.focus();
              e.preventDefault();
            }
          }
        }

        // Phase 20 (ADHD Optimization): T/S/E shortcuts for detail panel task_type
        if (taskOverlay && !taskOverlay.classList.contains("hidden")) {
          const typeSelect = document.getElementById("td-task-type") as HTMLSelectElement | null;
          if (typeSelect) {
            let newType = null;
            if (e.key.toLowerCase() === "t") newType = "task";
            if (e.key.toLowerCase() === "s") newType = "story";
            if (e.key.toLowerCase() === "e") newType = "epic";
            
            if (newType && typeSelect.value !== newType) {
              e.preventDefault();
              typeSelect.value = newType;
              typeSelect.dispatchEvent(new Event("change"));
            }
          }
        }
      });

      // Keyboard shortcut onboarding hint (show once)
      if (!localStorage.getItem("meitheal_shortcut_hint_dismissed")) {
        const hint = document.createElement("div");
        hint.className = "shortcut-hint";
        hint.textContent = "💡 Press ? for keyboard shortcuts";
        hint.setAttribute("role", "tooltip");
        hint.addEventListener("click", () => {
          hint.remove();
          localStorage.setItem("meitheal_shortcut_hint_dismissed", "1");
        });
        document.body.appendChild(hint);
        setTimeout(() => hint.remove(), 8000);
      }
      // Board switcher
      (async function initBoardSwitcher() {
        const select = document.getElementById(
          "board-select",
        ) as HTMLSelectElement | null;
        const addBtn = document.getElementById("add-board-btn");
        if (!select) return;

        // Load boards from API
        try {
          const res = await fetch("/api/boards");
          if (res.ok) {
            const data = await res.json();
            const boards = data.boards ?? [];
            select.innerHTML = "";
            // "All Boards" option first
            const allOpt = document.createElement("option");
            allOpt.value = "all";
            allOpt.textContent = "🗂 All Boards";
            select.appendChild(allOpt);
            boards.forEach((b: { id: string; title: string; icon: string }) => {
              const opt = document.createElement("option");
              opt.value = b.id;
              opt.textContent = `${b.icon} ${b.title}`;
              select.appendChild(opt);
            });
          }
        } catch {
          /* fallback to default option */
        }

        // Restore active board from localStorage
        const saved = localStorage.getItem("meitheal_active_board") ?? "all";
        if (select.querySelector(`option[value="${saved}"]`)) {
          select.value = saved;
        }

        // Expose active board globally for page scripts
        (window as any).__activeBoard = select.value;

        // Apply board filter to visible items
        function applyBoardFilter() {
          const board = select!.value;
          (window as any).__activeBoard = board;
          // Filter task items (tasks page)
          document.querySelectorAll(".task-item[data-board]").forEach((el) => {
            const item = el as HTMLElement;
            item.style.display =
              board === "all" || item.dataset.board === board ? "" : "none";
          });
          // Filter kanban cards
          document
            .querySelectorAll(".kanban-card[data-board]")
            .forEach((el) => {
              const card = el as HTMLElement;
              card.style.display =
                board === "all" || card.dataset.board === board ? "" : "none";
            });
          // Filter table rows
          document
            .querySelectorAll("#task-table tbody tr[data-board]")
            .forEach((el) => {
              const row = el as HTMLElement;
              row.style.display =
                board === "all" || row.dataset.board === board ? "" : "none";
            });
        }

        // Apply on load
        applyBoardFilter();

        // Switch board → save + filter
        select.addEventListener("change", () => {
          localStorage.setItem("meitheal_active_board", select.value);
          applyBoardFilter();
        });

        // Add new board
        addBtn?.addEventListener("click", async () => {
          const title = prompt("Board name:");
          if (!title?.trim()) return;
          try {
            const res = await fetch("/api/boards", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ title: title.trim() }),
            });
            if (res.ok) {
              const board = await res.json();
              localStorage.setItem("meitheal_active_board", board.id);
              window.location.reload();
            }
          } catch {
            /* ignore */
          }
        });
      })();
    </script>

    <script>
      import { askAIForTask } from "../domains/ai/ai-context-service";

      // === Task Detail Panel ===
      const tdOverlay = document.getElementById(
        "task-detail-overlay",
      ) as HTMLDivElement;
      let currentTaskId: string | null = null;

      function closeTD() {
        tdOverlay?.classList.add("hidden");
        currentTaskId = null;
        history.pushState(null, "", window.location.pathname);
      }

      async function openTaskDetail(taskId: string) {
        if (!tdOverlay) return;
        currentTaskId = taskId;
        tdOverlay.classList.remove("hidden");
        history.pushState(null, "", `#task-${taskId}`);

        try {
          // Populate status dropdown from lanes API
          const statusSelect = document.getElementById("td-status") as HTMLSelectElement;
          try {
            const lanesRes = await fetch("/api/lanes");
            if (lanesRes.ok) {
              const lanesData = await lanesRes.json();
              const lanes = lanesData.lanes || [];
              statusSelect.innerHTML = "";
              for (const lane of lanes) {
                // Add the main key as an option
                const opt = document.createElement("option");
                opt.value = lane.key;
                opt.textContent = `${lane.icon} ${lane.label}`;
                statusSelect.appendChild(opt);
              }
            }
          } catch { /* keep existing options */ }

          const res = await fetch(`/api/tasks/${taskId}`);
          if (!res.ok) return;
          const t = (await res.json()) as Record<string, unknown>;

          const parentEl = document.getElementById("td-parent") as HTMLAnchorElement | null;
          if (parentEl && t.parent_id) {
            parentEl.textContent = `↑ ${t.parent_title ?? t.parent_id}`;
            parentEl.href = `#task-${t.parent_id}`;
            parentEl.classList.remove("hidden");
            parentEl.onclick = (e) => {
              e.preventDefault();
              openTaskDetail(String(t.parent_id));
            };
          } else if (parentEl) {
            parentEl.classList.add("hidden");
          }

          (document.getElementById("td-id") as HTMLElement).textContent =
            `#${String(t.id).slice(0, 8)}`;
          (document.getElementById("td-title") as HTMLInputElement).value =
            String(t.title ?? "");
          // If the task's status isn't in the dropdown, add it as an option
          const taskStatus = String(t.status ?? "pending");
          if (!statusSelect.querySelector(`option[value="${taskStatus}"]`)) {
            const opt = document.createElement("option");
            opt.value = taskStatus;
            opt.textContent = taskStatus;
            statusSelect.appendChild(opt);
          }
          statusSelect.value = taskStatus;
          (
            document.getElementById("td-description") as HTMLTextAreaElement
          ).value = String(t.description ?? "");
          (document.getElementById("td-priority") as HTMLSelectElement).value =
            String(t.priority ?? 3);
          const progress = Number(t.progress ?? 0);
          (document.getElementById("td-progress") as HTMLInputElement).value =
            String(progress);
          (
            document.getElementById("td-progress-value") as HTMLElement
          ).textContent = `${progress}%`;
          (document.getElementById("td-color") as HTMLInputElement).value =
            String(t.color ?? "#10b981");
          (document.getElementById("td-due-date") as HTMLInputElement).value =
            String(t.due_date ?? "");
          (document.getElementById("td-start-date") as HTMLInputElement).value =
            String(t.start_date ?? "");
          (document.getElementById("td-end-date") as HTMLInputElement).value =
            String(t.end_date ?? "");
          (document.getElementById("td-board") as HTMLElement).textContent =
            String(t.board_id ?? "default");
          // Phase 20: Agile hierarchy type
          (document.getElementById("td-task-type") as HTMLSelectElement).value =
            String(t.task_type ?? "task");

          const isFav = Number(t.is_favorite ?? 0);
          (
            document.getElementById("td-toggle-favorite") as HTMLElement
          ).textContent = isFav ? "★ Favorited" : "⭐ Add to Favorites";
          const isDone =
            String(t.status) === "done" || String(t.status) === "complete";
          (
            document.getElementById("td-toggle-done") as HTMLElement
          ).textContent = isDone ? "↩ Mark as Undone" : "✓ Mark as Done";

          // Rice score
          try {
            const fp = JSON.parse(String(t.framework_payload ?? "{}"));
            const rice = document.getElementById("td-rice") as HTMLElement;
            if (fp.rice_score)
              rice.textContent = `RICE Score: ${fp.rice_score}`;
            else rice.textContent = "";
          } catch {
            /* skip */
          }

          // Labels (interactive chips)
          const labelsDiv = document.getElementById("td-labels") as HTMLElement;
          labelsDiv.innerHTML = "";
          currentLabels = [];
          try {
            const labels = JSON.parse(String(t.labels ?? "[]"));
            if (Array.isArray(labels)) {
              currentLabels = labels.map((l: string | { name: string }) =>
                typeof l === "string" ? l : l.name,
              );
              currentLabels.forEach((lbl) => addLabelChip(lbl));
            }
          } catch {
            /* skip */
          }

          // Custom fields (interactive rows)
          const cfDiv = document.getElementById(
            "td-custom-fields",
          ) as HTMLElement;
          cfDiv.innerHTML = "";
          try {
            const cf = JSON.parse(String(t.custom_fields ?? "{}")) as Record<
              string,
              string
            >;
            for (const [k, v] of Object.entries(cf)) {
              if (v !== null && v !== undefined) addCFRow(k, String(v));
            }
          } catch {
            /* skip */
          }

          // Timestamps
          const created = t.created_at
            ? new Date(Number(t.created_at)).toLocaleDateString()
            : "";
          const updated = t.updated_at
            ? new Date(Number(t.updated_at)).toLocaleDateString()
            : "";
          (document.getElementById("td-created") as HTMLElement).textContent =
            created ? `Created: ${created}` : "";
          (document.getElementById("td-updated") as HTMLElement).textContent =
            updated ? `Updated: ${updated}` : "";

          // Load comments
          loadComments(taskId);
        } catch (e) {
          console.error("Failed to load task detail", e);
        }
      }

      async function loadComments(taskId: string) {
        const container = document.getElementById("td-comments") as HTMLElement;
        try {
          const res = await fetch(`/api/tasks/${taskId}/comments`);
          const data = (await res.json()) as {
            comments: Array<{
              content: string;
              author: string;
              created_at: string;
            }>;
          };
          container.innerHTML = (data.comments || [])
            .map(
              (c) =>
                `<div class="bg-bg-card rounded-md p-3 border border-border">
              <div class="flex justify-between text-xs text-text-muted mb-1"><span>${c.author}</span><span>${new Date(c.created_at).toLocaleString()}</span></div>
              <div class="text-sm text-text-primary">${c.content}</div>
            </div>`,
            )
            .join("");
        } catch {
          container.innerHTML = "";
        }
      }

      async function saveTD(field: string, value: unknown) {
        if (!currentTaskId) return;
        await fetch(`/api/tasks/${currentTaskId}`, {
          method: "PUT",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ [field]: value }),
        });
      }

      // Auto-save on change
      document
        .getElementById("td-title")
        ?.addEventListener("blur", (e) =>
          saveTD("title", (e.target as HTMLInputElement).value),
        );
      document
        .getElementById("td-description")
        ?.addEventListener("blur", (e) =>
          saveTD("description", (e.target as HTMLTextAreaElement).value),
        );
      document.getElementById("td-status")?.addEventListener("change", (e) => {
        saveTD("status", (e.target as HTMLSelectElement).value);
        const isDone = (e.target as HTMLSelectElement).value === "done";
        (document.getElementById("td-toggle-done") as HTMLElement).textContent =
          isDone ? "↩ Mark as Undone" : "✓ Mark as Done";
      });
      document
        .getElementById("td-priority")
        ?.addEventListener("change", (e) =>
          saveTD("priority", Number((e.target as HTMLSelectElement).value)),
        );
      // Phase 20: task_type auto-save
      document
        .getElementById("td-task-type")
        ?.addEventListener("change", (e) => {
          saveTD("task_type", (e.target as HTMLSelectElement).value);
        });
      document.getElementById("td-progress")?.addEventListener("input", (e) => {
        const v = (e.target as HTMLInputElement).value;
        (
          document.getElementById("td-progress-value") as HTMLElement
        ).textContent = `${v}%`;
      });
      document
        .getElementById("td-progress")
        ?.addEventListener("change", (e) =>
          saveTD("progress", Number((e.target as HTMLInputElement).value)),
        );
      document
        .getElementById("td-color")
        ?.addEventListener("change", (e) =>
          saveTD("color", (e.target as HTMLInputElement).value),
        );
      document
        .getElementById("td-due-date")
        ?.addEventListener("change", (e) =>
          saveTD("due_date", (e.target as HTMLInputElement).value || null),
        );
      document
        .getElementById("td-start-date")
        ?.addEventListener("change", (e) =>
          saveTD("start_date", (e.target as HTMLInputElement).value || null),
        );
      document
        .getElementById("td-end-date")
        ?.addEventListener("change", (e) =>
          saveTD("end_date", (e.target as HTMLInputElement).value || null),
        );

      // ───── Labels interactive ─────
      let currentLabels: string[] = [];

      function addLabelChip(label: string) {
        const labelsDiv = document.getElementById("td-labels") as HTMLElement;
        const chip = document.createElement("span");
        chip.className = "label-chip";
        chip.style.cssText =
          "cursor:pointer;display:inline-flex;align-items:center;gap:4px;";
        chip.innerHTML = `${label}<span class="td-label-remove" style="font-size:14px;line-height:1;opacity:0.6;">&times;</span>`;
        chip
          .querySelector(".td-label-remove")!
          .addEventListener("click", () => {
            currentLabels = currentLabels.filter((l) => l !== label);
            chip.remove();
            saveTD("labels", JSON.stringify(currentLabels));
          });
        labelsDiv.appendChild(chip);
      }

      document
        .getElementById("td-label-input")
        ?.addEventListener("keydown", (e) => {
          if (e.key !== "Enter") return;
          e.preventDefault();
          const input = e.target as HTMLInputElement;
          const val = input.value.trim();
          if (!val || currentLabels.includes(val)) {
            input.value = "";
            return;
          }
          currentLabels.push(val);
          addLabelChip(val);
          input.value = "";
          saveTD("labels", JSON.stringify(currentLabels));
        });

      // ───── Custom Fields interactive ─────
      function getCFFromUI(): Record<string, string> {
        const result: Record<string, string> = {};
        document.querySelectorAll(".td-cf-row").forEach((row) => {
          const key = (
            row.querySelector(".td-cf-key") as HTMLInputElement
          )?.value.trim();
          const val = (
            row.querySelector(".td-cf-val") as HTMLInputElement
          )?.value.trim();
          if (key) result[key] = val;
        });
        return result;
      }

      function saveCF() {
        saveTD("custom_fields", JSON.stringify(getCFFromUI()));
      }

      function addCFRow(key: string, value: string) {
        const cfDiv = document.getElementById(
          "td-custom-fields",
        ) as HTMLElement;
        const row = document.createElement("div");
        row.className = "td-cf-row";
        row.style.cssText = "display:flex;gap:6px;align-items:center;";
        row.innerHTML = `
          <input type="text" class="form-input td-cf-key text-sm py-1" placeholder="Field name" value="${key.replace(/"/g, "&quot;")}" style="flex:1;" />
          <input type="text" class="form-input td-cf-val text-sm py-1" placeholder="Value" value="${value.replace(/"/g, "&quot;")}" style="flex:1;" />
          <button type="button" class="td-cf-remove" style="color:var(--danger);font-size:16px;cursor:pointer;background:none;border:none;padding:0 4px;">&times;</button>
        `;
        row.querySelector(".td-cf-key")!.addEventListener("blur", saveCF);
        row.querySelector(".td-cf-val")!.addEventListener("blur", saveCF);
        row.querySelector(".td-cf-remove")!.addEventListener("click", () => {
          row.remove();
          saveCF();
        });
        cfDiv.appendChild(row);
      }

      document.getElementById("td-add-cf")?.addEventListener("click", () => {
        addCFRow("", "");
      });

      // Toggle done
      document
        .getElementById("td-toggle-done")
        ?.addEventListener("click", () => {
          const statusEl = document.getElementById(
            "td-status",
          ) as HTMLSelectElement;
          const newStatus = statusEl.value === "done" ? "pending" : "done";
          statusEl.value = newStatus;
          saveTD("status", newStatus);
          (
            document.getElementById("td-toggle-done") as HTMLElement
          ).textContent =
            newStatus === "done" ? "↩ Mark as Undone" : "✓ Mark as Done";
        });

      // Toggle favorite
      document
        .getElementById("td-toggle-favorite")
        ?.addEventListener("click", async () => {
          if (!currentTaskId) return;
          const btn = document.getElementById(
            "td-toggle-favorite",
          ) as HTMLElement;
          const isFav = btn.textContent?.startsWith("★");
          await saveTD("is_favorite", isFav ? 0 : 1);
          btn.textContent = isFav ? "⭐ Add to Favorites" : "★ Favorited";
        });

      // Ask AI
      document
        .getElementById("td-ask-ai")
        ?.addEventListener("click", async () => {
          if (!currentTaskId) return;
          try {
            const btn = document.getElementById("td-ask-ai") as HTMLElement;
            const originalText = btn.innerHTML;
            btn.innerHTML = "⏳ Generating...";
            await askAIForTask(currentTaskId);
            btn.innerHTML = "✅ Copied!";
            setTimeout(() => (btn.innerHTML = originalText), 2000);
          } catch (err) {
            console.error("AI Context error:", err);
            alert("Failed to generate AI context.");
          }
        });

      // Delete
      document
        .getElementById("td-delete")
        ?.addEventListener("click", async () => {
          if (!currentTaskId || !confirm("Delete this task?")) return;
          await fetch(`/api/tasks/${currentTaskId}`, { method: "DELETE" });
          closeTD();
          window.location.reload();
        });

      // Add comment
      document
        .getElementById("td-comment-submit")
        ?.addEventListener("click", async () => {
          const input = document.getElementById(
            "td-comment-input",
          ) as HTMLInputElement;
          if (!input.value.trim() || !currentTaskId) return;
          await fetch(`/api/tasks/${currentTaskId}/comments`, {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ content: input.value.trim() }),
          });
          input.value = "";
          loadComments(currentTaskId);
        });

      // Close
      document.getElementById("td-close")?.addEventListener("click", closeTD);
      tdOverlay?.addEventListener("click", (e) => {
        if (e.target === tdOverlay) closeTD();
      });

      // Hash navigation
      function checkHash() {
        const hash = window.location.hash;
        if (hash.startsWith("#task-")) {
          openTaskDetail(hash.replace("#task-", ""));
        }
      }
      window.addEventListener("hashchange", checkHash);
      checkHash();

      // Delegated click → open task detail for any task element
      document.body.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        const taskEl = target.closest(
          ".task-item, .kanban-card, tr[data-id], [data-task-id]",
        ) as HTMLElement | null;
        if (!taskEl) return;
        // Don't intercept action buttons
        if (target.closest("button, a, .task-actions, .action-btn")) return;
        const taskId = taskEl.dataset.id || taskEl.dataset.taskId;
        if (taskId) {
          e.preventDefault();
          e.stopPropagation();
          // Clean up search dropdown if opened from search results
          if (taskEl.closest("#search-results")) {
            const sr = document.getElementById("search-results");
            const si = document.getElementById("global-search") as HTMLInputElement;
            if (sr) sr.style.display = "none";
            if (si) si.value = "";
          }
          openTaskDetail(taskId);
        }
      });
      // Global access
      (window as unknown as Record<string, unknown>).openTaskDetail =
        openTaskDetail;

      // === Command Palette ===
      const cpOverlay = document.getElementById(
        "command-palette-overlay",
      ) as HTMLDivElement;
      const cpSearch = document.getElementById("cp-search") as HTMLInputElement;
      const cpTasksSection = document.getElementById(
        "cp-tasks-section",
      ) as HTMLDivElement;
      const cpTasks = document.getElementById("cp-tasks") as HTMLDivElement;
      let cpAllTasks: Array<{ id: string; title: string }> = [];

      function openCP() {
        cpOverlay?.classList.remove("hidden");
        cpSearch?.focus();
        // Load tasks for search
        fetch("/api/tasks?limit=200")
          .then((r) => r.json())
          .then((d: { tasks: Array<{ id: string; title: string }> }) => {
            cpAllTasks = d.tasks || [];
          })
          .catch(() => {});
      }

      function closeCP() {
        cpOverlay?.classList.add("hidden");
        if (cpSearch) cpSearch.value = "";
        cpTasksSection?.classList.add("hidden");
      }

      // Ctrl+K / Cmd+K
      document.addEventListener("keydown", (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key === "k") {
          e.preventDefault();
          if (cpOverlay?.classList.contains("hidden")) openCP();
          else closeCP();
        }
        if (e.key === "Escape") {
          if (!tdOverlay?.classList.contains("hidden")) closeTD();
          if (!cpOverlay?.classList.contains("hidden")) closeCP();
        }
      });

      cpOverlay?.addEventListener("click", (e) => {
        if (e.target === cpOverlay) closeCP();
      });

      // Search
      cpSearch?.addEventListener("input", () => {
        const q = cpSearch.value.toLowerCase().trim();
        if (!q) {
          cpTasksSection?.classList.add("hidden");
          return;
        }

        const matches = cpAllTasks
          .filter((t) => t.title.toLowerCase().includes(q))
          .slice(0, 10);
        if (matches.length > 0) {
          cpTasksSection?.classList.remove("hidden");
          cpTasks.innerHTML = matches
            .map(
              (t) =>
                `<div class="cp-item px-4 py-2.5 cursor-pointer hover:bg-bg-hover text-sm text-text-primary" data-task-id="${t.id}">${t.title}</div>`,
            )
            .join("");
        } else {
          cpTasksSection?.classList.add("hidden");
        }
      });

      // Click handlers
      document.getElementById("cp-results")?.addEventListener("click", (e) => {
        const target = (e.target as HTMLElement).closest(
          ".cp-item",
        ) as HTMLElement | null;
        if (!target) return;
        const action = target.dataset.action;
        const taskId = target.dataset.taskId;

        closeCP();

        if (action === "new-task") {
          // Open create modal if on tasks page, or navigate
          const createBtn = document.querySelector(
            "[data-action='create-task']",
          ) as HTMLElement;
          if (createBtn) createBtn.click();
          else window.location.href = "/tasks";
        } else if (action === "new-board") {
          const boardBtn = document.querySelector(
            ".board-add-btn",
          ) as HTMLElement;
          if (boardBtn) boardBtn.click();
        } else if (taskId) {
          openTaskDetail(taskId);
        }
      });
    </script>

    <!-- Keyboard Shortcuts Modal -->
    <div
      id="shortcut-modal"
      class="hidden"
      style="position:fixed;inset:0;z-index:70;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.6);"
      onclick="this.classList.add('hidden')"
    >
      <div
        style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:24px 32px;max-width:360px;width:90%;box-shadow:0 8px 32px rgba(0,0,0,0.4);"
        onclick="arguments[0].stopPropagation()"
      >
        <h3 style="margin:0 0 16px;font-size:16px;color:var(--accent);">
          ⌨ Keyboard Shortcuts
        </h3>
        <div
          style="display:grid;grid-template-columns:auto 1fr;gap:8px 16px;font-size:13px;"
        >
          <kbd
            style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:4px;padding:2px 8px;font-family:monospace;font-size:12px;"
            >/</kbd
          ><span>Focus search</span>
          <kbd
            style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:4px;padding:2px 8px;font-family:monospace;font-size:12px;"
            >n</kbd
          ><span>New task</span>
          <kbd
            style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:4px;padding:2px 8px;font-family:monospace;font-size:12px;"
            >d</kbd
          ><span>Dashboard</span>
          <kbd
            style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:4px;padding:2px 8px;font-family:monospace;font-size:12px;"
            >k</kbd
          ><span>Kanban board</span>
          <kbd
            style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:4px;padding:2px 8px;font-family:monospace;font-size:12px;"
            >t</kbd
          ><span>Table view</span>
          <kbd
            style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:4px;padding:2px 8px;font-family:monospace;font-size:12px;"
            >⌘K</kbd
          ><span>Command palette</span>
          <kbd
            style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:4px;padding:2px 8px;font-family:monospace;font-size:12px;"
            >?</kbd
          ><span>This help</span>
          <kbd
            style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:4px;padding:2px 8px;font-family:monospace;font-size:12px;"
            >Esc</kbd
          ><span>Close modal / blur</span>
        </div>
      </div>
    </div>
  </body>
</html>
