    <script>
      import { createFocusTrap } from "@lib/focus-trap";
      const shortcutOverlay = document.getElementById("shortcut-modal");
      const shortcutTrap = shortcutOverlay ? createFocusTrap(shortcutOverlay) : null;
      function openShortcutModal() {
        shortcutOverlay?.classList.remove("hidden");
        shortcutTrap?.activate();
      }
      function closeShortcutModal() {
        shortcutTrap?.deactivate();
        shortcutOverlay?.classList.add("hidden");
      }
      shortcutOverlay?.addEventListener("click", (e) => {
        if (e.target === shortcutOverlay) closeShortcutModal();
      });
      document.getElementById("shortcut-modal-close")?.addEventListener("click", () => {
        closeShortcutModal();
      });
    </script>

    <!-- Graceful fallback when JavaScript is disabled -->
    <noscript>
      <div style="position:fixed;inset:0;z-index:9999;background:var(--bg-primary,#0f0f23);color:var(--text-primary,#e2e8f0);display:flex;align-items:center;justify-content:center;padding:2rem;text-align:center;">
        <div>
          <h1 style="font-size:1.5rem;margin-bottom:1rem;">JavaScript Required</h1>
          <p>Meitheal requires JavaScript to function. Please enable JavaScript in your browser settings and reload this page.</p>
        </div>
      </div>
    </noscript>
  </body>
</html>
