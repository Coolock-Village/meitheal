---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Meitheal — Settings">
  <span slot="page-title">Settings</span>

  <div class="settings-grid">
    <!-- HA Connection -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">☘ Home Assistant</div>
          <div class="card-subtitle">Connection and integration settings</div>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="ha-url">HA URL</label>
        <input
          type="url"
          class="form-input"
          id="ha-url"
          placeholder="http://homeassistant.local:8123"
        />
      </div>
      <div class="form-group">
        <label class="form-label" for="ha-token">Long-Lived Access Token</label>
        <input
          type="password"
          class="form-input"
          id="ha-token"
          placeholder="••••••••"
        />
        <small style="color: var(--text-muted); font-size: 12px;">
          Generate in HA → Profile → Long-Lived Access Tokens
        </small>
      </div>
      <div class="form-group">
        <label class="form-label" for="calendar-entity">Calendar Entity</label>
        <input
          type="text"
          class="form-input"
          id="calendar-entity"
          placeholder="calendar.meitheal_tasks"
        />
      </div>
      <div style="display: flex; gap: 8px;">
        <button class="btn btn-primary" id="test-connection"
          >Test Connection</button
        >
        <button class="btn btn-ghost" id="save-ha">Save</button>
      </div>
      <div id="ha-status" style="margin-top: 12px;"></div>
    </div>

    <!-- Custom Fields -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">📋 Custom Fields</div>
          <div class="card-subtitle">Define custom fields for tasks</div>
        </div>
        <button class="btn btn-ghost" id="add-custom-field">+ Add Field</button>
      </div>
      <div id="custom-fields-list">
        <div class="custom-field-row">
          <input
            type="text"
            class="form-input"
            placeholder="Field name"
            value="sprint"
            disabled
          />
          <select class="form-select" disabled>
            <option value="text" selected>Text</option>
            <option value="number">Number</option>
            <option value="select">Select</option>
            <option value="date">Date</option>
            <option value="checkbox">Checkbox</option>
          </select>
          <span style="color: var(--text-muted); font-size: 12px;"
            >Built-in</span
          >
        </div>
        <div class="custom-field-row">
          <input
            type="text"
            class="form-input"
            placeholder="Field name"
            value="story_points"
            disabled
          />
          <select class="form-select" disabled>
            <option value="number" selected>Number</option>
          </select>
          <span style="color: var(--text-muted); font-size: 12px;"
            >Built-in</span
          >
        </div>
      </div>
    </div>

    <!-- Framework Scoring -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">📊 Framework Scoring</div>
          <div class="card-subtitle">Configure task scoring frameworks</div>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Active Framework</label>
        <select class="form-select" id="scoring-framework">
          <option value="rice" selected
            >RICE (Reach × Impact × Confidence / Effort)</option
          >
          <option value="drice">DRICE (Dependencies + RICE)</option>
          <option value="heart"
            >HEART (Happiness, Engagement, Adoption, Retention, Task Success)</option
          >
          <option value="kcs">KCS (Knowledge-Centered Support)</option>
          <option value="custom">Custom</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Score Display</label>
        <select class="form-select" id="score-display">
          <option value="badge">Badge (high/med/low)</option>
          <option value="number" selected>Numeric score</option>
          <option value="both">Both</option>
        </select>
      </div>
    </div>

    <!-- Integrations -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">🔗 Integrations</div>
          <div class="card-subtitle">External service connections</div>
        </div>
      </div>
      <div class="integration-row">
        <span>📅 Calendar Sync</span>
        <span class="badge badge-active" id="cal-status">Connected</span>
      </div>
      <div class="integration-row">
        <span>🛒 Grocy</span>
        <span class="badge badge-pending">Not configured</span>
      </div>
      <div class="integration-row">
        <span>⚙ n8n / Node-RED</span>
        <span class="badge badge-pending">Not configured</span>
      </div>
      <div class="integration-row">
        <span>🔔 Webhooks</span>
        <span class="badge badge-active">Active</span>
      </div>
    </div>

    <!-- Keyboard Shortcuts -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">⌨ Keyboard Shortcuts</div>
          <div class="card-subtitle">Navigate quickly through the app</div>
        </div>
      </div>
      <div class="shortcut-grid">
        <div class="shortcut-row"><kbd>n</kbd><span>New task</span></div>
        <div class="shortcut-row"><kbd>/</kbd><span>Search</span></div>
        <div class="shortcut-row"><kbd>l</kbd><span>List view</span></div>
        <div class="shortcut-row"><kbd>k</kbd><span>Kanban view</span></div>
        <div class="shortcut-row"><kbd>t</kbd><span>Table view</span></div>
        <div class="shortcut-row"><kbd>Esc</kbd><span>Close modal</span></div>
        <div class="shortcut-row"><kbd>?</kbd><span>Show shortcuts</span></div>
      </div>
    </div>

    <!-- About -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">ℹ About Meitheal</div>
          <div class="card-subtitle">The cooperative task and life engine</div>
        </div>
      </div>
      <div
        style="font-size: 13px; color: var(--text-secondary); line-height: 1.6;"
      >
        <p>
          <strong>Meitheal</strong> (IPA: /ˈmɛhəl/) — Irish for "cooperative work
          party."
        </p>
        <p>
          A Home Assistant-native, Astro-first task and life management engine.
        </p>
        <p>
          Version: <code>0.1.0</code> · Phase 6: Functional UI & Feature Parity
        </p>
      </div>
    </div>
  </div>

  <div id="toast-container" class="toast-container"></div>

  <script>
    function showToast(message: string, type: "success" | "error" = "success") {
      const container = document.getElementById("toast-container");
      if (!container) return;
      const toast = document.createElement("div");
      toast.className = `toast ${type}`;
      toast.textContent = message;
      container.appendChild(toast);
      setTimeout(() => toast.remove(), 3000);
    }

    // Test HA connection
    document
      .getElementById("test-connection")
      ?.addEventListener("click", async () => {
        const statusEl = document.getElementById("ha-status");
        if (statusEl)
          statusEl.innerHTML =
            '<span style="color: var(--accent);">Testing...</span>';
        try {
          const res = await fetch("/api/health");
          const data = await res.json();
          if (statusEl) {
            statusEl.innerHTML =
              data.status === "ok"
                ? '<span style="color: var(--accent);">✅ Connected — API healthy</span>'
                : '<span style="color: var(--danger);">⚠ API returned non-ok status</span>';
          }
        } catch {
          if (statusEl)
            statusEl.innerHTML =
              '<span style="color: var(--danger);">❌ Connection failed</span>';
        }
      });

    // Add custom field
    document
      .getElementById("add-custom-field")
      ?.addEventListener("click", () => {
        const list = document.getElementById("custom-fields-list");
        if (!list) return;
        const row = document.createElement("div");
        row.className = "custom-field-row";
        row.innerHTML = `
        <input type="text" class="form-input" placeholder="Field name" />
        <select class="form-select">
          <option value="text">Text</option>
          <option value="number">Number</option>
          <option value="select">Select</option>
          <option value="date">Date</option>
          <option value="checkbox">Checkbox</option>
        </select>
        <button class="btn btn-ghost" style="padding: 4px 8px; color: var(--danger);" onclick="this.closest('.custom-field-row')?.remove()">×</button>
      `;
        list.appendChild(row);
      });
  </script>
</Layout>

<style>
  .settings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 16px;
  }
  .custom-field-row {
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
  }
  .custom-field-row:last-child {
    border-bottom: none;
  }
  .integration-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
  }
  .integration-row:last-child {
    border-bottom: none;
  }
  .shortcut-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .shortcut-row {
    display: flex;
    gap: 12px;
    align-items: center;
    font-size: 13px;
  }
  kbd {
    background: var(--bg-hover);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 2px 8px;
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--text-primary);
  }
  .badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 500;
  }
  .badge-active {
    background: rgba(16, 185, 129, 0.15);
    color: var(--accent);
  }
  .badge-pending {
    background: rgba(107, 114, 128, 0.15);
    color: var(--text-muted);
  }
  @media (max-width: 768px) {
    .settings-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
