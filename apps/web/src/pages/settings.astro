---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Meitheal — Settings">
  <span slot="page-title">Settings</span>

  <div class="settings-grid">
    <!-- HA Connection -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">☘ Home Assistant</div>
          <div class="card-subtitle">Connection and integration settings</div>
        </div>
      </div>
      <form id="ha-form">
        <div class="form-group">
          <label class="form-label" for="ha-url">HA URL</label>
          <input
            type="url"
            class="form-input"
            id="ha-url"
            placeholder="http://homeassistant.local:8123"
            pattern="https?://.*"
            required
          />
        </div>
        <div class="form-group">
          <label class="form-label" for="ha-token">Long-Lived Access Token</label>
          <input
            type="password"
            class="form-input"
            id="ha-token"
            placeholder="••••••••"
          />
          <small style="color: var(--text-muted); font-size: 12px;">
            Generate in HA → Profile → Long-Lived Access Tokens
          </small>
        </div>
        <div class="form-group">
          <label class="form-label" for="calendar-entity">Calendar Entity</label>
          <input
            type="text"
            class="form-input"
            id="calendar-entity"
            placeholder="calendar.meitheal_tasks"
          />
        </div>
        <div style="display: flex; gap: 8px;">
          <button type="button" class="btn btn-ghost" id="test-connection"
            >Test Connection</button
          >
          <button type="submit" class="btn btn-primary" id="save-ha">💾 Save</button>
        </div>
        <div id="ha-status" style="margin-top: 12px;"></div>
      </form>
    </div>

    <!-- Custom Fields -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">📋 Custom Fields</div>
          <div class="card-subtitle">Define custom fields for tasks</div>
        </div>
        <button class="btn btn-ghost" id="add-custom-field">+ Add Field</button>
      </div>
      <div id="custom-fields-list">
        <div class="custom-field-row">
          <input
            type="text"
            class="form-input"
            placeholder="Field name"
            value="sprint"
            disabled
          />
          <select class="form-select" disabled>
            <option value="text" selected>Text</option>
            <option value="number">Number</option>
            <option value="select">Select</option>
            <option value="date">Date</option>
            <option value="checkbox">Checkbox</option>
          </select>
          <span style="color: var(--text-muted); font-size: 12px;"
            >Built-in</span
          >
        </div>
        <div class="custom-field-row">
          <input
            type="text"
            class="form-input"
            placeholder="Field name"
            value="story_points"
            disabled
          />
          <select class="form-select" disabled>
            <option value="number" selected>Number</option>
          </select>
          <span style="color: var(--text-muted); font-size: 12px;"
            >Built-in</span
          >
        </div>
      </div>
    </div>

    <!-- Framework Scoring — Configurable enable/disable -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">📊 Framework Scoring</div>
          <div class="card-subtitle">
            Enable/disable and configure scoring frameworks
          </div>
        </div>
      </div>
      <div id="framework-list">
        <div class="framework-row" data-framework="rice">
          <div class="framework-info">
            <label class="toggle-label">
              <input
                type="checkbox"
                class="framework-toggle"
                data-fw="rice"
                checked
              />
              <span class="toggle-slider"></span>
            </label>
            <div>
              <strong>RICE</strong>
              <div class="framework-desc">
                Reach × Impact × Confidence / Effort
              </div>
            </div>
          </div>
        </div>
        <div class="framework-row" data-framework="drice">
          <div class="framework-info">
            <label class="toggle-label">
              <input type="checkbox" class="framework-toggle" data-fw="drice" />
              <span class="toggle-slider"></span>
            </label>
            <div>
              <strong>DRICE</strong>
              <div class="framework-desc">Dependencies + RICE</div>
            </div>
          </div>
        </div>
        <div class="framework-row" data-framework="heart">
          <div class="framework-info">
            <label class="toggle-label">
              <input type="checkbox" class="framework-toggle" data-fw="heart" />
              <span class="toggle-slider"></span>
            </label>
            <div>
              <strong>HEART</strong>
              <div class="framework-desc">
                Happiness, Engagement, Adoption, Retention, Task Success
              </div>
            </div>
          </div>
        </div>
        <div class="framework-row" data-framework="kcs">
          <div class="framework-info">
            <label class="toggle-label">
              <input type="checkbox" class="framework-toggle" data-fw="kcs" />
              <span class="toggle-slider"></span>
            </label>
            <div>
              <strong>KCS</strong>
              <div class="framework-desc">Knowledge-Centered Support</div>
            </div>
          </div>
        </div>
        <div class="framework-row" data-framework="ddd">
          <div class="framework-info">
            <label class="toggle-label">
              <input type="checkbox" class="framework-toggle" data-fw="ddd" />
              <span class="toggle-slider"></span>
            </label>
            <div>
              <strong>DDD</strong>
              <div class="framework-desc">Domain-Driven Design scoring</div>
            </div>
          </div>
        </div>
        <div class="framework-row" data-framework="custom">
          <div class="framework-info">
            <label class="toggle-label">
              <input
                type="checkbox"
                class="framework-toggle"
                data-fw="custom"
              />
              <span class="toggle-slider"></span>
            </label>
            <div>
              <strong>Custom</strong>
              <div class="framework-desc">User-defined scoring fields</div>
            </div>
          </div>
        </div>
      </div>
      <div class="form-group" style="margin-top: 12px;">
        <label class="form-label">Active Framework</label>
        <select class="form-select" id="scoring-framework">
          <option value="rice" selected>RICE</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Score Display</label>
        <select class="form-select" id="score-display">
          <option value="badge">Badge (high/med/low)</option>
          <option value="number" selected>Numeric score</option>
          <option value="both">Both</option>
        </select>
      </div>
    </div>

    <!-- Integrations — Comprehensive Configuration -->
    <div class="card" style="grid-column: 1 / -1;">
      <div class="card-header">
        <div>
          <div class="card-title">🔗 Integrations</div>
          <div class="card-subtitle">Connect Meitheal to external services for automation, sync, and enhanced workflows</div>
        </div>
      </div>

      <!-- Calendar Sync -->
      <div class="integration-section">
        <div class="integration-header">
          <div>
            <strong>📅 Calendar Sync</strong>
            <div class="integration-desc">Sync tasks with due dates to your Home Assistant or CalDAV calendar. Tasks appear as events with priority color coding.</div>
          </div>
          <span class="badge badge-active" id="cal-status">Connected</span>
        </div>
        <div class="integration-config">
          <div class="form-group">
            <label class="form-label" for="cal-entity">Calendar Entity</label>
            <input type="text" class="form-input" id="cal-entity" placeholder="calendar.meitheal_tasks" />
            <small style="color: var(--text-muted); font-size: 11px;">The HA calendar entity to sync tasks to. Find it in HA → Developer Tools → States → search "calendar."</small>
          </div>
          <div class="form-group">
            <label class="form-label" for="caldav-url">CalDAV URL (optional)</label>
            <input type="url" class="form-input" id="caldav-url" placeholder="https://your-server.com/dav/calendars/" />
            <small style="color: var(--text-muted); font-size: 11px;">For direct CalDAV sync (Nextcloud, Radicale, etc). Leave blank to use HA calendar only.</small>
          </div>
          <div style="display: flex; gap: 8px; align-items: center;">
            <button class="btn btn-primary" id="save-cal" style="font-size: 13px;">Save Calendar Settings</button>
            <button class="btn btn-ghost" id="test-cal" style="font-size: 13px;">Test Sync</button>
          </div>
        </div>
      </div>

      <!-- Grocy -->
      <div class="integration-section">
        <div class="integration-header">
          <div>
            <strong>🛒 Grocy</strong>
            <div class="integration-desc">Connect to Grocy for household inventory and chore management. Meitheal can import Grocy tasks and expose its own tasks back.</div>
          </div>
          <span class="badge badge-pending" id="grocy-status">Not configured</span>
        </div>
        <div class="integration-config">
          <div class="form-group">
            <label class="form-label" for="grocy-url">Grocy URL</label>
            <input type="url" class="form-input" id="grocy-url" placeholder="http://homeassistant.local:9192" />
            <small style="color: var(--text-muted); font-size: 11px;">The URL of your Grocy instance. Often runs as a HA add-on on port 9192.</small>
          </div>
          <div class="form-group">
            <label class="form-label" for="grocy-key">API Key</label>
            <input type="password" class="form-input" id="grocy-key" placeholder="••••••••" />
            <small style="color: var(--text-muted); font-size: 11px;">Generate in Grocy → Settings → API Keys → Add.</small>
          </div>
          <div class="form-group">
            <label class="form-label" for="grocy-sync-mode">Sync Mode</label>
            <select class="form-select" id="grocy-sync-mode">
              <option value="import">Import Grocy → Meitheal</option>
              <option value="export">Export Meitheal → Grocy</option>
              <option value="bidirectional">Bidirectional sync</option>
            </select>
          </div>
          <button class="btn btn-primary" id="save-grocy" style="font-size: 13px;">Save Grocy Settings</button>
        </div>
      </div>

      <!-- n8n / Node-RED -->
      <div class="integration-section">
        <div class="integration-header">
          <div>
            <strong>⚙ n8n / Node-RED</strong>
            <div class="integration-desc">Trigger automation workflows when tasks are created, updated, or completed. Create complex pipelines that react to task events.</div>
          </div>
          <span class="badge badge-pending" id="n8n-status">Not configured</span>
        </div>
        <div class="integration-config">
          <div class="form-group">
            <label class="form-label" for="n8n-webhook-url">Webhook URL</label>
            <input type="url" class="form-input" id="n8n-webhook-url" placeholder="https://n8n.example.com/webhook/meitheal" />
            <small style="color: var(--text-muted); font-size: 11px;">The webhook URL from your n8n/Node-RED flow. Meitheal will POST task events here.</small>
          </div>
          <div class="form-group">
            <label class="form-label">Trigger Events</label>
            <div style="display: flex; gap: 12px; flex-wrap: wrap;">
              <label style="font-size: 13px; display: flex; gap: 4px; align-items: center;">
                <input type="checkbox" class="n8n-event" value="task.created" checked /> Created
              </label>
              <label style="font-size: 13px; display: flex; gap: 4px; align-items: center;">
                <input type="checkbox" class="n8n-event" value="task.updated" checked /> Updated
              </label>
              <label style="font-size: 13px; display: flex; gap: 4px; align-items: center;">
                <input type="checkbox" class="n8n-event" value="task.completed" checked /> Completed
              </label>
              <label style="font-size: 13px; display: flex; gap: 4px; align-items: center;">
                <input type="checkbox" class="n8n-event" value="task.deleted" /> Deleted
              </label>
            </div>
          </div>
          <button class="btn btn-primary" id="save-n8n" style="font-size: 13px;">Save n8n Settings</button>
        </div>
      </div>

      <!-- Webhooks -->
      <div class="integration-section">
        <div class="integration-header">
          <div>
            <strong>🔔 Webhooks</strong>
            <div class="integration-desc">Generic outgoing webhooks for any service. Each event sends a JSON payload with the full task object and event type.</div>
          </div>
          <span class="badge badge-active" id="webhook-status">Active</span>
        </div>
        <div class="integration-config">
          <div class="form-group">
            <label class="form-label" for="webhook-endpoint">Endpoint URL</label>
            <input type="url" class="form-input" id="webhook-endpoint" placeholder="https://your-service.com/webhook" />
          </div>
          <div class="form-group">
            <label class="form-label" for="webhook-secret">Signing Secret (optional)</label>
            <input type="password" class="form-input" id="webhook-secret" placeholder="••••••••" />
            <small style="color: var(--text-muted); font-size: 11px;">HMAC-SHA256 secret used to sign webhook payloads. Verify with the X-Webhook-Signature header.</small>
          </div>
          <div class="form-group">
            <label class="form-label">Payload Format</label>
            <select class="form-select" id="webhook-format">
              <option value="json" selected>JSON</option>
              <option value="form">Form-encoded</option>
            </select>
          </div>
          <div style="display: flex; gap: 8px;">
            <button class="btn btn-primary" id="save-webhook" style="font-size: 13px;">Save Webhook</button>
            <button class="btn btn-ghost" id="test-webhook" style="font-size: 13px;">Send Test</button>
          </div>
        </div>
      </div>

      <!-- AI Provider -->
      <div class="integration-section">
        <div class="integration-header">
          <div>
            <strong>🤖 AI Provider</strong>
            <div class="integration-desc">Configure which AI service the "Ask AI" button sends tasks to. Generates a pre-filled prompt with task context for analysis.</div>
          </div>
          <span class="badge badge-active">ChatGPT</span>
        </div>
        <div class="integration-config">
          <div class="form-group">
            <label class="form-label" for="ai-provider">Provider</label>
            <select class="form-select" id="ai-provider">
              <option value="chatgpt" selected>ChatGPT</option>
              <option value="claude">Claude</option>
              <option value="gemini">Google Gemini</option>
              <option value="ollama">Ollama (local)</option>
              <option value="custom">Custom URL</option>
            </select>
          </div>
          <div class="form-group" id="ai-custom-url-group" style="display: none;">
            <label class="form-label" for="ai-custom-url">Custom API URL</label>
            <input type="url" class="form-input" id="ai-custom-url" placeholder="http://localhost:11434/api/chat" />
          </div>
          <button class="btn btn-primary" id="save-ai" style="font-size: 13px;">Save AI Settings</button>
        </div>
      </div>
    </div>

    <!-- Keyboard Shortcuts -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">⌨ Keyboard Shortcuts</div>
          <div class="card-subtitle">Navigate quickly through the app</div>
        </div>
      </div>
      <div class="shortcut-grid">
        <div class="shortcut-row"><kbd>n</kbd><span>New task</span></div>
        <div class="shortcut-row"><kbd>/</kbd><span>Search</span></div>
        <div class="shortcut-row"><kbd>l</kbd><span>List view</span></div>
        <div class="shortcut-row"><kbd>k</kbd><span>Kanban view</span></div>
        <div class="shortcut-row"><kbd>t</kbd><span>Table view</span></div>
        <div class="shortcut-row"><kbd>Esc</kbd><span>Close modal</span></div>
        <div class="shortcut-row"><kbd>?</kbd><span>Show shortcuts</span></div>
      </div>
    </div>

    <!-- Data Portability -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">💾 Data Portability</div>
          <div class="card-subtitle">Meitheal is local-first. You own your data.</div>
        </div>
      </div>
      <div class="form-group" style="margin-top: 12px;">
        <label class="form-label" style="margin-bottom: 8px;">Export Tasks</label>
        <div style="display: flex; gap: 8px;">
          <a href="#" class="btn btn-primary" id="export-json-btn" style="flex: 1; text-align: center; text-decoration: none;">📥 Download JSON</a>
          <a href="/api/export/tasks.csv" download class="btn btn-secondary" id="export-csv-btn" style="flex: 1; text-align: center; text-decoration: none;">📊 Download CSV</a>
          <a href="/api/export/database.sqlite" download class="btn btn-secondary" id="export-db-btn" style="flex: 1; text-align: center; text-decoration: none;">🗄️ Raw DB</a>
        </div>
        <small style="color: var(--text-muted); font-size: 11px; display: block; margin-top: 6px;">
          Export your tasks to JSON/CSV, or download the entire raw SQLite database file for full local-first data sovereignty.
        </small>
      </div>

      <div class="form-group" style="margin-top: 16px; border-top: 1px solid var(--border-color); padding-top: 16px;">
        <label class="form-label" style="margin-bottom: 8px;">Settings Configuration</label>
        <div style="display: flex; gap: 8px;">
          <a href="/api/export/settings.json" download class="btn btn-secondary" id="export-settings-btn" style="flex: 1; text-align: center; text-decoration: none;">⚙️ Export Config</a>
          <label class="btn btn-secondary" style="flex: 1; text-align: center; cursor: pointer; margin: 0; padding: 6px 16px; display: inline-flex; justify-content: center; align-items: center;">
            🔄 Import Config
            <input type="file" id="import-settings-input" accept=".json" style="display: none;" />
          </label>
        </div>
        <small style="color: var(--text-muted); font-size: 11px; display: block; margin-top: 6px;">
          Backup or restore your tokens, shortcuts, UI layouts, and active integrations. Restoring will trigger a page reload.
        </small>
      </div>
    </div>

    <!-- About -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">ℹ About Meitheal</div>
          <div class="card-subtitle">The cooperative task and life engine</div>
        </div>
      </div>
      <div
        style="font-size: 13px; color: var(--text-secondary); line-height: 1.6;"
      >
        <p>
          <strong>Meitheal</strong> (IPA: /ˈmɛhəl/) — Irish for "cooperative work
          party."
        </p>
        <p>
          A Home Assistant-native, Astro-first task and life management engine.
        </p>
        <p>
          Version: <code>0.2.0</code> · Phase 26: UX Polish
        </p>
      </div>
    </div>
  </div>

  <div id="toast-container" class="toast-container"></div>

  <script>
    import { exportLocalDataAsJson } from "../domains/offline/export-service";

    // Export Tasks Binding
    document.getElementById("export-json-btn")?.addEventListener("click", async (e) => {
      e.preventDefault();
      try {
        await exportLocalDataAsJson();
        showToast("Local data and attachments exported successfully.");
      } catch (err) {
        console.error("Failed to export JSON:", err);
        showToast("Failed to generate local export.", "error");
      }
    });

    // Import Config Binding
    const importInput = document.getElementById("import-settings-input") as HTMLInputElement;
    if (importInput) {
      importInput.addEventListener("change", async (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (!file) return;

        try {
          const text = await file.text();
          const payload = JSON.parse(text);

          const response = await fetch("/api/import/settings", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });

          if (!response.ok) {
            throw new Error(await response.text());
          }

          showToast("Settings restored successfully. Reloading...");
          setTimeout(() => window.location.reload(), 1500);
        } catch (error) {
          console.error("Failed to import settings:", error);
          showToast("Import failed. Check console.", "error");
        }
      });
    }

    function showToast(message: string, type: "success" | "error" = "success") {
      const container = document.getElementById("toast-container");
      if (!container) return;
      const toast = document.createElement("div");
      toast.className = `toast ${type}`;
      toast.textContent = message;
      container.appendChild(toast);
      setTimeout(() => toast.remove(), 3000);
    }

    // Save a setting to the API
    async function saveSetting(key: string, value: unknown) {
      try {
        await fetch("/api/settings", {
          method: "PUT",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ key, value }),
        });
      } catch {
        /* ignore */
      }
    }

    // Load settings from API on page init
    async function loadSettings() {
      try {
        const res = await fetch("/api/settings");
        const settings = await res.json();

        // Restore framework toggles
        if (settings.frameworks_enabled) {
          const enabled = settings.frameworks_enabled as Record<
            string,
            boolean
          >;
          document.querySelectorAll(".framework-toggle").forEach((cb) => {
            const fw = (cb as HTMLInputElement).dataset.fw;
            if (fw && fw in enabled) {
              (cb as HTMLInputElement).checked = !!enabled[fw];
            }
          });
        }

        // Restore active framework
        if (settings.active_framework) {
          (
            document.getElementById("scoring-framework") as HTMLSelectElement
          ).value = String(settings.active_framework);
        }

        // Restore score display
        if (settings.score_display) {
          (
            document.getElementById("score-display") as HTMLSelectElement
          ).value = String(settings.score_display);
        }

        updateFrameworkSelect();
      } catch {
        /* API not available */
      }
    }

    // Update active framework select options based on enabled toggles
    function updateFrameworkSelect() {
      const select = document.getElementById(
        "scoring-framework",
      ) as HTMLSelectElement;
      const current = select.value;
      const labels: Record<string, string> = {
        rice: "RICE",
        drice: "DRICE",
        heart: "HEART",
        kcs: "KCS",
        ddd: "DDD",
        custom: "Custom",
      };
      select.innerHTML = "";
      document.querySelectorAll(".framework-toggle:checked").forEach((cb) => {
        const fw = (cb as HTMLInputElement).dataset.fw ?? "";
        const opt = document.createElement("option");
        opt.value = fw;
        opt.textContent = labels[fw] ?? fw;
        select.appendChild(opt);
      });
      if (select.querySelector(`option[value="${current}"]`)) {
        select.value = current;
      }
    }

    // Framework toggle change — save and update select
    document.querySelectorAll(".framework-toggle").forEach((cb) => {
      cb.addEventListener("change", () => {
        const enabled: Record<string, boolean> = {};
        document.querySelectorAll(".framework-toggle").forEach((c) => {
          const fw = (c as HTMLInputElement).dataset.fw;
          if (fw) enabled[fw] = (c as HTMLInputElement).checked;
        });
        saveSetting("frameworks_enabled", enabled);
        updateFrameworkSelect();
        showToast("Frameworks updated");
      });
    });

    // Active framework change
    document
      .getElementById("scoring-framework")
      ?.addEventListener("change", (e) => {
        saveSetting("active_framework", (e.target as HTMLSelectElement).value);
        showToast("Active framework saved");
      });

    // Score display change
    document
      .getElementById("score-display")
      ?.addEventListener("change", (e) => {
        saveSetting("score_display", (e.target as HTMLSelectElement).value);
        showToast("Display preference saved");
      });

    // Test HA connection
    document
      .getElementById("test-connection")
      ?.addEventListener("click", async () => {
        const statusEl = document.getElementById("ha-status");
        if (statusEl)
          statusEl.innerHTML =
            '<span style="color: var(--accent);">Testing HA connection...</span>';
        try {
          const res = await fetch("/api/ha/connection");
          const data = (await res.json()) as Record<string, unknown>;
          if (statusEl) {
            if (data.connected) {
              const comps = Array.isArray(data.components)
                ? (data.components as string[]).join(", ")
                : "";
              statusEl.innerHTML =
                `<span style="color: var(--accent);">✅ Connected — HA ${data.version} (${data.mode})</span>` +
                (comps
                  ? `<br><small style="color: var(--text-muted);">Available: ${comps}</small>`
                  : "") +
                `<br><small style="color: var(--text-muted);">${data.location_name} · ${data.time_zone}</small>`;
            } else {
              statusEl.innerHTML =
                `<span style="color: var(--danger);">⚠ ${data.message ?? "HA not reachable"}</span>` +
                `<br><small style="color: var(--text-muted);">Mode: ${data.mode ?? "unknown"}</small>`;
            }
          }
        } catch {
          if (statusEl)
            statusEl.innerHTML =
              '<span style="color: var(--danger);">❌ Connection test failed</span>';
        }
      });

    // Save HA settings
    document.getElementById("ha-form")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const haUrl = (document.getElementById("ha-url") as HTMLInputElement)
        .value;
      const calEntity = (
        document.getElementById("calendar-entity") as HTMLInputElement
      ).value;
      
      const saveBtn = document.getElementById("save-ha") as HTMLButtonElement;
      const origText = saveBtn.innerHTML;
      saveBtn.innerHTML = "💾 Saving...";
      saveBtn.disabled = true;

      await saveSetting("ha_url", haUrl);
      await saveSetting("calendar_entity", calEntity);
      
      saveBtn.innerHTML = origText;
      saveBtn.disabled = false;
      showToast("HA settings saved");
    });

    // Add custom field
    document
      .getElementById("add-custom-field")
      ?.addEventListener("click", () => {
        const list = document.getElementById("custom-fields-list");
        if (!list) return;
        const row = document.createElement("div");
        row.className = "custom-field-row";
        row.innerHTML = `
        <input type="text" class="form-input" placeholder="Field name" />
        <select class="form-select">
          <option value="text">Text</option>
          <option value="number">Number</option>
          <option value="url">URL</option>
          <option value="select">Select</option>
          <option value="date">Date</option>
          <option value="checkbox">Checkbox</option>
        </select>
        <button class="btn btn-primary custom-field-save" style="padding: 4px 12px; font-size: 12px;">Save</button>
        <button class="btn btn-ghost" style="padding: 4px 8px; color: var(--danger);" onclick="this.closest('.custom-field-row')?.remove()">×</button>
      `;
        list.appendChild(row);
        row.querySelector("input")?.focus();

        // Attach save handler to new row
        row.querySelector(".custom-field-save")?.addEventListener("click", async function() {
          const nameInput = row.querySelector("input") as HTMLInputElement;
          const typeSelect = row.querySelector("select") as HTMLSelectElement;
          const name = nameInput?.value?.trim();
          const type = typeSelect?.value || "text";
          if (!name) { nameInput?.focus(); return; }

          try {
            const settingsRes = await fetch("/api/settings");
            const settings = settingsRes.ok ? await settingsRes.json() : {};
            const existing = settings.custom_fields ? JSON.parse(settings.custom_fields) : [];
            existing.push({ name, type });

            await fetch("/api/settings", {
              method: "PUT",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ key: "custom_fields", value: JSON.stringify(existing) }),
            });

            nameInput.disabled = true;
            typeSelect.disabled = true;
            const saveBtn = row.querySelector(".custom-field-save") as HTMLButtonElement;
            if (saveBtn) {
              saveBtn.textContent = "✓ Saved";
              saveBtn.disabled = true;
              saveBtn.style.color = "var(--success)";
            }
            showToast("Custom field saved!");
          } catch {
            showToast("Failed to save field", "error");
          }
        });
      });

    // AI provider custom URL toggle
    document.getElementById("ai-provider")?.addEventListener("change", function() {
      const group = document.getElementById("ai-custom-url-group");
      if (group) {
        group.style.display = (this as HTMLSelectElement).value === "custom" ? "block" : "none";
      }
    });

    document.getElementById("save-ai")?.addEventListener("click", async () => {
      const provider = (document.getElementById("ai-provider") as HTMLSelectElement).value;
      const customUrl = (document.getElementById("ai-custom-url") as HTMLInputElement).value;
      
      const saveBtn = document.getElementById("save-ai") as HTMLButtonElement;
      if (!saveBtn) return;
      const origText = saveBtn.innerHTML;
      saveBtn.innerHTML = "💾 Saving...";
      saveBtn.disabled = true;

      await saveSetting("ai-provider", provider);
      if (provider === "custom") {
        await saveSetting("ai-custom-url", customUrl);
      }

      saveBtn.innerHTML = origText;
      saveBtn.disabled = false;
      showToast("AI settings saved");
    });

    // Init
    loadSettings();
  </script>
</Layout>

<style>
  .settings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 16px;
  }
  .custom-field-row {
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
  }
  .custom-field-row:last-child {
    border-bottom: none;
  }
  .integration-section {
    border-bottom: 1px solid var(--border);
    padding: 16px 0;
  }
  .integration-section:last-child {
    border-bottom: none;
  }
  .integration-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 12px;
  }
  .integration-desc {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 4px;
    line-height: 1.4;
  }
  .integration-config {
    padding-left: 8px;
    border-left: 2px solid var(--border);
    margin-left: 4px;
  }
  .shortcut-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .shortcut-row {
    display: flex;
    gap: 12px;
    align-items: center;
    font-size: 13px;
  }
  kbd {
    background: var(--bg-hover);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 2px 8px;
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--text-primary);
  }
  .badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 500;
  }
  .badge-active {
    background: rgba(16, 185, 129, 0.15);
    color: var(--accent);
  }
  .badge-pending {
    background: rgba(107, 114, 128, 0.15);
    color: var(--text-muted);
  }
  @media (max-width: 768px) {
    .settings-grid {
      grid-template-columns: 1fr;
    }
  }
  .framework-row {
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }
  .framework-row:last-child {
    border-bottom: none;
  }
  .framework-info {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .framework-desc {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 2px;
  }
  /* Toggle switch */
  .toggle-label {
    position: relative;
    display: inline-block;
    width: 40px;
    height: 22px;
    flex-shrink: 0;
    cursor: pointer;
  }
  .toggle-label input {
    opacity: 0;
    width: 0;
    height: 0;
  }
  .toggle-slider {
    position: absolute;
    inset: 0;
    background: var(--bg-hover);
    border: 1px solid var(--border);
    border-radius: 11px;
    transition: all 200ms;
  }
  .toggle-slider::before {
    content: "";
    position: absolute;
    width: 16px;
    height: 16px;
    left: 2px;
    bottom: 2px;
    background: var(--text-muted);
    border-radius: 50%;
    transition: all 200ms;
  }
  .toggle-label input:checked + .toggle-slider {
    background: var(--accent);
    border-color: var(--accent);
  }
  .toggle-label input:checked + .toggle-slider::before {
    transform: translateX(18px);
    background: white;
  }
</style>
