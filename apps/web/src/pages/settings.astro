---
import Layout from "../layouts/Layout.astro";
import { t } from "../i18n/translations";
import type { Locale } from "../lib/locale";

const cookieLocale = Astro.cookies.get("meitheal-locale")?.value;
const locale: Locale = cookieLocale === "ga" ? "ga" : "en";
---

<Layout title={`Meitheal — ${t("settings.title", locale)}`}>
  <span slot="page-title">{t("settings.title", locale)}</span>

  <div
    class="settings-tabs"
    style="display: flex; gap: 24px; border-bottom: 1px solid var(--border); margin-bottom: 24px; overflow-x: auto;"
  >
    <button
      class="settings-tab active"
      data-target="tab-general"
      style="padding-bottom: 12px; border-bottom: 2px solid var(--accent); color: var(--text-primary); font-weight: 500; cursor: pointer; background: transparent; white-space: nowrap;"
      >General</button
    >
    <button
      class="settings-tab"
      data-target="tab-integrations"
      style="padding-bottom: 12px; border-bottom: 2px solid transparent; color: var(--text-muted); font-weight: 500; cursor: pointer; background: transparent; white-space: nowrap;"
      >Integrations</button
    >
    <button
      class="settings-tab"
      data-target="tab-agents"
      style="padding-bottom: 12px; border-bottom: 2px solid transparent; color: var(--text-muted); font-weight: 500; cursor: pointer; background: transparent; white-space: nowrap;"
      >Agents & AI</button
    >
    <button
      class="settings-tab"
      data-target="tab-system"
      style="padding-bottom: 12px; border-bottom: 2px solid transparent; color: var(--text-muted); font-weight: 500; cursor: pointer; background: transparent; white-space: nowrap;"
      >System & Danger</button
    >
  </div>

  <div id="tab-general" class="tab-pane active" style="display: block;">
    <div class="settings-grid">
      <!-- HA Connection -->
      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">{t("settings.ha_title", locale)}</div>
            <div class="card-subtitle">{t("settings.ha_subtitle", locale)}</div>
          </div>
        </div>
        <form id="ha-form">
          <div class="form-group">
            <label class="form-label" for="ha-url">HA URL</label>
            <input
              type="url"
              class="form-input"
              id="ha-url"
              placeholder="http://homeassistant.local:8123"
              pattern="https?://.*"
              required
            />
          </div>
          <div class="form-group">
            <label class="form-label" for="ha-token"
              >Long-Lived Access Token</label
            >
            <input
              type="password"
              class="form-input"
              id="ha-token"
              placeholder="••••••••"
            />
            <small style="color: var(--text-muted); font-size: 12px;">
              Generate in HA → Profile → Long-Lived Access Tokens
            </small>
          </div>
          <div class="form-group">
            <label class="form-label" for="calendar-entity"
              >Calendar Entity</label
            >
            <input
              type="text"
              class="form-input"
              id="calendar-entity"
              placeholder="calendar.meitheal_tasks"
            />
          </div>
          <div style="display: flex; gap: 8px;">
            <button type="button" class="btn btn-ghost" id="test-connection"
              >Test Connection</button
            >
            <button type="submit" class="btn btn-primary" id="save-ha"
              >💾 Save</button
            >
          </div>
          <div id="ha-status" style="margin-top: 12px;"></div>
        </form>
      </div>

      <!-- Sidebar Config -->
      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">Sidebar Configuration</div>
            <div class="card-subtitle">
              Configure visibility, order, and custom labels for navigation
              items.
            </div>
          </div>
        </div>
        <div style="padding: 16px;">
          <div
            id="sidebar-item-list"
            style="display: flex; flex-direction: column; gap: 8px;"
          >
            <!-- Populated by JS -->
          </div>
          <button
            class="btn btn-primary"
            id="save-sidebar"
            style="font-size: 13px; margin-top: 16px;"
            >Save Sidebar Config</button
          >
        </div>
      </div>

      <!-- Custom Fields -->
      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">
              {t("settings.custom_fields_title", locale)}
            </div>
            <div class="card-subtitle">
              {t("settings.custom_fields_subtitle", locale)}
            </div>
          </div>
          <button class="btn btn-ghost" id="add-custom-field"
            >+ Add Field</button
          >
        </div>
        <div id="custom-fields-list">
          <div class="custom-field-row">
            <input
              type="text"
              class="form-input"
              placeholder="Field name"
              value="sprint"
              disabled
            />
            <select class="form-select" disabled>
              <option value="text" selected>Text</option>
              <option value="number">Number</option>
              <option value="select">Select</option>
              <option value="date">Date</option>
              <option value="checkbox">Checkbox</option>
            </select>
            <span style="color: var(--text-muted); font-size: 12px;"
              >Built-in</span
            >
          </div>
          <div class="custom-field-row">
            <input
              type="text"
              class="form-input"
              placeholder="Field name"
              value="story_points"
              disabled
            />
            <select class="form-select" disabled>
              <option value="number" selected>Number</option>
            </select>
            <span style="color: var(--text-muted); font-size: 12px;"
              >Built-in</span
            >
          </div>
        </div>
      </div>

      <!-- Strategic Lenses — Contextual Mapping -->
      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">Strategic Lenses</div>
            <div class="card-subtitle">
              Map evaluation frameworks contextually by Task Type.
            </div>
          </div>
        </div>
        <div class="flex flex-col gap-3 mt-4">
          <div
            class="flex items-center justify-between p-3 border border-border rounded-md bg-bg-secondary"
          >
            <div>
              <strong class="block text-sm">🎯 Epic</strong>
              <span class="text-xs text-text-muted">High-level initiatives</span
              >
            </div>
            <select
              class="form-select framework-mapping-select h-24"
              data-task-type="epic"
              multiple
            >
              <option value="ddd">DDD (Domain-Driven Design)</option>
              <option value="rice">RICE (Priority Math)</option>
              <option value="drice">DRICE (Deps + RICE)</option>
              <option value="heart">HEART (UX Matrix)</option>
              <option value="kcs">KCS (Knowledge Workflow)</option>
            </select>
          </div>

          <div
            class="flex items-center justify-between p-3 border border-border rounded-md bg-bg-secondary"
          >
            <div>
              <strong class="block text-sm">📖 Story</strong>
              <span class="text-xs text-text-muted">User-facing features</span>
            </div>
            <select
              class="form-select framework-mapping-select h-24"
              data-task-type="story"
              multiple
            >
              <option value="rice">RICE (Priority Math)</option>
              <option value="drice">DRICE (Deps + RICE)</option>
              <option value="ddd">DDD (Domain-Driven Design)</option>
              <option value="heart">HEART (UX Matrix)</option>
              <option value="kcs">KCS (Knowledge Workflow)</option>
            </select>
          </div>

          <div
            class="flex items-center justify-between p-3 border border-border rounded-md bg-bg-secondary"
          >
            <div>
              <strong class="block text-sm">✅ Task</strong>
              <span class="text-xs text-text-muted">Standard work items</span>
            </div>
            <select
              class="form-select framework-mapping-select h-24"
              data-task-type="task"
              multiple
            >
              <option value="heart">HEART (UX Matrix)</option>
              <option value="rice">RICE (Priority Math)</option>
              <option value="drice">DRICE (Deps + RICE)</option>
              <option value="ddd">DDD (Domain-Driven Design)</option>
              <option value="kcs">KCS (Knowledge Workflow)</option>
            </select>
          </div>

          <div
            class="flex items-center justify-between p-3 border border-border rounded-md bg-bg-secondary"
          >
            <div>
              <strong class="block text-sm">📝 Documentation</strong>
              <span class="text-xs text-text-muted">Knowledge articles</span>
            </div>
            <select
              class="form-select framework-mapping-select h-24"
              data-task-type="documentation"
              multiple
            >
              <option value="kcs">KCS (Knowledge Workflow)</option>
              <option value="heart">HEART (UX Matrix)</option>
              <option value="rice">RICE (Priority Math)</option>
              <option value="drice">DRICE (Deps + RICE)</option>
              <option value="ddd">DDD (Domain-Driven Design)</option>
            </select>
          </div>
        </div>
      </div>
    </div>
    <!-- /settings-grid -->
  </div>
  <!-- /tab-general -->

  <div id="tab-integrations" class="tab-pane" style="display: none;">
    <div class="settings-grid">
      <!-- Integrations — Comprehensive Configuration -->
      <div class="card" style="grid-column: 1 / -1;">
        <div class="card-header">
          <div>
            <div class="card-title">
              {t("settings.integrations_title", locale)}
            </div>
            <div class="card-subtitle">
              {t("settings.integrations_subtitle", locale)}
            </div>
          </div>
        </div>

        <!-- Calendar Sync -->
        <div class="integration-section">
          <div class="integration-header">
            <div>
              <strong>📅 Calendar Sync</strong>
              <div class="integration-desc">
                Sync tasks with due dates to your Home Assistant or CalDAV
                calendar. Tasks appear as events with priority color coding.
              </div>
            </div>
            <span class="badge badge-active" id="cal-status">Connected</span>
          </div>
          <div class="integration-config">
            <div class="form-group">
              <label class="form-label" for="cal-entity">Calendar Entity</label>
              <input
                type="text"
                class="form-input"
                id="cal-entity"
                placeholder="calendar.meitheal_tasks"
              />
              <small style="color: var(--text-muted); font-size: 11px;"
                >The HA calendar entity to sync tasks to. Find it in HA →
                Developer Tools → States → search "calendar."</small
              >
            </div>
            <div class="form-group">
              <label class="form-label" for="caldav-url"
                >CalDAV URL (optional)</label
              >
              <input
                type="url"
                class="form-input"
                id="caldav-url"
                placeholder="https://your-server.com/dav/calendars/"
              />
              <small style="color: var(--text-muted); font-size: 11px;"
                >For direct CalDAV sync (Nextcloud, Radicale, etc). Leave blank
                to use HA calendar only.</small
              >
            </div>
            <div style="display: flex; gap: 8px; align-items: center;">
              <button
                class="btn btn-primary"
                id="save-cal"
                style="font-size: 13px;">Save Calendar Settings</button
              >
              <button
                class="btn btn-ghost"
                id="test-cal"
                style="font-size: 13px;">Test Sync</button
              >
            </div>
          </div>
        </div>

        <!-- Grocy -->
        <div class="integration-section">
          <div class="integration-header">
            <div>
              <strong>🛒 Grocy</strong>
              <div class="integration-desc">
                Connect to Grocy for household inventory and chore management.
                Meitheal can import Grocy tasks and expose its own tasks back.
              </div>
            </div>
            <span class="badge badge-pending" id="grocy-status"
              >Not configured</span
            >
          </div>
          <div class="integration-config">
            <div class="form-group">
              <label class="form-label" for="grocy-url">Grocy URL</label>
              <input
                type="url"
                class="form-input"
                id="grocy-url"
                placeholder="http://homeassistant.local:9192"
              />
              <small style="color: var(--text-muted); font-size: 11px;"
                >The URL of your Grocy instance. Often runs as a HA add-on on
                port 9192.</small
              >
            </div>
            <div class="form-group">
              <label class="form-label" for="grocy-key">API Key</label>
              <input
                type="password"
                class="form-input"
                id="grocy-key"
                placeholder="••••••••"
              />
              <small style="color: var(--text-muted); font-size: 11px;"
                >Generate in Grocy → Settings → API Keys → Add.</small
              >
            </div>
            <div class="form-group">
              <label class="form-label" for="grocy-sync-mode">Sync Mode</label>
              <select class="form-select" id="grocy-sync-mode">
                <option value="import">Import Grocy → Meitheal</option>
                <option value="export">Export Meitheal → Grocy</option>
                <option value="bidirectional">Bidirectional sync</option>
              </select>
            </div>
            <button
              class="btn btn-primary"
              id="save-grocy"
              style="font-size: 13px;">Save Grocy Settings</button
            >
          </div>
        </div>

        <!-- n8n / Node-RED -->
        <div class="integration-section">
          <div class="integration-header">
            <div>
              <strong>⚙ n8n / Node-RED</strong>
              <div class="integration-desc">
                Trigger automation workflows when tasks are created, updated, or
                completed. Create complex pipelines that react to task events.
              </div>
            </div>
            <span class="badge badge-pending" id="n8n-status"
              >Not configured</span
            >
          </div>
          <div class="integration-config">
            <div class="form-group">
              <label class="form-label" for="n8n-webhook-url">Webhook URL</label
              >
              <input
                type="url"
                class="form-input"
                id="n8n-webhook-url"
                placeholder="https://n8n.example.com/webhook/meitheal"
              />
              <small style="color: var(--text-muted); font-size: 11px;"
                >The webhook URL from your n8n/Node-RED flow. Meitheal will POST
                task events here.</small
              >
            </div>
            <div class="form-group">
              <label class="form-label">Trigger Events</label>
              <div style="display: flex; gap: 12px; flex-wrap: wrap;">
                <label
                  style="font-size: 13px; display: flex; gap: 4px; align-items: center;"
                >
                  <input
                    type="checkbox"
                    class="n8n-event"
                    value="task.created"
                    checked
                  /> Created
                </label>
                <label
                  style="font-size: 13px; display: flex; gap: 4px; align-items: center;"
                >
                  <input
                    type="checkbox"
                    class="n8n-event"
                    value="task.updated"
                    checked
                  /> Updated
                </label>
                <label
                  style="font-size: 13px; display: flex; gap: 4px; align-items: center;"
                >
                  <input
                    type="checkbox"
                    class="n8n-event"
                    value="task.completed"
                    checked
                  /> Completed
                </label>
                <label
                  style="font-size: 13px; display: flex; gap: 4px; align-items: center;"
                >
                  <input
                    type="checkbox"
                    class="n8n-event"
                    value="task.deleted"
                  /> Deleted
                </label>
              </div>
            </div>
            <button
              class="btn btn-primary"
              id="save-n8n"
              style="font-size: 13px;">Save n8n Settings</button
            >
          </div>
        </div>

        <!-- Webhooks -->
        <div class="integration-section">
          <div class="integration-header">
            <div>
              <strong>🔔 Webhooks</strong>
              <div class="integration-desc">
                Generic outgoing webhooks for any service. Each event sends a
                JSON payload with the full task object and event type.
              </div>
            </div>
            <span class="badge badge-active" id="webhook-status">Active</span>
          </div>
          <div class="integration-config">
            <div class="form-group">
              <label class="form-label" for="webhook-endpoint"
                >Endpoint URL</label
              >
              <input
                type="url"
                class="form-input"
                id="webhook-endpoint"
                placeholder="https://your-service.com/webhook"
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="webhook-secret"
                >Signing Secret (optional)</label
              >
              <input
                type="password"
                class="form-input"
                id="webhook-secret"
                placeholder="••••••••"
              />
              <small style="color: var(--text-muted); font-size: 11px;"
                >HMAC-SHA256 secret used to sign webhook payloads. Verify with
                the X-Webhook-Signature header.</small
              >
            </div>
            <div class="form-group">
              <label class="form-label">Payload Format</label>
              <select class="form-select" id="webhook-format">
                <option value="json" selected>JSON</option>
                <option value="form">Form-encoded</option>
              </select>
            </div>
            <div style="display: flex; gap: 8px;">
              <button
                class="btn btn-primary"
                id="save-webhook"
                style="font-size: 13px;">Save Webhook</button
              >
              <button
                class="btn btn-ghost"
                id="test-webhook"
                style="font-size: 13px;">Send Test</button
              >
            </div>
          </div>
        </div>
      </div>
      <!-- /card -->
    </div>
    <!-- /settings-grid (integrations) -->
  </div>
  <!-- /tab-integrations -->

  <div id="tab-agents" class="tab-pane" style="display: none;">
    <div class="settings-grid">
      <div class="card" style="grid-column: 1 / -1;">
        <div class="card-header">
          <div>
            <div class="card-title">Agents & AI</div>
            <div class="card-subtitle">
              Configure AI providers and agent-to-agent protocols mapping.
            </div>
          </div>
        </div>

        <!-- AI Provider -->
        <div class="integration-section">
          <div class="integration-header">
            <div>
              <strong>🤖 AI Provider</strong>
              <div class="integration-desc">
                Configure which AI service the "Ask AI" button sends tasks to.
                Generates a pre-filled prompt with task context for analysis.
              </div>
            </div>
            <span class="badge badge-active">ChatGPT</span>
          </div>
          <div class="integration-config">
            <div class="form-group">
              <label class="form-label" for="ai-provider">Provider</label>
              <select class="form-select" id="ai-provider">
                <option value="chatgpt" selected>ChatGPT</option>
                <option value="claude">Claude</option>
                <option value="gemini">Google Gemini</option>
                <option value="ollama">Ollama (local)</option>
                <option value="custom">Custom URL</option>
              </select>
            </div>
            <div
              class="form-group"
              id="ai-custom-url-group"
              style="display: none;"
            >
              <label class="form-label" for="ai-custom-url"
                >Custom API URL</label
              >
              <input
                type="url"
                class="form-input"
                id="ai-custom-url"
                placeholder="http://localhost:11434/api/chat"
              />
            </div>
            <button
              class="btn btn-primary"
              id="save-ai"
              style="font-size: 13px;">Save AI Settings</button
            >
          </div>
        </div>

        <!-- Agent Protocols -->
        <div class="integration-section">
          <div class="integration-header">
            <div>
              <strong>🔗 Agent Protocols</strong>
              <div class="integration-desc">
                Expose Meitheal tools to AI agents via A2A, WebMCP, and MCP
                protocols. Enable agent-to-agent collaboration, browser agent
                tools, and tool discovery.
              </div>
            </div>
            <span class="badge badge-active" id="agent-protocols-status"
              >Active</span
            >
          </div>
          <div class="integration-config">
            <!-- A2A -->
            <div
              class="form-group"
              style="padding-bottom: 16px; border-bottom: 1px solid var(--border);"
            >
              <div
                style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;"
              >
                <label class="toggle-label">
                  <input type="checkbox" id="agent-a2a-enabled" checked />
                  <span class="toggle-slider"></span>
                </label>
                <div>
                  <strong style="font-size: 14px;">A2A (Agent-to-Agent)</strong>
                  <div
                    style="color: var(--text-muted); font-size: 12px; margin-top: 2px;"
                  >
                    Serve an Agent Card at <code
                      >/.well-known/agent-card.json</code
                    > so other AI agents can discover and delegate tasks to Meitheal.
                    <a
                      href="/api/a2a/agent-card"
                      target="_blank"
                      rel="noopener noreferrer"
                      style="color: var(--accent);">View Agent Card →</a
                    >
                  </div>
                </div>
              </div>
            </div>

            <!-- WebMCP -->
            <div
              class="form-group"
              style="padding-top: 16px; padding-bottom: 16px; border-bottom: 1px solid var(--border);"
            >
              <div
                style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;"
              >
                <label class="toggle-label">
                  <input type="checkbox" id="agent-webmcp-enabled" />
                  <span class="toggle-slider"></span>
                </label>
                <div>
                  <strong style="font-size: 14px;"
                    >WebMCP (Browser Agent)</strong
                  >
                  <span
                    style="font-size: 10px; padding: 2px 6px; background: var(--accent); color: #fff; border-radius: 4px; margin-left: 6px; vertical-align: middle;"
                    >Experimental</span
                  >
                  <div
                    style="color: var(--text-muted); font-size: 12px; margin-top: 2px;"
                  >
                    Register Meitheal tools with your browser's AI assistant
                    (Chrome EPP). Allows browser agents to create tasks, search,
                    and navigate boards.
                  </div>
                </div>
              </div>
            </div>

            <!-- MCP Discovery -->
            <div class="form-group" style="padding-top: 16px;">
              <div
                style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;"
              >
                <label class="toggle-label">
                  <input type="checkbox" id="agent-mcp-enabled" checked />
                  <span class="toggle-slider"></span>
                </label>
                <div>
                  <strong style="font-size: 14px;">MCP Discovery</strong>
                  <div
                    style="color: var(--text-muted); font-size: 12px; margin-top: 2px;"
                  >
                    Serve tool definitions at <code>/.well-known/mcp.json</code> for
                    MCP-compatible clients.
                    <a
                      href="/.well-known/mcp.json"
                      target="_blank"
                      rel="noopener noreferrer"
                      style="color: var(--accent);">View MCP manifest →</a
                    >
                  </div>
                </div>
              </div>
            </div>

            <button
              class="btn btn-primary"
              id="save-agent-protocols"
              style="font-size: 13px;">Save Agent Protocol Settings</button
            >
          </div>
        </div>
      </div>
    </div>
    <!-- /settings-grid (agents) -->
  </div>
  <!-- /tab-agents -->

  <div id="tab-system" class="tab-pane" style="display: none;">
    <div class="settings-grid">
      <!-- Keyboard Shortcuts -->
      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">
              {t("settings.shortcuts_title", locale)}
            </div>
            <div class="card-subtitle">
              {t("settings.shortcuts_subtitle", locale)}
            </div>
          </div>
        </div>
        <div class="shortcut-grid">
          <div class="shortcut-row">
            <kbd>n</kbd><span>{t("settings.shortcut_new_task", locale)}</span>
          </div>
          <div class="shortcut-row">
            <kbd>/</kbd><span>{t("settings.shortcut_search", locale)}</span>
          </div>
          <div class="shortcut-row">
            <kbd>l</kbd><span>{t("settings.shortcut_list", locale)}</span>
          </div>
          <div class="shortcut-row">
            <kbd>k</kbd><span>{t("settings.shortcut_kanban", locale)}</span>
          </div>
          <div class="shortcut-row">
            <kbd>t</kbd><span>{t("settings.shortcut_table", locale)}</span>
          </div>
          <div class="shortcut-row">
            <kbd>y</kbd><span>{t("settings.shortcut_today", locale)}</span>
          </div>
          <div class="shortcut-row">
            <kbd>u</kbd><span>{t("settings.shortcut_upcoming", locale)}</span>
          </div>
          <div class="shortcut-row">
            <kbd>c</kbd><span>{t("settings.shortcut_calendar", locale)}</span>
          </div>
          <div class="shortcut-row">
            <kbd>Esc</kbd><span>{t("settings.shortcut_close", locale)}</span>
          </div>
          <div class="shortcut-row">
            <kbd>?</kbd><span>{t("settings.shortcut_help", locale)}</span>
          </div>
        </div>
      </div>

      <!-- Language -->
      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">{t("settings.language_title", locale)}</div>
            <div class="card-subtitle">
              {t("settings.language_subtitle", locale)}
            </div>
          </div>
        </div>
        <div class="form-group" style="margin-top: 12px;">
          <label class="form-label" for="locale-select">Display Language</label>
          <select
            class="form-select"
            id="locale-select"
            style="max-width: 240px;"
          >
            <option value="en">English</option>
            <option value="ga">Gaeilge</option>
          </select>
        </div>
        <div class="form-group" style="margin-top: 12px;">
          <label class="form-label" for="timezone-select">Timezone</label>
          <select
            class="form-select"
            id="timezone-select"
            style="max-width: 300px;"
          >
            <option value="Europe/Dublin">Europe/Dublin</option>
            <option value="Europe/London">Europe/London</option>
            <option value="Europe/Berlin">Europe/Berlin</option>
            <option value="Europe/Paris">Europe/Paris</option>
            <option value="America/New_York">America/New_York</option>
            <option value="America/Chicago">America/Chicago</option>
            <option value="America/Denver">America/Denver</option>
            <option value="America/Los_Angeles">America/Los_Angeles</option>
            <option value="Asia/Tokyo">Asia/Tokyo</option>
            <option value="Asia/Shanghai">Asia/Shanghai</option>
            <option value="Australia/Sydney">Australia/Sydney</option>
            <option value="UTC">UTC</option>
          </select>
        </div>
        <div class="form-group" style="margin-top: 12px;">
          <label class="form-label" for="week-start-select"
            >Week Starts On</label
          >
          <select
            class="form-select"
            id="week-start-select"
            style="max-width: 240px;"
          >
            <option value="monday">Monday</option>
            <option value="sunday">Sunday</option>
            <option value="saturday">Saturday</option>
          </select>
        </div>
        <div class="form-group" style="margin-top: 12px;">
          <label class="form-label" for="date-format-select"
            >Date Display Format</label
          >
          <select
            class="form-select"
            id="date-format-select"
            style="max-width: 300px;"
          >
            <option value="relative">Relative (e.g. "2 days ago")</option>
            <option value="absolute-iso">Absolute ISO (2026-03-01)</option>
            <option value="absolute-eu">Absolute EU (01/03/2026)</option>
            <option value="absolute-us">Absolute US (03/01/2026)</option>
          </select>
        </div>
      </div>

      <!-- Data Portability -->
      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">{t("settings.data_title", locale)}</div>
            <div class="card-subtitle">
              {t("settings.data_subtitle", locale)}
            </div>
          </div>
        </div>
        <div class="form-group" style="margin-top: 12px;">
          <label class="form-label" style="margin-bottom: 8px;"
            >Export Tasks</label
          >
          <div style="display: flex; gap: 8px;">
            <a
              href="#"
              class="btn btn-primary"
              id="export-json-btn"
              style="flex: 1; text-align: center; text-decoration: none;"
              >📥 Download JSON</a
            >
            <a
              href="/api/export/tasks.csv"
              download
              class="btn btn-secondary"
              id="export-csv-btn"
              style="flex: 1; text-align: center; text-decoration: none;"
              >📊 Download CSV</a
            >
            <a
              href="/api/export/database.sqlite"
              download
              class="btn btn-secondary"
              id="export-db-btn"
              style="flex: 1; text-align: center; text-decoration: none;"
              >🗄️ Raw DB</a
            >
          </div>
          <small
            style="color: var(--text-muted); font-size: 11px; display: block; margin-top: 6px;"
          >
            Export your tasks to JSON/CSV, or download the entire raw SQLite
            database file for full local-first data sovereignty.
          </small>
        </div>

        <div
          class="form-group"
          style="margin-top: 16px; border-top: 1px solid var(--border-color); padding-top: 16px;"
        >
          <label class="form-label" style="margin-bottom: 8px;"
            >Settings Configuration</label
          >
          <div style="display: flex; gap: 8px;">
            <a
              href="/api/export/settings.json"
              download
              class="btn btn-secondary"
              id="export-settings-btn"
              style="flex: 1; text-align: center; text-decoration: none;"
              >⚙️ Export Config</a
            >
            <label
              class="btn btn-secondary"
              style="flex: 1; text-align: center; cursor: pointer; margin: 0; padding: 6px 16px; display: inline-flex; justify-content: center; align-items: center;"
            >
              🔄 Import Config
              <input
                type="file"
                id="import-settings-input"
                accept=".json"
                style="display: none;"
              />
            </label>
          </div>
          <small
            style="color: var(--text-muted); font-size: 11px; display: block; margin-top: 6px;"
          >
            Backup or restore your tokens, shortcuts, UI layouts, and active
            integrations. Restoring will trigger a page reload.
          </small>
        </div>
      </div>

      <!-- About -->
      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">{t("settings.about_title", locale)}</div>
            <div class="card-subtitle">
              {t("settings.about_subtitle", locale)}
            </div>
          </div>
        </div>
        <div
          style="font-size: 13px; color: var(--text-secondary); line-height: 1.6;"
        >
          <p>
            <strong>Meitheal</strong> (IPA: /ˈmɛhəl/) — Irish for "cooperative work
            party."
          </p>
          <p>
            A Home Assistant-native, Astro-first task and life management
            engine.
          </p>
          <p>
            Version: <code>0.3.0</code> · Phase 32: Deep Audit
          </p>
        </div>
      </div>

      <!-- Danger Zone -->
      <div class="card" style="border-color: var(--danger); border-width: 2px;">
        <div class="card-header">
          <div>
            <div class="card-title" style="color: var(--danger);">
              {t("settings.danger_title", locale)}
            </div>
            <div class="card-subtitle">
              {t("settings.danger_subtitle", locale)}
            </div>
          </div>
        </div>
        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
          <button
            class="btn"
            id="purge-tasks"
            style="border-color: var(--danger); color: var(--danger);"
            >🗑 Purge All Tasks</button
          >
          <button
            class="btn"
            id="reset-settings"
            style="border-color: var(--danger); color: var(--danger);"
            >🔄 Reset Settings</button
          >
        </div>
      </div>
    </div>
  </div>
  <!-- /tab-system -->

  <div
    id="toast-container"
    class="toast-container"
    aria-live="polite"
    role="status"
  >
  </div>

  <script>
    // Tab switching logic
    document.addEventListener("DOMContentLoaded", () => {
      const tabs = document.querySelectorAll(".settings-tab");
      const panes = document.querySelectorAll(".tab-pane");

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          tabs.forEach((t) => {
            t.classList.remove("active");
            (t as HTMLElement).style.color = "var(--text-muted)";
            (t as HTMLElement).style.borderBottomColor = "transparent";
          });
          panes.forEach((p) => ((p as HTMLElement).style.display = "none"));

          tab.classList.add("active");
          const isDanger = tab.getAttribute("data-target") === "tab-system";
          (tab as HTMLElement).style.color = isDanger
            ? "var(--text-primary)"
            : "var(--text-primary)"; // System tab gets primary color, danger is handled within card
          (tab as HTMLElement).style.borderBottomColor = isDanger
            ? "var(--danger)"
            : "var(--accent)";

          const targetId = tab.getAttribute("data-target");
          if (targetId) {
            const targetPane = document.getElementById(targetId);
            if (targetPane) targetPane.style.display = "block";
          }
        });
      });
    });

    import { exportLocalDataAsJson } from "../domains/offline/export-service";
    import { confirmDialog } from "../lib/confirm-dialog";

    // Export Tasks Binding
    document
      .getElementById("export-json-btn")
      ?.addEventListener("click", async (e) => {
        e.preventDefault();
        try {
          await exportLocalDataAsJson();
          showToast("settings.export_success");
        } catch (err) {
          console.error("Failed to export JSON:", err);
          showToast("settings.export_failed", "error");
        }
      });

    // Import Config Binding
    const importInput = document.getElementById(
      "import-settings-input",
    ) as HTMLInputElement;
    if (importInput) {
      importInput.addEventListener("change", async (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (!file) return;

        try {
          const text = await file.text();
          const payload = JSON.parse(text);

          const response = await fetch("/api/import/settings", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });

          if (!response.ok) {
            throw new Error(await response.text());
          }

          showToast("settings.import_success");
          setTimeout(() => window.location.reload(), 1500);
        } catch (error) {
          console.error("Failed to import settings:", error);
          showToast("settings.import_failed", "error");
        }
      });
    }

    import { showToast } from "../lib/toast";

    // Save a setting to the API
    async function saveSetting(key: string, value: unknown) {
      try {
        await fetch("/api/settings", {
          method: "PUT",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ key, value }),
        });
      } catch {
        /* ignore */
      }
    }

    // Load settings from API on page init
    async function loadSettings() {
      try {
        const res = await fetch("/api/settings");
        const settings = await res.json();

        // Restore contextual framework mappings (arrays)
        if (settings.framework_mapping) {
          const mapping = settings.framework_mapping as Record<
            string,
            string[]
          >;
          document
            .querySelectorAll(".framework-mapping-select")
            .forEach((sel) => {
              const select = sel as HTMLSelectElement;
              const taskType = select.dataset.taskType;
              if (
                taskType &&
                mapping[taskType] &&
                Array.isArray(mapping[taskType])
              ) {
                const selectedVals = mapping[taskType];
                Array.from(select.options).forEach((opt) => {
                  opt.selected = selectedVals.includes(opt.value);
                });
              }
            });
        }

        // Restore locale
        if (settings.locale) {
          (
            document.getElementById("locale-select") as HTMLSelectElement
          ).value = String(settings.locale);
        } else {
          // Fall back to localStorage / cookie
          const stored = localStorage.getItem("meitheal-locale") || "en";
          (
            document.getElementById("locale-select") as HTMLSelectElement
          ).value = stored;
        }

        // Restore timezone
        const tz =
          settings.timezone ||
          localStorage.getItem("meitheal-timezone") ||
          "Europe/Dublin";
        const tzEl = document.getElementById(
          "timezone-select",
        ) as HTMLSelectElement;
        if (tzEl) tzEl.value = tz;

        // Restore week start
        const ws =
          settings.week_start ||
          localStorage.getItem("meitheal-week-start") ||
          "monday";
        const wsEl = document.getElementById(
          "week-start-select",
        ) as HTMLSelectElement;
        if (wsEl) wsEl.value = ws;

        // Restore date format
        const df =
          settings.date_format ||
          localStorage.getItem("meitheal-date-format") ||
          "relative";
        const dfEl = document.getElementById(
          "date-format-select",
        ) as HTMLSelectElement;
        if (dfEl) dfEl.value = df;

        // Restore sidebar config
        const DEFAULT_SIDEBAR_ORDER = [
          "kanban",
          "tasks",
          "table",
          "today",
          "upcoming",
          "calendar",
        ];
        const SIDEBAR_DEFAULTS = {
          kanban: "Kanban Board",
          tasks: "Tasks List",
          table: "Table",
          today: "Today",
          upcoming: "Upcoming",
          calendar: "Calendar",
        } as Record<string, string>;
        let sidebarOrder = [...DEFAULT_SIDEBAR_ORDER];
        let sidebarLabels = {} as Record<string, string>;
        let sidebarVisibility = {
          kanban: true,
          tasks: true,
          table: true,
          today: true,
          upcoming: true,
          calendar: true,
        } as Record<string, boolean>;

        if (settings.sidebar_config) {
          try {
            const sc = JSON.parse(settings.sidebar_config);
            if (Array.isArray(sc.order)) sidebarOrder = sc.order;
            if (sc.labels && typeof sc.labels === "object")
              sidebarLabels = sc.labels;
            for (const k of DEFAULT_SIDEBAR_ORDER) {
              sidebarVisibility[k] = sc[k] !== false;
            }
          } catch {
            /* skip */
          }
        }

        function renderSidebarList() {
          const list = document.getElementById("sidebar-item-list");
          if (!list) return;
          list.innerHTML = "";
          sidebarOrder.forEach((key, idx) => {
            const row = document.createElement("div");
            row.style.cssText =
              "display:flex;align-items:center;gap:8px;padding:8px 12px;background:var(--bg-primary);border:1px solid var(--border);border-radius:8px;";
            row.innerHTML = `
              <input type="checkbox" data-sidebar-key="${key}" ${sidebarVisibility[key] !== false ? "checked" : ""} style="accent-color:var(--accent);" />
              <span style="font-size:13px;font-weight:500;min-width:80px;color:var(--text-secondary);">${SIDEBAR_DEFAULTS[key] || key}</span>
              <input type="text" data-sidebar-label="${key}" placeholder="Custom label..." value="${(sidebarLabels[key] || "").replace(/"/g, "&quot;")}" style="flex:1;font-size:12px;padding:4px 8px;border:1px solid var(--border);border-radius:4px;background:var(--bg-secondary);color:var(--text-primary);" />
              <button data-move-up="${idx}" ${idx === 0 ? "disabled" : ""} style="font-size:14px;padding:2px 6px;border:1px solid var(--border);border-radius:4px;background:var(--bg-secondary);color:var(--text-secondary);cursor:pointer;">&uarr;</button>
              <button data-move-down="${idx}" ${idx === sidebarOrder.length - 1 ? "disabled" : ""} style="font-size:14px;padding:2px 6px;border:1px solid var(--border);border-radius:4px;background:var(--bg-secondary);color:var(--text-secondary);cursor:pointer;">&darr;</button>
            `;
            list.appendChild(row);
          });

          // Bind move buttons
          list.querySelectorAll("[data-move-up]").forEach((btn) => {
            btn.addEventListener("click", () => {
              const i = Number((btn as HTMLElement).dataset.moveUp);
              if (i > 0) {
                const tmp = sidebarOrder[i]!;
                sidebarOrder[i] = sidebarOrder[i - 1]!;
                sidebarOrder[i - 1] = tmp;
                renderSidebarList();
              }
            });
          });
          list.querySelectorAll("[data-move-down]").forEach((btn) => {
            btn.addEventListener("click", () => {
              const i = Number((btn as HTMLElement).dataset.moveDown);
              if (i < sidebarOrder.length - 1) {
                const tmp = sidebarOrder[i]!;
                sidebarOrder[i] = sidebarOrder[i + 1]!;
                sidebarOrder[i + 1] = tmp;
                renderSidebarList();
              }
            });
          });
        }
        renderSidebarList();

        // Render saved custom fields
        if (settings.custom_fields) {
          try {
            const fields = JSON.parse(settings.custom_fields) as Array<{
              name: string;
              type: string;
            }>;
            const list = document.getElementById("custom-fields-list");
            if (list && fields.length > 0) {
              for (const field of fields) {
                const row = document.createElement("div");
                row.className = "custom-field-row";
                row.innerHTML = `
                  <input type="text" class="form-input" value="${field.name.replace(/"/g, "&quot;")}" disabled />
                  <select class="form-select" disabled>
                    <option value="${field.type}" selected>${field.type.charAt(0).toUpperCase() + field.type.slice(1)}</option>
                  </select>
                  <span style="color: var(--text-muted); font-size: 12px;">Saved</span>
                  <button type="button" class="btn btn-ghost" style="padding: 4px 8px; color: var(--danger);" title="Remove field definition (data on existing tasks is preserved)">×</button>
                `;
                row
                  .querySelector("button")
                  ?.addEventListener("click", async () => {
                    try {
                      const curRes = await fetch("/api/settings");
                      const curSettings = curRes.ok ? await curRes.json() : {};
                      const curFields = curSettings.custom_fields
                        ? JSON.parse(curSettings.custom_fields)
                        : [];
                      const updated = curFields.filter(
                        (f: { name: string }) => f.name !== field.name,
                      );
                      await fetch("/api/settings", {
                        method: "PUT",
                        headers: { "content-type": "application/json" },
                        body: JSON.stringify({
                          key: "custom_fields",
                          value: JSON.stringify(updated),
                        }),
                      });
                      row.remove();
                      showToast("settings.field_removed");
                    } catch {
                      showToast("common.failed_delete", "error");
                    }
                  });
                list.appendChild(row);
              }
            }
          } catch {
            /* skip */
          }
        }
      } catch {
        /* API not available — try localStorage fallback for locale */
        const stored = localStorage.getItem("meitheal-locale") || "en";
        (document.getElementById("locale-select") as HTMLSelectElement).value =
          stored;
      }
    }

    // Contextual framework mapping change (multiple)
    document.querySelectorAll(".framework-mapping-select").forEach((sel) => {
      sel.addEventListener("change", () => {
        const mapping: Record<string, string[]> = {};
        document.querySelectorAll(".framework-mapping-select").forEach((s) => {
          const select = s as HTMLSelectElement;
          const taskType = select.dataset.taskType;
          if (taskType) {
            mapping[taskType] = Array.from(select.selectedOptions).map(
              (o) => o.value,
            );
          }
        });
        saveSetting("framework_mapping", mapping);
        showToast("settings.frameworks_updated");
      });
    });

    // Test HA connection
    document
      .getElementById("test-connection")
      ?.addEventListener("click", async () => {
        const statusEl = document.getElementById("ha-status");
        if (statusEl)
          statusEl.innerHTML =
            '<span style="color: var(--accent);">Testing HA connection...</span>';
        try {
          const res = await fetch("/api/ha/connection");
          const data = (await res.json()) as Record<string, unknown>;
          if (statusEl) {
            if (data.connected) {
              const comps = Array.isArray(data.components)
                ? (data.components as string[]).join(", ")
                : "";
              statusEl.innerHTML =
                `<span style="color: var(--accent);">✅ Connected — HA ${data.version} (${data.mode})</span>` +
                (comps
                  ? `<br><small style="color: var(--text-muted);">Available: ${comps}</small>`
                  : "") +
                `<br><small style="color: var(--text-muted);">${data.location_name} · ${data.time_zone}</small>`;
            } else {
              statusEl.innerHTML =
                `<span style="color: var(--danger);">⚠ ${data.message ?? "HA not reachable"}</span>` +
                `<br><small style="color: var(--text-muted);">Mode: ${data.mode ?? "unknown"}</small>`;
            }
          }
        } catch {
          if (statusEl)
            statusEl.innerHTML =
              '<span style="color: var(--danger);">❌ Connection test failed</span>';
        }
      });

    // Save HA settings
    document
      .getElementById("ha-form")
      ?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const haUrl = (document.getElementById("ha-url") as HTMLInputElement)
          .value;
        const haToken = (
          document.getElementById("ha-token") as HTMLInputElement
        ).value;
        const calEntity = (
          document.getElementById("calendar-entity") as HTMLInputElement
        ).value;

        const saveBtn = document.getElementById("save-ha") as HTMLButtonElement;
        const origText = saveBtn.innerHTML;
        saveBtn.innerHTML = "💾 Saving...";
        saveBtn.disabled = true;

        await saveSetting("ha_url", haUrl);
        if (haToken) await saveSetting("ha_token", haToken);
        await saveSetting("calendar_entity", calEntity);

        saveBtn.innerHTML = origText;
        saveBtn.disabled = false;
        showToast("settings.ha_saved");
      });

    // Save sidebar config
    document
      .getElementById("save-sidebar")
      ?.addEventListener("click", async () => {
        // Read current state from the rendered list
        const list = document.getElementById("sidebar-item-list");
        if (!list) return;
        const config: Record<string, unknown> = {};
        const order: string[] = [];
        const labels: Record<string, string> = {};

        list.querySelectorAll("[data-sidebar-key]").forEach((cb) => {
          const key = (cb as HTMLElement).dataset.sidebarKey!;
          config[key] = (cb as HTMLInputElement).checked;
          order.push(key);
        });
        list.querySelectorAll("[data-sidebar-label]").forEach((input) => {
          const key = (input as HTMLElement).dataset.sidebarLabel!;
          const val = (input as HTMLInputElement).value.trim();
          if (val) labels[key] = val;
        });
        config.order = order;
        config.labels = labels;

        const btn = document.getElementById(
          "save-sidebar",
        ) as HTMLButtonElement;
        if (!btn) return;
        const oText = btn.textContent;
        btn.textContent = "Saving...";
        btn.disabled = true;

        await saveSetting("sidebar_config", JSON.stringify(config));

        btn.textContent = oText;
        btn.disabled = false;
        showToast("settings.sidebar_saved");
        setTimeout(() => window.location.reload(), 1000);
      });

    // Add custom field
    document
      .getElementById("add-custom-field")
      ?.addEventListener("click", () => {
        const list = document.getElementById("custom-fields-list");
        if (!list) return;
        const row = document.createElement("div");
        row.className = "custom-field-row";
        row.innerHTML = `
        <input type="text" class="form-input" placeholder="Field name" />
        <select class="form-select">
          <option value="text">Text</option>
          <option value="number">Number</option>
          <option value="url">URL</option>
          <option value="select">Select</option>
          <option value="date">Date</option>
          <option value="checkbox">Checkbox</option>
        </select>
        <button type="button" class="btn btn-primary custom-field-save" style="padding: 4px 12px; font-size: 12px;">Save</button>
        <button type="button" class="btn btn-ghost" style="padding: 4px 8px; color: var(--danger);" onclick="this.closest('.custom-field-row')?.remove()">×</button>
      `;
        list.appendChild(row);
        row.querySelector("input")?.focus();

        // Attach save handler to new row
        row
          .querySelector(".custom-field-save")
          ?.addEventListener("click", async function () {
            const nameInput = row.querySelector("input") as HTMLInputElement;
            const typeSelect = row.querySelector("select") as HTMLSelectElement;
            const name = nameInput?.value?.trim();
            const type = typeSelect?.value || "text";
            if (!name) {
              nameInput?.focus();
              return;
            }

            try {
              const settingsRes = await fetch("/api/settings");
              const settings = settingsRes.ok ? await settingsRes.json() : {};
              const existing = settings.custom_fields
                ? JSON.parse(settings.custom_fields)
                : [];
              existing.push({ name, type });

              await fetch("/api/settings", {
                method: "PUT",
                headers: { "content-type": "application/json" },
                body: JSON.stringify({
                  key: "custom_fields",
                  value: JSON.stringify(existing),
                }),
              });

              nameInput.disabled = true;
              typeSelect.disabled = true;
              const saveBtn = row.querySelector(
                ".custom-field-save",
              ) as HTMLButtonElement;
              if (saveBtn) {
                saveBtn.textContent = "✓ Saved";
                saveBtn.disabled = true;
                saveBtn.style.color = "var(--success)";
              }
              showToast("settings.custom_field_saved");
            } catch {
              showToast("settings.failed_save_field", "error");
            }
          });
      });

    // AI provider custom URL toggle
    document
      .getElementById("ai-provider")
      ?.addEventListener("change", function () {
        const group = document.getElementById("ai-custom-url-group");
        if (group) {
          group.style.display =
            (this as HTMLSelectElement).value === "custom" ? "block" : "none";
        }
      });

    document.getElementById("save-ai")?.addEventListener("click", async () => {
      const provider = (
        document.getElementById("ai-provider") as HTMLSelectElement
      ).value;
      const customUrl = (
        document.getElementById("ai-custom-url") as HTMLInputElement
      ).value;

      const saveBtn = document.getElementById("save-ai") as HTMLButtonElement;
      if (!saveBtn) return;
      const origText = saveBtn.innerHTML;
      saveBtn.innerHTML = "💾 Saving...";
      saveBtn.disabled = true;

      await saveSetting("ai-provider", provider);
      if (provider === "custom") {
        await saveSetting("ai-custom-url", customUrl);
      }

      saveBtn.innerHTML = origText;
      saveBtn.disabled = false;
      showToast("settings.ai_saved");
    });

    // ───── Webhook Save + Test ─────

    // ───── Agent Protocol Save ─────
    document
      .getElementById("save-agent-protocols")
      ?.addEventListener("click", async () => {
        const a2a =
          (document.getElementById("agent-a2a-enabled") as HTMLInputElement)
            ?.checked ?? true;
        const webmcp =
          (document.getElementById("agent-webmcp-enabled") as HTMLInputElement)
            ?.checked ?? false;
        const mcp =
          (document.getElementById("agent-mcp-enabled") as HTMLInputElement)
            ?.checked ?? true;

        const saveBtn = document.getElementById(
          "save-agent-protocols",
        ) as HTMLButtonElement;
        if (!saveBtn) return;
        const origText = saveBtn.innerHTML;
        saveBtn.innerHTML = "💾 Saving...";
        saveBtn.disabled = true;

        await saveSetting("agent-protocols-a2a-enabled", a2a);
        await saveSetting("agent-protocols-webmcp-enabled", webmcp);
        await saveSetting("agent-protocols-mcp-enabled", mcp);

        // Update status badge
        const statusEl = document.getElementById("agent-protocols-status");
        if (statusEl) {
          const anyEnabled = a2a || webmcp || mcp;
          statusEl.textContent = anyEnabled ? "Active" : "Disabled";
          statusEl.className = anyEnabled
            ? "badge badge-active"
            : "badge badge-pending";
        }

        saveBtn.innerHTML = origText;
        saveBtn.disabled = false;
        showToast("settings.agent_protocols_saved");
      });
    document
      .getElementById("save-webhook")
      ?.addEventListener("click", async () => {
        const endpoint = (
          document.getElementById("webhook-endpoint") as HTMLInputElement
        ).value;
        const secret = (
          document.getElementById("webhook-secret") as HTMLInputElement
        ).value;
        const format = (
          document.getElementById("webhook-format") as HTMLSelectElement
        ).value;

        if (!endpoint) {
          showToast("settings.webhook_required", "error");
          return;
        }

        const btn = document.getElementById(
          "save-webhook",
        ) as HTMLButtonElement;
        btn.textContent = "Saving...";
        btn.disabled = true;

        await saveSetting("webhook_endpoint", endpoint);
        if (secret) await saveSetting("webhook_secret", secret);
        await saveSetting("webhook_format", format);

        btn.textContent = "Save Webhook";
        btn.disabled = false;
        showToast("settings.webhook_saved");
      });

    document
      .getElementById("test-webhook")
      ?.addEventListener("click", async () => {
        const endpoint = (
          document.getElementById("webhook-endpoint") as HTMLInputElement
        ).value;
        if (!endpoint) {
          showToast("settings.webhook_enter_url", "error");
          return;
        }

        const btn = document.getElementById(
          "test-webhook",
        ) as HTMLButtonElement;
        btn.textContent = "Sending...";
        btn.disabled = true;

        try {
          const res = await fetch(endpoint, {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({
              eventType: "webhook.test",
              timestamp: new Date().toISOString(),
              payload: {
                message: "Test ping from Meitheal",
                source: "settings",
              },
            }),
          });
          showToast(
            res.ok
              ? `✅ Test sent — ${res.status}`
              : `⚠ Response: ${res.status}`,
            res.ok ? "success" : "error",
          );
        } catch (err) {
          showToast(
            `❌ Failed: ${err instanceof Error ? err.message : "Network error"}`,
            "error",
          );
        }

        btn.textContent = "Send Test";
        btn.disabled = false;
      });

    // ───── n8n Save ─────
    document.getElementById("save-n8n")?.addEventListener("click", async () => {
      const webhookUrl = (
        document.getElementById("n8n-webhook-url") as HTMLInputElement
      ).value;
      if (!webhookUrl) {
        showToast("settings.n8n_required", "error");
        return;
      }

      const events: string[] = [];
      document.querySelectorAll(".n8n-event:checked").forEach((cb) => {
        events.push((cb as HTMLInputElement).value);
      });

      const btn = document.getElementById("save-n8n") as HTMLButtonElement;
      btn.textContent = "Saving...";
      btn.disabled = true;

      await saveSetting("n8n_webhook_url", webhookUrl);
      await saveSetting("n8n_events", events);

      const statusEl = document.getElementById("n8n-status");
      if (statusEl) {
        statusEl.textContent = "Configured";
        statusEl.className = "badge badge-active";
      }

      btn.textContent = "Save n8n Settings";
      btn.disabled = false;
      showToast("settings.n8n_saved");
    });

    // ───── Grocy Save ─────
    document
      .getElementById("save-grocy")
      ?.addEventListener("click", async () => {
        const url = (document.getElementById("grocy-url") as HTMLInputElement)
          .value;
        const key = (document.getElementById("grocy-key") as HTMLInputElement)
          .value;
        const syncMode = (
          document.getElementById("grocy-sync-mode") as HTMLSelectElement
        ).value;

        if (!url) {
          showToast("settings.grocy_required", "error");
          return;
        }

        const btn = document.getElementById("save-grocy") as HTMLButtonElement;
        btn.textContent = "Saving...";
        btn.disabled = true;

        await saveSetting("grocy_url", url);
        if (key) await saveSetting("grocy_api_key", key);
        await saveSetting("grocy_sync_mode", syncMode);

        const statusEl = document.getElementById("grocy-status");
        if (statusEl) {
          statusEl.textContent = "Configured";
          statusEl.className = "badge badge-active";
        }

        btn.textContent = "Save Grocy Settings";
        btn.disabled = false;
        showToast("settings.grocy_saved");
      });

    // ───── Calendar Save + Test ─────
    document.getElementById("save-cal")?.addEventListener("click", async () => {
      const entity = (document.getElementById("cal-entity") as HTMLInputElement)
        .value;
      const caldav = (document.getElementById("caldav-url") as HTMLInputElement)
        .value;

      const btn = document.getElementById("save-cal") as HTMLButtonElement;
      btn.textContent = "Saving...";
      btn.disabled = true;

      await saveSetting("cal_entity", entity);
      if (caldav) await saveSetting("caldav_url", caldav);

      const statusEl = document.getElementById("cal-status");
      if (statusEl && entity) {
        statusEl.textContent = "Configured";
        statusEl.className = "badge badge-active";
      }

      btn.textContent = "Save Calendar Settings";
      btn.disabled = false;
      showToast("settings.calendar_saved");
    });

    document.getElementById("test-cal")?.addEventListener("click", async () => {
      const btn = document.getElementById("test-cal") as HTMLButtonElement;
      btn.textContent = "Testing...";
      btn.disabled = true;

      try {
        const res = await fetch("/api/ha/connection");
        const data = (await res.json()) as Record<string, unknown>;
        const components = Array.isArray(data.components)
          ? (data.components as string[])
          : [];
        const hasCalendar = components.includes("calendar");
        showToast(
          data.connected
            ? hasCalendar
              ? "✅ Calendar integration available"
              : "⚠ HA connected but no calendar component found"
            : `❌ ${data.message ?? "HA not reachable"}`,
          data.connected && hasCalendar ? "success" : "error",
        );
      } catch {
        showToast("❌ Calendar sync test failed", "error");
      }

      btn.textContent = "Test Sync";
      btn.disabled = false;
    });

    // ───── Restore Integration Settings ─────
    (async function restoreIntegrationSettings() {
      try {
        const res = await fetch("/api/settings");
        if (!res.ok) return;
        const s = (await res.json()) as Record<string, unknown>;

        // Grocy
        if (s.grocy_url)
          (document.getElementById("grocy-url") as HTMLInputElement).value =
            String(s.grocy_url);
        if (s.grocy_sync_mode)
          (
            document.getElementById("grocy-sync-mode") as HTMLSelectElement
          ).value = String(s.grocy_sync_mode);
        if (s.grocy_url) {
          const el = document.getElementById("grocy-status");
          if (el) {
            el.textContent = "Configured";
            el.className = "badge badge-active";
          }
        }

        // Calendar
        if (s.cal_entity)
          (document.getElementById("cal-entity") as HTMLInputElement).value =
            String(s.cal_entity);
        if (s.caldav_url)
          (document.getElementById("caldav-url") as HTMLInputElement).value =
            String(s.caldav_url);

        // n8n
        if (s.n8n_webhook_url) {
          (
            document.getElementById("n8n-webhook-url") as HTMLInputElement
          ).value = String(s.n8n_webhook_url);
          const el = document.getElementById("n8n-status");
          if (el) {
            el.textContent = "Configured";
            el.className = "badge badge-active";
          }
        }
        if (Array.isArray(s.n8n_events)) {
          document.querySelectorAll(".n8n-event").forEach((cb) => {
            (cb as HTMLInputElement).checked = (
              s.n8n_events as string[]
            ).includes((cb as HTMLInputElement).value);
          });
        }

        // Webhook
        if (s.webhook_endpoint)
          (
            document.getElementById("webhook-endpoint") as HTMLInputElement
          ).value = String(s.webhook_endpoint);
        if (s.webhook_format)
          (
            document.getElementById("webhook-format") as HTMLSelectElement
          ).value = String(s.webhook_format);
        if (s.webhook_endpoint) {
          const el = document.getElementById("webhook-status");
          if (el) {
            el.textContent = "Active";
            el.className = "badge badge-active";
          }
        } else {
          const el = document.getElementById("webhook-status");
          if (el) {
            el.textContent = "Not configured";
            el.className = "badge badge-pending";
          }
        }

        // Agent Protocols
        const a2aEnabled = s["agent-protocols-a2a-enabled"];
        const webmcpEnabled = s["agent-protocols-webmcp-enabled"];
        const mcpEnabled = s["agent-protocols-mcp-enabled"];
        if (a2aEnabled !== undefined)
          (
            document.getElementById("agent-a2a-enabled") as HTMLInputElement
          ).checked = a2aEnabled === true || a2aEnabled === "true";
        if (webmcpEnabled !== undefined)
          (
            document.getElementById("agent-webmcp-enabled") as HTMLInputElement
          ).checked = webmcpEnabled === true || webmcpEnabled === "true";
        if (mcpEnabled !== undefined)
          (
            document.getElementById("agent-mcp-enabled") as HTMLInputElement
          ).checked = mcpEnabled === true || mcpEnabled === "true";
        {
          const anyConfigured =
            a2aEnabled !== undefined ||
            webmcpEnabled !== undefined ||
            mcpEnabled !== undefined;
          const anyActive =
            a2aEnabled === true ||
            a2aEnabled === "true" ||
            webmcpEnabled === true ||
            webmcpEnabled === "true" ||
            mcpEnabled === true ||
            mcpEnabled === "true";
          const statusEl = document.getElementById("agent-protocols-status");
          if (statusEl && anyConfigured) {
            statusEl.textContent = anyActive ? "Active" : "Disabled";
            statusEl.className = anyActive
              ? "badge badge-active"
              : "badge badge-pending";
          }
        }
      } catch {
        /* settings not available */
      }
    })();

    // ───── Danger Zone ─────
    document
      .getElementById("purge-tasks")
      ?.addEventListener("click", async () => {
        const ok = await confirmDialog({
          title: "Purge All Tasks",
          message:
            "This will permanently delete ALL tasks. This action is irreversible.",
          variant: "danger",
          confirmText: "Purge Everything",
        });
        if (!ok) return;
        const typed = prompt("Type YES to confirm purge:");
        if (typed?.toUpperCase() !== "YES") {
          showToast("settings.purge_cancelled", "error");
          return;
        }
        try {
          const res = await fetch("/api/tasks?purge=all", { method: "DELETE" });
          if (res.ok) {
            showToast("settings.purge_success");
            setTimeout(() => window.location.reload(), 1000);
          } else showToast("settings.purge_failed", "error");
        } catch {
          showToast("common.network_error", "error");
        }
      });

    document
      .getElementById("reset-settings")
      ?.addEventListener("click", async () => {
        const ok = await confirmDialog({
          title: "Reset Settings",
          message: "This will reset ALL settings to their default values.",
          variant: "warning",
          confirmText: "Reset All",
        });
        if (!ok) return;
        try {
          const res = await fetch("/api/settings?reset=all", {
            method: "DELETE",
          });
          if (res.ok) {
            showToast("settings.reset_success");
            setTimeout(() => window.location.reload(), 1000);
          } else showToast("settings.reset_failed", "error");
        } catch {
          showToast("common.network_error", "error");
        }
      });

    // Language selector — persist to API, cookie, localStorage
    document
      .getElementById("locale-select")
      ?.addEventListener("change", async (e) => {
        const locale = (e.target as HTMLSelectElement).value;
        // Store in localStorage
        localStorage.setItem("meitheal-locale", locale);
        // Set cookie for SSR
        document.cookie = `meitheal-locale=${locale};path=/;max-age=31536000;SameSite=Lax`;
        // Persist to settings API
        try {
          await fetch("/api/settings", {
            method: "PUT",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ key: "locale", value: locale }),
          });
        } catch {
          /* ignore API errors */
        }
        // Dispatch event for any listening components
        window.dispatchEvent(
          new CustomEvent("meitheal:locale-changed", { detail: { locale } }),
        );
        // Reload to get SSR-rendered translations
        showToast(
          locale === "ga"
            ? "Teanga athraithe go Gaeilge"
            : "Language changed to English",
        );
        setTimeout(() => window.location.reload(), 800);
      });

    // Timezone selector — persist to API + localStorage
    document
      .getElementById("timezone-select")
      ?.addEventListener("change", async (e) => {
        const tz = (e.target as HTMLSelectElement).value;
        localStorage.setItem("meitheal-timezone", tz);
        await saveSetting("timezone", tz);
        showToast("common.updated");
      });

    // Week start selector
    document
      .getElementById("week-start-select")
      ?.addEventListener("change", async (e) => {
        const ws = (e.target as HTMLSelectElement).value;
        localStorage.setItem("meitheal-week-start", ws);
        await saveSetting("week_start", ws);
        showToast("common.updated");
      });

    // Date format selector
    document
      .getElementById("date-format-select")
      ?.addEventListener("change", async (e) => {
        const df = (e.target as HTMLSelectElement).value;
        localStorage.setItem("meitheal-date-format", df);
        await saveSetting("date_format", df);
        showToast("common.updated");
      });

    // Init
    loadSettings();
  </script>
</Layout>

<style>
  .settings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 16px;
  }
  .custom-field-row {
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
  }
  .custom-field-row:last-child {
    border-bottom: none;
  }
  .integration-section {
    border-bottom: 1px solid var(--border);
    padding: 16px 0;
  }
  .integration-section:last-child {
    border-bottom: none;
  }
  .integration-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 12px;
  }
  .integration-desc {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 4px;
    line-height: 1.4;
  }
  .integration-config {
    padding-left: 8px;
    border-left: 2px solid var(--border);
    margin-left: 4px;
  }
  .shortcut-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .shortcut-row {
    display: flex;
    gap: 12px;
    align-items: center;
    font-size: 13px;
  }
  kbd {
    background: var(--bg-hover);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 2px 8px;
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--text-primary);
  }
  .badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 500;
  }
  .badge-active {
    background: rgba(16, 185, 129, 0.15);
    color: var(--accent);
  }
  .badge-pending {
    background: rgba(107, 114, 128, 0.15);
    color: var(--text-muted);
  }
  @media (max-width: 768px) {
    .settings-grid {
      grid-template-columns: 1fr;
    }
  }
  .framework-row {
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }
  .framework-row:last-child {
    border-bottom: none;
  }
  .framework-info {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .framework-desc {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 2px;
  }
  /* Toggle switch */
  .toggle-label {
    position: relative;
    display: inline-block;
    width: 40px;
    height: 22px;
    flex-shrink: 0;
    cursor: pointer;
  }
  .toggle-label input {
    opacity: 0;
    width: 0;
    height: 0;
  }
  .toggle-slider {
    position: absolute;
    inset: 0;
    background: var(--bg-hover);
    border: 1px solid var(--border);
    border-radius: 11px;
    transition: all 200ms;
  }
  .toggle-slider::before {
    content: "";
    position: absolute;
    width: 16px;
    height: 16px;
    left: 2px;
    bottom: 2px;
    background: var(--text-muted);
    border-radius: 50%;
    transition: all 200ms;
  }
  .toggle-label input:checked + .toggle-slider {
    background: var(--accent);
    border-color: var(--accent);
  }
  .toggle-label input:checked + .toggle-slider::before {
    transform: translateX(18px);
    background: white;
  }
</style>
