---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Meitheal — Settings">
  <span slot="page-title">Settings</span>

  <div class="settings-grid">
    <!-- HA Connection -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">☘ Home Assistant</div>
          <div class="card-subtitle">Connection and integration settings</div>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="ha-url">HA URL</label>
        <input
          type="url"
          class="form-input"
          id="ha-url"
          placeholder="http://homeassistant.local:8123"
        />
      </div>
      <div class="form-group">
        <label class="form-label" for="ha-token">Long-Lived Access Token</label>
        <input
          type="password"
          class="form-input"
          id="ha-token"
          placeholder="••••••••"
        />
        <small style="color: var(--text-muted); font-size: 12px;">
          Generate in HA → Profile → Long-Lived Access Tokens
        </small>
      </div>
      <div class="form-group">
        <label class="form-label" for="calendar-entity">Calendar Entity</label>
        <input
          type="text"
          class="form-input"
          id="calendar-entity"
          placeholder="calendar.meitheal_tasks"
        />
      </div>
      <div style="display: flex; gap: 8px;">
        <button class="btn btn-primary" id="test-connection"
          >Test Connection</button
        >
        <button class="btn btn-ghost" id="save-ha">Save</button>
      </div>
      <div id="ha-status" style="margin-top: 12px;"></div>
    </div>

    <!-- Custom Fields -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">📋 Custom Fields</div>
          <div class="card-subtitle">Define custom fields for tasks</div>
        </div>
        <button class="btn btn-ghost" id="add-custom-field">+ Add Field</button>
      </div>
      <div id="custom-fields-list">
        <div class="custom-field-row">
          <input
            type="text"
            class="form-input"
            placeholder="Field name"
            value="sprint"
            disabled
          />
          <select class="form-select" disabled>
            <option value="text" selected>Text</option>
            <option value="number">Number</option>
            <option value="select">Select</option>
            <option value="date">Date</option>
            <option value="checkbox">Checkbox</option>
          </select>
          <span style="color: var(--text-muted); font-size: 12px;"
            >Built-in</span
          >
        </div>
        <div class="custom-field-row">
          <input
            type="text"
            class="form-input"
            placeholder="Field name"
            value="story_points"
            disabled
          />
          <select class="form-select" disabled>
            <option value="number" selected>Number</option>
          </select>
          <span style="color: var(--text-muted); font-size: 12px;"
            >Built-in</span
          >
        </div>
      </div>
    </div>

    <!-- Framework Scoring — Configurable enable/disable -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">📊 Framework Scoring</div>
          <div class="card-subtitle">
            Enable/disable and configure scoring frameworks
          </div>
        </div>
      </div>
      <div id="framework-list">
        <div class="framework-row" data-framework="rice">
          <div class="framework-info">
            <label class="toggle-label">
              <input
                type="checkbox"
                class="framework-toggle"
                data-fw="rice"
                checked
              />
              <span class="toggle-slider"></span>
            </label>
            <div>
              <strong>RICE</strong>
              <div class="framework-desc">
                Reach × Impact × Confidence / Effort
              </div>
            </div>
          </div>
        </div>
        <div class="framework-row" data-framework="drice">
          <div class="framework-info">
            <label class="toggle-label">
              <input type="checkbox" class="framework-toggle" data-fw="drice" />
              <span class="toggle-slider"></span>
            </label>
            <div>
              <strong>DRICE</strong>
              <div class="framework-desc">Dependencies + RICE</div>
            </div>
          </div>
        </div>
        <div class="framework-row" data-framework="heart">
          <div class="framework-info">
            <label class="toggle-label">
              <input type="checkbox" class="framework-toggle" data-fw="heart" />
              <span class="toggle-slider"></span>
            </label>
            <div>
              <strong>HEART</strong>
              <div class="framework-desc">
                Happiness, Engagement, Adoption, Retention, Task Success
              </div>
            </div>
          </div>
        </div>
        <div class="framework-row" data-framework="kcs">
          <div class="framework-info">
            <label class="toggle-label">
              <input type="checkbox" class="framework-toggle" data-fw="kcs" />
              <span class="toggle-slider"></span>
            </label>
            <div>
              <strong>KCS</strong>
              <div class="framework-desc">Knowledge-Centered Support</div>
            </div>
          </div>
        </div>
        <div class="framework-row" data-framework="ddd">
          <div class="framework-info">
            <label class="toggle-label">
              <input type="checkbox" class="framework-toggle" data-fw="ddd" />
              <span class="toggle-slider"></span>
            </label>
            <div>
              <strong>DDD</strong>
              <div class="framework-desc">Domain-Driven Design scoring</div>
            </div>
          </div>
        </div>
        <div class="framework-row" data-framework="custom">
          <div class="framework-info">
            <label class="toggle-label">
              <input
                type="checkbox"
                class="framework-toggle"
                data-fw="custom"
              />
              <span class="toggle-slider"></span>
            </label>
            <div>
              <strong>Custom</strong>
              <div class="framework-desc">User-defined scoring fields</div>
            </div>
          </div>
        </div>
      </div>
      <div class="form-group" style="margin-top: 12px;">
        <label class="form-label">Active Framework</label>
        <select class="form-select" id="scoring-framework">
          <option value="rice" selected>RICE</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Score Display</label>
        <select class="form-select" id="score-display">
          <option value="badge">Badge (high/med/low)</option>
          <option value="number" selected>Numeric score</option>
          <option value="both">Both</option>
        </select>
      </div>
    </div>

    <!-- Integrations -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">🔗 Integrations</div>
          <div class="card-subtitle">External service connections</div>
        </div>
      </div>
      <div class="integration-row">
        <span>📅 Calendar Sync</span>
        <span class="badge badge-active" id="cal-status">Connected</span>
      </div>
      <div class="integration-row">
        <span>🛒 Grocy</span>
        <span class="badge badge-pending">Not configured</span>
      </div>
      <div class="integration-row">
        <span>⚙ n8n / Node-RED</span>
        <span class="badge badge-pending">Not configured</span>
      </div>
      <div class="integration-row">
        <span>🔔 Webhooks</span>
        <span class="badge badge-active">Active</span>
      </div>
    </div>

    <!-- Keyboard Shortcuts -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">⌨ Keyboard Shortcuts</div>
          <div class="card-subtitle">Navigate quickly through the app</div>
        </div>
      </div>
      <div class="shortcut-grid">
        <div class="shortcut-row"><kbd>n</kbd><span>New task</span></div>
        <div class="shortcut-row"><kbd>/</kbd><span>Search</span></div>
        <div class="shortcut-row"><kbd>l</kbd><span>List view</span></div>
        <div class="shortcut-row"><kbd>k</kbd><span>Kanban view</span></div>
        <div class="shortcut-row"><kbd>t</kbd><span>Table view</span></div>
        <div class="shortcut-row"><kbd>Esc</kbd><span>Close modal</span></div>
        <div class="shortcut-row"><kbd>?</kbd><span>Show shortcuts</span></div>
      </div>
    </div>

    <!-- About -->
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">ℹ About Meitheal</div>
          <div class="card-subtitle">The cooperative task and life engine</div>
        </div>
      </div>
      <div
        style="font-size: 13px; color: var(--text-secondary); line-height: 1.6;"
      >
        <p>
          <strong>Meitheal</strong> (IPA: /ˈmɛhəl/) — Irish for "cooperative work
          party."
        </p>
        <p>
          A Home Assistant-native, Astro-first task and life management engine.
        </p>
        <p>
          Version: <code>0.1.0</code> · Phase 7: Audit &amp; UX Improvements
        </p>
      </div>
    </div>
  </div>

  <div id="toast-container" class="toast-container"></div>

  <script>
    function showToast(message: string, type: "success" | "error" = "success") {
      const container = document.getElementById("toast-container");
      if (!container) return;
      const toast = document.createElement("div");
      toast.className = `toast ${type}`;
      toast.textContent = message;
      container.appendChild(toast);
      setTimeout(() => toast.remove(), 3000);
    }

    // Save a setting to the API
    async function saveSetting(key: string, value: unknown) {
      try {
        await fetch("/api/settings", {
          method: "PUT",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ key, value }),
        });
      } catch {
        /* ignore */
      }
    }

    // Load settings from API on page init
    async function loadSettings() {
      try {
        const res = await fetch("/api/settings");
        const settings = await res.json();

        // Restore framework toggles
        if (settings.frameworks_enabled) {
          const enabled = settings.frameworks_enabled as Record<
            string,
            boolean
          >;
          document.querySelectorAll(".framework-toggle").forEach((cb) => {
            const fw = (cb as HTMLInputElement).dataset.fw;
            if (fw && fw in enabled) {
              (cb as HTMLInputElement).checked = !!enabled[fw];
            }
          });
        }

        // Restore active framework
        if (settings.active_framework) {
          (
            document.getElementById("scoring-framework") as HTMLSelectElement
          ).value = String(settings.active_framework);
        }

        // Restore score display
        if (settings.score_display) {
          (
            document.getElementById("score-display") as HTMLSelectElement
          ).value = String(settings.score_display);
        }

        updateFrameworkSelect();
      } catch {
        /* API not available */
      }
    }

    // Update active framework select options based on enabled toggles
    function updateFrameworkSelect() {
      const select = document.getElementById(
        "scoring-framework",
      ) as HTMLSelectElement;
      const current = select.value;
      const labels: Record<string, string> = {
        rice: "RICE",
        drice: "DRICE",
        heart: "HEART",
        kcs: "KCS",
        ddd: "DDD",
        custom: "Custom",
      };
      select.innerHTML = "";
      document.querySelectorAll(".framework-toggle:checked").forEach((cb) => {
        const fw = (cb as HTMLInputElement).dataset.fw ?? "";
        const opt = document.createElement("option");
        opt.value = fw;
        opt.textContent = labels[fw] ?? fw;
        select.appendChild(opt);
      });
      if (select.querySelector(`option[value="${current}"]`)) {
        select.value = current;
      }
    }

    // Framework toggle change — save and update select
    document.querySelectorAll(".framework-toggle").forEach((cb) => {
      cb.addEventListener("change", () => {
        const enabled: Record<string, boolean> = {};
        document.querySelectorAll(".framework-toggle").forEach((c) => {
          const fw = (c as HTMLInputElement).dataset.fw;
          if (fw) enabled[fw] = (c as HTMLInputElement).checked;
        });
        saveSetting("frameworks_enabled", enabled);
        updateFrameworkSelect();
        showToast("Frameworks updated");
      });
    });

    // Active framework change
    document
      .getElementById("scoring-framework")
      ?.addEventListener("change", (e) => {
        saveSetting("active_framework", (e.target as HTMLSelectElement).value);
        showToast("Active framework saved");
      });

    // Score display change
    document
      .getElementById("score-display")
      ?.addEventListener("change", (e) => {
        saveSetting("score_display", (e.target as HTMLSelectElement).value);
        showToast("Display preference saved");
      });

    // Test HA connection
    document
      .getElementById("test-connection")
      ?.addEventListener("click", async () => {
        const statusEl = document.getElementById("ha-status");
        if (statusEl)
          statusEl.innerHTML =
            '<span style="color: var(--accent);">Testing...</span>';
        try {
          const res = await fetch("/api/health");
          const data = await res.json();
          if (statusEl) {
            statusEl.innerHTML =
              data.status === "ok"
                ? '<span style="color: var(--accent);">✅ Connected — API healthy</span>'
                : '<span style="color: var(--danger);">⚠ API returned non-ok status</span>';
          }
        } catch {
          if (statusEl)
            statusEl.innerHTML =
              '<span style="color: var(--danger);">❌ Connection failed</span>';
        }
      });

    // Save HA settings
    document.getElementById("save-ha")?.addEventListener("click", async () => {
      const haUrl = (document.getElementById("ha-url") as HTMLInputElement)
        .value;
      const calEntity = (
        document.getElementById("calendar-entity") as HTMLInputElement
      ).value;
      await saveSetting("ha_url", haUrl);
      await saveSetting("calendar_entity", calEntity);
      showToast("HA settings saved");
    });

    // Add custom field
    document
      .getElementById("add-custom-field")
      ?.addEventListener("click", () => {
        const list = document.getElementById("custom-fields-list");
        if (!list) return;
        const row = document.createElement("div");
        row.className = "custom-field-row";
        row.innerHTML = `
        <input type="text" class="form-input" placeholder="Field name" />
        <select class="form-select">
          <option value="text">Text</option>
          <option value="number">Number</option>
          <option value="select">Select</option>
          <option value="date">Date</option>
          <option value="checkbox">Checkbox</option>
        </select>
        <button class="btn btn-ghost" style="padding: 4px 8px; color: var(--danger);" onclick="this.closest('.custom-field-row')?.remove()">×</button>
      `;
        list.appendChild(row);
      });

    // Init
    loadSettings();
  </script>
</Layout>

<style>
  .settings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 16px;
  }
  .custom-field-row {
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
  }
  .custom-field-row:last-child {
    border-bottom: none;
  }
  .integration-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
  }
  .integration-row:last-child {
    border-bottom: none;
  }
  .shortcut-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .shortcut-row {
    display: flex;
    gap: 12px;
    align-items: center;
    font-size: 13px;
  }
  kbd {
    background: var(--bg-hover);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 2px 8px;
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--text-primary);
  }
  .badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 500;
  }
  .badge-active {
    background: rgba(16, 185, 129, 0.15);
    color: var(--accent);
  }
  .badge-pending {
    background: rgba(107, 114, 128, 0.15);
    color: var(--text-muted);
  }
  @media (max-width: 768px) {
    .settings-grid {
      grid-template-columns: 1fr;
    }
  }
  .framework-row {
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }
  .framework-row:last-child {
    border-bottom: none;
  }
  .framework-info {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .framework-desc {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 2px;
  }
  /* Toggle switch */
  .toggle-label {
    position: relative;
    display: inline-block;
    width: 40px;
    height: 22px;
    flex-shrink: 0;
    cursor: pointer;
  }
  .toggle-label input {
    opacity: 0;
    width: 0;
    height: 0;
  }
  .toggle-slider {
    position: absolute;
    inset: 0;
    background: var(--bg-hover);
    border: 1px solid var(--border);
    border-radius: 11px;
    transition: all 200ms;
  }
  .toggle-slider::before {
    content: "";
    position: absolute;
    width: 16px;
    height: 16px;
    left: 2px;
    bottom: 2px;
    background: var(--text-muted);
    border-radius: 50%;
    transition: all 200ms;
  }
  .toggle-label input:checked + .toggle-slider {
    background: var(--accent);
    border-color: var(--accent);
  }
  .toggle-label input:checked + .toggle-slider::before {
    transform: translateX(18px);
    background: white;
  }
</style>
