---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Meitheal — Page Not Found">
  <span slot="page-title">404</span>

  <div class="flex flex-col items-center justify-center" style="min-height: 50vh;">
    <div style="font-size: 72px; margin-bottom: 16px;">☘</div>
    <h1 class="text-2xl font-bold text-text-primary mb-2">Page Not Found</h1>
    <p class="text-text-muted text-sm mb-6">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div style="display: flex; gap: 12px;">
      <a href="/" class="btn btn-primary">Go Home</a>
      <a href="/tasks" class="btn btn-ghost">View Tasks</a>
    </div>
  </div>
</Layout>
