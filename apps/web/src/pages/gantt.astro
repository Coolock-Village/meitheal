---
import Layout from "../layouts/Layout.astro";
import TaskViewTabs from "../components/tasks/TaskViewTabs.astro";
import { t } from "../i18n/translations";
import type { Locale } from "../lib/locale";
import {
  ensureSchema,
  getPersistenceClient,
} from "@domains/tasks/persistence/store";
import { TaskRepository } from "@domains/tasks/persistence/task-repository";
import { STATUS } from "../lib/status-config";

interface TaskRecord {
  id: string;
  title: string;
  status: string;
  priority: number;
  due_date: string | null;
  start_date: string | null;
  color: string | null;
  task_type: string | null;
  progress: number | null;
  ticket_number: number | null;
  parent_id: string | null;
  [key: string]: any;
}

const cookieLocale = Astro.cookies.get("meitheal-locale")?.value;
const locale: Locale = cookieLocale === "ga" ? "ga" : "en";

let tasks: TaskRecord[] = [];
try {
  await ensureSchema();
  const repo = new TaskRepository(getPersistenceClient());
  tasks = (await repo.getGanttTasks()) as unknown as TaskRecord[];
} catch (e) {
  /* DB not available */
}

// Gantt Timeframe Logic: Let's show a rolling window (e.g. 1 week ago -> 4 weeks ahead)
const today = new Date();
today.setHours(0, 0, 0, 0);

const startDate = new Date(today);
startDate.setDate(today.getDate() - 7); // Start 7 days ago

const endDate = new Date(startDate);
endDate.setDate(startDate.getDate() + 35); // Show 35 days total (5 weeks)

const days: Date[] = [];
for (let d = new Date(startDate); d < endDate; d.setDate(d.getDate() + 1)) {
  days.push(new Date(d));
}

// Format tasks for the Gantt Chart
const ganttTasks = tasks.map(task => {
  const start = task.start_date ? new Date(String(task.start_date)) : (task.due_date ? new Date(String(task.due_date)) : today);
  const end = task.due_date ? new Date(String(task.due_date)) : new Date(start);

  // Normalize times for grid placement
  start.setHours(0,0,0,0);
  end.setHours(0,0,0,0);

  // Avoid negative widths by ensuring end >= start
  if (end < start) end.setTime(start.getTime());

  // Calculate grid columns
  const diffStart = Math.round((start.getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24));
  const diffEnd = Math.round((end.getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24));

  // Grid column index is 1-based, plus we have a label column (so add 2 to the difference)
  // Assuming grid-template-columns: 250px repeat(35, 1fr)
  // Day 0 (startDate) is column 2
  const colStart = Math.max(2, diffStart + 2);
  const colEnd = Math.min(days.length + 2, diffEnd + 3); // +3 because CSS grid columns are exclusive ending

  return {
    ...task,
    colStart,
    colEnd,
    isVisible: colEnd > 2 && colStart <= days.length + 1
  };
}).filter(t => t.isVisible);

// Grouping logic based on Meitheal's DDD (Phase 20 typed epics)
const epics = ganttTasks.filter(t => String(t.task_type) === 'epic');

---
<Layout title={`Meitheal — Gantt`}>
  <span slot="page-title">📊 Timeline</span>
  <div slot="actions">
    <button type="button" class="btn btn-primary" id="create-task-btn"
      >{t("tasks.new_task", locale)}</button
    >
  </div>

  <TaskViewTabs activeView="gantt" />

  <div class="gantt-container">
    <div class="gantt-grid" style={`grid-template-columns: 250px repeat(${days.length}, 1fr);`}>

      <!-- HEADER ROW -->
      <div class="gantt-header-cell task-list-header">Task</div>
      {days.map(d => {
        const isToday = d.getTime() === today.getTime();
        const isWeekend = d.getDay() === 0 || d.getDay() === 6;
        return (
          <div class={`gantt-header-cell day-header ${isToday ? 'is-today' : ''} ${isWeekend ? 'is-weekend' : ''}`}>
             <div class="day-name">{d.toLocaleDateString(locale, { weekday: 'short' }).substring(0, 1)}</div>
             <div class="day-num">{d.getDate()}</div>
          </div>
        )
      })}

      <!-- BACKGROUND GRID LINES -->
      <div class="gantt-bg-row" style={`grid-column: 1 / span ${days.length + 1}`}></div>
      {days.map((d, index) => {
        const isWeekend = d.getDay() === 0 || d.getDay() === 6;
        const isToday = d.getTime() === today.getTime();
        return (
          <div
            class={`gantt-bg-line ${isWeekend ? 'bg-weekend' : ''} ${isToday ? 'bg-today' : ''}`}
            style={`grid-column: ${index + 2}; grid-row: 2 / 1000;`}
          />
        )
      })}

      <!-- TASKS (Grouped by Epic mapping) -->
      {(() => {
        let currentRow = 2; // +2 offset for the header row

        // Helper to render a task row
        const renderTaskRow = (task: typeof ganttTasks[0], indent = 0) => {
          const isDone = String(task.status) === STATUS.COMPLETE;
          const r = currentRow++;
          return (
            <>
              <!-- Task Label -->
              <div class={`gantt-row-label ${isDone ? 'is-done' : ''}`} style={`grid-row: ${r}; grid-column: 1; padding-left: ${12 + indent * 16}px;`}>
                 <span class="type-icon">
                   {String(task.task_type) === 'epic' ? '🎯' : String(task.task_type) === 'story' ? '📖' : '✅'}
                 </span>
                 <span class="task-title-text" style={String(task.task_type) === 'epic' ? 'font-weight: 600;' : ''}>{String(task.title)}</span>
                 {Number(task.progress ?? 0) > 0 && <span class="task-progress">{task.progress}%</span>}
              </div>

              <!-- Task Bar -->
              {task.colStart < task.colEnd && (
                  <div
                    class={`gantt-bar ${isDone ? 'is-done' : ''} type-${String(task.task_type)}`}
                    style={`grid-row: ${r}; grid-column: ${task.colStart} / ${task.colEnd}; background-color: ${task.color || 'var(--accent)'};`}
                    title={`${task.title} (${task.start_date || '?'} to ${task.due_date || '?'})`}
                    data-id={String(task.id)}
                  >
                     <span class="gantt-bar-label">{String(task.title)}</span>
                  </div>
              )}
            </>
          );
        };

        const rows = [];

        // 1. Render Epics and their children
        epics.forEach(epic => {
          rows.push(renderTaskRow(epic, 0));

          // Find children of this epic
          const children = ganttTasks.filter(t => t.parent_id === epic.id && t.id !== epic.id);
          children.forEach(child => {
            rows.push(renderTaskRow(child, 1));
            // Grandchildren (tasks under stories under epics)
            const grandchildren = ganttTasks.filter(t => t.parent_id === child.id && t.id !== child.id);
            grandchildren.forEach(gc => {
              rows.push(renderTaskRow(gc, 2));
            });
          });
        });

        // 2. Render orphaned stories/tasks (no parent, or parent not in this timeframe)
        const renderedIds = new Set(epics.map(e => e.id));
        ganttTasks.forEach(t => {
          if (t.parent_id && epics.find(e => e.id === t.parent_id)) renderedIds.add(t.id); // Child of epic
          if (t.parent_id) {
            const parent = ganttTasks.find(pt => pt.id === t.parent_id);
            if (parent && parent.parent_id && epics.find(e => e.id === parent.parent_id)) {
               renderedIds.add(t.id); // Grandchild
            }
          }
        });

        const orphaned = ganttTasks.filter(t => !renderedIds.has(t.id));
        if (epics.length > 0 && orphaned.length > 0) {
           // Add a separator for Unassigned
           const r = currentRow++;
           rows.push(
             <div class="gantt-row-label unassigned-header" style={`grid-row: ${r}; grid-column: 1; background: var(--bg-secondary); font-weight: 600; color: var(--text-muted);`}>
               Other Tasks
             </div>
           );
        }

        orphaned.forEach(task => {
          rows.push(renderTaskRow(task, 0));
        });

        return rows;
      })()}

      {ganttTasks.length === 0 && (
         <div class="gantt-empty" style={`grid-row: 2; grid-column: 1 / span ${days.length + 1};`}>
            No tasks scheduled in this timeframe. Set Start Dates and Due Dates.
         </div>
      )}

    </div>
  </div>
</Layout>

<style>
  .gantt-container {
    overflow-x: auto;
    overflow-y: auto;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    max-height: calc(100vh - 200px);
  }

  .gantt-grid {
    display: grid;
    min-width: 1200px; /* Ensure minimum width to prevent super squished days */
    border-bottom: 1px solid var(--border);
  }

  .gantt-header-cell {
    position: sticky;
    top: 0;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
    border-right: 1px solid var(--border);
    padding: 8px 4px;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: var(--text-secondary);
  }

  .task-list-header {
    left: 0;
    z-index: 20; /* Keep above columns when scrolling right */
    align-items: flex-start;
    padding-left: 16px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .day-header.is-today {
    color: var(--accent);
    background: rgba(99, 102, 241, 0.1);
  }

  .day-header.is-weekend {
    background: var(--bg-primary);
    opacity: 0.7;
  }

  .day-num {
    font-weight: 600;
    font-size: 13px;
    margin-top: 2px;
  }

  .gantt-bg-line {
    border-right: 1px solid color-mix(in srgb, var(--border) 40%, transparent);
    z-index: 1;
  }

  .gantt-bg-line.bg-weekend {
    background-color: rgba(0,0,0,0.1);
  }

  .gantt-bg-line.bg-today {
    border-right: 1px solid var(--accent);
    background-color: rgba(99, 102, 241, 0.05);
  }

  .gantt-row-label {
    position: sticky;
    left: 0;
    background: var(--bg-card);
    border-bottom: 1px solid color-mix(in srgb, var(--border) 40%, transparent);
    border-right: 1px solid var(--border);
    padding: 0 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    z-index: 15;
    font-size: 13px;
    min-height: 48px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .gantt-row-label.is-done {
    opacity: 0.5;
  }

  .task-title-text {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .task-progress {
    font-size: 10px;
    color: var(--text-muted);
    background: var(--bg-hover);
    padding: 2px 6px;
    border-radius: 10px;
  }

  .gantt-bar {
    position: relative;
    margin: 8px 0; /* Padding top/bottom within the row */
    border-radius: 6px;
    z-index: 5;
    box-shadow: 0 2px 6px rgba(0,0,0,0.2);
    display: flex;
    align-items: center;
    padding: 0 8px;
    color: white;
    font-size: 11px;
    font-weight: 500;
    overflow: hidden;
    white-space: nowrap;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
    cursor: pointer;
    transition: transform 0.15s, filter 0.15s;
    height: 32px;
  }

  .gantt-bar:hover {
    transform: translateY(-1px);
    filter: brightness(1.1);
  }

  .gantt-bar.is-done {
    opacity: 0.6;
    background-image: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 10px,
      rgba(0,0,0,0.1) 10px,
      rgba(0,0,0,0.1) 20px
    );
  }

  .gantt-bar-label {
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .gantt-empty {
    padding: 32px;
    text-align: center;
    color: var(--text-muted);
    font-size: 14px;
    font-style: italic;
  }
</style>

<script>
  // Handlers to open task details on click
  document.querySelectorAll(".gantt-bar").forEach(bar => {
    bar.addEventListener("click", () => {
      const id = (bar as HTMLElement).dataset.id;
      if (id && typeof window.openTaskDetail === "function") {
         window.openTaskDetail(id);
      } else if (id) {
         window.location.href = (window.__ingress_path || "") + `/tasks#edit-${id}`;
      }
    });
  });
</script>
