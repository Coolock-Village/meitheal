---
import Layout from "../layouts/Layout.astro";
import EmptyState from "../components/ui/EmptyState.astro";
import LabelBadges from "../components/ui/LabelBadges.astro";
import StreakBadge from "../components/gamification/StreakBadge.astro";
import GamificationWidget from "../components/gamification/GamificationWidget.astro";
import { getStats as getGamificationStats, getWeeklyData as getGamificationWeekly, getLevel, getProgressToNextLevel } from "@domains/gamification";
import { t } from "../i18n/translations";
import type { Locale } from "../lib/locale";
import {
  ensureSchema,
  getPersistenceClient,
} from "@domains/tasks/persistence/store";
import { TaskRepository } from "@domains/tasks/persistence/task-repository";

// i18n: resolve locale from cookie
const cookieLocale = Astro.cookies.get("meitheal-locale")?.value;
const locale: Locale = cookieLocale === "ga" ? "ga" : "en";

let tasks: Record<string, unknown>[] = [];
let favorites: Record<string, unknown>[] = [];
let openTasks: Record<string, unknown>[] = [];
let stats = { total: 0, open: 0, active: 0, completed: 0, overdue: 0 };
let gamificationStats = { currentStreak: 0, todayCompleted: 0, totalCompleted: 0, longestStreak: 0, totalPoints: 0 };
let gamificationWeekly: Array<{ date: string; completedCount: number; streakCount: number; points: number }> = [];
let boardMap: Record<string, { name: string; color: string }> = {
  default: { name: "Default", color: "#6366F1" },
};

try {
  await ensureSchema();
  const repo = new TaskRepository(getPersistenceClient());
  tasks = await repo.getRecentTasks(10);
  favorites = await repo.getFavoriteTasks(5);
  openTasks = await repo.getOpenTasks(15);
  stats = await repo.getStatusCounts();
  stats.overdue = await repo.getOverdueCount();
  const boards = await repo.getBoards();
  boardMap = Object.fromEntries(
    Object.entries(boards).map(([k, v]) => [
      k,
      { name: v.name, color: v.color },
    ]),
  );
} catch (e) {
  // DB not available - show empty state
}

try {
  gamificationStats = await getGamificationStats();
  gamificationWeekly = await getGamificationWeekly();
} catch {
  // Gamification not available
}
const gamLevel = getLevel(gamificationStats.totalPoints);
const gamProgress = getProgressToNextLevel(gamificationStats.totalPoints);

import { PRIORITY_LABELS } from "../lib/priority-config";
import { STATUS_LABELS as statusLabels } from "../lib/status-config";
const priorityLabels = PRIORITY_LABELS;

// Vikunja-inspired: time-of-day greeting
const hour = new Date().getHours();
const greeting =
  hour < 12
    ? t("dashboard.greeting_morning", locale)
    : hour < 18
      ? t("dashboard.greeting_afternoon", locale)
      : t("dashboard.greeting_evening", locale);

// Relative time helper for due dates
function relativeTime(dueDate: string): string {
  const due = new Date(dueDate);
  const now = new Date();
  const diffMs = due.getTime() - now.getTime();
  const absDiffMs = Math.abs(diffMs);
  const hours = Math.round(absDiffMs / (1000 * 60 * 60));
  const days = Math.round(absDiffMs / (1000 * 60 * 60 * 24));
  const prefix = diffMs < 0 ? "Overdue by" : "Due in";
  if (hours < 1) return diffMs < 0 ? "Overdue" : "Due soon";
  if (hours < 24) return `${prefix} ${hours} hour${hours !== 1 ? "s" : ""}`;
  return `${prefix} ${days} day${days !== 1 ? "s" : ""}`;
}

// Build context hint for greeting based on urgency
const greetingHint =
  stats.overdue > 0
    ? `— ${stats.overdue} overdue`
    : stats.active > 0
      ? `— ${stats.active} in progress`
      : "✦";

import { getPriorityColor } from "../lib/priority-config";
---

<Layout title={`Meitheal — ${greeting}!`}>
  <span slot="page-title"
    >{greeting}! {
      stats.overdue > 0 ? (
        <a
          href="/tasks?status=overdue"
          class="text-text-muted text-base font-normal hover:text-danger transition-colors no-underline hover:underline"
        >
          {greetingHint}
        </a>
      ) : stats.active > 0 ? (
        <a
          href="/tasks?status=active"
          class="text-text-muted text-base font-normal hover:text-accent transition-colors no-underline hover:underline"
        >
          {greetingHint}
        </a>
      ) : (
        <span class="text-text-muted text-base font-normal">
          {greetingHint}
        </span>
      )
    }</span
  >
  <button
    type="button"
    slot="actions"
    class="btn btn-primary"
    id="quick-add-btn">{t("dashboard.new_task", locale)}</button
  >

  <div class="stats-grid">
    {gamificationStats.currentStreak > 0 && (
      <div class="stat-card" title="Your current daily completion streak">
        <StreakBadge streak={gamificationStats.currentStreak} />
        <div>
          <span class="stat-value">{gamificationStats.todayCompleted}</span>
          <span class="stat-label">today</span>
        </div>
      </div>
    )}
    <a
      href="/tasks"
      class="stat-card stat-card-link"
      title="Open tasks — not yet completed"
    >
      <span class="stat-icon">📋</span>
      <div>
        <div class="stat-value">{stats.open}</div>
        <div class="stat-label">Open</div>
      </div>
    </a>
    <a
      href="/tasks?status=active"
      class="stat-card stat-card-link stat-card-entrance"
      id="stat-active"
      title="Tasks currently in progress or active"
    >
      <span class="stat-icon">⚡</span>
      <div>
        <div class="stat-value">{stats.active}</div>
        <div class="stat-label">{t("dashboard.active", locale)}</div>
      </div>
    </a>
    <a
      href="/tasks?status=complete"
      class="stat-card stat-card-link"
      title="Tasks marked as done"
    >
      <span class="stat-icon">✅</span>
      <div>
        <div class="stat-value">{stats.completed}</div>
        <div class="stat-label">{t("dashboard.completed", locale)}</div>
      </div>
    </a>
    <a
      href="/tasks?status=overdue"
      id="stat-overdue"
      class={`stat-card stat-card-link stat-card-entrance ${stats.overdue > 0 ? "stat-card-danger" : ""}`}
      title="Tasks past their due date across all boards"
    >
      <span class="stat-icon">⏰</span>
      <div>
        <div
          class="stat-value"
          style={stats.overdue > 0 ? "color: var(--danger)" : ""}
        >
          {stats.overdue}
        </div>
        <div class="stat-label">{t("dashboard.overdue", locale)}</div>
      </div>
    </a>
  </div>

  <div class="card" style="margin-bottom: 20px; padding: 0; overflow: hidden;">
    <GamificationWidget stats={gamificationStats} weekly={gamificationWeekly} level={gamLevel} progressToNext={gamProgress} />
  </div>
  {
    favorites.length > 0 && (
      <div class="card" style="margin-bottom: 20px;">
        <div class="card-header">
          <div>
            <div class="card-title">⭐ {t("dashboard.favorites", locale)}</div>
            <div class="card-subtitle">
              {favorites.length}{" "}
              {favorites.length !== 1
                ? t("dashboard.pinned_tasks_plural", locale, {
                    count: String(favorites.length),
                  })
                : t("dashboard.pinned_tasks", locale, {
                    count: String(favorites.length),
                  })}
            </div>
          </div>
        </div>
        <div class="task-list">
          {favorites.map((fav) => (
            <div
              class="task-item"
              data-id={String(fav.id)}
              style="cursor:pointer;"
            >
              <div class="task-title">
                <span
                  class="priority-dot"
                  style={`background: ${getPriorityColor(Number(fav.priority ?? 3))}`}
                ></span>
                {String(fav.title)}
              </div>
              {fav.due_date && (
                <span class="text-xs text-text-muted">
                  {relativeTime(String(fav.due_date))}
                </span>
              )}
            </div>
          ))}
        </div>
      </div>
    )
  }

  <div class="card" style="margin-bottom: 20px;">
    <div class="card-header">
      <div>
        <div class="card-title">{t("dashboard.quick_add", locale)}</div>
        <div class="card-subtitle">
          {t("dashboard.quick_add_subtitle", locale)}
        </div>
      </div>
    </div>
    <form
      id="quick-add-form"
      class="max-w-xl flex flex-col sm:flex-row gap-3 items-stretch"
    >
      <input
        type="text"
        class="form-input"
        style="flex: 1;"
        id="quick-title"
        placeholder={t("dashboard.quick_add_placeholder", locale)}
        autocomplete="off"
        autofocus
        required
        minlength="2"
        maxlength="200"
      />
      <button type="submit" class="btn btn-primary"
        >{t("dashboard.add", locale)}</button
      >
    </form>
  </div>

  <!-- Open Tasks -->
  <div class="card" style="margin-bottom: 20px;" id="my-open-tasks-card">
    <div class="card-header">
      <div>
        <div class="card-title" id="open-tasks-title">🎯 Open Tasks</div>
        <div class="card-subtitle" id="my-open-count">
          {openTasks.length} open task{openTasks.length !== 1 ? "s" : ""}
        </div>
      </div>
      <div style="display: flex; gap: 8px; align-items: center;">
        <select
          class="form-select"
          id="my-open-user-filter"
          style="font-size: 12px; padding: 4px 8px; min-width: 120px;"
        >
          <option value="all">All users</option>
        </select>
        <a
          href="/kanban"
          class="btn btn-ghost"
          id="kanban-link"
          style="font-size: 12px;">Kanban →</a
        >
      </div>
    </div>
    <div class="task-list" id="my-open-list">
      {
        openTasks.length === 0 ? (
          <div style="padding: 20px; text-align: center; color: var(--text-muted); font-size: 13px;">
            🎉 All caught up — no open tasks!
          </div>
        ) : (
          openTasks.map((task) => {
            const p = Number(task.priority ?? 3);
            const priColor = getPriorityColor(p);
            const ticketNum = task.ticket_number
              ? `MTH-${String(task.ticket_number).padStart(3, "0")}`
              : null;
            const statusLabel =
              statusLabels[String(task.status)] ?? String(task.status);
            return (
              <div
                class="task-item"
                data-id={String(task.id)}
                data-assigned={String(task.assigned_to ?? "")}
                style="cursor:pointer;"
              >
                <div class="task-title">
                  <span class="priority-dot" style={`background: ${priColor}`}></span>
                  {ticketNum && (
                    <span style="font-size: 11px; color: var(--text-muted); margin-right: 6px;">
                      {ticketNum}
                    </span>
                  )}
                  {String(task.title)}
                </div>
                <div style="display: flex; gap: 6px; align-items: center;">
                  <span class={`task-badge badge-${String(task.status)}`}>
                    {statusLabel}
                  </span>
                  {task.due_date && (
                    <span class="text-xs text-text-muted">
                      {relativeTime(String(task.due_date))}
                    </span>
                  )}
                </div>
              </div>
            );
          })
        )
      }
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <div>
        <div class="card-title">{t("dashboard.recent_tasks", locale)}</div>
        <div class="card-subtitle">
          {
            t("dashboard.tasks_of_total", locale, {
              count: String(tasks.length),
              total: String(stats.total),
            })
          }
        </div>
      </div>
      <a href="/tasks" class="btn btn-ghost"
        >{t("dashboard.view_all", locale)}</a
      >
    </div>
    <div class="bento-grid" id="task-list">
      {
        tasks.length === 0 ? (
          <div class="bento-empty-state">
            <EmptyState
              title={t("dashboard.no_tasks_yet", locale)}
              description={t("dashboard.create_first_task", locale)}
            >
              <span slot="icon" style="font-size: 48px; line-height: 1;">
                ✦
              </span>
            </EmptyState>
          </div>
        ) : (
          tasks.map((task) => {
            const p = Number(task.priority ?? 3);
            const isDone = String(task.status) === "complete";
            const taskColor = task.color
              ? String(task.color)
              : p === 1
                ? "#ef4444"
                : p === 2
                  ? "#f97316"
                  : p === 4
                    ? "#22c55e"
                    : p === 5
                      ? "#6b7280"
                      : "#eab308";
            const boardId = String(task.board_id ?? "default");
            const board = boardMap[boardId] ?? {
              name: "Default",
              color: "#6366F1",
            };
            const ticketNum = task.ticket_number
              ? `MTH-${String(task.ticket_number).padStart(3, "0")}`
              : null;
            return (
              <div
                class={`bento-card ${isDone ? "bento-card-done" : ""}`}
                data-id={String(task.id)}
                data-board={boardId}
                style={`border-left: 3px solid ${taskColor};`}
              >
                <div class="bento-card-body">
                  <div class="bento-card-header">
                    <div class={`bento-card-title ${isDone ? "done" : ""}`}>
                      {ticketNum && (
                        <span class="bento-ticket-key">{ticketNum}</span>
                      )}
                      {String(task.title)}
                    </div>
                  </div>
                  <div class="bento-card-footer">
                    <span
                      class={`task-badge badge-${isDone ? "complete" : String(task.status)}`}
                    >
                      {statusLabels[String(task.status)] ?? String(task.status)}
                    </span>
                    <span
                      class="bento-board-badge"
                      style={`background: ${board.color}20; color: ${board.color}; border-color: ${board.color}40;`}
                    >
                      {board.name}
                    </span>
                    {task.due_date && (
                      <span class="bento-card-due">
                        {relativeTime(String(task.due_date))}
                      </span>
                    )}
                  </div>
                  {task.labels && String(task.labels) !== "[]" && (
                    <LabelBadges labels={String(task.labels)} compact max={2} />
                  )}
                </div>
                <div class="bento-card-actions">
                  <button
                    class="card-action-btn card-edit-btn"
                    data-id={String(task.id)}
                    title="Edit task"
                  >
                    ✏️
                  </button>
                  <button
                    class="card-action-btn card-ai-btn"
                    data-title={String(task.title)}
                    data-desc={task.description ? String(task.description) : ""}
                    data-status={String(task.status ?? "pending")}
                    data-priority={String(p)}
                    title="Ask AI"
                  >
                    🤖
                  </button>
                </div>
              </div>
            );
          })
        )
      }
    </div>
  </div>

  <div
    id="toast-container"
    class="toast-container"
    aria-live="polite"
    role="status"
    data-no-scroll-lock="true"
  >
  </div>

  <script>
    import "@lib/dashboard-controller"
  </script>
</Layout>
