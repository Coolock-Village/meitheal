</style>

<style is:global>
  /* T-1914: Keyboard focus ring */
  .kanban-card.kb-focused {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    box-shadow: 0 0 12px rgba(16, 185, 129, 0.3);
  }

  /* T-1911: Due-date color badges */
  .kanban-card-due.due-overdue {
    color: var(--danger);
    font-weight: 600;
  }
  .kanban-card-due.due-today {
    color: var(--warning);
    font-weight: 600;
  }
  .kanban-card-due.due-upcoming {
    color: var(--accent);
  }

  /* T-1915: Collapsed column state */
  .kanban-column.collapsed {
    min-width: 48px !important;
    max-width: 48px !important;
    padding: 8px 4px;
    transition: all 200ms ease;
  }
  .kanban-column.collapsed .kanban-column-header {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
</style>
