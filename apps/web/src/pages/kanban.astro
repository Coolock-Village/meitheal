---
import Layout from "../layouts/Layout.astro";
import {
  ensureSchema,
  getPersistenceClient,
} from "@domains/tasks/persistence/store";

let tasks: Record<string, unknown>[] = [];
try {
  await ensureSchema();
  const client = getPersistenceClient();
  const result = await client.execute(
    "SELECT id, title, description, status, priority, due_date, labels, framework_payload, calendar_sync_state, board_id, custom_fields, start_date, end_date, progress, color, is_favorite, created_at FROM tasks ORDER BY priority ASC, created_at DESC",
  );
  tasks = result.rows as Record<string, unknown>[];
} catch (e) {
  /* DB not available */
}

const columns = [
  {
    key: "pending",
    label: "Pending",
    icon: "📋",
    includes: ["pending", "todo"],
    builtIn: true,
  },
  {
    key: "active",
    label: "Active",
    icon: "⚡",
    includes: ["active", "in_progress"],
    builtIn: true,
  },
  {
    key: "complete",
    label: "Complete",
    icon: "✅",
    includes: ["complete", "done"],
    builtIn: true,
  },
];

const priorityLabels: Record<number, string> = {
  1: "Critical",
  2: "High",
  3: "Medium",
  4: "Low",
  5: "Minimal",
};
const priorityColors: Record<number, string> = {
  1: "#ef4444",
  2: "#f59e0b",
  3: "#3b82f6",
  4: "#10b981",
  5: "#6b7280",
};
---

<Layout title="Meitheal — Kanban">
  <span slot="page-title">Kanban Board</span>
  <div slot="actions" style="display: flex; gap: 8px; align-items: center;">
    <div class="view-switcher" role="group" aria-label="View mode">
      <a href="/tasks" class="view-btn" title="List view" aria-label="List view"
        >☰</a
      >
      <a
        href="/kanban"
        class="view-btn active"
        title="Kanban board"
        aria-label="Kanban board">▦</a
      >
      <a
        href="/table"
        class="view-btn"
        title="Table view"
        aria-label="Table view">⊞</a
      >
    </div>
    <button class="btn btn-ghost" id="manage-lanes-btn" title="Manage swimlanes"
      >⚙ Lanes</button
    >
  </div>

  <!-- Lane management panel -->
  <div class="lane-mgmt" id="lane-mgmt" style="display: none;">
    <div class="lane-mgmt-inner">
      <strong>Manage Swimlanes</strong>
      <div id="lane-list"></div>
      <div style="display: flex; gap: 8px; margin-top: 8px;">
        <input
          type="text"
          class="form-input"
          id="new-lane-input"
          placeholder="New lane name..."
          style="flex: 1; font-size: 13px;"
        />
        <button
          class="btn btn-primary"
          id="add-lane-btn"
          style="font-size: 13px;">+ Add</button
        >
      </div>
    </div>
  </div>

  <div class="kanban-board">
    {
      columns.map((col) => {
        const colTasks = tasks.filter((t) =>
          col.includes.includes(String(t.status)),
        );
        return (
          <div
            class="kanban-column"
            data-status={col.key}
            ondrop="handleDrop(event)"
            ondragover="event.preventDefault(); this.classList.add('drag-over')"
            ondragleave="this.classList.remove('drag-over')"
          >
            <div class="kanban-column-header">
              <span>
                {col.icon} {col.label}
              </span>
              <span class="kanban-count">{colTasks.length}</span>
            </div>
            <div class="kanban-cards">
              {colTasks.map((task) => {
                const p = Number(task.priority ?? 3);
                const fp =
                  typeof task.framework_payload === "string"
                    ? JSON.parse(String(task.framework_payload))
                    : {};
                const rice =
                  fp.reach && fp.impact && fp.confidence && fp.effort
                    ? Math.round(
                        (Number(fp.reach) *
                          Number(fp.impact) *
                          Number(fp.confidence)) /
                          Number(fp.effort),
                      )
                    : null;
                // T-1911: Due-date status computation
                const dueDate = task.due_date
                  ? new Date(String(task.due_date))
                  : null;
                const today = new Date();
                today.setHours(0, 0, 0, 0);
                const dueStatus = dueDate
                  ? dueDate < today
                    ? "overdue"
                    : dueDate.toDateString() === new Date().toDateString()
                      ? "today"
                      : "upcoming"
                  : null;
                return (
                  <div
                    class="kanban-card"
                    draggable="true"
                    data-id={String(task.id)}
                    data-title={String(task.title)}
                    data-desc={
                      task.description
                        ? String(task.description).slice(0, 200)
                        : ""
                    }
                    data-priority={String(p)}
                    data-status={String(task.status)}
                    data-board={String(task.board_id ?? "default")}
                    ondragstart="event.dataTransfer.setData('text/plain', this.dataset.id); this.classList.add('dragging');"
                    ondragend="this.classList.remove('dragging');"
                    style={`border-left: 3px solid ${task.color ? String(task.color) : priorityColors[p]};`}
                  >
                    <div class="kanban-card-header">
                      <div class="kanban-card-title">{String(task.title)}</div>
                      {Number(task.is_favorite ?? 0) === 1 && (
                        <span class="kanban-fav" title="Favorite">
                          ★
                        </span>
                      )}
                    </div>
                    {task.description && String(task.description).trim() && (
                      <div class="kanban-card-desc">
                        {String(task.description).slice(0, 80)}
                        {String(task.description).length > 80 ? "…" : ""}
                      </div>
                    )}
                    <div class="kanban-card-meta">
                      <span
                        class="priority-dot"
                        style={`background: ${priorityColors[p]}`}
                        title={priorityLabels[p]}
                      />
                      <span
                        style={`color: ${priorityColors[p]}; font-size: 11px;`}
                      >
                        {priorityLabels[p]}
                      </span>
                      {task.due_date ? (
                        <span
                          class={`kanban-card-due ${dueStatus ? `due-${dueStatus}` : ""}`}
                        >
                          {dueStatus === "overdue"
                            ? "🔴"
                            : dueStatus === "today"
                              ? "🟡"
                              : "🟢"}{" "}
                          {String(task.due_date).split("T")[0]}
                        </span>
                      ) : null}
                      {rice ? (
                        <span class="kanban-rice-badge">RICE: {rice}</span>
                      ) : null}
                      {String(task.calendar_sync_state) === "confirmed" && (
                        <span class="kanban-sync-badge" title="Calendar synced">
                          📅✓
                        </span>
                      )}
                    </div>
                    {/* Progress bar */}
                    {Number(task.progress ?? 0) > 0 && (
                      <div class="kanban-progress">
                        <div class="kanban-progress-track">
                          <div
                            class="kanban-progress-bar"
                            style={`width: ${Number(task.progress)}%`}
                          />
                        </div>
                        <span class="kanban-progress-text">
                          {Number(task.progress)}%
                        </span>
                      </div>
                    )}
                    {/* Labels */}
                    {(() => {
                      try {
                        const lbls = JSON.parse(String(task.labels ?? "[]"));
                        if (Array.isArray(lbls) && lbls.length > 0) {
                          return (
                            <div class="kanban-labels">
                              {lbls.map(
                                (
                                  l:
                                    | string
                                    | {
                                        name: string;
                                        color?: string;
                                        hex_color?: string;
                                      },
                                ) => {
                                  const labelName =
                                    typeof l === "string" ? l : l.name;
                                  const labelColor =
                                    typeof l === "object"
                                      ? l.hex_color || l.color || ""
                                      : "";
                                  return (
                                    <span
                                      class="label-chip"
                                      style={
                                        labelColor
                                          ? `background: ${labelColor}20; color: ${labelColor}; border-color: ${labelColor}40;`
                                          : ""
                                      }
                                    >
                                      {labelName}
                                    </span>
                                  );
                                },
                              )}
                            </div>
                          );
                        }
                      } catch {
                        /* skip */
                      }
                      return null;
                    })()}
                    {/* Custom fields */}
                    {(() => {
                      try {
                        const cf =
                          typeof task.custom_fields === "string"
                            ? JSON.parse(String(task.custom_fields ?? "{}"))
                            : {};
                        const keys = Object.keys(cf);
                        if (keys.length > 0) {
                          return (
                            <div class="kanban-custom-fields">
                              {keys.slice(0, 4).map((k) => (
                                <span
                                  class="kanban-cf-chip"
                                  title={`${k}: ${cf[k]}`}
                                >
                                  {k}: {String(cf[k]).slice(0, 20)}
                                </span>
                              ))}
                              {keys.length > 4 && (
                                <span class="kanban-cf-chip">
                                  +{keys.length - 4} more
                                </span>
                              )}
                            </div>
                          );
                        }
                      } catch {
                        /* skip */
                      }
                      return null;
                    })()}
                    <div class="kanban-card-actions">
                      <button
                        class="card-action-btn card-edit-btn"
                        data-id={String(task.id)}
                        title="Edit task"
                      >
                        ✏️
                      </button>
                      <button
                        class="card-action-btn card-ai-btn"
                        data-title={String(task.title)}
                        data-desc={
                          task.description ? String(task.description) : ""
                        }
                        data-status={String(task.status ?? "pending")}
                        data-priority={String(p)}
                        title="Ask AI"
                      >
                        🤖
                      </button>
                      <button
                        class="card-action-btn card-dup-btn"
                        data-id={String(task.id)}
                        title="Duplicate"
                      >
                        ⧉
                      </button>
                    </div>
                  </div>
                );
              })}
              {colTasks.length === 0 && (
                <div class="kanban-empty">Drop tasks here</div>
              )}
            </div>
            <button
              class="kanban-add-btn"
              data-status={col.key}
              aria-label={`Add task to ${col.label}`}
            >
              + Add Task
            </button>
          </div>
        );
      })
    }
  </div>

  <div id="toast-container" class="toast-container"></div>

  <script is:inline>
    async function handleDrop(e) {
      e.preventDefault();
      const col = e.currentTarget;
      col.classList.remove("drag-over");
      const taskId = e.dataTransfer.getData("text/plain");
      const newStatus = col.dataset.status;
      if (!taskId || !newStatus) return;

      // T-1902: Optimistic DOM update — no page reload
      const card = document.querySelector(`.kanban-card[data-id="${taskId}"]`);
      if (!card) return;

      // Move card to target column's card container
      const oldCol = card.closest(".kanban-column");
      const targetCards = col.querySelector(".kanban-cards");
      if (targetCards) {
        // Remove empty state if present
        const empty = targetCards.querySelector(".kanban-empty");
        if (empty) empty.remove();
        targetCards.appendChild(card);
        card.dataset.status = newStatus;
      }

      // Update column counts
      [oldCol, col].forEach((c) => {
        if (!c) return;
        const count = c.querySelector(".kanban-count");
        const cards = c.querySelectorAll(".kanban-card");
        if (count) count.textContent = cards.length;
        // Show empty state if column is now empty
        if (cards.length === 0) {
          const cardsContainer = c.querySelector(".kanban-cards");
          if (
            cardsContainer &&
            !cardsContainer.querySelector(".kanban-empty")
          ) {
            const emptyDiv = document.createElement("div");
            emptyDiv.className = "kanban-empty";
            emptyDiv.textContent = "Drop tasks here";
            cardsContainer.appendChild(emptyDiv);
          }
        }
      });

      // Toast feedback
      const container = document.getElementById("toast-container");
      const toast = document.createElement("div");
      toast.className = "toast success";
      toast.textContent = `Moved to ${newStatus}`;
      container?.appendChild(toast);
      setTimeout(() => toast.remove(), 2000);

      // Persist to API (background, no reload)
      try {
        await fetch(`/api/tasks/${taskId}`, {
          method: "PUT",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ status: newStatus }),
        });
      } catch {
        // Revert on failure — reload to get server state
        window.location.reload();
      }
    }

    // Kanban card action handlers
    // T-1903: Edit button opens inline task detail panel (not redirect)
    document.querySelectorAll(".card-edit-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const id = btn.dataset.id;
        if (id && typeof window.openTaskDetail === "function") {
          window.openTaskDetail(id);
        } else if (id) {
          window.location.href = `/tasks#edit-${id}`;
        }
      });
    });

    // AI: open ChatGPT with task context prompt
    document.querySelectorAll(".card-ai-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const el = btn;
        const title = el.dataset.title ?? "";
        const desc = el.dataset.desc ?? "";
        const status = el.dataset.status ?? "pending";
        const priority = el.dataset.priority ?? "3";
        const prompt = `I have a task:\n\nTitle: ${title}\nStatus: ${status}\nPriority: ${priority}/5\n${desc ? `Description: ${desc}` : ""}\n\nCan you help me break this down, suggest next steps, estimate effort, or identify blockers?`;
        window.open(
          `https://chatgpt.com/?q=${encodeURIComponent(prompt)}`,
          "_blank",
        );
      });
    });

    // Duplicate: clone task via API
    document.querySelectorAll(".card-dup-btn").forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        e.stopPropagation();
        const id = btn.dataset.id;
        if (!id) return;
        try {
          const res = await fetch(`/api/tasks/${id}`);
          if (!res.ok) return;
          const task = await res.json();
          const dupRes = await fetch("/api/tasks", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({
              title: `${task.title} (Copy)`,
              description: task.description ?? "",
              priority: task.priority ?? 3,
              status: "pending",
              due_date: task.due_date ?? null,
              labels: task.labels ?? "[]",
              framework_payload: task.framework_payload ?? "{}",
            }),
          });
          if (dupRes.ok) window.location.reload();
        } catch {}
      });
    });

    // T-1903: Click anywhere on kanban card → open inline detail panel
    document.querySelectorAll(".kanban-card").forEach((card) => {
      card.addEventListener("click", (e) => {
        // Don't open if clicking action buttons or dragging
        if (e.target.closest(".card-action-btn")) return;
        const id = card.dataset.id;
        if (id && typeof window.openTaskDetail === "function") {
          window.openTaskDetail(id);
        } else if (id) {
          window.location.href = `/tasks#edit-${id}`;
        }
      });
    });

    // Quick add from kanban column — uses inline form, not prompt()
    document.querySelectorAll(".kanban-add-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        // If inline form already exists, focus it
        const existing = btn.parentElement.querySelector(".kanban-inline-add");
        if (existing) {
          existing.querySelector("input")?.focus();
          return;
        }

        const status = btn.dataset.status;
        const form = document.createElement("div");
        form.className = "kanban-inline-add";
        form.style.cssText = "display:flex;gap:6px;margin-top:8px;";
        form.innerHTML = `
          <input type="text" class="form-input" placeholder="Task title..." style="flex:1;font-size:13px;padding:6px 10px;" autofocus />
          <button class="btn btn-primary" style="font-size:13px;padding:6px 12px;">Add</button>
        `;
        btn.parentElement.insertBefore(form, btn);
        btn.style.display = "none";

        const input = form.querySelector("input");
        const addBtn = form.querySelector("button");
        input.focus();

        async function submitTask() {
          const title = input.value.trim();
          if (!title) {
            cleanup();
            return;
          }
          try {
            const res = await fetch("/api/tasks", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ title, status }),
            });
            if (res.ok) window.location.reload();
          } catch {
            /* ignore */
          }
        }

        function cleanup() {
          form.remove();
          btn.style.display = "";
        }

        addBtn.addEventListener("click", submitTask);
        input.addEventListener("keydown", (e) => {
          if (e.key === "Enter") {
            e.preventDefault();
            submitTask();
          }
          if (e.key === "Escape") {
            cleanup();
          }
        });
        input.addEventListener("blur", () => {
          // Delay to allow button click
          setTimeout(() => {
            if (!form.contains(document.activeElement)) cleanup();
          }, 200);
        });
      });
    });

    // Lane management (client-side with localStorage)
    const LANE_KEY = "meitheal-kanban-lanes";
    const manageLanesBtn = document.getElementById("manage-lanes-btn");
    const laneMgmt = document.getElementById("lane-mgmt");
    const laneList = document.getElementById("lane-list");
    const newLaneInput = document.getElementById("new-lane-input");
    const addLaneBtn = document.getElementById("add-lane-btn");

    function getCustomLanes() {
      try {
        return JSON.parse(localStorage.getItem(LANE_KEY) || "[]");
      } catch {
        return [];
      }
    }

    function saveCustomLanes(lanes) {
      localStorage.setItem(LANE_KEY, JSON.stringify(lanes));
    }

    function renderLaneList() {
      const builtInKeys = ["pending", "active", "complete"];
      const allLanes = [
        { key: "pending", label: "Pending", builtIn: true },
        { key: "active", label: "Active", builtIn: true },
        { key: "complete", label: "Complete", builtIn: true },
        ...getCustomLanes(),
      ];
      laneList.innerHTML = allLanes
        .map(
          (lane) => `
        <div class="lane-item" style="display: flex; align-items: center; gap: 8px; padding: 4px 0;">
          <span style="flex: 1; font-size: 13px;">${lane.builtIn ? "🔒" : "📌"} ${lane.label}</span>
          ${
            !lane.builtIn
              ? `
            <button class="lane-edit" data-key="${lane.key}" title="Rename" style="background:none;border:none;cursor:pointer;color:var(--text-muted);">✏️</button>
            <button class="lane-remove" data-key="${lane.key}" title="Remove" style="background:none;border:none;cursor:pointer;color:var(--danger);">×</button>
          `
              : '<span style="font-size:11px;color:var(--text-muted);">built-in</span>'
          }
        </div>
      `,
        )
        .join("");

      // Edit handlers
      laneList.querySelectorAll(".lane-edit").forEach((btn) => {
        btn.addEventListener("click", () => {
          const key = btn.dataset.key;
          const lanes = getCustomLanes();
          const lane = lanes.find((l) => l.key === key);
          if (!lane) return;
          const newName = prompt("Rename lane:", lane.label);
          if (newName?.trim()) {
            lane.label = newName.trim();
            saveCustomLanes(lanes);
            window.location.reload();
          }
        });
      });

      // Remove handlers
      laneList.querySelectorAll(".lane-remove").forEach((btn) => {
        btn.addEventListener("click", () => {
          const key = btn.dataset.key;
          const lanes = getCustomLanes().filter((l) => l.key !== key);
          saveCustomLanes(lanes);
          window.location.reload();
        });
      });
    }

    // T-1904: Toggle lanes panel — use 'flex' to preserve centered layout
    manageLanesBtn?.addEventListener("click", () => {
      const isOpen = laneMgmt.style.display !== "none";
      laneMgmt.style.display = isOpen ? "none" : "flex";
      if (!isOpen) renderLaneList();
    });

    // T-1905: Lane creation with validation (1-50 chars, strip HTML)
    addLaneBtn?.addEventListener("click", () => {
      const raw = newLaneInput.value.trim();
      const name = raw.replace(/<[^>]*>/g, "");
      if (!name || name.length < 1 || name.length > 50) {
        alert("Lane name must be 1-50 characters");
        return;
      }
      const key = name.toLowerCase().replace(/[^a-z0-9]+/g, "_");
      const lanes = getCustomLanes();
      if (lanes.some((l) => l.key === key)) {
        alert("Lane already exists");
        return;
      }
      lanes.push({
        key,
        label: name,
        icon: "📌",
        includes: [key],
        builtIn: false,
      });
      saveCustomLanes(lanes);
      window.location.reload();
    });

    // Inject custom lane columns into the DOM on page load
    function injectCustomColumns() {
      const customLanes = getCustomLanes();
      if (customLanes.length === 0) return;

      const board = document.querySelector(".kanban-board");
      if (!board) return;

      // Fetch all tasks to check for tasks in custom statuses
      const allTasks = window.__kanbanAllTasks || [];

      customLanes.forEach((lane) => {
        // Don't duplicate if column already exists
        if (board.querySelector(`[data-status="${lane.key}"]`)) return;

        const col = document.createElement("div");
        col.className = "kanban-column";
        col.dataset.status = lane.key;
        col.ondrop = (e) => handleDrop(e);
        col.ondragover = (e) => {
          e.preventDefault();
          col.classList.add("drag-over");
        };
        col.ondragleave = () => col.classList.remove("drag-over");

        // Find tasks matching this lane
        const laneTasks = allTasks.filter((t) =>
          lane.includes.includes(String(t.status)),
        );

        col.innerHTML = `
          <div class="kanban-column-header">
            <span>${lane.icon} ${lane.label}</span>
            <span class="kanban-count">${laneTasks.length}</span>
          </div>
          <div class="kanban-cards">
            ${laneTasks.length === 0 ? '<div class="kanban-empty">Drop tasks here</div>' : ""}
            ${laneTasks
              .map((task) => {
                const p = Number(task.priority ?? 3);
                const pLabels = {
                  1: "Critical",
                  2: "High",
                  3: "Medium",
                  4: "Low",
                  5: "Minimal",
                };
                const pColors = {
                  1: "#ef4444",
                  2: "#f59e0b",
                  3: "#3b82f6",
                  4: "#10b981",
                  5: "#6b7280",
                };
                return `
                <div class="kanban-card" draggable="true" data-id="${task.id}"
                  data-title="${(task.title || "").replace(/"/g, "&quot;")}"
                  data-desc="${(task.description || "").slice(0, 200).replace(/"/g, "&quot;")}"
                  data-priority="${p}"
                  data-status="${task.status || "pending"}"
                  ondragstart="event.dataTransfer.setData('text/plain', this.dataset.id); this.classList.add('dragging');"
                  ondragend="this.classList.remove('dragging');"
                  style="border-left: 3px solid ${task.color || pColors[p]};">
                  <div class="kanban-card-header">
                    <div class="kanban-card-title">${task.title}</div>
                    ${Number(task.is_favorite) === 1 ? '<span class="kanban-fav" title="Favorite">★</span>' : ""}
                  </div>
                  ${task.description ? `<div class="kanban-card-desc">${task.description.slice(0, 80)}${task.description.length > 80 ? "…" : ""}</div>` : ""}
                  <div class="kanban-card-meta">
                    <span class="priority-dot" style="background: ${pColors[p]}" title="${pLabels[p]}"></span>
                    <span style="color: ${pColors[p]}; font-size: 11px;">${pLabels[p]}</span>
                    ${task.due_date ? `<span class="kanban-card-due">📅 ${String(task.due_date).split("T")[0]}</span>` : ""}
                    ${(() => {
                      try {
                        const fp = JSON.parse(task.framework_payload || "{}");
                        const rice =
                          fp.reach && fp.impact && fp.confidence && fp.effort
                            ? Math.round(
                                (fp.reach * fp.impact * fp.confidence) /
                                  fp.effort,
                              )
                            : null;
                        return rice
                          ? `<span class="kanban-rice-badge">RICE: ${rice}</span>`
                          : "";
                      } catch {
                        return "";
                      }
                    })()}
                  </div>
                  ${Number(task.progress || 0) > 0 ? `<div class="kanban-progress"><div class="kanban-progress-track"><div class="kanban-progress-bar" style="width: ${task.progress}%"></div></div><span class="kanban-progress-text">${task.progress}%</span></div>` : ""}
                  ${(() => {
                    try {
                      const lbls = JSON.parse(task.labels || "[]");
                      return Array.isArray(lbls) && lbls.length > 0
                        ? `<div class="kanban-labels">${lbls.map((l) => `<span class="label-chip">${typeof l === "string" ? l : l.name}</span>`).join("")}</div>`
                        : "";
                    } catch {
                      return "";
                    }
                  })()}
                  ${(() => {
                    try {
                      const cf = JSON.parse(task.custom_fields || "{}");
                      const keys = Object.keys(cf);
                      return keys.length > 0
                        ? `<div class="kanban-custom-fields">${keys
                            .slice(0, 4)
                            .map(
                              (k) =>
                                `<span class="kanban-cf-chip" title="${k}: ${cf[k]}">${k}: ${String(cf[k]).slice(0, 20)}</span>`,
                            )
                            .join(
                              "",
                            )}${keys.length > 4 ? `<span class="kanban-cf-chip">+${keys.length - 4} more</span>` : ""}</div>`
                        : "";
                    } catch {
                      return "";
                    }
                  })()}
                  <div class="kanban-card-actions">
                    <button class="card-action-btn card-edit-btn" data-id="${task.id}" title="Edit task">✏️</button>
                    <button class="card-action-btn card-ai-btn" data-title="${(task.title || "").replace(/"/g, "&quot;")}" data-desc="${(task.description || "").replace(/"/g, "&quot;")}" data-status="${task.status || "pending"}" data-priority="${p}" title="Ask AI">🤖</button>
                    <button class="card-action-btn card-dup-btn" data-id="${task.id}" title="Duplicate">⧉</button>
                  </div>
                </div>`;
              })
              .join("")}
          </div>
          <button class="kanban-add-btn" data-status="${lane.key}" aria-label="Add task to ${lane.label}">+ Add Task</button>
        `;

        board.appendChild(col);

        // Wire up inline add for the new column
        const addBtn = col.querySelector(".kanban-add-btn");
        if (addBtn) {
          addBtn.addEventListener("click", () => {
            const existing =
              addBtn.parentElement.querySelector(".kanban-inline-add");
            if (existing) {
              existing.querySelector("input")?.focus();
              return;
            }
            const status = addBtn.dataset.status;
            const form = document.createElement("div");
            form.className = "kanban-inline-add";
            form.style.cssText = "display:flex;gap:6px;margin-top:8px;";
            form.innerHTML = `
              <input type="text" class="form-input" placeholder="Task title..." style="flex:1;font-size:13px;padding:6px 10px;" autofocus />
              <button class="btn btn-primary" style="font-size:13px;padding:6px 12px;">Add</button>
            `;
            addBtn.parentElement.insertBefore(form, addBtn);
            addBtn.style.display = "none";
            const input2 = form.querySelector("input");
            const submitBtn = form.querySelector("button");
            input2.focus();
            async function submitNew() {
              const title = input2.value.trim();
              if (!title) {
                form.remove();
                addBtn.style.display = "";
                return;
              }
              try {
                const res = await fetch("/api/tasks", {
                  method: "POST",
                  headers: { "content-type": "application/json" },
                  body: JSON.stringify({ title, status }),
                });
                if (res.ok) window.location.reload();
              } catch {}
            }
            submitBtn.addEventListener("click", submitNew);
            input2.addEventListener("keydown", (e) => {
              if (e.key === "Enter") {
                e.preventDefault();
                submitNew();
              }
              if (e.key === "Escape") {
                form.remove();
                addBtn.style.display = "";
              }
            });
          });
        }
      });

      // Update grid to accommodate all columns
      const totalCols = board.querySelectorAll(".kanban-column").length;
      board.style.gridTemplateColumns = `repeat(${totalCols}, 1fr)`;
    }

    // Store tasks data for client-side custom column rendering
    window.__kanbanAllTasks = [];
    (async function () {
      try {
        const res = await fetch("/api/tasks?limit=500");
        if (res.ok) {
          const data = await res.json();
          window.__kanbanAllTasks = data.tasks || [];
        }
      } catch {}
      injectCustomColumns();
    })();

    // T-1907: Search filters Kanban cards in real-time
    (() => {
      const searchInput = document.querySelector(".search-input");
      if (!searchInput) return;

      searchInput.addEventListener("input", () => {
        const query = searchInput.value.toLowerCase().trim();
        const cards = document.querySelectorAll(".kanban-card");

        cards.forEach((card) => {
          const title = (card.dataset.title || "").toLowerCase();
          const desc = (card.dataset.desc || "").toLowerCase();
          const match = !query || title.includes(query) || desc.includes(query);
          card.style.display = match ? "" : "none";
        });

        // Update column counts to reflect visible cards
        document.querySelectorAll(".kanban-column").forEach((col) => {
          const count = col.querySelector(".kanban-count");
          const visible = col.querySelectorAll(
            '.kanban-card:not([style*="display: none"])',
          );
          if (count) count.textContent = visible.length;
        });
      });
    })();

    // T-1914: Keyboard navigation for kanban board
    (() => {
      const board = document.querySelector(".kanban-board");
      if (!board) return;

      let focusedCard = null;

      board.addEventListener("keydown", (e) => {
        const cards = Array.from(board.querySelectorAll(".kanban-card"));
        if (!cards.length) return;

        if (!focusedCard || !document.contains(focusedCard)) {
          focusedCard = cards[0];
        }

        const currentCol = focusedCard.closest(".kanban-column");
        const colCards = Array.from(
          currentCol.querySelectorAll(".kanban-card"),
        );
        const colIdx = colCards.indexOf(focusedCard);
        const columns = Array.from(board.querySelectorAll(".kanban-column"));
        const colPos = columns.indexOf(currentCol);

        let nextCard = null;

        switch (e.key) {
          case "ArrowDown":
            e.preventDefault();
            nextCard = colCards[colIdx + 1] || colCards[0];
            break;
          case "ArrowUp":
            e.preventDefault();
            nextCard = colCards[colIdx - 1] || colCards[colCards.length - 1];
            break;
          case "ArrowRight":
            e.preventDefault();
            const nextCol = columns[colPos + 1] || columns[0];
            const nextColCards = nextCol.querySelectorAll(".kanban-card");
            nextCard = nextColCards[0] || null;
            break;
          case "ArrowLeft":
            e.preventDefault();
            const prevCol = columns[colPos - 1] || columns[columns.length - 1];
            const prevColCards = prevCol.querySelectorAll(".kanban-card");
            nextCard = prevColCards[0] || null;
            break;
          case "Enter":
            e.preventDefault();
            const id = focusedCard.dataset.id;
            if (id && typeof window.openTaskDetail === "function") {
              window.openTaskDetail(id);
            }
            return;
        }

        if (nextCard) {
          focusedCard.classList.remove("kb-focused");
          focusedCard = nextCard;
          focusedCard.classList.add("kb-focused");
          focusedCard.scrollIntoView({ block: "nearest" });
        }
      });

      // Make board focusable for keyboard events
      board.setAttribute("tabindex", "0");

      // Focus first card when board gets focus
      board.addEventListener("focus", () => {
        const firstCard = board.querySelector(".kanban-card");
        if (firstCard) {
          focusedCard = firstCard;
          focusedCard.classList.add("kb-focused");
        }
      });

      board.addEventListener("blur", () => {
        if (focusedCard) focusedCard.classList.remove("kb-focused");
      });
    })();

    // T-1915: Column collapse toggle
    (() => {
      document.querySelectorAll(".kanban-column-header").forEach((header) => {
        header.style.cursor = "pointer";
        header.title = "Click to collapse/expand";

        header.addEventListener("click", (e) => {
          // Don't collapse if clicking the count badge
          if (e.target.classList.contains("kanban-count")) return;

          const col = header.closest(".kanban-column");
          const cards = col.querySelector(".kanban-cards");
          const addBtn = col.querySelector(".kanban-add-btn");

          col.classList.toggle("collapsed");

          if (col.classList.contains("collapsed")) {
            cards.style.display = "none";
            if (addBtn) addBtn.style.display = "none";
            col.style.minWidth = "48px";
            col.style.maxWidth = "48px";
            header.querySelector("span:first-child").style.writingMode =
              "vertical-rl";
          } else {
            cards.style.display = "";
            if (addBtn) addBtn.style.display = "";
            col.style.minWidth = "";
            col.style.maxWidth = "";
            header.querySelector("span:first-child").style.writingMode = "";
          }
        });
      });
    })();
  </script>
</Layout>

<style>
  .kanban-board {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    min-height: calc(100vh - 140px);
  }
  .kanban-column {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 16px;
    display: flex;
    flex-direction: column;
    transition: border-color 200ms;
  }
  .kanban-column.drag-over {
    border-color: var(--accent);
    background: rgba(16, 185, 129, 0.05);
  }
  .kanban-column-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 600;
    font-size: 14px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 12px;
  }
  .kanban-count {
    background: var(--bg-hover);
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 12px;
    color: var(--text-secondary);
  }
  .kanban-cards {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 100px;
  }
  .kanban-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 14px;
    cursor: grab;
    transition: all 200ms;
  }
  .kanban-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }
  .kanban-card.dragging {
    opacity: 0.5;
  }
  .kanban-card-title {
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 8px;
  }
  .kanban-card-meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
  }
  .priority-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .kanban-empty {
    text-align: center;
    padding: 30px;
    color: var(--text-muted);
    font-size: 13px;
    border: 2px dashed var(--border);
    border-radius: var(--radius-md);
  }
  .kanban-add-btn {
    margin-top: 8px;
    padding: 8px;
    background: none;
    border: 1px dashed var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    cursor: pointer;
    font-size: 13px;
    transition: all 200ms;
  }
  .kanban-add-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .kanban-card-desc {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 8px;
    line-height: 1.4;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .kanban-card-due {
    font-size: 11px;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.05);
    padding: 1px 6px;
    border-radius: 4px;
  }
  .kanban-card-actions {
    display: flex;
    gap: 4px;
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid var(--border);
    opacity: 0;
    transition: opacity 150ms;
  }
  .kanban-card:hover .kanban-card-actions {
    opacity: 1;
  }
  .card-action-btn {
    background: none;
    border: 1px solid transparent;
    cursor: pointer;
    font-size: 12px;
    padding: 3px 8px;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    transition: all 150ms;
  }
  .card-action-btn:hover {
    background: var(--bg-hover);
    border-color: var(--border);
  }
  .card-edit-btn:hover {
    color: var(--info);
  }
  .card-ai-btn:hover {
    color: var(--success);
  }
  .card-dup-btn:hover {
    color: var(--warning);
  }
  .view-switcher {
    display: flex;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  .view-btn {
    padding: 6px 12px;
    text-decoration: none;
    color: var(--text-secondary);
    font-size: 16px;
    transition: all 200ms;
    border-right: 1px solid var(--border);
  }
  .view-btn:last-child {
    border-right: none;
  }
  .view-btn:hover {
    background: var(--bg-hover);
    color: var(--text-primary);
  }
  .view-btn.active {
    background: var(--accent-light);
    color: var(--accent);
  }
  @media (max-width: 768px) {
    .kanban-board {
      grid-template-columns: 1fr;
    }
  }

  /* Card header with favorite */
  .kanban-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 4px;
  }
  .kanban-fav {
    color: #f59e0b;
    font-size: 14px;
    flex-shrink: 0;
  }

  /* Progress bar */
  .kanban-progress {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 8px;
  }
  .kanban-progress-track {
    flex: 1;
    height: 4px;
    background: var(--bg-hover);
    border-radius: 2px;
    overflow: hidden;
  }
  .kanban-progress-bar {
    height: 100%;
    background: var(--accent);
    border-radius: 2px;
    transition: width 300ms ease;
  }
  .kanban-progress-text {
    font-size: 10px;
    color: var(--text-muted);
    flex-shrink: 0;
    min-width: 28px;
    text-align: right;
  }

  /* RICE + sync badges */
