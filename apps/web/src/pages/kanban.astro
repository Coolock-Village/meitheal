    padding: 1px 6px;
    border-radius: 4px;
  }
  .kanban-sync-badge {
    font-size: 11px;
    color: var(--info);
  }

  /* Labels on cards */
  .kanban-labels {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    margin-top: 6px;
  }

  /* Custom fields on cards */
  .kanban-custom-fields {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    margin-top: 6px;
  }
  .kanban-cf-chip {
    font-size: 10px;
    padding: 1px 6px;
    border-radius: 4px;
    background: rgba(59, 130, 246, 0.1);
    color: var(--info);
    border: 1px solid rgba(59, 130, 246, 0.2);
    white-space: nowrap;
    max-width: 120px;
    overflow: hidden;
    text-overflow: ellipsis;
