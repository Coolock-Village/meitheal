---
import Layout from "../layouts/Layout.astro";
import TaskViewTabs from "../components/tasks/TaskViewTabs.astro";
import { t } from "../i18n/translations";
import type { Locale } from "../lib/locale";
import { formatRegionalDate } from "../lib/date";
import { formatTicketKey } from "../lib/ticket-key";
import {
  ensureSchema,
  getPersistenceClient,
} from "@domains/tasks/persistence/store";

const {
  ingressPath,
  hassioTokenPresent,
  hassUserId,
  timezone,
  weekStart,
  dateFormat,
} = Astro.locals;

// i18n: resolve locale from cookie
const cookieLocale = Astro.cookies.get("meitheal-locale")?.value;
const locale: Locale = cookieLocale === "ga" ? "ga" : "en";

await ensureSchema();
const client = getPersistenceClient();

let tasks: Record<string, unknown>[] = [];
let commentCounts: Record<string, number> = {};
try {
  const result = await client.execute(
    "SELECT id, title, description, status, priority, due_date, labels, framework_payload, calendar_sync_state, board_id, custom_fields, start_date, end_date, progress, color, is_favorite, task_type, parent_id, ticket_number, created_at, updated_at FROM tasks ORDER BY priority ASC, created_at DESC",
  );
  tasks = result.rows as Record<string, unknown>[];
  // Comment count aggregation (competitor parity: Jira/Asana/Linear show comment counts)
  try {
    const ccResult = await client.execute(
      "SELECT task_id, COUNT(*) as cnt FROM comments GROUP BY task_id",
    );
    for (const row of ccResult.rows) {
      const r = row as Record<string, unknown>;
      commentCounts[String(r.task_id)] = Number(r.cnt);
    }
  } catch {
    /* comments table may not exist yet */
  }
} catch (e) {
  /* DB not available */
}

let columns: {
  key: string;
  label: string;
  icon: string;
  includes: string[];
  builtIn: boolean;
  wipLimit: number;
  id: string;
}[] = [];
try {
  const laneResult = await client.execute(
    "SELECT id, key, label, icon, position, wip_limit, includes, built_in FROM kanban_lanes ORDER BY position ASC",
  );
  columns = laneResult.rows.map((r: Record<string, unknown>) => ({
    id: String(r.id),
    key: String(r.key),
    label: String(r.label),
    icon: String(r.icon),
    includes: JSON.parse(String(r.includes ?? "[]")),
    builtIn: Number(r.built_in ?? 0) === 1,
    wipLimit: Number(r.wip_limit ?? 0),
  }));
} catch {
  /* fallback to defaults */
}

// Fallback if no lanes in DB
if (columns.length === 0) {
  columns = [
    {
      id: "lane-pending",
      key: "pending",
      label: "Pending",
      icon: "📋",
      includes: ["pending", "todo"],
      builtIn: true,
      wipLimit: 0,
    },
    {
      id: "lane-active",
      key: "active",
      label: "Active",
      icon: "⚡",
      includes: ["active", "in_progress"],
      builtIn: true,
      wipLimit: 0,
    },
    {
      id: "lane-complete",
      key: "complete",
      label: "Complete",
      icon: "✅",
      includes: ["complete", "done"],
      builtIn: true,
      wipLimit: 0,
    },
  ];
}

const priorityLabels: Record<number, string> = {
  1: t("priority.critical", locale),
  2: t("priority.high", locale),
  3: t("priority.medium", locale),
  4: t("priority.low", locale),
  5: t("priority.minimal", locale),
};
const priorityColors: Record<number, string> = {
  1: "#ef4444",
  2: "#f59e0b",
  3: "#3b82f6",
  4: "#10b981",
  5: "#6b7280",
};

// Phase 20: Agile type metadata
const typeConfig: Record<
  string,
  { icon: string; label: string; color: string }
> = {
  epic: { icon: "🎯", label: "Epic", color: "#8b5cf6" },
  story: { icon: "📖", label: "Story", color: "#3b82f6" },
  task: { icon: "✅", label: "Task", color: "#10b981" },
};
---

<Layout title={`Meitheal — ${t("kanban.title", locale)}`}>
  <span slot="page-title">{t("kanban.title", locale)}</span>
  <div slot="actions" style="display: flex; gap: 8px; align-items: center;">
    <button
      type="button"
      class="btn btn-ghost"
      id="manage-lanes-btn"
      title={t("kanban.manage_swimlanes", locale)}
      >{t("kanban.manage_lanes", locale)}</button
    >
    <button type="button" class="btn btn-primary" id="kanban-new-task-btn"
      >{t("kanban.new_task", locale)}</button
    >
  </div>

  <TaskViewTabs activeView="board" />

  <!-- Phase 20: Type filter + grouping toolbar -->
  <div
    class="type-toolbar"
    style="padding: 8px 0;"
    role="toolbar"
    aria-label="Filter by work item type"
  >
    <div class="type-filters">
      <button
        type="button"
        class="type-filter-btn active"
        data-type="all"
        title={t("kanban.show_all_types", locale)}
      >
        📋 {t("kanban.all_types", locale)}
      </button>
      <button
        type="button"
        class="type-filter-btn active"
        data-type="epic"
        title={t("kanban.toggle_epics", locale)}
      >
        <span class="type-dot" style="background: #8b5cf6;"></span>
        {t("kanban.epics", locale)}
      </button>
      <button
        type="button"
        class="type-filter-btn active"
        data-type="story"
        title={t("kanban.toggle_stories", locale)}
      >
        <span class="type-dot" style="background: #3b82f6;"></span>
        {t("kanban.stories", locale)}
      </button>
      <button
        type="button"
        class="type-filter-btn active"
        data-type="task"
        title={t("kanban.toggle_tasks", locale)}
      >
        <span class="type-dot" style="background: #10b981;"></span>
        {t("kanban.tasks_label", locale)}
      </button>
    </div>
    <div class="type-group-toggle">
      <label
        class="text-xs text-text-muted"
        for="group-by-select"
        style="margin-right: 4px;">≡ {t("kanban.group", locale)}</label
      >
      <select
        id="group-by-select"
        class="inline-select"
        title={t("kanban.group_by_tooltip", locale)}
      >
        <option value="none">{t("kanban.group_none", locale)}</option>
        <option value="type" selected>{t("kanban.group_type", locale)}</option>
        <option value="board">{t("kanban.group_board", locale)}</option>
        <option value="priority">{t("kanban.group_priority", locale)}</option>
      </select>
    </div>
  </div>

  <!-- Lane management panel -->
  <div class="lane-mgmt" id="lane-mgmt" style="display: none;">
    <div class="lane-mgmt-inner">
      <div
        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;"
      >
        <strong>{t("kanban.manage_swimlanes", locale)}</strong>
        <button
          type="button"
          class="btn-icon"
          id="lane-mgmt-close"
          aria-label="Close"
          style="font-size: 18px; padding: 4px 8px;">✕</button
        >
      </div>
      <div id="lane-list"></div>
      <div style="display: flex; gap: 8px; margin-top: 8px;">
        <input
          type="text"
          class="form-input"
          id="new-lane-input"
          placeholder={t("kanban.new_lane_placeholder", locale)}
          style="flex: 1; font-size: 13px;"
        />
        <button
          type="button"
          class="btn btn-primary"
          id="add-lane-btn"
          style="font-size: 13px;">{t("kanban.add_lane", locale)}</button
        >
      </div>
    </div>
  </div>

  <div
    class="kanban-board"
    style={`padding: 0 0 8px; grid-template-columns: repeat(${columns.length}, 1fr);`}
  >
    {
      columns.map((col) => {
        const colTasks = tasks.filter((t) =>
          col.includes.includes(String(t.status)),
        );
        const wipExceeded = col.wipLimit > 0 && colTasks.length > col.wipLimit;
        return (
          <div
            class={`kanban-column${wipExceeded ? " wip-exceeded" : ""}`}
            data-status={col.key}
            data-lane-id={col.id}
            data-wip-limit={String(col.wipLimit)}
            role="region"
            aria-label={`${col.label} Swimlane`}
            ondrop="handleDrop(arguments[0])"
            ondragover="arguments[0].preventDefault(); this.classList.add('drag-over');"
            ondragleave="this.classList.remove('drag-over');"
          >
            <div class="kanban-column-header">
              <span>
                {col.icon} {col.label}
              </span>
              <span class="kanban-header-right">
                {col.wipLimit > 0 && (
                  <span
                    class={`kanban-wip${wipExceeded ? " wip-over" : ""}`}
                    title={`WIP limit: ${col.wipLimit}`}
                  >
                    {colTasks.length}/{col.wipLimit}
                  </span>
                )}
                <span class="kanban-count">{colTasks.length}</span>
              </span>
            </div>
            <div class="kanban-cards">
              {/* Swimlane group containers (hidden by default, JS-driven grouping) */}
              {["epic", "story", "task"].map((type) => {
                const tc = typeConfig[type] ?? {
                  icon: "📋",
                  label: type,
                  color: "#6b7280",
                };
                const count = colTasks.filter(
                  (t) => String(t.task_type ?? "task") === type,
                ).length;
                return (
                  <div
                    class={`swimlane-group swimlane-${type}`}
                    data-swimlane-type={type}
                    style="display: none;"
                  >
                    <div class="swimlane-header" data-type={type}>
                      <span class="swimlane-toggle">▼</span>
                      <span
                        class="swimlane-type-dot"
                        style={`background: ${tc.color};`}
                      />
                      <span class="swimlane-label">
                        {tc.icon} {tc.label}
                      </span>
                      <span class="swimlane-count">{count}</span>
                    </div>
                    <div class="swimlane-cards">
                      {/* Cards moved here by JS when grouping is active */}
                    </div>
                    <button
                      type="button"
                      class="kanban-add-btn swimlane-add-btn"
                      style="margin-top: 8px; font-size: 13px; color: var(--text-muted); background: none; border: 1px dashed var(--border); width: 100%; text-align: left; padding: 6px 12px; border-radius: 6px;"
                      data-status={col.key}
                      data-task-type={type}
                      aria-label={`Add ${type} to ${col.label}`}
                    >
                      {t("kanban.add_task", locale)}
                    </button>
                  </div>
                );
              })}
              {/* Flat (non-grouped) card rendering */}
              {colTasks.map((task) => {
                const p = Number(task.priority ?? 3);
                const tt = String(task.task_type ?? "task");
                const tc = (typeConfig[tt] || typeConfig.task)!;
                const fp =
                  typeof task.framework_payload === "string"
                    ? JSON.parse(String(task.framework_payload))
                    : {};
                // Phase 20: Sub-task indicator (ADHD Optimization)
                const childCount = tasks.filter(
                  (t) => t.parent_id === task.id,
                ).length;
                const rice =
                  fp.reach && fp.impact && fp.confidence && fp.effort
                    ? Math.round(
                        (Number(fp.reach) *
                          Number(fp.impact) *
                          Number(fp.confidence)) /
                          Number(fp.effort),
                      )
                    : null;
                const dueDate = task.due_date
                  ? new Date(String(task.due_date))
                  : null;
                const today = new Date();
                today.setHours(0, 0, 0, 0);
                const dueStatus = dueDate
                  ? dueDate < today
                    ? "overdue"
                    : dueDate.toDateString() === new Date().toDateString()
                      ? "today"
                      : "upcoming"
                  : null;
                return (
                  <div
                    class={`kanban-card flat-card`}
                    draggable="true"
                    role="button"
                    tabindex="0"
                    aria-label={`Task: ${String(task.title)}, Priority: ${priorityLabels[p]}`}
                    data-id={String(task.id)}
                    data-title={String(task.title)}
                    data-desc={
                      task.description
                        ? String(task.description).slice(0, 200)
                        : ""
                    }
                    data-priority={String(p)}
                    data-status={String(task.status)}
                    data-task-type={tt}
                    data-board={String(task.board_id ?? "default")}
                    ondragstart="arguments[0].dataTransfer.setData('text/plain', this.dataset.id); this.classList.add('dragging');"
                    ondragend="this.classList.remove('dragging'); document.querySelectorAll('.drag-ghost').forEach(g=>g.remove()); document.querySelectorAll('.drag-over').forEach(c=>c.classList.remove('drag-over'));"
                    style={`border-left: 3px solid ${task.color ? String(task.color) : tc.color};`}
                  >
                    <div class="kanban-card-header">
                      <div
                        class="kanban-card-title"
                        style="font-weight: 600; line-height: 1.4; padding-bottom: 2px;"
                      >
                        <span
                          class="type-badge"
                          style={`background: ${tc.color}20; color: ${tc.color}; border-color: ${tc.color}40;`}
                          title={tc.label}
                        >
                          {tc.icon}
                        </span>
                        <span
                          class="kanban-ticket-key"
                          style="font-size:11px;font-family:'JetBrains Mono',monospace;color:var(--text-muted);margin-right:6px;font-weight:500;background:rgba(255,255,255,0.05);padding:2px 4px;border-radius:4px;"
                        >
                          {formatTicketKey(Number(task.ticket_number))}
                        </span>
                        {String(task.title)}
                      </div>
                      {Number(task.is_favorite ?? 0) === 1 && (
                        <span
                          class="kanban-fav"
                          title={t("kanban.favorite", locale)}
                        >
                          ★
                        </span>
                      )}
                    </div>
                    {/* Attachment Placeholder */}
                    <img
                      class="kanban-attachment hidden"
                      data-task-id={String(task.id)}
                      alt="Attachment"
                      loading="lazy"
                    />

                    {task.description && String(task.description).trim() && (
                      <div class="kanban-card-desc">
                        {String(task.description).slice(0, 80)}
                        {String(task.description).length > 80 ? "…" : ""}
                      </div>
                    )}
                    <div class="kanban-card-meta">
                      <span
                        class="priority-dot"
                        style={`background: ${priorityColors[p]}`}
                        title={priorityLabels[p]}
                      />
                      <span
                        style={`color: ${priorityColors[p]}; font-size: 11px;`}
                      >
                        {priorityLabels[p]}
                      </span>
                      {task.due_date ? (
                        <span
                          class={`kanban-card-due ${dueStatus ? `due-${dueStatus}` : ""}`}
                        >
                          {dueStatus === "overdue"
                            ? "🔴"
                            : dueStatus === "today"
                              ? "🟡"
                              : "📅"}{" "}
                          {formatRegionalDate(dueDate, {
                            format: dateFormat,
                            timezone,
                          })}
                        </span>
                      ) : null}
                      {childCount > 0 && (
                        <span
                          class="kanban-card-due"
                          title={`${childCount} sub-tasks`}
                          style="color:var(--text-primary);"
                        >
                          ↳ {childCount} sub-tasks
                        </span>
                      )}
                      {rice ? (
                        <span class="kanban-rice-badge">RICE: {rice}</span>
                      ) : null}
                      {String(task.calendar_sync_state) === "confirmed" && (
                        <span
                          class="kanban-sync-badge"
                          title={t("kanban.calendar_synced", locale)}
                        >
                          📅✓
                        </span>
                      )}
                      {(commentCounts[String(task.id)] ?? 0) > 0 && (
                        <span
                          class="kanban-card-due"
                          title={`${commentCounts[String(task.id)] ?? 0} comments`}
                          style="color:var(--text-primary);"
                        >
                          💬 {commentCounts[String(task.id)] ?? 0}
                        </span>
                      )}
                    </div>
                    {/* Progress bar */}
                    {Number(task.progress ?? 0) > 0 && (
                      <div class="kanban-progress">
                        <div class="kanban-progress-track">
                          <div
                            class="kanban-progress-bar"
                            style={`width: ${Number(task.progress)}%`}
                          />
                        </div>
                        <span class="kanban-progress-text">
                          {Number(task.progress)}%
                        </span>
                      </div>
                    )}
                    {/* Labels */}
                    {(() => {
                      try {
                        const lbls = JSON.parse(String(task.labels ?? "[]"));
                        if (Array.isArray(lbls) && lbls.length > 0) {
                          return (
                            <div class="kanban-labels">
                              {lbls.map(
                                (
                                  l:
                                    | string
                                    | {
                                        name: string;
                                        color?: string;
                                        hex_color?: string;
                                      },
                                ) => {
                                  const labelName =
                                    typeof l === "string" ? l : l.name;
                                  const labelColor =
                                    typeof l === "object"
                                      ? l.hex_color || l.color || ""
                                      : "";
                                  return (
                                    <span
                                      class="label-chip"
                                      style={
                                        labelColor
                                          ? `background: ${labelColor}20; color: ${labelColor}; border-color: ${labelColor}40;`
                                          : ""
                                      }
                                    >
                                      {labelName}
                                    </span>
                                  );
                                },
                              )}
                            </div>
                          );
                        }
                      } catch {
                        /* skip */
                      }
                      return null;
                    })()}
                    {/* Custom fields */}
                    {(() => {
                      try {
                        const cf =
                          typeof task.custom_fields === "string"
                            ? JSON.parse(String(task.custom_fields ?? "{}"))
                            : {};
                        const keys = Object.keys(cf);
                        if (keys.length > 0) {
                          return (
                            <div class="kanban-custom-fields">
                              {keys.slice(0, 4).map((k) => (
                                <span
                                  class="kanban-cf-chip"
                                  title={`${k}: ${cf[k]}`}
                                >
                                  {k}: {String(cf[k]).slice(0, 20)}
                                </span>
                              ))}
                              {keys.length > 4 && (
                                <span class="kanban-cf-chip">
                                  +{keys.length - 4} more
                                </span>
                              )}
                            </div>
                          );
                        }
                      } catch {
                        /* skip */
                      }
                      return null;
                    })()}
                    <div class="kanban-card-actions">
                      <button
                        class="card-action-btn card-edit-btn"
                        data-id={String(task.id)}
                        title={t("kanban.edit_task", locale)}
                      >
                        ✏️
                      </button>
                      <button
                        class="card-action-btn card-ai-btn"
                        data-title={String(task.title)}
                        data-desc={
                          task.description ? String(task.description) : ""
                        }
                        data-status={String(task.status ?? "pending")}
                        data-priority={String(p)}
                        title={t("tasks.ask_ai", locale)}
                      >
                        🤖
                      </button>
                      <button
                        class="card-action-btn card-dup-btn"
                        data-id={String(task.id)}
                        title={t("kanban.duplicate", locale)}
                      >
                        ⧉
                      </button>
                    </div>
                  </div>
                );
              })}
              {colTasks.length === 0 && (
                <div class="kanban-empty">
                  {t("kanban.drop_tasks_here", locale)}
                </div>
              )}
            </div>
            <button
              class="kanban-add-btn"
              data-status={col.key}
              aria-label={`Add task to ${col.label}`}
            >
              {t("kanban.add_task", locale)}
            </button>
          </div>
        );
      })
    }
  </div>

  <div
    id="toast-container"
    class="toast-container"
    aria-live="polite"
    role="status"
  >
  </div>

  <script is:inline>
    async function handleDrop(e) {
      e.preventDefault();
      const col = e.currentTarget;
      col.classList.remove("drag-over");
      const taskId = e.dataTransfer.getData("text/plain");
      const newStatus = col.dataset.status;
      if (!taskId || !newStatus) return;

      // WIP Limit enforcement
      const wipLimit = parseInt(col.dataset.wipLimit || "0");
      const targetCardsContainer = col.querySelector(".kanban-cards");
      const currentCardCount = targetCardsContainer
        ? targetCardsContainer.querySelectorAll(".kanban-card").length
        : 0;

      const card = document.querySelector(`.kanban-card[data-id="${taskId}"]`);
      if (!card) return;

      const oldCol = card.closest(".kanban-column");
      if (oldCol !== col && wipLimit > 0 && currentCardCount >= wipLimit) {
        const wipToast = document.createElement("div");
        wipToast.className = "toast error kanban-contextual-toast";
        wipToast.textContent = `WIP limit of ${wipLimit} reached for this lane`;
        wipToast.style.cssText =
          "position:fixed;top:16px;right:16px;z-index:100;pointer-events:none;";
        document.body.appendChild(wipToast);
        setTimeout(() => wipToast.remove(), 3000);
        return;
      }

      // T-1902: Optimistic DOM update — no page reload
      // Phase 20: Detect drop into specific swimlane
      const targetSwimlane = e.target.closest(".swimlane-group");
      const targetCards = targetSwimlane
        ? targetSwimlane.querySelector(".swimlane-cards")
        : col.querySelector(".kanban-cards");

      if (targetCards) {
        // Remove empty state if present
        const empty = targetCards.querySelector(".kanban-empty");
        if (empty) empty.remove();

        // Remove ghost if present
        const ghost = targetCards.querySelector(".drag-ghost");
        if (ghost) ghost.remove();

        targetCards.appendChild(card);
        card.dataset.status = newStatus;
        if (targetSwimlane) {
          // Update the card's native dataset so filtering still works on reload
          card.dataset.taskType = targetSwimlane.dataset.swimlaneType;
          // Find the badge inside the card and update visually if possible - this requires a reload for full icon update, but we keep the structure
        }
      }

      // Update column counts
      [oldCol, col].forEach((c) => {
        if (!c) return;
        const count = c.querySelector(".kanban-count");
        const cards = c.querySelectorAll(".kanban-card");
        if (count) count.textContent = cards.length;
        // Show empty state if column is now empty
        if (cards.length === 0) {
          const cardsContainer = c.querySelector(".kanban-cards");
          if (
            cardsContainer &&
            !cardsContainer.querySelector(".kanban-empty")
          ) {
            const emptyDiv = document.createElement("div");
            emptyDiv.className = "kanban-empty";
            emptyDiv.textContent = "Drop tasks here";
            cardsContainer.appendChild(emptyDiv);
          }
        }
      });

      // Toast feedback — positioned near the dropped card
      const toast = document.createElement("div");
      toast.className = "toast success kanban-contextual-toast";
      toast.textContent = `Moved to ${newStatus}`;
      const cardRect = card.getBoundingClientRect();
      toast.style.cssText = `position:fixed;top:${Math.max(cardRect.top - 40, 8)}px;left:${cardRect.left}px;z-index:100;pointer-events:none;`;
      document.body.appendChild(toast);
      setTimeout(() => toast.remove(), 2000);

      // Persist to API (background, no reload)
      try {
        const payload = { status: newStatus };
        if (targetSwimlane) {
          payload.task_type = targetSwimlane.dataset.swimlaneType;
        }
        await fetch(`${window.__ingress_path || ""}/api/tasks/${taskId}`, {
          method: "PUT",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload),
        });
      } catch {
        // Revert on failure — reload to get server state
        window.location.reload();
      }
    }

    // Kanban card action handlers
    // T-1903: Edit button opens inline task detail panel (not redirect)
    document.querySelectorAll(".card-edit-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const id = btn.dataset.id;
        if (!id) return;
        // openTaskDetail may not be available immediately (Layout script loads async)
        // Retry briefly before falling back
        let attempts = 0;
        function tryOpen() {
          if (typeof window.openTaskDetail === "function") {
            window.openTaskDetail(id);
          } else if (attempts < 10) {
            attempts++;
            setTimeout(tryOpen, 50);
          }
        }
        tryOpen();
      });
    });

    // AI: open ChatGPT with task context prompt
    document.querySelectorAll(".card-ai-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const el = btn;
        const title = el.dataset.title ?? "";
        const desc = el.dataset.desc ?? "";
        const status = el.dataset.status ?? "pending";
        const priority = el.dataset.priority ?? "3";
        const prompt = `I have a task:\n\nTitle: ${title}\nStatus: ${status}\nPriority: ${priority}/5\n${desc ? `Description: ${desc}` : ""}\n\nCan you help me break this down, suggest next steps, estimate effort, or identify blockers?`;
        window.open(
          `https://chatgpt.com/?q=${encodeURIComponent(prompt)}`,
          "_blank",
        );
      });
    });

    // Duplicate: clone task via API
    document.querySelectorAll(".card-dup-btn").forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        e.stopPropagation();
        const id = btn.dataset.id;
        if (!id) return;
        try {
          const res = await fetch(
            `${window.__ingress_path || ""}/api/tasks/${id}`,
          );
          if (!res.ok) return;
          const task = await res.json();
          const dupRes = await fetch(
            (window.__ingress_path || "") + "/api/tasks",
            {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({
                title: `${task.title} (Copy)`,
                description: task.description ?? "",
                priority: task.priority ?? 3,
                status: "pending",
                due_date: task.due_date ?? null,
                labels: task.labels ?? "[]",
                framework_payload: task.framework_payload ?? "{}",
              }),
            },
          );
          if (dupRes.ok) window.location.reload();
        } catch {}
      });
    });

    // T-1903: Click anywhere on kanban card is natively handled by Layout.astro delegated click listener.

    // Quick add from kanban column — uses inline form, not prompt()
    document.querySelectorAll(".kanban-add-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        // If inline form already exists, focus it
        const existing = btn.parentElement.querySelector(".kanban-inline-add");
        if (existing) {
          existing.querySelector("input")?.focus();
          return;
        }

        const status = btn.dataset.status;
        const taskType = btn.dataset.taskType;
        const form = document.createElement("div");
        form.className = "kanban-inline-add";
        form.style.cssText = "display:flex;gap:6px;margin-top:8px;";
        form.innerHTML = `
          <input type="text" class="form-input" placeholder="Task title..." aria-label="New task title" style="flex:1;font-size:13px;padding:6px 10px;" autofocus />
          <button type="button" class="btn btn-primary" style="font-size:13px;padding:6px 12px;">Add</button>
        `;
        btn.parentElement.insertBefore(form, btn);
        btn.style.display = "none";

        const input = form.querySelector("input");
        const addBtn = form.querySelector("button");
        input.focus();

        async function submitTask() {
          const title = input.value.trim();
          if (!title) {
            cleanup();
            return;
          }
          try {
            const payload = { title, status };
            if (taskType) payload.task_type = taskType;
            const res = await fetch(
              (window.__ingress_path || "") + "/api/tasks",
              {
                method: "POST",
                headers: { "content-type": "application/json" },
                body: JSON.stringify(payload),
              },
            );
            if (res.ok) window.location.reload();
          } catch {
            /* ignore */
          }
        }

        function cleanup() {
          form.remove();
          btn.style.display = "";
        }

        addBtn.addEventListener("click", submitTask);
        input.addEventListener("keydown", (e) => {
          if (e.key === "Enter") {
            e.preventDefault();
            submitTask();
          }
          if (e.key === "Escape") {
            cleanup();
          }
        });
        input.addEventListener("blur", () => {
          // Delay to allow button click
          setTimeout(() => {
            if (!form.contains(document.activeElement)) cleanup();
          }, 200);
        });
      });
    });

    // Header "+ New Task" button → open the full New Task modal dialog
    document
      .getElementById("kanban-new-task-btn")
      ?.addEventListener("click", () => {
        if (typeof window.openNewTaskModal === "function") {
          window.openNewTaskModal();
        }
      });

    // Lane management (API-backed, server-persisted)
    const manageLanesBtn = document.getElementById("manage-lanes-btn");
    const laneMgmt = document.getElementById("lane-mgmt");
    const laneList = document.getElementById("lane-list");
    const newLaneInput = document.getElementById("new-lane-input");
    const addLaneBtn = document.getElementById("add-lane-btn");

    async function fetchLanes() {
      try {
        const res = await fetch((window.__ingress_path || "") + "/api/lanes");
        if (res.ok) {
          const data = await res.json();
          return data.lanes || [];
        }
      } catch {}
      return [];
    }

    async function renderLaneList() {
      const lanes = await fetchLanes();
      laneList.innerHTML = lanes
        .map(
          (lane) => `
        <div class="lane-item" data-id="${lane.id}" data-position="${lane.position}" style="display: flex; align-items: center; gap: 8px; padding: 6px 0; border-bottom: 1px solid var(--border);">
          <span class="lane-drag-handle" style="cursor: grab; color: var(--text-muted); font-size: 12px;" title="Drag to reorder">⠿</span>
          <span style="flex: 1; font-size: 13px;">${lane.builtIn ? "🔒" : "📌"} ${lane.label}</span>
          <label style="font-size: 11px; color: var(--text-muted); display: flex; align-items: center; gap: 4px;" title="WIP limit (0 = unlimited)">
            WIP: <input type="number" class="lane-wip-input" data-id="${lane.id}" value="${lane.wip_limit}" min="0" max="99" style="width: 40px; font-size: 11px; padding: 2px 4px; border: 1px solid var(--border); border-radius: 4px; background: var(--bg-card); color: var(--text-primary);" />
          </label>
          ${
            !lane.builtIn
              ? `
            <button type="button" class="lane-edit" data-id="${lane.id}" data-label="${lane.label}" title="Rename" aria-label="Rename lane" style="background:none;border:none;cursor:pointer;color:var(--text-muted);font-size:14px;">✏️</button>
            <button type="button" class="lane-remove" data-id="${lane.id}" title="Remove" aria-label="Remove lane" style="background:none;border:none;cursor:pointer;color:var(--danger);font-size:14px;">×</button>
          `
              : '<span style="font-size:11px;color:var(--text-muted);">built-in</span>'
          }
        </div>
      `,
        )
        .join("");

      // WIP limit change handlers
      laneList.querySelectorAll(".lane-wip-input").forEach((input) => {
        input.addEventListener("change", async () => {
          const laneId = input.dataset.id;
          const wipLimit = Math.max(0, parseInt(input.value) || 0);
          try {
            await fetch(`${window.__ingress_path || ""}/api/lanes/${laneId}`, {
              method: "PUT",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ wip_limit: wipLimit }),
            });
            window.location.reload();
          } catch {}
        });
      });

      // Edit handlers
      laneList.querySelectorAll(".lane-edit").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const laneId = btn.dataset.id;
          const currentLabel = btn.dataset.label;
          const newName = prompt("Rename lane:", currentLabel);
          if (newName?.trim()) {
            try {
              await fetch(
                `${window.__ingress_path || ""}/api/lanes/${laneId}`,
                {
                  method: "PUT",
                  headers: { "content-type": "application/json" },
                  body: JSON.stringify({ label: newName.trim() }),
                },
              );
              window.location.reload();
            } catch {}
          }
        });
      });

      // Remove handlers
      laneList.querySelectorAll(".lane-remove").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const laneId = btn.dataset.id;
          const ok = await window.confirmDialog({
            message: "Tasks in this lane will move to Pending.",
            variant: "warning",
            confirmText: "Delete Lane",
            title: "Delete Lane",
          });
          if (!ok) return;
          try {
            await fetch(`${window.__ingress_path || ""}/api/lanes/${laneId}`, {
              method: "DELETE",
            });
            window.location.reload();
          } catch {}
        });
      });

      // Drag to reorder lanes
      let draggedItem = null;
      laneList.querySelectorAll(".lane-item").forEach((item) => {
        const handle = item.querySelector(".lane-drag-handle");
        if (!handle) return;

        handle.addEventListener("mousedown", () => {
          item.setAttribute("draggable", "true");
        });
        handle.addEventListener("mouseup", () => {
          item.removeAttribute("draggable");
        });

        item.addEventListener("dragstart", (e) => {
          draggedItem = item;
          item.style.opacity = "0.5";
          e.dataTransfer.effectAllowed = "move";
        });
        item.addEventListener("dragend", async () => {
          item.style.opacity = "";
          item.removeAttribute("draggable");
          draggedItem = null;

          // Collect new order and save positions
          const items = laneList.querySelectorAll(".lane-item");
          const updates = [];
          items.forEach((el, idx) => {
            updates.push(
              fetch(
                `${window.__ingress_path || ""}/api/lanes/${el.dataset.id}`,
                {
                  method: "PUT",
                  headers: { "content-type": "application/json" },
                  body: JSON.stringify({ position: idx }),
                },
              ),
            );
          });
          await Promise.all(updates);
          window.location.reload();
        });
        item.addEventListener("dragover", (e) => {
          e.preventDefault();
          if (draggedItem && draggedItem !== item) {
            const rect = item.getBoundingClientRect();
            const mid = rect.top + rect.height / 2;
            if (e.clientY < mid) {
              item.parentElement.insertBefore(draggedItem, item);
            } else {
              item.parentElement.insertBefore(draggedItem, item.nextSibling);
            }
          }
        });
      });
    }

    // Helper to close lanes panel
    function closeLaneMgmt() {
      if (laneMgmt) laneMgmt.style.display = "none";
    }

    // T-1904: Toggle lanes panel
    manageLanesBtn?.addEventListener("click", () => {
      const isOpen = laneMgmt.style.display !== "none";
      laneMgmt.style.display = isOpen ? "none" : "flex";
      if (!isOpen) renderLaneList();
    });

    // Close on backdrop click (click on outer lane-mgmt, not inner content)
    laneMgmt?.addEventListener("click", (e) => {
      if (e.target === laneMgmt) closeLaneMgmt();
    });

    // Close on Escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && laneMgmt?.style.display !== "none") {
        closeLaneMgmt();
      }
    });

    // Close button
    document
      .getElementById("lane-mgmt-close")
      ?.addEventListener("click", closeLaneMgmt);

    // T-1905: Lane creation via API
    addLaneBtn?.addEventListener("click", async () => {
      const raw = newLaneInput.value.trim();
      const name = raw.replace(/<[^>]*>/g, "");
      if (!name || name.length < 1 || name.length > 50) {
        const t = document.createElement("div");
        t.className = "toast error";
        t.textContent = "Lane name must be 1-50 characters";
        document.getElementById("toast-container")?.appendChild(t);
        setTimeout(() => t.remove(), 3000);
        return;
      }
      try {
        const res = await fetch((window.__ingress_path || "") + "/api/lanes", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ label: name }),
        });
        if (res.ok) {
          window.location.reload();
        } else {
          const err = await res.json();
          const t = document.createElement("div");
          t.className = "toast error";
          t.textContent = err.error || "Failed to create lane";
          document.getElementById("toast-container")?.appendChild(t);
          setTimeout(() => t.remove(), 3000);
        }
      } catch {}
    });

    // T-1907: Search filters Kanban cards in real-time
    (() => {
      const searchInput = document.querySelector(".search-input");
      if (!searchInput) return;

      searchInput.addEventListener("input", () => {
        const query = searchInput.value.toLowerCase().trim();
        const cards = document.querySelectorAll(".kanban-card");

        cards.forEach((card) => {
          const title = (card.dataset.title || "").toLowerCase();
          const desc = (card.dataset.desc || "").toLowerCase();
          const match = !query || title.includes(query) || desc.includes(query);
          card.style.display = match ? "" : "none";
        });

        // Update column counts to reflect visible cards
        document.querySelectorAll(".kanban-column").forEach((col) => {
          const count = col.querySelector(".kanban-count");
          const visible = col.querySelectorAll(
            '.kanban-card:not([style*="display: none"])',
          );
          if (count) count.textContent = visible.length;
        });
      });
    })();

    // T-1914: Keyboard navigation for kanban board
    (() => {
      const board = document.querySelector(".kanban-board");
      if (!board) return;

      let focusedCard = null;

      board.addEventListener("keydown", (e) => {
        const cards = Array.from(board.querySelectorAll(".kanban-card"));
        if (!cards.length) return;

        if (!focusedCard || !document.contains(focusedCard)) {
          focusedCard = cards[0];
        }

        const currentCol = focusedCard.closest(".kanban-column");
        const colCards = Array.from(
          currentCol.querySelectorAll(".kanban-card"),
        );
        const colIdx = colCards.indexOf(focusedCard);
        const columns = Array.from(board.querySelectorAll(".kanban-column"));
        const colPos = columns.indexOf(currentCol);

        let nextCard = null;

        switch (e.key) {
          case "ArrowDown":
            e.preventDefault();
            nextCard = colCards[colIdx + 1] || colCards[0];
            break;
          case "ArrowUp":
            e.preventDefault();
            nextCard = colCards[colIdx - 1] || colCards[colCards.length - 1];
            break;
          case "ArrowRight":
            e.preventDefault();
            const nextCol = columns[colPos + 1] || columns[0];
            const nextColCards = nextCol.querySelectorAll(".kanban-card");
            nextCard = nextColCards[0] || null;
            break;
          case "ArrowLeft":
            e.preventDefault();
            const prevCol = columns[colPos - 1] || columns[columns.length - 1];
            const prevColCards = prevCol.querySelectorAll(".kanban-card");
            nextCard = prevColCards[0] || null;
            break;
          case "Enter":
            e.preventDefault();
            const id = focusedCard.dataset.id;
            if (id && typeof window.openTaskDetail === "function") {
              window.openTaskDetail(id);
            }
            return;
        }

        if (nextCard) {
          focusedCard.classList.remove("kb-focused");
          focusedCard = nextCard;
          focusedCard.classList.add("kb-focused");
          focusedCard.scrollIntoView({ block: "nearest" });
        }
      });

      // Make board focusable for keyboard events
      board.setAttribute("tabindex", "0");

      // Focus first card when board gets focus
      board.addEventListener("focus", () => {
        const firstCard = board.querySelector(".kanban-card");
        if (firstCard) {
          focusedCard = firstCard;
          focusedCard.classList.add("kb-focused");
        }
      });

      board.addEventListener("blur", () => {
        if (focusedCard) focusedCard.classList.remove("kb-focused");
      });
    })();

    // Phase 20: Type filter + swimlane grouping
    (() => {
      const activeTypes = new Set(["epic", "story", "task"]);
      let isGrouped = false;

      // Type filter buttons
      document.querySelectorAll(".type-filter-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          const type = btn.dataset.type;
          if (type === "all") {
            // Toggle all types
            const allActive = activeTypes.size === 3;
            if (allActive) {
              activeTypes.clear();
              document
                .querySelectorAll(".type-filter-btn")
                .forEach((b) => b.classList.remove("active"));
            } else {
              ["epic", "story", "task"].forEach((t) => activeTypes.add(t));
              document
                .querySelectorAll(".type-filter-btn")
                .forEach((b) => b.classList.add("active"));
            }
          } else {
            if (activeTypes.has(type)) {
              activeTypes.delete(type);
              btn.classList.remove("active");
            } else {
              activeTypes.add(type);
              btn.classList.add("active");
            }
            // Update "All" button state
            const allBtn = document.querySelector(
              '.type-filter-btn[data-type="all"]',
            );
            if (activeTypes.size === 3) {
              allBtn?.classList.add("active");
            } else {
              allBtn?.classList.remove("active");
            }
          }
          applyTypeFilters();
        });
      });

      function applyTypeFilters() {
        // Find visible types using safe match
        const btnTypes = Array.from(
          document.querySelectorAll(".type-filter-btn.active"),
        ).map((b) => b.getAttribute("data-type") || "");

        // 1. Filter flat cards
        document.querySelectorAll(".flat-card").forEach((c) => {
          const ct = String(
            c.getAttribute("data-task-type") || "task",
          ).toLowerCase();
          // Graceful fallback: treat invalid types as "task" for filtering
          const safeType = ["epic", "story", "task"].includes(ct) ? ct : "task";

          if (btnTypes.includes("all") || btnTypes.includes(safeType)) {
            c.style.display = "";
          } else {
            c.style.display = "none";
          }
        });
        updateColumnCounts();
      }

      function updateColumnCounts() {
        document.querySelectorAll(".kanban-column").forEach((col) => {
          const count = col.querySelector(".kanban-count");
          const visible = col.querySelectorAll(
            '.kanban-card:not([style*="display: none"])',
          );
          if (count) count.textContent = visible.length;
        });
      }

      // Swimlane group-by dropdown
      const groupBySelect = document.getElementById("group-by-select");

      // Restore saved group-by mode from localStorage
      const savedGroupBy = localStorage.getItem("meitheal-kanban-group-by");
      if (savedGroupBy && groupBySelect) {
        groupBySelect.value = savedGroupBy;
        // Trigger change event to apply saved mode
        groupBySelect.dispatchEvent(new Event("change"));
      }

      groupBySelect?.addEventListener("change", () => {
        const mode = groupBySelect.value;
        // Persist selection
        localStorage.setItem("meitheal-kanban-group-by", mode);

        if (mode === "board" || mode === "priority") {
          // Future: dynamic swimlane generation for board/priority
          const toast = document.createElement("div");
          toast.className = "toast success";
          toast.textContent = `Group by ${mode} coming soon`;
          document.querySelector(".toast-container")?.appendChild(toast);
          setTimeout(() => toast.remove(), 2500);
          groupBySelect.value = isGrouped ? "type" : "none";
          return;
        }

        const shouldGroup = mode === "type";
        if (shouldGroup === isGrouped) return;
        isGrouped = shouldGroup;

        document.querySelectorAll(".kanban-column").forEach((col) => {
          const cardsContainer = col.querySelector(".kanban-cards");
          if (!cardsContainer) return;

          const flatCards = cardsContainer.querySelectorAll(".flat-card");
          const swimlaneGroups =
            cardsContainer.querySelectorAll(".swimlane-group");

          if (isGrouped) {
            // Move flat cards into respective swimlane groups
            flatCards.forEach((card) => {
              const type = card.dataset.taskType || "task";
              const swimlane = cardsContainer.querySelector(
                `.swimlane-group[data-swimlane-type="${type}"] .swimlane-cards`,
              );
              if (swimlane) {
                card.classList.remove("flat-card");
                card.classList.add("grouped-card");
                swimlane.appendChild(card);
              }
            });
            // Show swimlane groups, hide flat empty state
            swimlaneGroups.forEach((group) => {
              const groupType = group.dataset.swimlaneType;
              group.style.display = activeTypes.has(groupType) ? "" : "none";
              // Update swimlane count
              const countEl = group.querySelector(".swimlane-count");
              const cards = group.querySelectorAll(".kanban-card");
              if (countEl) countEl.textContent = cards.length;
            });
          } else {
            // Move cards back to flat container
            swimlaneGroups.forEach((group) => {
              const swimlaneCards = group.querySelector(".swimlane-cards");
              if (swimlaneCards) {
                const cards = swimlaneCards.querySelectorAll(".kanban-card");
                cards.forEach((card) => {
                  card.classList.remove("grouped-card");
                  card.classList.add("flat-card");
                  // Insert before the first swimlane group
                  const firstGroup =
                    cardsContainer.querySelector(".swimlane-group");
                  cardsContainer.insertBefore(card, firstGroup);
                });
              }
              group.style.display = "none";
            });
          }
        });
        applyTypeFilters();
      });

      // Swimlane header collapse toggle
      document.querySelectorAll(".swimlane-header").forEach((header) => {
        header.addEventListener("click", () => {
          const group = header.closest(".swimlane-group");
          if (!group) return;
          const cards = group.querySelector(".swimlane-cards");
          const toggle = header.querySelector(".swimlane-toggle");
          if (cards) {
            const isCollapsed = cards.style.display === "none";
            cards.style.display = isCollapsed ? "" : "none";
            if (toggle) toggle.textContent = isCollapsed ? "▼" : "▶";
            group.classList.toggle("swimlane-collapsed", !isCollapsed);
          }
        });
      });
    })();

    // T-1915: Column collapse toggle (REMOVED — clicking lane headers to collapse
    // was unintuitive UX and caused visual breakage, per user feedback).

    // --- Offline Attachments Feature (Phase 23) ---
    (async function renderThumbnails() {
      if (!window.indexedDB) return;
      // Only attempt module load if there are attachment slots in the DOM
      var slots = document.querySelectorAll("img.kanban-attachment");
      if (!slots.length) return;
      try {
        // Dynamic import — Vite resolves this at build time into the
        // bundled chunk. No @vite-ignore needed since path is static.
        var mod = await import("../../domains/offline/offline-store.ts").catch(
          function () {
            return null; // Silently skip if module not available
          },
        );
        if (!mod || !mod.getAttachmentsByTaskId) return;
        var getAttachmentsByTaskId = mod.getAttachmentsByTaskId;
        slots.forEach(async (img) => {
          const taskId = img.getAttribute("data-task-id");
          if (!taskId) return;
          const attachments = await getAttachmentsByTaskId(taskId);
          if (attachments.length > 0) {
            // Get the first image
            const cover = attachments.find((a) =>
              a.mimeType.startsWith("image/"),
            );
            if (cover) {
              img.setAttribute("src", cover.base64Data);
              img.classList.remove("hidden");
            }
          }
        });
      } catch (_) {
        /* Offline attachments unavailable — non-critical */
      }
    })();
  </script>
</Layout>

<style>
  .kanban-board {
    display: flex;
    gap: 10px;
    min-height: calc(100vh - 140px);
    max-width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0 0 8px; /* horizontal padding handled by global .content */
  }

  /* Mobile: stack columns vertically */
  @media (max-width: 768px) {
    .kanban-board {
      flex-direction: column;
      overflow-x: hidden;
      min-height: auto;
      gap: 12px;
    }
  }

  /* Tablet: horizontal scroll with minimum column widths */
  @media (min-width: 769px) and (max-width: 1024px) {
    .kanban-board {
      overflow-x: auto;
    }
  }
  .kanban-column {
    background: var(--bg-secondary);
    border-radius: var(--radius-md);
    min-width: 280px;
    flex: 1;
    display: flex;
    flex-direction: column;
    max-height: 100%;
    transition:
      background 200ms,
      border-color 200ms;
    border: 2px solid transparent;
    padding: 12px;
  }
  @media (max-width: 768px) {
    .kanban-board {
      flex-direction: column;
      overflow-x: hidden;
      overflow-y: auto;
      height: auto;
    }
    .kanban-column {
      min-width: 100%;
      max-width: 100%;
    }
  }
  .kanban-column.drag-over {
    border-color: var(--accent);
    background: rgba(16, 185, 129, 0.05);
  }
  .kanban-column.drag-over .kanban-cards::after {
    content: "";
    display: block;
    height: 80px;
    border: 2px dashed var(--accent);
    border-radius: 6px;
    background: rgba(16, 185, 129, 0.05);
    margin-top: 8px;
    transition: all 0.2s;
