    // T-1914: Keyboard navigation for kanban board
    (() => {
      const board = document.querySelector(".kanban-board");
      if (!board) return;

      let focusedCard = null;

      board.addEventListener("keydown", (e) => {
        const cards = Array.from(board.querySelectorAll(".kanban-card"));
        if (!cards.length) return;

        if (!focusedCard || !document.contains(focusedCard)) {
          focusedCard = cards[0];
        }

        const currentCol = focusedCard.closest(".kanban-column");
        const colCards = Array.from(
          currentCol.querySelectorAll(".kanban-card"),
        );
        const colIdx = colCards.indexOf(focusedCard);
        const columns = Array.from(board.querySelectorAll(".kanban-column"));
        const colPos = columns.indexOf(currentCol);

        let nextCard = null;

        switch (e.key) {
          case "ArrowDown":
            e.preventDefault();
            nextCard = colCards[colIdx + 1] || colCards[0];
            break;
          case "ArrowUp":
            e.preventDefault();
            nextCard = colCards[colIdx - 1] || colCards[colCards.length - 1];
            break;
          case "ArrowRight":
            e.preventDefault();
            const nextCol = columns[colPos + 1] || columns[0];
            const nextColCards = nextCol.querySelectorAll(".kanban-card");
            nextCard = nextColCards[0] || null;
            break;
          case "ArrowLeft":
            e.preventDefault();
            const prevCol = columns[colPos - 1] || columns[columns.length - 1];
            const prevColCards = prevCol.querySelectorAll(".kanban-card");
            nextCard = prevColCards[0] || null;
            break;
          case "Enter":
            e.preventDefault();
            const id = focusedCard.dataset.id;
            if (id && typeof window.openTaskDetail === "function") {
              window.openTaskDetail(id);
            }
            return;
        }

        if (nextCard) {
          focusedCard.classList.remove("kb-focused");
          focusedCard = nextCard;
          focusedCard.classList.add("kb-focused");
          focusedCard.scrollIntoView({ block: "nearest" });
        }
      });

      // Board-level tabindex removed — it causes drag ghost artifacts and
      // makes the entire board draggable. Keyboard nav works via individual
      // card tabindex/focus instead.

      // Focus first card when board gets focus
      board.addEventListener("focus", () => {
        const firstCard = board.querySelector(".kanban-card");
        if (firstCard) {
          focusedCard = firstCard;
          focusedCard.classList.add("kb-focused");
        }
      });

      board.addEventListener("blur", () => {
        if (focusedCard) focusedCard.classList.remove("kb-focused");
      });
    })();

    // Phase 20: Type filter + swimlane grouping
    (() => {
      const activeTypes = new Set(["epic", "story", "task"]);
      let isGrouped = false;

      // Restore saved type filter state
      const savedTypeFilter = localStorage.getItem("meitheal-kanban-type-filter")
      if (savedTypeFilter) {
        try {
          const savedTypes = JSON.parse(savedTypeFilter)
          if (Array.isArray(savedTypes) && savedTypes.length > 0) {
            activeTypes.clear()
            savedTypes.forEach(t => activeTypes.add(t))
            // Update button visual state
            document.querySelectorAll(".filter-toolbar__type-btn").forEach(btn => {
              const type = btn.dataset.type
              if (type === "all") {
                btn.classList.toggle("active", activeTypes.size === 3)
              } else {
                btn.classList.toggle("active", activeTypes.has(type))
              }
            })
          }
        } catch {}
      }

      // Type filter buttons
      document.querySelectorAll(".filter-toolbar__type-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          const type = btn.dataset.type;
          if (type === "all") {
            // Toggle all types
            const allActive = activeTypes.size === 3;
            if (allActive) {
              activeTypes.clear();
              document
                .querySelectorAll(".filter-toolbar__type-btn")
                .forEach((b) => b.classList.remove("active"));
            } else {
              ["epic", "story", "task"].forEach((t) => activeTypes.add(t));
              document
                .querySelectorAll(".filter-toolbar__type-btn")
                .forEach((b) => b.classList.add("active"));
            }
          } else {
            if (activeTypes.has(type)) {
              activeTypes.delete(type);
              btn.classList.remove("active");
            } else {
              activeTypes.add(type);
              btn.classList.add("active");
            }
            // Update "All" button state
            const allBtn = document.querySelector(
              '.filter-toolbar__type-btn[data-type="all"]',
            );
            if (activeTypes.size === 3) {
              allBtn?.classList.add("active");
            } else {
              allBtn?.classList.remove("active");
            }
          }
          applyTypeFilters();
        });
      });

      function applyTypeFilters() {
        // Find visible types using safe match
        const btnTypes = Array.from(
          document.querySelectorAll(".filter-toolbar__type-btn.active"),
        ).map((b) => b.getAttribute("data-type") || "");

        // 1. Filter all cards (flat + grouped — works in all swimlane modes)
        document.querySelectorAll(".kanban-card").forEach((c) => {
          const ct = String(
            c.getAttribute("data-task-type") || "task",
          ).toLowerCase();
          // Graceful fallback: treat invalid types as "task" for filtering
          const safeType = ["epic", "story", "task"].includes(ct) ? ct : "task";

          if (btnTypes.includes("all") || btnTypes.includes(safeType)) {
            c.style.display = "";
          } else {
            c.style.display = "none";
          }
        });

        // Persist active type filter state
        const activeTypesArr = btnTypes.filter(t => t !== "all")
        if (activeTypesArr.length === 3) {
          localStorage.removeItem("meitheal-kanban-type-filter")
        } else {
          localStorage.setItem("meitheal-kanban-type-filter", JSON.stringify(activeTypesArr))
        }

        updateAllCounts();
        applyLabelFilter();
      }

      // =============================================
      // Label filter — listens for LabelFilterBar events
      // Guard: remove any previous listener to prevent stacking on ViewTransition re-exec
      // =============================================
      var activeLabelFilter = [];

      function __handleLabelFilter(e) {
        activeLabelFilter = (e.detail && e.detail.labels) || [];
        // Persist label filter state
        if (activeLabelFilter.length > 0) {
          localStorage.setItem("meitheal-kanban-label-filter", JSON.stringify(activeLabelFilter))
        } else {
          localStorage.removeItem("meitheal-kanban-label-filter")
        }
        applyLabelFilter();
      }
      document.removeEventListener("meitheal:label-filter", __handleLabelFilter);
      document.addEventListener("meitheal:label-filter", __handleLabelFilter);

      // Restore saved label filter on page load
      const savedLabelFilter = localStorage.getItem("meitheal-kanban-label-filter")
      if (savedLabelFilter) {
        try {
          const savedLabels = JSON.parse(savedLabelFilter)
          if (Array.isArray(savedLabels) && savedLabels.length > 0) {
            activeLabelFilter = savedLabels
          }
        } catch {}
      }

      function applyLabelFilter() {
        document.querySelectorAll(".kanban-card").forEach(function (c) {
          var el = c;
          if (activeLabelFilter.length === 0) {
            // No label filter — don't override type filter visibility
            return;
          }

          // Parse card labels
          var cardLabels = [];
          try {
            var raw = el.getAttribute("data-labels") || "[]";
            var parsed = JSON.parse(raw);
            if (Array.isArray(parsed)) {
              cardLabels = parsed.map(function (l) {
                return (typeof l === "string" ? l : (l.name || "")).toLowerCase();
              });
            }
          } catch (ex) { /* skip */ }

          var matchesLabel = activeLabelFilter.some(function (f) {
            return cardLabels.indexOf(f.toLowerCase()) >= 0;
          });

          if (!matchesLabel) {
            el.style.display = "none";
          }
        });
        updateAllCounts();
      }

      // Unified visibility helper — checks ALL filter dimensions
      function isCardVisible(card) {
        if (card.style.display === "none") return false
        if (card.classList.contains("user-filtered-out")) return false
        if (card.classList.contains("hidden")) return false
        return true
      }

      // Unified count updater — column headers + swimlane badges
      function updateAllCounts() {
        // 1. Column header counts
        document.querySelectorAll(".kanban-column").forEach((col) => {
          const count = col.querySelector(".kanban-count")
          const visible = Array.from(
            col.querySelectorAll(".kanban-card"),
          ).filter(isCardVisible)
          if (count) count.textContent = visible.length
        })

        // 2. Swimlane group counts (both static + dynamic)
        document.querySelectorAll(".swimlane-group").forEach((group) => {
          const countEl = group.querySelector(".swimlane-count")
          if (!countEl) return
          const visible = Array.from(
            group.querySelectorAll(".kanban-card"),
          ).filter(isCardVisible)
          countEl.textContent = visible.length
        })

        // Auto-detect filter state for clear button
        updateFilterClearBtn()
      }

      // Show/hide filter clear button based on active filter state
      const filterClearBtn = document.getElementById("kanban-clear-filters")
      function updateFilterClearBtn() {
        if (!filterClearBtn) return
        let anyActive = false
        // Type filter: any button NOT active means filter is on
        const typeButtons = document.querySelectorAll(".filter-toolbar__type-btn:not(.all-type-toggle)")
        typeButtons.forEach(btn => {
          if (!btn.classList.contains("active")) anyActive = true
        })
        // User filter: not "all" selected
        const activeUserBtn = document.querySelector(".filter-toolbar__user-btn.active")
        if (activeUserBtn && activeUserBtn.dataset.user !== "all") anyActive = true
        // Board filter: not empty/all
        const boardSelect = document.getElementById("kanban-filter-board")
        if (boardSelect && boardSelect.value) anyActive = true
        // Label filter: check via event system (label filter dispatches custom events)
        const anyCardHidden = document.querySelector(".kanban-card[style*='display: none']")
        if (anyCardHidden) anyActive = true

        filterClearBtn.classList.toggle("hidden", !anyActive)
      }

      // Clear all filters handler
      if (filterClearBtn) {
        filterClearBtn.addEventListener("click", () => {
          // Reset type filters — activate all
          document.querySelectorAll(".filter-toolbar__type-btn").forEach(btn => {
            btn.classList.add("active")
          })

          // Reset user filter — show all
          document.querySelectorAll(".filter-toolbar__user-btn").forEach(btn => {
            btn.classList.toggle("active", btn.dataset.user === "all")
          })
          document.querySelectorAll(".kanban-card.user-filtered-out").forEach(card => {
            card.classList.remove("user-filtered-out")
          })

          // Reset board filter
          const boardSelect = document.getElementById("kanban-filter-board")
          if (boardSelect) boardSelect.value = ""

          // Show all cards
          document.querySelectorAll(".kanban-card").forEach(card => {
            card.style.display = ""
          })

          // Show all swimlane groups
          document.querySelectorAll(".swimlane-group.hidden").forEach(group => {
            group.classList.remove("hidden")
          })

          // Clear label filter via event
          document.dispatchEvent(new CustomEvent("meitheal:label-filter", { detail: { label: "" } }))

          // Clear saved filter state
          localStorage.removeItem("meitheal-board-filter")
          localStorage.removeItem("meitheal-user-filter")
          localStorage.removeItem("meitheal-kanban-type-filter")
          localStorage.removeItem("meitheal-kanban-board-filter")
          localStorage.removeItem("meitheal-kanban-label-filter")

          updateAllCounts()
          updateFilterClearBtn()

          if (window.showToast) window.showToast("All filters cleared", "info")
        })
      }

      // Swimlane group-by dropdown
      const groupBySelect = document.getElementById("kanban-group-by");

      // Board filter toolbar integration (P1 fix)
      const boardFilterSelect = document.getElementById("kanban-filter-board");
      if (boardFilterSelect) {
        // Populate board options from API
        fetch((window.__ingress_path || "") + "/api/boards")
          .then(r => r.ok ? r.json() : { boards: [] })
          .then(data => {
            (data.boards || []).forEach(b => {
              const opt = document.createElement("option");
              opt.value = b.id;
              opt.textContent = `${b.icon || '📋'} ${b.title}`;
              boardFilterSelect.appendChild(opt);
            });
            // Restore saved board filter
            const savedBoard = localStorage.getItem("meitheal-kanban-board-filter");
            if (savedBoard) {
              boardFilterSelect.value = savedBoard;
              boardFilterSelect.dispatchEvent(new Event("change"));
            }
          })
          .catch(() => { /* graceful fallback — filter stays on "All Boards" */ });

        // Filter cards when board selection changes
        boardFilterSelect.addEventListener("change", () => {
          const boardId = boardFilterSelect.value;
          localStorage.setItem("meitheal-kanban-board-filter", boardId);
          document.querySelectorAll(".kanban-card").forEach(card => {
            if (!boardId || card.dataset.board === boardId) {
              card.style.display = "";
            } else {
              card.style.display = "none";
            }
          });
          updateAllCounts();
          // Sync with sidebar
          document.dispatchEvent(new CustomEvent("board-filter-change", {
            detail: { boardId }
          }));
        });

        // Listen for sidebar board changes to sync toolbar
        document.addEventListener("board-changed", (e) => {
          if (e.detail?.boardId) {
            boardFilterSelect.value = e.detail.boardId;
            boardFilterSelect.dispatchEvent(new Event("change"));
          }
        });
      }


      // Restore saved group-by mode from localStorage
      const savedGroupBy = localStorage.getItem("meitheal-kanban-group-by");
      if (savedGroupBy && groupBySelect) {
        groupBySelect.value = savedGroupBy;
        // Trigger change event to apply saved mode
        groupBySelect.dispatchEvent(new Event("change"));
      }

      groupBySelect?.addEventListener("change", async () => {
        const mode = groupBySelect.value;
        // Persist selection
        localStorage.setItem("meitheal-kanban-group-by", mode);

        // Resolve board titles for group-by-board mode
        let boardTitleMap = {};
        if (mode === "board") {
          try {
            const res = await fetch((window.__ingress_path || "") + "/api/boards");
            if (res.ok) {
              const data = await res.json();
              (data.boards || []).forEach(b => { boardTitleMap[b.id] = `${b.icon || '📋'} ${b.title}`; });
            }
          } catch { /* use raw IDs as fallback */ }
          boardTitleMap["default"] = "📋 Default";
        }

        // Ungroup everything first
        document.querySelectorAll(".kanban-column").forEach((col) => {
          const cardsContainer = col.querySelector(".kanban-cards");
          if (!cardsContainer) return;

          // Move all cards back to flat
          cardsContainer
            .querySelectorAll(".swimlane-group")
            .forEach((group) => {
              const swimlaneCards = group.querySelector(".swimlane-cards");
              if (swimlaneCards) {
                swimlaneCards
                  .querySelectorAll(".kanban-card")
                  .forEach((card) => {
                    card.classList.remove("grouped-card");
                    card.classList.add("flat-card");
                    cardsContainer.insertBefore(card, group);
                  });
              }
            });

          // Remove dynamic swimlane groups
          cardsContainer
            .querySelectorAll(".swimlane-group.dynamic-group")
            .forEach((g) => g.remove());
          // Hide static type swimlane groups
          cardsContainer
            .querySelectorAll(".swimlane-group:not(.dynamic-group)")
            .forEach((g) => {
              g.style.display = "none";
            });
        });

        isGrouped = mode !== "none";

        if (mode === "none") {
          applyTypeFilters();
          return;
        }

        if (mode === "type") {
          // Use the pre-rendered type swimlane groups
          document.querySelectorAll(".kanban-column").forEach((col) => {
            const cardsContainer = col.querySelector(".kanban-cards");
            if (!cardsContainer) return;
            cardsContainer.querySelectorAll(".flat-card").forEach((card) => {
              const type = card.dataset.taskType || "task";
              const swimlane = cardsContainer.querySelector(
                `.swimlane-group[data-swimlane-type="${type}"] .swimlane-cards`,
              );
              if (swimlane) {
                card.classList.remove("flat-card");
                card.classList.add("grouped-card");
                swimlane.appendChild(card);
              }
            });
            cardsContainer
              .querySelectorAll(".swimlane-group:not(.dynamic-group)")
              .forEach((group) => {
                const groupType = group.dataset.swimlaneType;
                group.classList.toggle("hidden", !activeTypes.has(groupType));
                const countEl = group.querySelector(".swimlane-count");
                const cards = group.querySelectorAll(".kanban-card");
                if (countEl) countEl.textContent = Array.from(cards).filter(isCardVisible).length;
              });
          });
        } else if (mode === "board" || mode === "priority") {
          // Dynamic swimlane generation for board/priority
          const dataAttr = mode === "board" ? "board" : "priority";
          const icons =
            mode === "priority"
              ? {
                  "1": "🔴 P1 — Critical",
                  "2": "🟠 P2 — High",
                  "3": "🟡 P3 — Medium",
                  "4": "🟢 P4 — Low",
                  "5": "⚪ P5 — Minimal",
                }
              : {};
          const defaultLabel =
            mode === "priority" ? "🟡 P3 — Medium" : "📋 Default";

          document.querySelectorAll(".kanban-column").forEach((col) => {
            const cardsContainer = col.querySelector(".kanban-cards");
            if (!cardsContainer) return;
            const flatCards = Array.from(
              cardsContainer.querySelectorAll(".flat-card"),
            );

            // Collect unique values
            const groups = new Map();
            flatCards.forEach((card) => {
              const val =
                card.dataset[dataAttr] ||
                (mode === "priority" ? "3" : "default");
              if (!groups.has(val)) groups.set(val, []);
              groups.get(val).push(card);
            });

            // Sort: priority by number, board alphabetically
            const sortedKeys = Array.from(groups.keys()).sort((a, b) => {
              if (mode === "priority") return Number(a) - Number(b);
              return a.localeCompare(b);
            });

            sortedKeys.forEach((key) => {
              const cards = groups.get(key);
              const group = document.createElement("div");
              group.className = "swimlane-group dynamic-group";
              group.dataset.swimlaneType = key;

              const header = document.createElement("div");
              header.className = "swimlane-header";
              const label =
                icons[key] || (mode === "board" ? (boardTitleMap[key] || `📋 ${key}`) : defaultLabel);
              const toggleSpan = document.createElement("span");
              toggleSpan.className = "swimlane-toggle";
              toggleSpan.textContent = "▼";
              const labelSpan = document.createElement("span");
              labelSpan.className = "swimlane-label";
              labelSpan.textContent = label;
              const countSpan = document.createElement("span");
              countSpan.className = "swimlane-count";
              countSpan.textContent = String(cards.filter(isCardVisible).length);
              header.append(toggleSpan, labelSpan, countSpan);

              // Collapse toggle — matches static swimlane CSS class pattern
              header.style.cursor = "pointer"
              header.addEventListener("click", () => {
                const cardsEl = group.querySelector(".swimlane-cards")
                const toggle = header.querySelector(".swimlane-toggle")
                if (!cardsEl) return
                const isCollapsed = cardsEl.classList.toggle("collapsed")
                if (toggle) {
                  toggle.classList.toggle("collapsed", isCollapsed)
                  toggle.textContent = isCollapsed ? "▶" : "▼"
                }
                group.classList.toggle("swimlane-collapsed", isCollapsed)
                // Persist collapse state
                const collapseKey = `meitheal-swimlane-dyn-${key}`
                localStorage.setItem(collapseKey, isCollapsed ? "collapsed" : "expanded")
              });

              const swimlaneCards = document.createElement("div");
              swimlaneCards.className = "swimlane-cards";
              cards.forEach((card) => {
                card.classList.remove("flat-card");
                card.classList.add("grouped-card");
                swimlaneCards.appendChild(card);
              });

              group.appendChild(header);
              group.appendChild(swimlaneCards);
              cardsContainer.appendChild(group);

              // Restore saved collapse state for dynamic swimlane
              const collapseKey = `meitheal-swimlane-dyn-${key}`;
              if (localStorage.getItem(collapseKey) === "collapsed") {
                swimlaneCards.classList.add("collapsed");
                toggleSpan.classList.add("collapsed");
                toggleSpan.textContent = "▶";
                group.classList.add("swimlane-collapsed");
              }
            });
          });
        }

        applyTypeFilters();
      });

      // Swimlane header collapse toggle — CSS animation + localStorage persistence
      document.querySelectorAll(".swimlane-header").forEach((header) => {
        const group = header.closest(".swimlane-group");
        if (!group) return;
        const cards = group.querySelector(".swimlane-cards");
        const toggle = header.querySelector(".swimlane-toggle");
        const type = header.dataset.type || "unknown";
        const storageKey = `meitheal-kanban-swimlane-${type}`;

        // Restore saved collapse state
        const saved = localStorage.getItem(storageKey);
        if (saved === "collapsed" && cards) {
          cards.classList.add("collapsed");
          if (toggle) {
            toggle.classList.add("collapsed");
            toggle.textContent = "▶";
          }
          group.classList.add("swimlane-collapsed");
        }

        header.style.cursor = "pointer";
        header.addEventListener("click", () => {
          if (!cards) return;
          const isCollapsed = cards.classList.toggle("collapsed");
          if (toggle) {
            toggle.classList.toggle("collapsed", isCollapsed);
            toggle.textContent = isCollapsed ? "▶" : "▼";
          }
          group.classList.toggle("swimlane-collapsed", isCollapsed);
          localStorage.setItem(storageKey, isCollapsed ? "collapsed" : "expanded");
        });
      });
    })();

    // T-1915: Column collapse toggle (REMOVED — clicking lane headers to collapse
    // was unintuitive UX and caused visual breakage, per user feedback).

    // --- Offline Attachments Feature (Phase 23) ---
    (async function renderThumbnails() {
      if (!window.indexedDB) return;
      // Only attempt module load if there are attachment slots in the DOM
      var slots = document.querySelectorAll("img.kanban-attachment");
      if (!slots.length) return;
      try {
        // Dynamic import — Vite resolves this at build time into the
        // bundled chunk. No @vite-ignore needed since path is static.
        var mod = await import("../../domains/offline/offline-store.ts").catch(
          function () {
            return null; // Silently skip if module not available
          },
        );
        if (!mod || !mod.getAttachmentsByTaskId) return;
        var getAttachmentsByTaskId = mod.getAttachmentsByTaskId;
        slots.forEach(async (img) => {
          const taskId = img.getAttribute("data-task-id");
          if (!taskId) return;
          const attachments = await getAttachmentsByTaskId(taskId);
          if (attachments.length > 0) {
            // Get the first image
            const cover = attachments.find((a) =>
              a.mimeType.startsWith("image/"),
            );
            if (cover) {
              img.setAttribute("src", cover.base64Data);
              img.classList.remove("hidden");
            }
          }
        });
      } catch (_) {
        /* Offline attachments unavailable — non-critical */
      }
    })();

    // Phase 32: User filter — Jira-style assignee pills
    (async function initUserFilter() {
      const container = document.getElementById("kanban-user-filters");
      if (!container) return;

      try {
        const res = await fetch((window.__ingress_path || "") + "/api/users");
        if (!res.ok) return;
        const data = await res.json();
        const users = data.users || [];

        // Render user pills dynamically
        users.forEach((u) => {
          const btn = document.createElement("button");
          btn.type = "button";
          btn.className = "user-filter-btn";
          btn.dataset.user = u.id;
          btn.title = u.display_name || u.name || u.id;

          const avatar = document.createElement("span");
          avatar.className = "user-avatar-pill";
          avatar.style.background = u.color || "var(--accent)";
          avatar.textContent = (u.display_name || u.name || "?")
            .slice(0, 2)
            .toUpperCase();
          btn.appendChild(avatar);
          // No text label — initials avatar + title tooltip is sufficient
          // (matches Teamhood/Jira/Linear initials-only pattern)

          container.appendChild(btn);
        });
      } catch {
        /* users API unavailable — filter stays with All/Unassigned */
      }

      // Restore saved filter
      const saved =
        localStorage.getItem("meitheal-kanban-user-filter") || "all";
      const savedBtn = container.querySelector(
        `[data-user="${CSS.escape(saved)}"]`,
      );
      if (savedBtn) {
        container
          .querySelector(".filter-toolbar__user-btn.active")
          ?.classList.remove("active");
        savedBtn.classList.add("active");
      }

      // Apply filter
      function applyUserFilter() {
        const activeBtn = container.querySelector(".filter-toolbar__user-btn.active");
        const userId = activeBtn?.dataset.user || "all";
        localStorage.setItem("meitheal-kanban-user-filter", userId);

        document
          .querySelectorAll(".kanban-card[data-assigned]")
          .forEach((el) => {
            const card = el;
            const assigned = card.dataset.assigned || "";

            if (userId === "all") {
              card.classList.remove("user-filtered-out");
            } else if (userId === "unassigned") {
              card.classList.toggle("user-filtered-out", assigned !== "");
            } else {
              card.classList.toggle("user-filtered-out", assigned !== userId);
            }
          });

        updateAllCounts()
      }

      // Click handlers
      container.addEventListener("click", (e) => {
        const btn = e.target.closest(".filter-toolbar__user-btn");
        if (!btn) return;
        container
          .querySelectorAll(".filter-toolbar__user-btn")
          .forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        applyUserFilter();
      });

      // Apply on load
      applyUserFilter();
    })();

    // ─── Touch Drag Polyfill (Long-Press Paradigm) ─────────────
    // HTML5 Drag API doesn't fire on touch devices. Mobile UX:
    // Hold card 300ms → haptic vibrate → enter drag mode → drop on column.
    (function initTouchDrag() {
      let dragCard = null;
      let ghost = null;
      let holdTimer = null;
      let isDragging = false;
      let startX = 0,
        startY = 0;

      function cancelHold() {
        if (holdTimer) {
          clearTimeout(holdTimer);
          holdTimer = null;
        }
      }

      function createGhost(card, x, y) {
        ghost = card.cloneNode(true);
        const w = card.offsetWidth;
        ghost.style.cssText =
          "position:fixed;pointer-events:none;opacity:0.85;z-index:9999;" +
          "width:" +
          w +
          "px;transform:rotate(2deg) scale(1.05);" +
          "box-shadow:0 12px 40px rgba(0,0,0,0.5);border-radius:12px;" +
          "left:" +
          (x - w / 2) +
          "px;top:" +
          (y - 30) +
          "px;transition:none;";
        document.body.appendChild(ghost);
      }

      function activateDrag(card, x, y) {
        isDragging = true;
        dragCard = card;
        card.classList.add("dragging");
        card.style.opacity = "0.3";
        card.style.touchAction = "none";
        createGhost(card, x, y);
        // Haptic feedback on supported devices
        if (navigator.vibrate) navigator.vibrate(30);
      }

      function cleanup() {
        cancelHold();
        if (dragCard) {
          dragCard.classList.remove("dragging");
          dragCard.style.opacity = "";
          dragCard.style.touchAction = "";
        }
        if (ghost) {
          ghost.remove();
          ghost = null;
        }
        document
          .querySelectorAll(".kanban-column.drag-over")
          .forEach(function (c) {
            c.classList.remove("drag-over");
          });
        dragCard = null;
        isDragging = false;
      }

      // Use event delegation on the board container
      var board = document.querySelector(".kanban-board");
      if (!board) return;

      board.addEventListener(
        "touchstart",
        function (e) {
          var card = e.target.closest('.kanban-card[draggable="true"]');
          if (!card) return;
          // Don't interfere with action button taps
          if (e.target.closest("button, a, .card-action-btn")) return;

          var t = e.touches[0];
          if (!t) return;
          startX = t.clientX;
          startY = t.clientY;

          // Start 300ms hold timer
          cancelHold();
          holdTimer = setTimeout(function () {
            holdTimer = null;
            activateDrag(card, startX, startY);
          }, 300);
        },
        { passive: true },
      );

      board.addEventListener(
        "touchmove",
        function (e) {
          var t = e.touches[0];
          if (!t) return;

          // If hold timer is still active, cancel if finger moves too much (scrolling)
          if (holdTimer) {
            var dx = Math.abs(t.clientX - startX);
            var dy = Math.abs(t.clientY - startY);
            if (dx > 8 || dy > 8) {
              cancelHold(); // user is scrolling, not holding
            }
            return;
          }

          if (!isDragging || !dragCard) return;
          e.preventDefault(); // prevent scroll during drag

          // Move ghost to follow finger
          if (ghost) {
            ghost.style.left = t.clientX - ghost.offsetWidth / 2 + "px";
            ghost.style.top = t.clientY - 30 + "px";
          }

          // Highlight column under touch (hide ghost briefly for elementFromPoint)
          if (ghost) ghost.style.display = "none";
          var el = document.elementFromPoint(t.clientX, t.clientY);
          if (ghost) ghost.style.display = "";

          document.querySelectorAll(".kanban-column").forEach(function (col) {
            col.classList.remove("drag-over");
          });
          var col = el ? el.closest(".kanban-column") : null;
          if (col) col.classList.add("drag-over");
        },
        { passive: false },
      );

      board.addEventListener(
        "touchend",
        function (e) {
          cancelHold();
          if (!isDragging || !dragCard) {
            cleanup();
            return;
          }

          var t = e.changedTouches[0];
          if (!t) {
            cleanup();
            return;
          }

          // Hide ghost for accurate elementFromPoint
          if (ghost) ghost.style.display = "none";
          var el = document.elementFromPoint(t.clientX, t.clientY);
          if (ghost) ghost.style.display = "";

          var targetCol = el ? el.closest(".kanban-column") : null;
          var cardId = dragCard.dataset.id;

          cleanup(); // reset visual state first

          if (targetCol && cardId) {
            var fakeEvent = {
              preventDefault: function () {},
              currentTarget: targetCol,
              target: el,
              dataTransfer: {
                getData: function () {
                  return cardId;
                },
              },
            };
            handleDrop(fakeEvent);
          }
        },
        { passive: true },
      );

      // Cancel drag on context menu / multi-touch
      board.addEventListener(
        "touchcancel",
        function () {
          cleanup();
        },
        { passive: true },
      );
    })();
  </script>
</Layout>

