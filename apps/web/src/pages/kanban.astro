---
import Layout from "../layouts/Layout.astro";
import TaskViewTabs from "../components/tasks/TaskViewTabs.astro";
import LabelBadges from "../components/ui/LabelBadges.astro";
import FilterToolbar from "../components/ui/FilterToolbar.astro";
import { t } from "../i18n/translations";
import type { Locale } from "../lib/locale";
import { formatRegionalDate } from "../lib/date";
import { formatTicketKey } from "../lib/ticket-key";
import {
  ensureSchema,
  getPersistenceClient,
} from "@domains/tasks/persistence/store";
import { TaskRepository } from "@domains/tasks/persistence/task-repository";

const {
  ingressPath,
  hassioTokenPresent,
  hassUserId,
  timezone,
  weekStart,
  dateFormat,
} = Astro.locals;

// i18n: resolve locale from cookie
const cookieLocale = Astro.cookies.get("meitheal-locale")?.value;
const locale: Locale = cookieLocale === "ga" ? "ga" : "en";

await ensureSchema();
const repo = new TaskRepository(getPersistenceClient());

// Completed task auto-hide: read retention setting (default 30 days, 0 = never hide)
let completedAutoHideDays = 30;
// Backlog mode: visible (default) | hidden | disabled
let backlogMode = "visible";
try {
  const settings = await repo.getSettings([
    "completed_auto_hide_days",
    "backlog_mode",
  ]);
  if (settings.completed_auto_hide_days) {
    const val = Number(JSON.parse(settings.completed_auto_hide_days));
    if (!isNaN(val) && val >= 0) completedAutoHideDays = val;
  }
  if (settings.backlog_mode) {
    const val = JSON.parse(settings.backlog_mode);
    if (val === "hidden" || val === "disabled") backlogMode = val;
  }
} catch {
  /* settings table may not exist yet — use defaults */
}

const completedCutoffMs =
  completedAutoHideDays > 0 ? Date.now() - completedAutoHideDays * 86400000 : 0; // 0 = show all

let tasks: Record<string, unknown>[] = [];
let commentCounts: Record<string, number> = {};
try {
  let allTasks = await repo.getKanbanTasks();

  // Filter out completed tasks older than retention window (kanban-only; table view shows all)
  if (completedCutoffMs > 0) {
    allTasks = allTasks.filter((t) => {
      const status = String(t.status ?? "").toLowerCase();
      if (status === "complete") {
        return Number(t.updated_at ?? 0) >= completedCutoffMs;
      }
      return true;
    });
  }
  tasks = allTasks;
  // Comment count aggregation (competitor parity: Jira/Asana/Linear show comment counts)
  try {
    commentCounts = await repo.getCommentCounts();
  } catch {
    /* comments table may not exist yet */
  }
} catch (e) {
  /* DB not available */
}

let columns: {
  key: string;
  label: string;
  icon: string;
  includes: string[];
  builtIn: boolean;
  wipLimit: number;
  id: string;
}[] = [];
try {
  columns = await repo.getKanbanLanes();
} catch {
  /* fallback to defaults */
}

// Fallback if no lanes in DB
if (columns.length === 0) {
  columns = [
    {
      id: "lane-backlog",
      key: "backlog",
      label: "Backlog",
      icon: "📥",
      includes: ["backlog"],
      builtIn: true,
      wipLimit: 0,
    },
    {
      id: "lane-pending",
      key: "pending",
      label: "Todo",
      icon: "📋",
      includes: ["pending"],
      builtIn: true,
      wipLimit: 0,
    },
    {
      id: "lane-active",
      key: "active",
      label: "In Progress",
      icon: "⚡",
      includes: ["active"],
      builtIn: true,
      wipLimit: 0,
    },
    {
      id: "lane-complete",
      key: "complete",
      label: "Done",
      icon: "✅",
      includes: ["complete"],
      builtIn: true,
      wipLimit: 0,
    },
  ];
}

// Backlog mode: filter out backlog lane when hidden or disabled
if (backlogMode === "hidden" || backlogMode === "disabled") {
  columns = columns.filter((col) => col.key !== "backlog");
}

import { PRIORITY_COLORS as priorityColors, PRIORITY_CSS_CLASSES as priorityClasses } from "../lib/priority-config";

const priorityLabels: Record<number, string> = {
  1: t("priority.critical", locale),
  2: t("priority.high", locale),
  3: t("priority.medium", locale),
  4: t("priority.low", locale),
  5: t("priority.minimal", locale),
};

// Phase 20: Agile type metadata
const typeConfig: Record<
  string,
  { icon: string; label: string; color: string }
> = {
  epic: { icon: "🎯", label: "Epic", color: "#8b5cf6" },
  story: { icon: "📖", label: "Story", color: "#3b82f6" },
  task: { icon: "✅", label: "Task", color: "#6366F1" },
};
---

<Layout title={`Meitheal — ${t("kanban.title", locale)}`}>
  <span slot="page-title">{t("kanban.title", locale)}</span>
  <div slot="actions" class="kanban-actions-slot">
    <button
      type="button"
      class="btn btn-ghost"
      id="manage-lanes-btn"
      title={t("kanban.manage_swimlanes", locale)}
      >{t("kanban.manage_lanes", locale)}</button
    >
    <button type="button" class="btn btn-primary" id="kanban-new-task-btn"
      >{t("kanban.new_task", locale)}</button
    >
  </div>

  <TaskViewTabs activeView="board" />

  {/* Label filter bar */}
  {/* Shared FilterToolbar — replaces inline type-toolbar + LabelFilterBar (Phase 2) */}
  <FilterToolbar
    view="kanban"
    showGroupBy
    showUserPills
  />

  <!-- Lane management panel -->
  <div class="lane-mgmt hidden" id="lane-mgmt">
    <div class="lane-mgmt-inner">
      <div class="lane-mgmt-header">
        <strong>{t("kanban.manage_swimlanes", locale)}</strong>
        <button
          type="button"
          class="btn-icon lane-mgmt-close"
          id="lane-mgmt-close"
          aria-label="Close"
          >✕</button
        >
      </div>
      <div id="lane-list"></div>
      <div class="lane-mgmt-add-row">
        <input
          type="text"
          class="form-input lane-mgmt-add-input"
          id="new-lane-input"
          placeholder={t("kanban.new_lane_placeholder", locale)}
        />
        <button
          type="button"
          class="btn btn-primary lane-mgmt-add-btn"
          id="add-lane-btn"
          >{t("kanban.add_lane", locale)}</button
        >
      </div>
    </div>
  </div>

  <div
    class="kanban-board"
    data-backlog-mode={backlogMode}
    style={`padding: 0 0 8px; grid-template-columns: repeat(${columns.length}, 1fr);`}
  >
    {
      columns.map((col) => {
        const colTasks = tasks.filter((t) =>
          col.includes.includes(String(t.status)),
        );
        const wipExceeded = col.wipLimit > 0 && colTasks.length > col.wipLimit;
        return (
          <div
            class={`kanban-column${wipExceeded ? " wip-exceeded" : ""}`}
            data-status={col.key}
            data-lane-id={col.id}
            data-wip-limit={String(col.wipLimit)}
            role="region"
            aria-label={`${col.label} Swimlane`}

          >
            <div class="kanban-column-header" data-column-key={col.key}>
              <span class="kanban-column-title">
                <span class={`column-status-dot status-${col.key}`}></span>
                {col.label}
              </span>
              <span class="kanban-header-right">
                {col.wipLimit > 0 && (
                  <span
                    class={`kanban-wip${wipExceeded ? " wip-over" : ""}`}
                    title={`WIP limit: ${col.wipLimit}`}
                  >
                    {colTasks.length}/{col.wipLimit}
                  </span>
                )}
                <span class="kanban-count">{colTasks.length}</span>
              </span>
            </div>
            <div class="kanban-cards">
              {/* Swimlane group containers (hidden by default, JS-driven grouping) */}
              {["epic", "story", "task"].map((type) => {
                const tc = typeConfig[type] ?? {
                  icon: "📋",
                  label: type,
                  color: "#6b7280",
                };
                const count = colTasks.filter(
                  (t) => String(t.task_type ?? "task") === type,
                ).length;
                return (
                  <div
                    class={`swimlane-group swimlane-${type} hidden`}
                    data-swimlane-type={type}
                  >
                    <div class="swimlane-header" data-type={type}>
                      <span class="swimlane-toggle">▼</span>
                      <span
                        class="swimlane-type-dot"
                        style={`background: ${tc.color};`}
                      />
                      <span class="swimlane-label">
                        {tc.icon} {tc.label}
                      </span>
                      <span class="swimlane-count">{count}</span>
                    </div>
                    <div class="swimlane-cards">
                      {/* Cards moved here by JS when grouping is active */}
                    </div>
                    <button
                      type="button"
                      class="kanban-add-btn swimlane-add-btn"
                      data-status={col.key}
                      data-task-type={type}
                      aria-label={`Add ${type} to ${col.label}`}
                    >
                      + {t("kanban.add_task", locale)}
                    </button>
                  </div>
                );
              })}
              {/* Flat (non-grouped) card rendering */}
              {colTasks.map((task) => {
                const p = Number(task.priority ?? 3);
                const tt = String(task.task_type ?? "task");
                const tc = (typeConfig[tt] || typeConfig.task)!;
                const fp =
                  typeof task.framework_payload === "string"
                    ? JSON.parse(String(task.framework_payload))
                    : {};
                // Phase 20: Sub-task indicator (ADHD Optimization)
                const childCount = tasks.filter(
                  (t) => t.parent_id === task.id,
                ).length;
                const rice =
                  fp.reach && fp.impact && fp.confidence && fp.effort
                    ? Math.round(
                        (Number(fp.reach) *
                          Number(fp.impact) *
                          Number(fp.confidence)) /
                          Number(fp.effort),
                      )
                    : null;
                const dueDate = task.due_date
                  ? new Date(String(task.due_date))
                  : null;
                const today = new Date();
                today.setHours(0, 0, 0, 0);
                const dueStatus = dueDate
                  ? dueDate < today
                    ? "overdue"
                    : dueDate.toDateString() === new Date().toDateString()
                      ? "today"
                      : "upcoming"
                  : null;
                return (
                  <div
                    class={`kanban-card flat-card`}
                    draggable="true"
                    role="button"
                    tabindex="0"
                    aria-label={`Task: ${String(task.title)}, Priority: ${priorityLabels[p]}`}
                    data-id={String(task.id)}
                    data-title={String(task.title)}
                    data-desc={
                      task.description
                        ? String(task.description).slice(0, 200)
                        : ""
                    }
                    data-priority={String(p)}
                    data-status={String(task.status)}
                    data-task-type={tt}
                    data-board={String(task.board_id ?? "default")}
                    data-assigned={String(task.assigned_to ?? "")}
                    data-labels={String(task.labels ?? "[]")}

                    style={`border-left: 4px solid ${task.color ? String(task.color) : tc.color};`}
                  >
                    <div class="kanban-card-header">
                      <div
                        class="kanban-card-title"
                      >
                        <span
                          class="type-badge"
                          style={`background: ${tc.color}20; color: ${tc.color}; border-color: ${tc.color}40;`}
                          title={tc.label}
                        >
                          {tc.icon}
                        </span>
                        <span
                          class="kanban-ticket-key"
                        >
                          {formatTicketKey(Number(task.ticket_number))}
                        </span>
                        <span class="kanban-title-text" data-task-id={String(task.id)}>{String(task.title)}</span>
                      </div>
                      {Number(task.is_favorite ?? 0) === 1 && (
                        <span
                          class="kanban-fav"
                          title={t("kanban.favorite", locale)}
                        >
                          ★
                        </span>
                      )}
                    </div>
                    {/* Attachment Placeholder */}
                    <img
                      class="kanban-attachment hidden"
                      data-task-id={String(task.id)}
                      alt="Attachment"
                      loading="lazy"
                    />

                    {task.description && String(task.description).trim() && (
                      <div class="kanban-card-desc">
                        {String(task.description).slice(0, 80)}
                        {String(task.description).length > 80 ? "…" : ""}
                      </div>
                    )}
                    <div class="kanban-card-meta">
                      <span
                        class={`priority-dot ${priorityClasses[p] ?? 'priority-medium'}`}
                        title={priorityLabels[p]}
                      />
                      <span class={`priority-label ${priorityClasses[p] ?? 'priority-medium'}`}>
                        {priorityLabels[p]}
                      </span>
                      {task.due_date ? (
                        <span
                          class={`kanban-card-due ${dueStatus ? `due-${dueStatus}` : ""}`}
                        >
                          {dueStatus === "overdue"
                            ? "🔴"
                            : dueStatus === "today"
                              ? "🟡"
                              : "📅"}{" "}
                          {formatRegionalDate(dueDate, {
                            format: dateFormat,
                            timezone,
                          })}
                        </span>
                      ) : null}
                      {childCount > 0 && (
                        <span
                          class="kanban-meta-subtasks"
                          title={`${childCount} sub-tasks`}
                        >
                          ↳ {childCount}
                        </span>
                      )}
                      {rice ? (
                        <span class="kanban-rice-badge">RICE: {rice}</span>
                      ) : null}
                      {String(task.calendar_sync_state) === "confirmed" && (
                        <span
                          class="kanban-sync-badge"
                          title={t("kanban.calendar_synced", locale)}
                        >
                          📅✓
                        </span>
                      )}
                      {task.recurrence_rule && (
                        <span
                          class="kanban-meta-recurrence"
                          title="Recurring task"
                        >
                          🔁
                        </span>
                      )}
                      {(() => {
                        try {
                          const cl = task.checklists ? (typeof task.checklists === "string" ? JSON.parse(String(task.checklists)) : task.checklists) : [];
                          if (Array.isArray(cl) && cl.length > 0) {
                            const done = cl.filter((i: {done: boolean}) => i.done).length;
                            return (
                              <span
                                class={`kanban-meta-checklist${done === cl.length ? ' checklist-complete' : ''}`}
                                title={`Checklist: ${done}/${cl.length}`}
                              >
                                ✓ {done}/{cl.length}
                              </span>
                            );
                          }
                        } catch { /* skip */ }
                        return null;
                      })()}
                      {(commentCounts[String(task.id)] ?? 0) > 0 && (
                        <span
                          class="kanban-meta-comments"
                          title={`${commentCounts[String(task.id)] ?? 0} comments`}
                        >
                          💬 {commentCounts[String(task.id)] ?? 0}
                        </span>
                      )}
                      {task.assigned_to && (
                        <span
                          class="kanban-assignee-badge"
                          title={`Assigned: ${String(task.assigned_to).replace(/^(ha_|custom_)/, "")}`}
                          aria-label={`Assigned to ${String(task.assigned_to).replace(/^(ha_|custom_)/, "")}`}
                        >
                          {String(task.assigned_to)
                            .replace(/^(ha_|custom_)/, "")
                            .slice(0, 2)
                            .toUpperCase()}
                        </span>
                      )}
                    </div>
                    {/* Progress bar */}
                    {Number(task.progress ?? 0) > 0 && (
                      <div class="kanban-progress">
                        <div class="kanban-progress-track">
                          <div
                            class="kanban-progress-bar"
                            style={`width: ${Number(task.progress)}%`}
                          />
                        </div>
                        <span class="kanban-progress-text">
                          {Number(task.progress)}%
                        </span>
                      </div>
                    )}
                    {/* Labels */}
                    <LabelBadges labels={task.labels as string} compact max={4} />
                    {/* Custom fields */}
                    {(() => {
                      try {
                        const cf =
                          typeof task.custom_fields === "string"
                            ? JSON.parse(String(task.custom_fields ?? "{}"))
                            : {};
                        const keys = Object.keys(cf);
                        if (keys.length > 0) {
                          return (
                            <div class="kanban-custom-fields">
                              {keys.slice(0, 4).map((k) => (
                                <span
                                  class="kanban-cf-chip"
                                  title={`${k}: ${cf[k]}`}
                                >
                                  {k}: {String(cf[k]).slice(0, 20)}
                                </span>
                              ))}
                              {keys.length > 4 && (
                                <span class="kanban-cf-chip">
                                  +{keys.length - 4} more
                                </span>
                              )}
                            </div>
                          );
                        }
                      } catch {
                        /* skip */
                      }
                      return null;
                    })()}
                    <div class="kanban-card-actions">
                      <button
                        class="card-action-btn card-edit-btn"
                        data-id={String(task.id)}
                        title={t("kanban.edit_task", locale)}
                        aria-label={`Edit task: ${String(task.title ?? "").slice(0, 50)}`}
                      >
                        ✎
                      </button>
                      <button
                        class="card-action-btn card-ai-btn"
                        data-title={String(task.title)}
                        data-desc={
                          task.description ? String(task.description) : ""
                        }
                        data-status={String(task.status ?? "pending")}
                        data-priority={String(p)}
                        title={t("tasks.ask_ai", locale)}
                        aria-label={`AI assist for: ${String(task.title ?? "").slice(0, 50)}`}
                      >
                        ⚡
                      </button>
                      <button
                        class="card-action-btn card-dup-btn"
                        data-id={String(task.id)}
                        title={t("kanban.duplicate", locale)}
                        aria-label={`Duplicate task: ${String(task.title ?? "").slice(0, 50)}`}
                      >
                        ⊕
                      </button>
                      <button
                        class="card-action-btn card-more-btn"
                        data-id={String(task.id)}
                        title="More actions"
                        aria-label={`More options for: ${String(task.title ?? "").slice(0, 50)}`}
                      >
                        ⋯
                      </button>
                    </div>
                  </div>
                );
              })}
              {colTasks.length === 0 && (
                <div class="kanban-empty">
                  {t("kanban.drop_tasks_here", locale)}
                </div>
              )}
            </div>
            <button
              class="kanban-add-btn"
              data-status={col.key}
              aria-label={`Add task to ${col.label}`}
            >
              + {t("kanban.add_task", locale)}
            </button>
          </div>
        );
      })
    }
  </div>

  <div
    id="toast-container"
    class="toast-container"
    aria-live="polite"
    role="status"
    data-no-scroll-lock="true"
  >
  </div>

  <script is:inline>
    async function handleDrop(e) {
      e.preventDefault();
      const col = e.currentTarget;
      col.classList.remove("drag-over");
      const taskId = e.dataTransfer.getData("text/plain");
      const newStatus = col.dataset.status;
      if (!taskId || !newStatus) return;

      // WIP Limit enforcement
      const wipLimit = parseInt(col.dataset.wipLimit || "0");
      const targetCardsContainer = col.querySelector(".kanban-cards");
      const currentCardCount = targetCardsContainer
        ? targetCardsContainer.querySelectorAll(".kanban-card").length
        : 0;

      const card = document.querySelector(`.kanban-card[data-id="${taskId}"]`);
      if (!card) return;

      const oldCol = card.closest(".kanban-column");
      if (oldCol !== col && wipLimit > 0 && currentCardCount >= wipLimit) {
        const wipToast = document.createElement("div");
        wipToast.className = "toast error kanban-contextual-toast";
        wipToast.textContent = `WIP limit of ${wipLimit} reached for this lane`;
        wipToast.style.cssText =
          "position:fixed;top:16px;right:16px;z-index:100;pointer-events:none;";
        document.body.appendChild(wipToast);
        setTimeout(() => wipToast.remove(), 3000);
        return;
      }

      // T-1902: Optimistic DOM update — no page reload
      // Phase 20: Detect drop into specific swimlane
      const targetSwimlane = e.target.closest(".swimlane-group");
      const targetCards = targetSwimlane
        ? targetSwimlane.querySelector(".swimlane-cards")
        : col.querySelector(".kanban-cards");

      if (targetCards) {
        // Remove empty state if present
        const empty = targetCards.querySelector(".kanban-empty");
        if (empty) empty.remove();

        // Remove ghost if present
        const ghost = targetCards.querySelector(".drag-ghost");
        if (ghost) ghost.remove();

        targetCards.appendChild(card);
        card.dataset.status = newStatus;
        if (targetSwimlane) {
          // Update the card's native dataset so filtering still works on reload
          card.dataset.taskType = targetSwimlane.dataset.swimlaneType;
          // Find the badge inside the card and update visually if possible - this requires a reload for full icon update, but we keep the structure
        }
      }

      // Update column counts
      [oldCol, col].forEach((c) => {
        if (!c) return;
        const count = c.querySelector(".kanban-count");
        const cards = c.querySelectorAll(".kanban-card");
        if (count) count.textContent = cards.length;
        // Show empty state if column is now empty
        if (cards.length === 0) {
          const cardsContainer = c.querySelector(".kanban-cards");
          if (
            cardsContainer &&
            !cardsContainer.querySelector(".kanban-empty")
          ) {
            const emptyDiv = document.createElement("div");
            emptyDiv.className = "kanban-empty";
            emptyDiv.textContent = "Drop tasks here";
            cardsContainer.appendChild(emptyDiv);
          }
        }
      });

      // Toast feedback — positioned near the dropped card
      const toast = document.createElement("div");
      toast.className = "toast success kanban-contextual-toast";
      toast.textContent = `Moved to ${newStatus}`;
      const cardRect = card.getBoundingClientRect();
      toast.style.cssText = `position:fixed;top:${Math.max(cardRect.top - 40, 8)}px;left:${cardRect.left}px;z-index:100;pointer-events:none;`;
      document.body.appendChild(toast);
      setTimeout(() => toast.remove(), 2000);

      // Persist to API (background, no reload)
      try {
        const payload = { status: newStatus };
        if (targetSwimlane) {
          payload.task_type = targetSwimlane.dataset.swimlaneType;
        }
        await fetch(`${window.__ingress_path || ""}/api/tasks/${taskId}`, {
          method: "PUT",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload),
        });

        // WIP limit warning toast (soft limit — allows drop but warns)
        const wipLimit = parseInt(targetCol.dataset.wipLimit || "0", 10)
        if (wipLimit > 0) {
          const currentCount = targetCol.querySelectorAll(".kanban-card").length
          if (currentCount > wipLimit) {
            const colTitle = targetCol.querySelector(".kanban-column-title")?.textContent || "this column"
            if (window.showToast) window.showToast(`⚠️ WIP limit exceeded: ${currentCount}/${wipLimit} in ${colTitle}`, "warning")
          }
        }

        // Gamification: confetti + record completion when dropped to complete
        if (newStatus === "complete") {
          var ff = window.__featureFlags || {};
          if (ff.confetti !== false && typeof window.triggerConfetti === "function") window.triggerConfetti();
          if (ff.gamification !== false) {
            var cardPriority = parseInt(card.dataset.priority ?? "3", 10) || 3;
            fetch("/api/gamification", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ priority: cardPriority }),
            }).catch(function() {});
          }
        }
      } catch {
        // Show error feedback before reverting
        if (window.showToast) window.showToast("Failed to move task — reverting", "error")
        // Revert on failure — reload to get server state
        setTimeout(() => window.location.reload(), 800)
      }
    }

    // ── Drag-and-drop event listeners (migrated from inline handlers for CSP) ──
    document.querySelectorAll(".kanban-column").forEach((col) => {
      // Column-level: drop, dragover, dragleave
      col.addEventListener("drop", handleDrop);
      col.addEventListener("dragover", (e) => {
        e.preventDefault();
        col.classList.add("drag-over");
      });
      col.addEventListener("dragleave", () => {
        col.classList.remove("drag-over");
      });

      const cardsContainer = col.querySelector(".kanban-cards");
      if (!cardsContainer) return;

      // Card-level: dragstart, dragend (replaces inline handlers for CSP)
      cardsContainer.querySelectorAll(".kanban-card").forEach((card) => {
        card.addEventListener("dragstart", (e) => {
          e.dataTransfer.setData("text/plain", card.dataset.id);
          card.classList.add("dragging");
        });
        card.addEventListener("dragend", () => {
          card.classList.remove("dragging");
          document.querySelectorAll(".drag-ghost").forEach(g => g.remove());
          document.querySelectorAll(".drag-over").forEach(c => c.classList.remove("drag-over"));
        });
      });

      cardsContainer.addEventListener("dragover", (e) => {
        e.preventDefault();
        const dragging = document.querySelector(".kanban-card.dragging");
        if (!dragging) return;

        // Only show reorder indicator if dragging within the SAME column
        const sourceCol = dragging.closest(".kanban-column");
        if (sourceCol !== col) return;

        // Remove existing drop indicators
        cardsContainer
          .querySelectorAll(".reorder-indicator")
          .forEach((i) => i.remove());

        const afterEl = getDragAfterElement(cardsContainer, e.clientY);
        const indicator = document.createElement("div");
        indicator.className = "reorder-indicator";

        if (afterEl) {
          cardsContainer.insertBefore(indicator, afterEl);
        } else {
          cardsContainer.appendChild(indicator);
        }
      });

      cardsContainer.addEventListener("dragleave", () => {
        cardsContainer
          .querySelectorAll(".reorder-indicator")
          .forEach((i) => i.remove());
      });

      cardsContainer.addEventListener("drop", async (e) => {
        e.preventDefault();
        cardsContainer
          .querySelectorAll(".reorder-indicator")
          .forEach((i) => i.remove());

        const taskId = e.dataTransfer.getData("text/plain");
        const card = document.querySelector(
          `.kanban-card[data-id="${taskId}"]`,
        );
        if (!card) return;

        const sourceCol = card.closest(".kanban-column");
        // Only handle same-lane reorder here; cross-lane handled by handleDrop
        if (sourceCol !== col) return;

        // Stop propagation so the column-level handleDrop doesn't also fire
        e.stopPropagation();

        const afterEl = getDragAfterElement(cardsContainer, e.clientY);
        if (afterEl) {
          cardsContainer.insertBefore(card, afterEl);
        } else {
          cardsContainer.appendChild(card);
        }

        // Persist new order
        const orderedIds = Array.from(
          cardsContainer.querySelectorAll(".kanban-card"),
        )
          .map((c) => c.dataset.id)
          .filter(Boolean);

        try {
          await fetch((window.__ingress_path || "") + "/api/tasks/reorder", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ ordered_ids: orderedIds }),
          });
        } catch {
          // Silent fail — order will revert on next load
        }
      });
    });

    /**
     * Get the element after which the dragged card should be inserted,
     * based on the Y position of the mouse during the drag event.
     */
    function getDragAfterElement(container, y) {
      const cards = [
        ...container.querySelectorAll(".kanban-card:not(.dragging)"),
      ];
      return cards.reduce(
        (closest, child) => {
          const box = child.getBoundingClientRect();
          const offset = y - box.top - box.height / 2;
          if (offset < 0 && offset > closest.offset) {
            return { offset, element: child };
          }
          return closest;
        },
        { offset: Number.NEGATIVE_INFINITY, element: null },
      ).element;
    }
    // Kanban card action handlers
    // T-1903: Edit button opens inline task detail panel (not redirect)
    document.querySelectorAll(".card-edit-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const id = btn.dataset.id;
        if (!id) return;
        // openTaskDetail may not be available immediately (Layout script loads async)
        // Retry briefly before falling back
        let attempts = 0;
        function tryOpen() {
          if (typeof window.openTaskDetail === "function") {
            window.openTaskDetail(id);
          } else if (attempts < 10) {
            attempts++;
            setTimeout(tryOpen, 50);
          }
        }
        tryOpen();
      });
    });

    // Card body click → open task detail (Teamhood parity)
    // Excludes: action buttons, inline-editing, checkbox clicks
    document.querySelectorAll(".kanban-card").forEach((card) => {
      card.addEventListener("click", (e) => {
        // Skip if clicking action buttons, links, or inputs
        const target = e.target
        if (target.closest(".kanban-card-actions") ||
            target.closest("button") ||
            target.closest("a") ||
            target.closest("input") ||
            target.closest("[contenteditable='true']")) return

        const id = card.dataset.id
        if (!id) return

        // Debounce: skip if we just finished a drag
        if (card.classList.contains("dragging")) return

        let attempts = 0
        function tryOpen() {
          if (typeof window.openTaskDetail === "function") {
            window.openTaskDetail(id)
          } else if (attempts < 10) {
            attempts++
            setTimeout(tryOpen, 50)
          }
        }
        tryOpen()
      })
    })

    // Inline quick-edit: double-click card title to edit in place
    document.querySelectorAll(".kanban-title-text").forEach((titleSpan) => {
      titleSpan.addEventListener("dblclick", (e) => {
        e.stopPropagation()
        e.preventDefault()
        if (titleSpan.contentEditable === "true") return

        const card = titleSpan.closest(".kanban-card")
        const taskId = titleSpan.dataset.taskId
        if (!taskId) return

        // Save original for revert
        const originalText = titleSpan.textContent

        // Enter edit mode
        titleSpan.contentEditable = "true"
        titleSpan.focus()

        // Select all text for easy replacement
        const range = document.createRange()
        range.selectNodeContents(titleSpan)
        const sel = window.getSelection()
        sel.removeAllRanges()
        sel.addRange(range)

        // Prevent drag while editing
        if (card) card.setAttribute("draggable", "false")

        // Save handler
        async function saveEdit() {
          const newTitle = titleSpan.textContent.trim()
          titleSpan.contentEditable = "false"
          if (card) card.setAttribute("draggable", "true")

          // Remove listeners
          titleSpan.removeEventListener("blur", saveEdit)
          titleSpan.removeEventListener("keydown", handleKeys)

          if (!newTitle || newTitle === originalText) {
            titleSpan.textContent = originalText
            return
          }

          try {
            const res = await fetch(`${window.__ingress_path || ""}/api/tasks/${taskId}`, {
              method: "PUT",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ title: newTitle }),
            })
            if (!res.ok) throw new Error("save failed")
          } catch {
            titleSpan.textContent = originalText
            if (window.showToast) window.showToast("Failed to save title", "error")
          }
        }

        // Key handler
        function handleKeys(ev) {
          if (ev.key === "Enter") {
            ev.preventDefault()
            titleSpan.blur()
          } else if (ev.key === "Escape") {
            titleSpan.textContent = originalText
            titleSpan.contentEditable = "false"
            if (card) card.setAttribute("draggable", "true")
            titleSpan.removeEventListener("blur", saveEdit)
            titleSpan.removeEventListener("keydown", handleKeys)
          }
        }

        titleSpan.addEventListener("blur", saveEdit)
        titleSpan.addEventListener("keydown", handleKeys)
      })
    })

    // AI: open ChatGPT with task context prompt
    document.querySelectorAll(".card-ai-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
