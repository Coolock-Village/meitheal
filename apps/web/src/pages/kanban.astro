    const addLaneBtn = document.getElementById("add-lane-btn");

    async function fetchLanes() {
      try {
        const res = await fetch((window.__ingress_path || "") + "/api/lanes");
        if (res.ok) {
          const data = await res.json();
          return data.lanes || [];
        }
