---
import Layout from "../layouts/Layout.astro";
import {
  ensureSchema,
  getPersistenceClient,
} from "@domains/tasks/persistence/store";

let tasks: Record<string, unknown>[] = [];
try {
  await ensureSchema();
  const client = getPersistenceClient();
  const result = await client.execute(
    "SELECT id, title, description, status, priority, due_date, labels, framework_payload, calendar_sync_state, created_at FROM tasks ORDER BY priority ASC, created_at DESC",
  );
  tasks = result.rows as Record<string, unknown>[];
} catch (e) {
  /* DB not available */
}

const columns = [
  {
    key: "pending",
    label: "Pending",
    icon: "📋",
    includes: ["pending", "todo"],
    builtIn: true,
  },
  {
    key: "active",
    label: "Active",
    icon: "⚡",
    includes: ["active", "in_progress"],
    builtIn: true,
  },
  {
    key: "complete",
    label: "Complete",
    icon: "✅",
    includes: ["complete", "done"],
    builtIn: true,
  },
];

const priorityLabels: Record<number, string> = {
  1: "Critical",
  2: "High",
  3: "Medium",
  4: "Low",
  5: "Minimal",
};
const priorityColors: Record<number, string> = {
  1: "#ef4444",
  2: "#f59e0b",
  3: "#3b82f6",
  4: "#10b981",
  5: "#6b7280",
};
---

<Layout title="Meitheal — Kanban">
  <span slot="page-title">Kanban Board</span>
  <div slot="actions" style="display: flex; gap: 8px; align-items: center;">
    <div class="view-switcher" role="group" aria-label="View mode">
      <a href="/tasks" class="view-btn" title="List view" aria-label="List view"
        >☰</a
      >
      <a
        href="/kanban"
        class="view-btn active"
        title="Kanban board"
        aria-label="Kanban board">▦</a
      >
      <a
        href="/table"
        class="view-btn"
        title="Table view"
        aria-label="Table view">⊞</a
      >
    </div>
    <button class="btn btn-ghost" id="manage-lanes-btn" title="Manage swimlanes"
      >⚙ Lanes</button
    >
  </div>

  <!-- Lane management panel -->
  <div class="lane-mgmt" id="lane-mgmt" style="display: none;">
    <div class="lane-mgmt-inner">
      <strong>Manage Swimlanes</strong>
      <div id="lane-list"></div>
      <div style="display: flex; gap: 8px; margin-top: 8px;">
        <input
          type="text"
          class="form-input"
          id="new-lane-input"
          placeholder="New lane name..."
          style="flex: 1; font-size: 13px;"
        />
        <button
          class="btn btn-primary"
          id="add-lane-btn"
          style="font-size: 13px;">+ Add</button
        >
      </div>
    </div>
  </div>

  <div class="kanban-board">
    {
      columns.map((col) => {
        const colTasks = tasks.filter((t) =>
          col.includes.includes(String(t.status)),
        );
        return (
          <div
            class="kanban-column"
            data-status={col.key}
            ondrop="handleDrop(event)"
            ondragover="event.preventDefault(); this.classList.add('drag-over')"
            ondragleave="this.classList.remove('drag-over')"
          >
            <div class="kanban-column-header">
              <span>
                {col.icon} {col.label}
              </span>
              <span class="kanban-count">{colTasks.length}</span>
            </div>
            <div class="kanban-cards">
              {colTasks.map((task) => {
                const p = Number(task.priority ?? 3);
                const fp =
                  typeof task.framework_payload === "string"
                    ? JSON.parse(String(task.framework_payload))
                    : {};
                const rice =
                  fp.reach && fp.impact && fp.confidence && fp.effort
                    ? Math.round(
                        (Number(fp.reach) *
                          Number(fp.impact) *
                          Number(fp.confidence)) /
                          Number(fp.effort),
                      )
                    : null;
                return (
                  <div
                    class="kanban-card"
                    draggable="true"
                    data-id={String(task.id)}
                    data-title={String(task.title)}
                    data-desc={task.description ? String(task.description).slice(0, 200) : ""}
                    data-priority={String(p)}
                    data-status={String(task.status)}
                    ondragstart="event.dataTransfer.setData('text/plain', this.dataset.id); this.classList.add('dragging');"
                    ondragend="this.classList.remove('dragging');"
                    style={`border-left: 3px solid ${priorityColors[p]};`}
                  >
                    <div class="kanban-card-title">{String(task.title)}</div>
                    {task.description && String(task.description).trim() && (
                      <div class="kanban-card-desc">{String(task.description).slice(0, 80)}{String(task.description).length > 80 ? "…" : ""}</div>
                    )}
                    <div class="kanban-card-meta">
                      <span
                        class="priority-dot"
                        style={`background: ${priorityColors[p]}`}
                        title={priorityLabels[p]}
                      />
                      <span
                        style={`color: ${priorityColors[p]}; font-size: 11px;`}
                      >
                        {priorityLabels[p]}
                      </span>
                      {task.due_date ? (
                        <span class="kanban-card-due">
                          📅 {String(task.due_date).split("T")[0]}
                        </span>
                      ) : null}
                      {rice ? (
                        <span style="font-size: 11px; color: var(--accent);">
                          RICE: {rice}
                        </span>
                      ) : null}
                    </div>
                    {(() => {
                      try {
                        const lbls = JSON.parse(String(task.labels ?? "[]"));
                        if (Array.isArray(lbls) && lbls.length > 0) {
                          return (
                            <div class="task-labels" style="margin-top: 6px;">
                              {lbls.map((l: string) => (
                                <span class="label-chip">{l}</span>
                              ))}
                            </div>
                          );
                        }
                      } catch {
                        /* skip */
                      }
                      return null;
                    })()}
                    <div class="kanban-card-actions">
                      <button class="card-action-btn card-edit-btn" data-id={String(task.id)} title="Edit task">✏️</button>
                      <button class="card-action-btn card-ai-btn" data-title={String(task.title)} data-desc={task.description ? String(task.description) : ""} data-status={String(task.status ?? "pending")} data-priority={String(p)} title="Ask AI">🤖</button>
                      <button class="card-action-btn card-dup-btn" data-id={String(task.id)} title="Duplicate">⧉</button>
                    </div>
                    </div>
                );
              })}
              {colTasks.length === 0 && (
                <div class="kanban-empty">Drop tasks here</div>
              )}
            </div>
            <button
              class="kanban-add-btn"
              data-status={col.key}
              aria-label={`Add task to ${col.label}`}
            >
              + Add Task
            </button>
          </div>
        );
      })
    }
  </div>

  <div id="toast-container" class="toast-container"></div>

  <script is:inline>
    async function handleDrop(e) {
      e.preventDefault();
      e.currentTarget.classList.remove("drag-over");
      const taskId = e.dataTransfer.getData("text/plain");
      const newStatus = e.currentTarget.dataset.status;
      if (!taskId || !newStatus) return;

      try {
        const res = await fetch(`/api/tasks/${taskId}`, {
          method: "PUT",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ status: newStatus }),
        });
        if (res.ok) {
          const container = document.getElementById("toast-container");
          const toast = document.createElement("div");
          toast.className = "toast success";
          toast.textContent = `Moved to ${newStatus}`;
          container?.appendChild(toast);
          setTimeout(() => toast.remove(), 2000);
          setTimeout(() => window.location.reload(), 300);
        }
      } catch {
        /* ignore */
      }
    }

    // Kanban card action handlers
    // Edit: navigate to tasks page with task ID as hash
    document.querySelectorAll(".card-edit-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const id = btn.dataset.id;
        if (id) window.location.href = `/tasks#edit-${id}`;
      });
    });

    // AI: open ChatGPT with task context prompt
    document.querySelectorAll(".card-ai-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const el = btn;
        const title = el.dataset.title ?? "";
        const desc = el.dataset.desc ?? "";
        const status = el.dataset.status ?? "pending";
        const priority = el.dataset.priority ?? "3";
        const prompt = `I have a task:\n\nTitle: ${title}\nStatus: ${status}\nPriority: ${priority}/5\n${desc ? `Description: ${desc}` : ""}\n\nCan you help me break this down, suggest next steps, estimate effort, or identify blockers?`;
        window.open(`https://chatgpt.com/?q=${encodeURIComponent(prompt)}`, "_blank");
      });
    });

    // Duplicate: clone task via API
    document.querySelectorAll(".card-dup-btn").forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        e.stopPropagation();
        const id = btn.dataset.id;
        if (!id) return;
        try {
          const res = await fetch(`/api/tasks/${id}`);
          if (!res.ok) return;
          const task = await res.json();
          const dupRes = await fetch("/api/tasks", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({
              title: `${task.title} (Copy)`,
              description: task.description ?? "",
              priority: task.priority ?? 3,
              status: "pending",
              due_date: task.due_date ?? null,
              labels: task.labels ?? "[]",
              framework_payload: task.framework_payload ?? "{}",
            }),
          });
          if (dupRes.ok) window.location.reload();
        } catch {}
      });
    });

    // Click anywhere on kanban card → navigate to edit
    document.querySelectorAll(".kanban-card").forEach((card) => {
      card.addEventListener("click", (e) => {
        // Don't navigate if clicking action buttons or dragging
        if (e.target.closest(".card-action-btn")) return;
        const id = card.dataset.id;
        if (id) window.location.href = `/tasks#edit-${id}`;
      });
    });

    // Quick add from kanban column — uses inline form, not prompt()
    document.querySelectorAll(".kanban-add-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        // If inline form already exists, focus it
        const existing = btn.parentElement.querySelector(".kanban-inline-add");
        if (existing) { existing.querySelector("input")?.focus(); return; }

        const status = btn.dataset.status;
        const form = document.createElement("div");
        form.className = "kanban-inline-add";
        form.style.cssText = "display:flex;gap:6px;margin-top:8px;";
        form.innerHTML = `
          <input type="text" class="form-input" placeholder="Task title..." style="flex:1;font-size:13px;padding:6px 10px;" autofocus />
          <button class="btn btn-primary" style="font-size:13px;padding:6px 12px;">Add</button>
        `;
        btn.parentElement.insertBefore(form, btn);
        btn.style.display = "none";

        const input = form.querySelector("input");
        const addBtn = form.querySelector("button");
        input.focus();

        async function submitTask() {
          const title = input.value.trim();
          if (!title) { cleanup(); return; }
          try {
            const res = await fetch("/api/tasks", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ title, status }),
            });
            if (res.ok) window.location.reload();
          } catch { /* ignore */ }
        }

        function cleanup() {
          form.remove();
          btn.style.display = "";
        }

        addBtn.addEventListener("click", submitTask);
        input.addEventListener("keydown", (e) => {
          if (e.key === "Enter") { e.preventDefault(); submitTask(); }
          if (e.key === "Escape") { cleanup(); }
        });
        input.addEventListener("blur", () => {
          // Delay to allow button click
          setTimeout(() => { if (!form.contains(document.activeElement)) cleanup(); }, 200);
        });
      });
    });

    // Lane management (client-side with localStorage)
    const LANE_KEY = "meitheal-kanban-lanes";
    const manageLanesBtn = document.getElementById("manage-lanes-btn");
    const laneMgmt = document.getElementById("lane-mgmt");
    const laneList = document.getElementById("lane-list");
    const newLaneInput = document.getElementById("new-lane-input");
    const addLaneBtn = document.getElementById("add-lane-btn");

    function getCustomLanes() {
      try {
        return JSON.parse(localStorage.getItem(LANE_KEY) || "[]");
      } catch {
        return [];
      }
    }

    function saveCustomLanes(lanes) {
      localStorage.setItem(LANE_KEY, JSON.stringify(lanes));
    }

    function renderLaneList() {
      const builtInKeys = ["pending", "active", "complete"];
      const allLanes = [
        { key: "pending", label: "Pending", builtIn: true },
        { key: "active", label: "Active", builtIn: true },
        { key: "complete", label: "Complete", builtIn: true },
        ...getCustomLanes(),
      ];
      laneList.innerHTML = allLanes
        .map(
          (lane) => `
        <div class="lane-item" style="display: flex; align-items: center; gap: 8px; padding: 4px 0;">
          <span style="flex: 1; font-size: 13px;">${lane.builtIn ? "🔒" : "📌"} ${lane.label}</span>
          ${
            !lane.builtIn
              ? `
            <button class="lane-edit" data-key="${lane.key}" title="Rename" style="background:none;border:none;cursor:pointer;color:var(--text-muted);">✏️</button>
            <button class="lane-remove" data-key="${lane.key}" title="Remove" style="background:none;border:none;cursor:pointer;color:var(--danger);">×</button>
          `
              : '<span style="font-size:11px;color:var(--text-muted);">built-in</span>'
          }
        </div>
      `,
        )
        .join("");

      // Edit handlers
      laneList.querySelectorAll(".lane-edit").forEach((btn) => {
        btn.addEventListener("click", () => {
          const key = btn.dataset.key;
          const lanes = getCustomLanes();
          const lane = lanes.find((l) => l.key === key);
          if (!lane) return;
          const newName = prompt("Rename lane:", lane.label);
          if (newName?.trim()) {
            lane.label = newName.trim();
            saveCustomLanes(lanes);
            window.location.reload();
          }
        });
      });

      // Remove handlers
      laneList.querySelectorAll(".lane-remove").forEach((btn) => {
        btn.addEventListener("click", () => {
          const key = btn.dataset.key;
          const lanes = getCustomLanes().filter((l) => l.key !== key);
          saveCustomLanes(lanes);
          window.location.reload();
        });
      });
    }

    manageLanesBtn?.addEventListener("click", () => {
      const isOpen = laneMgmt.style.display !== "none";
      laneMgmt.style.display = isOpen ? "none" : "block";
      if (!isOpen) renderLaneList();
    });

    addLaneBtn?.addEventListener("click", () => {
      const name = newLaneInput.value.trim();
      if (!name) return;
      const key = name.toLowerCase().replace(/[^a-z0-9]+/g, "_");
      const lanes = getCustomLanes();
      if (lanes.some((l) => l.key === key)) {
        alert("Lane already exists");
        return;
      }
      lanes.push({
        key,
        label: name,
        icon: "📌",
        includes: [key],
        builtIn: false,
      });
      saveCustomLanes(lanes);
      window.location.reload();
    });

    // Inject custom lane columns into the DOM on page load
    function injectCustomColumns() {
      const customLanes = getCustomLanes();
      if (customLanes.length === 0) return;

      const board = document.querySelector(".kanban-board");
      if (!board) return;

      // Fetch all tasks to check for tasks in custom statuses
      const allTasks = window.__kanbanAllTasks || [];

      customLanes.forEach((lane) => {
        // Don't duplicate if column already exists
        if (board.querySelector(`[data-status="${lane.key}"]`)) return;

        const col = document.createElement("div");
        col.className = "kanban-column";
        col.dataset.status = lane.key;
        col.ondrop = (e) => handleDrop(e);
        col.ondragover = (e) => { e.preventDefault(); col.classList.add("drag-over"); };
        col.ondragleave = () => col.classList.remove("drag-over");

        // Find tasks matching this lane
        const laneTasks = allTasks.filter((t) =>
          lane.includes.includes(String(t.status))
        );

        col.innerHTML = `
          <div class="kanban-column-header">
            <span>${lane.icon} ${lane.label}</span>
            <span class="kanban-count">${laneTasks.length}</span>
          </div>
          <div class="kanban-cards">
            ${laneTasks.length === 0 ? '<div class="kanban-empty">Drop tasks here</div>' : ''}
            ${laneTasks.map((task) => {
              const p = Number(task.priority ?? 3);
              const pLabels = { 1: "Critical", 2: "High", 3: "Medium", 4: "Low", 5: "Minimal" };
              const pColors = { 1: "#ef4444", 2: "#f59e0b", 3: "#3b82f6", 4: "#10b981", 5: "#6b7280" };
              return `
                <div class="kanban-card" draggable="true" data-id="${task.id}"
                  ondragstart="event.dataTransfer.setData('text/plain', this.dataset.id); this.classList.add('dragging');"
                  ondragend="this.classList.remove('dragging');">
                  <div class="kanban-card-title">${task.title}</div>
                  <div class="kanban-card-meta">
                    <span class="priority-dot" style="background: ${pColors[p]}" title="${pLabels[p]}"></span>
                    <span style="color: ${pColors[p]}; font-size: 11px;">${pLabels[p]}</span>
                  </div>
                </div>`;
            }).join('')}
          </div>
          <button class="kanban-add-btn" data-status="${lane.key}" aria-label="Add task to ${lane.label}">+ Add Task</button>
        `;

        board.appendChild(col);

        // Wire up inline add for the new column
        const addBtn = col.querySelector(".kanban-add-btn");
        if (addBtn) {
          addBtn.addEventListener("click", () => {
            const existing = addBtn.parentElement.querySelector(".kanban-inline-add");
            if (existing) { existing.querySelector("input")?.focus(); return; }
            const status = addBtn.dataset.status;
            const form = document.createElement("div");
            form.className = "kanban-inline-add";
            form.style.cssText = "display:flex;gap:6px;margin-top:8px;";
            form.innerHTML = `
              <input type="text" class="form-input" placeholder="Task title..." style="flex:1;font-size:13px;padding:6px 10px;" autofocus />
              <button class="btn btn-primary" style="font-size:13px;padding:6px 12px;">Add</button>
            `;
            addBtn.parentElement.insertBefore(form, addBtn);
            addBtn.style.display = "none";
            const input2 = form.querySelector("input");
            const submitBtn = form.querySelector("button");
            input2.focus();
            async function submitNew() {
              const title = input2.value.trim();
              if (!title) { form.remove(); addBtn.style.display = ""; return; }
              try {
                const res = await fetch("/api/tasks", {
                  method: "POST", headers: { "content-type": "application/json" },
                  body: JSON.stringify({ title, status }),
                });
                if (res.ok) window.location.reload();
              } catch {}
            }
            submitBtn.addEventListener("click", submitNew);
            input2.addEventListener("keydown", (e) => {
              if (e.key === "Enter") { e.preventDefault(); submitNew(); }
              if (e.key === "Escape") { form.remove(); addBtn.style.display = ""; }
            });
          });
        }
      });

      // Update grid to accommodate all columns
      const totalCols = board.querySelectorAll(".kanban-column").length;
      board.style.gridTemplateColumns = `repeat(${totalCols}, 1fr)`;
    }

    // Store tasks data for client-side custom column rendering
    window.__kanbanAllTasks = [];
    (async function() {
      try {
        const res = await fetch("/api/tasks?limit=500");
        if (res.ok) {
          const data = await res.json();
          window.__kanbanAllTasks = data.tasks || [];
        }
      } catch {}
      injectCustomColumns();
    })();
  </script>
</Layout>

<style>
  .kanban-board {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    min-height: calc(100vh - 140px);
  }
  .kanban-column {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 16px;
    display: flex;
    flex-direction: column;
    transition: border-color 200ms;
  }
  .kanban-column.drag-over {
    border-color: var(--accent);
    background: rgba(16, 185, 129, 0.05);
  }
  .kanban-column-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 600;
    font-size: 14px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 12px;
  }
  .kanban-count {
    background: var(--bg-hover);
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 12px;
    color: var(--text-secondary);
  }
  .kanban-cards {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 100px;
  }
  .kanban-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 14px;
    cursor: grab;
    transition: all 200ms;
  }
  .kanban-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }
  .kanban-card.dragging {
    opacity: 0.5;
  }
  .kanban-card-title {
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 8px;
  }
  .kanban-card-meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
  }
  .priority-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .kanban-empty {
    text-align: center;
    padding: 30px;
    color: var(--text-muted);
    font-size: 13px;
    border: 2px dashed var(--border);
    border-radius: var(--radius-md);
  }
  .kanban-add-btn {
    margin-top: 8px;
    padding: 8px;
    background: none;
    border: 1px dashed var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    cursor: pointer;
    font-size: 13px;
    transition: all 200ms;
  }
  .kanban-add-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .kanban-card-desc {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 8px;
    line-height: 1.4;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .kanban-card-due {
    font-size: 11px;
    color: var(--text-muted);
    background: rgba(255,255,255,0.05);
    padding: 1px 6px;
    border-radius: 4px;
  }
  .kanban-card-actions {
    display: flex;
    gap: 4px;
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid var(--border);
    opacity: 0;
    transition: opacity 150ms;
  }
  .kanban-card:hover .kanban-card-actions {
    opacity: 1;
  }
  .card-action-btn {
    background: none;
    border: 1px solid transparent;
    cursor: pointer;
    font-size: 12px;
    padding: 3px 8px;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    transition: all 150ms;
  }
  .card-action-btn:hover {
    background: var(--bg-hover);
    border-color: var(--border);
  }
  .card-edit-btn:hover { color: var(--info); }
  .card-ai-btn:hover { color: var(--success); }
  .card-dup-btn:hover { color: var(--warning); }
  .view-switcher {
    display: flex;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  .view-btn {
