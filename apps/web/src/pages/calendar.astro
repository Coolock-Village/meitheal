---
import Layout from "../layouts/Layout.astro";
import TaskViewTabs from "../components/tasks/TaskViewTabs.astro";
import {
  ensureSchema,
  getPersistenceClient,
} from "@domains/tasks/persistence/store";
// Get current month from query param or default to today
const url = new URL(Astro.request.url);
const yearParam = url.searchParams.get("year");
const monthParam = url.searchParams.get("month");

const now = new Date();
const year = yearParam ? parseInt(yearParam, 10) : now.getFullYear();
const month = monthParam ? parseInt(monthParam, 10) : now.getMonth(); // 0-indexed

const firstDay = new Date(year, month, 1);
const lastDay = new Date(year, month + 1, 0);
const startDayOfWeek = firstDay.getDay(); // 0=Sun
const daysInMonth = lastDay.getDate();

const monthName = firstDay.toLocaleDateString("en-US", {
  month: "long",
  year: "numeric",
});

// Prev/next month links
const prevMonth = month === 0 ? 11 : month - 1;
const prevYear = month === 0 ? year - 1 : year;
const nextMonth = month === 11 ? 0 : month + 1;
const nextYear = month === 11 ? year + 1 : year;

// Query task counts per day for this month
const tasksByDay: Record<string, { count: number; colors: string[] }> = {};
let monthTotal = 0;

try {
  await ensureSchema();
  const client = getPersistenceClient();
  const monthStart = `${year}-${String(month + 1).padStart(2, "0")}-01`;
  const monthEnd = `${year}-${String(month + 1).padStart(2, "0")}-${String(daysInMonth).padStart(2, "0")}`;

  const result = await client.execute({
    sql: `SELECT due_date, COUNT(*) as cnt, GROUP_CONCAT(COALESCE(color, ''), ',') as colors
          FROM tasks
          WHERE due_date >= ? AND due_date <= ?
            AND status NOT IN ('complete', 'done')
          GROUP BY due_date`,
    args: [monthStart, monthEnd],
  });

  for (const row of result.rows) {
    const r = row as Record<string, unknown>;
    const dateStr = String(r.due_date);
    const count = Number(r.cnt);
    monthTotal += count;
    tasksByDay[dateStr] = {
      count,
      colors: String(r.colors ?? "")
        .split(",")
        .filter((c) => c.length > 0)
        .slice(0, 3),
    };
  }
} catch {
  /* DB not available */
}

// Build calendar grid (6 rows × 7 cols)
interface CalDay {
  day: number;
  dateStr: string;
  isCurrentMonth: boolean;
  isToday: boolean;
  isWeekend: boolean;
  taskCount: number;
  colors: string[];
}

const grid: CalDay[][] = [];
let currentDay = 1 - startDayOfWeek;
const todayStr = now.toISOString().split("T")[0] ?? "";

for (let week = 0; week < 6; week++) {
  const row: CalDay[] = [];
  for (let dow = 0; dow < 7; dow++) {
    const d = currentDay;
    const isCurrentMonth = d >= 1 && d <= daysInMonth;
    const dateStr = isCurrentMonth
      ? `${year}-${String(month + 1).padStart(2, "0")}-${String(d).padStart(2, "0")}`
      : "";
    const dayData = tasksByDay[dateStr];

    row.push({
      day: d,
      dateStr,
      isCurrentMonth,
      isToday: dateStr === todayStr,
      isWeekend: dow === 0 || dow === 6,
      taskCount: dayData?.count ?? 0,
      colors: dayData?.colors ?? [],
    });
    currentDay++;
  }
  // Skip empty trailing weeks
  if (row.every((d) => !d.isCurrentMonth) && week > 0) break;
  grid.push(row);
}
---

<Layout title={`Meitheal — ${monthName}`}>
  <span slot="page-title">🗓️ {monthName}</span>
  <div slot="actions">
    <a href="/today" class="btn btn-ghost" style="font-size: 13px;">☀️ Today</a>
    <a href="/upcoming" class="btn btn-ghost" style="font-size: 13px;"
      >📅 Upcoming</a
    >
  </div>

  <TaskViewTabs activeView="calendar" />

  <div class="calendar-controls">
    <a
      href={`/calendar?year=${prevYear}&month=${prevMonth}`}
      class="cal-nav-btn"
      aria-label="Previous month"
    >
      <span>←</span>
    </a>
    <h2 class="cal-month-title">{monthName}</h2>
    <a
      href={`/calendar?year=${nextYear}&month=${nextMonth}`}
      class="cal-nav-btn"
      aria-label="Next month"
    >
      <span>→</span>
    </a>
    <a href="/calendar" class="cal-today-btn">Today</a>
    <span class="cal-task-summary"
      >{monthTotal} {monthTotal === 1 ? "task" : "tasks"} this month</span
    >
  </div>

  <div class="calendar-grid">
    {
      ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"].map((d, i) => (
        <div
          class={`cal-header ${i === 0 || i === 6 ? "cal-header-weekend" : ""}`}
        >
          {d}
        </div>
      ))
    }
    {
      grid.flat().map((cell) => (
        <div
          class={`cal-cell ${cell.isToday ? "cal-today" : ""} ${!cell.isCurrentMonth ? "cal-other" : ""} ${cell.isWeekend && cell.isCurrentMonth ? "cal-weekend" : ""} ${cell.taskCount > 0 ? "cal-has-tasks" : ""}`}
          data-date={cell.dateStr}
          role={cell.isCurrentMonth ? "button" : undefined}
          tabindex={cell.isCurrentMonth ? "0" : undefined}
          aria-label={
            cell.isCurrentMonth
              ? `${cell.dateStr}, ${cell.taskCount} tasks`
              : undefined
          }
        >
          {cell.isCurrentMonth && (
            <div>
              <span
                class={`cal-day-num ${cell.isToday ? "cal-day-today" : ""}`}
              >
                {cell.day}
              </span>
              {cell.taskCount > 0 && (
                <div class="cal-task-indicator">
                  <span class="cal-task-badge">{cell.taskCount}</span>
                  {cell.colors.length > 0 && (
                    <div class="cal-color-dots">
                      {cell.colors.map((c) => (
                        <span
                          class="cal-color-dot"
                          style={`background: ${c || "var(--accent)"};`}
                        />
                      ))}
                    </div>
                  )}
                </div>
              )}
            </div>
          )}
        </div>
      ))
    }
  </div>
</Layout>

<style>
  .calendar-controls {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .cal-nav-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-primary);
    font-size: 16px;
    text-decoration: none;
    transition: all 0.15s;
  }
  .cal-nav-btn:hover {
    background: var(--bg-hover);
    border-color: var(--accent);
  }
  .cal-month-title {
    margin: 0;
    font-size: 18px;
    font-weight: 600;
    color: var(--text-primary);
  }
  .cal-today-btn {
    margin-left: auto;
    font-size: 12px;
    color: var(--accent);
    text-decoration: none;
    padding: 4px 10px;
    border-radius: 6px;
    background: var(--accent-bg, rgba(16, 185, 129, 0.1));
    transition: background 0.15s;
  }
  .cal-today-btn:hover {
    background: rgba(16, 185, 129, 0.2);
  }
  .cal-task-summary {
    font-size: 12px;
    color: var(--text-muted);
  }

  .calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .cal-header {
    padding: 8px;
    text-align: center;
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
    background: var(--bg-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .cal-header-weekend {
    color: var(--text-muted);
    opacity: 0.7;
  }

  .cal-cell {
    padding: 8px;
    min-height: 80px;
    background: var(--bg-card);
    cursor: default;
    position: relative;
    transition: background 0.15s;
  }
  .cal-cell[role="button"] {
    cursor: pointer;
  }
  .cal-cell[role="button"]:hover {
    background: var(--bg-hover);
  }
  .cal-cell:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
    z-index: 1;
  }

  .cal-today {
    background: var(--bg-hover) !important;
  }
  .cal-other {
    background: var(--bg-secondary);
  }
  .cal-weekend {
    background: color-mix(in srgb, var(--bg-card) 90%, var(--bg-secondary) 10%);
  }

  .cal-day-num {
    font-size: 13px;
    font-weight: 400;
    color: var(--text-primary);
  }
  .cal-day-today {
    font-weight: 700;
    color: var(--accent);
    background: var(--accent);
    color: white;
    width: 24px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-size: 12px;
  }

  .cal-task-indicator {
    margin-top: 4px;
  }
  .cal-task-badge {
    font-size: 10px;
    background: var(--accent);
    color: white;
    padding: 1px 5px;
    border-radius: 8px;
    font-weight: 600;
  }
  .cal-color-dots {
    display: flex;
    gap: 2px;
    margin-top: 3px;
  }
  .cal-color-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  @media (max-width: 640px) {
    .cal-cell {
      min-height: 48px;
      padding: 4px;
    }
    .cal-day-num {
      font-size: 11px;
    }
  }
</style>

<script>
  // Click calendar day to navigate to tasks filtered by date
  document
    .querySelectorAll<HTMLElement>(".cal-cell[data-date]")
    .forEach((cell) => {
      const handler = () => {
        const date = cell.dataset.date;
        if (date) window.location.href = `/tasks#due=${date}`;
      };
      cell.addEventListener("click", handler);
      cell.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          handler();
        }
      });
    });
</script>
