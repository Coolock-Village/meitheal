---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Offline — Meitheal">
  <div
    class="main-content"
    style="display: flex; align-items: center; justify-content: center; min-height: 80vh;"
  >
    <div
      class="card"
      style="max-width: 480px; text-align: center; padding: 48px 32px;"
    >
      <div style="font-size: 64px; margin-bottom: 16px;">📡</div>
      <h1 class="page-title" style="margin-bottom: 12px;">You're Offline</h1>
      <p
        style="color: var(--text-secondary); font-size: 14px; line-height: 1.6; margin-bottom: 24px;"
      >
        Meitheal works best with an internet connection. Your local data is safe
        — any changes made offline will sync automatically when you reconnect.
      </p>
      <div
        style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;"
      >
        <button
          type="button"
          class="btn btn-primary"
          onclick="window.location.reload()"
        >
          🔄 Try Again
        </button>
        <a href="/" class="btn btn-ghost" style="text-decoration: none;">
          🏠 Dashboard
        </a>
      </div>
      <div
        style="margin-top: 24px; padding-top: 16px; border-top: 1px solid var(--border);"
      >
        <small style="color: var(--text-muted); font-size: 11px;">
          Tip: Tasks you've visited before are cached and may still be
          accessible.
        </small>
      </div>
    </div>
  </div>
</Layout>
