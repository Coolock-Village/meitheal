---
import Layout from "../layouts/Layout.astro";
import EmptyState from "../components/ui/EmptyState.astro";
import {
  ensureSchema,
  getPersistenceClient,
} from "@domains/tasks/persistence/store";
let overdueTasks: Record<string, unknown>[] = [];
let todayTasks: Record<string, unknown>[] = [];
let noDueTasks: Record<string, unknown>[] = [];

try {
  await ensureSchema();
  const client = getPersistenceClient();
  const today = new Date().toISOString().split("T")[0] ?? "";

  const overdueResult = await client.execute({
    sql: `SELECT * FROM tasks
          WHERE due_date IS NOT NULL AND due_date < ?
            AND status NOT IN ('complete', 'done')
          ORDER BY due_date ASC`,
    args: [today],
  });
  overdueTasks = overdueResult.rows as Record<string, unknown>[];

  const todayResult = await client.execute({
    sql: `SELECT * FROM tasks
          WHERE due_date = ?
            AND status NOT IN ('complete', 'done')
          ORDER BY priority DESC, created_at ASC`,
    args: [today],
  });
  todayTasks = todayResult.rows as Record<string, unknown>[];

  const noDueResult = await client.execute({
    sql: `SELECT * FROM tasks
          WHERE due_date IS NULL
            AND status NOT IN ('complete', 'done')
          ORDER BY priority DESC, created_at DESC
          LIMIT 10`,
    args: [],
  });
  noDueTasks = noDueResult.rows as Record<string, unknown>[];
} catch {
  /* DB not available */
}

const priorityLabels: Record<number, string> = {
  1: "Lowest",
  2: "Low",
  3: "Medium",
  4: "High",
  5: "Highest",
};
const priorityColors: Record<number, string> = {
  1: "#6b7280",
  2: "#10b981",
  3: "#3b82f6",
  4: "#f59e0b",
  5: "#ef4444",
};
const typeIcons: Record<string, string> = {
  epic: "🎯",
  story: "📖",
  task: "📌",
};
---

<Layout title="Meitheal — Today">
  <span slot="page-title">☀️ Today</span>
  <div slot="actions">
    <button type="button" class="btn btn-primary" id="create-task-btn"
      >+ New Task</button
    >
  </div>

  <!-- Persona 10: Quick-add inline -->
  <div class="card" style="margin-bottom: 16px; padding: 12px 16px;">
    <form
      id="quick-add-form"
      style="display: flex; gap: 8px; align-items: center;"
    >
      <input
        type="text"
        id="quick-add-input"
        class="form-input flex-1"
        placeholder="Add a task... (try 'Buy groceries tomorrow' or 'Review docs every monday')"
        autocomplete="off"
        style="font-size: 14px;"
      />
      <button
        type="submit"
        class="btn btn-primary"
        style="padding: 8px 16px; white-space: nowrap;">Add</button
      >
    </form>
    <div
      id="quick-add-feedback"
      style="display: none; font-size: 11px; color: var(--text-muted); margin-top: 4px; padding-left: 2px;"
    >
    </div>
  </div>

  {
    overdueTasks.length > 0 && (
      <div
        class="card"
        style="margin-bottom: 16px; border-left: 3px solid var(--danger);"
      >
        <div class="card-header" style="padding: 12px 16px;">
          <div>
            <div
              class="card-title"
              style="color: var(--danger); font-size: 14px;"
            >
              ⚠️ Overdue ({overdueTasks.length})
            </div>
          </div>
        </div>
        <div class="task-list">
          {overdueTasks.map((task) => {
            const p = Number(task.priority ?? 3);
            const tt = String(task.task_type ?? "task");
            return (
              <div
                class="task-item"
                data-id={String(task.id)}
                style="cursor:pointer; padding: 10px 16px; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid var(--border); transition: background 0.15s;"
                role="button"
                tabindex="0"
                aria-label={`${String(task.title)}, priority ${priorityLabels[p] ?? "Medium"}, overdue since ${String(task.due_date)}`}
              >
                <input
                  type="checkbox"
                  class="task-checkbox"
                  data-id={String(task.id)}
                  aria-label={`Complete ${String(task.title)}`}
                />
                <span
                  style={`color: ${priorityColors[p] ?? "#3b82f6"}; font-size: 10px; flex-shrink: 0;`}
                  title={`Priority: ${priorityLabels[p] ?? "Medium"}`}
                >
                  ●
                </span>
                <div style="flex: 1; min-width: 0;">
                  <div style="font-size: 14px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                    <span style="margin-right: 4px; font-size: 12px;">
                      {typeIcons[tt] ?? ""}
                    </span>
                    {String(task.title)}
                  </div>
                  <div style="font-size: 11px; color: var(--danger); margin-top: 2px;">
                    {String(task.due_date)}
                  </div>
                </div>
                {task.recurrence_rule && (
                  <span
                    style="font-size: 11px; color: var(--text-muted);"
                    title="Recurring task"
                  >
                    🔁
                  </span>
                )}
              </div>
            );
          })}
        </div>
      </div>
    )
  }

  <div class="card" style="margin-bottom: 16px;">
    <div class="card-header" style="padding: 12px 16px;">
      <div>
        <div class="card-title" style="font-size: 14px;">
          {
            todayTasks.length > 0
              ? `☀️ Due Today (${todayTasks.length})`
              : "☀️ Today"
          }
        </div>
        {
          todayTasks.length > 0 && (
            <div class="card-subtitle" style="font-size: 12px;">
              Focus on these tasks
            </div>
          )
        }
      </div>
    </div>
    <div class="task-list" id="today-tasks">
      {
        todayTasks.length === 0 ? (
          <EmptyState
            title="No tasks due today"
            description="You're on top of things! 🎉"
          />
        ) : (
          todayTasks.map((task) => {
            const p = Number(task.priority ?? 3);
            const tt = String(task.task_type ?? "task");
            const progress = Number(task.progress ?? 0);
            return (
              <div
                class="task-item"
                data-id={String(task.id)}
                style="cursor:pointer; padding: 10px 16px; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid var(--border); transition: background 0.15s;"
                role="button"
                tabindex="0"
                aria-label={`${String(task.title)}, priority ${priorityLabels[p] ?? "Medium"}`}
              >
                <input
                  type="checkbox"
                  class="task-checkbox"
                  data-id={String(task.id)}
                  aria-label={`Complete ${String(task.title)}`}
                />
                <span
                  style={`color: ${priorityColors[p] ?? "#3b82f6"}; font-size: 10px; flex-shrink: 0;`}
                  title={`Priority: ${priorityLabels[p] ?? "Medium"}`}
                >
                  ●
                </span>
                <div style="flex: 1; min-width: 0;">
                  <div style="font-size: 14px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                    <span style="margin-right: 4px; font-size: 12px;">
                      {typeIcons[tt] ?? ""}
                    </span>
                    {String(task.title)}
                  </div>
                  {progress > 0 && (
                    <div style="margin-top: 4px; display: flex; align-items: center; gap: 6px;">
                      <div style="flex: 1; height: 3px; background: var(--border); border-radius: 2px; overflow: hidden;">
                        <div
                          style={`width: ${progress}%; height: 100%; background: var(--accent); border-radius: 2px; transition: width 0.3s;`}
                        />
                      </div>
                      <span style="font-size: 10px; color: var(--text-muted);">
                        {progress}%
                      </span>
                    </div>
                  )}
                </div>
                {task.color && (
                  <span
                    style={`width: 4px; height: 24px; border-radius: 2px; background: ${String(task.color)}; flex-shrink: 0;`}
                  />
                )}
                {task.recurrence_rule && (
                  <span
                    style="font-size: 11px; color: var(--text-muted);"
                    title="Recurring task"
                  >
                    🔁
                  </span>
                )}
              </div>
            );
          })
        )
      }
    </div>
  </div>

  {
    noDueTasks.length > 0 && (
      <div class="card">
        <div class="card-header" style="padding: 12px 16px;">
          <div>
            <div class="card-title" style="font-size: 14px;">
              📌 Unscheduled ({noDueTasks.length})
            </div>
            <div class="card-subtitle" style="font-size: 12px;">
              Consider scheduling these
            </div>
          </div>
        </div>
        <div class="task-list">
          {noDueTasks.map((task) => {
            const p = Number(task.priority ?? 3);
            const tt = String(task.task_type ?? "task");
            return (
              <div
                class="task-item"
                data-id={String(task.id)}
                style="cursor:pointer; padding: 10px 16px; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid var(--border); transition: background 0.15s;"
                role="button"
                tabindex="0"
                aria-label={`${String(task.title)}, priority ${priorityLabels[p] ?? "Medium"}, no due date`}
              >
                <input
                  type="checkbox"
                  class="task-checkbox"
                  data-id={String(task.id)}
                  aria-label={`Complete ${String(task.title)}`}
                />
                <span
                  style={`color: ${priorityColors[p] ?? "#3b82f6"}; font-size: 10px; flex-shrink: 0;`}
                  title={`Priority: ${priorityLabels[p] ?? "Medium"}`}
                >
                  ●
                </span>
                <div style="flex: 1; min-width: 0;">
                  <div style="font-size: 14px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                    <span style="margin-right: 4px; font-size: 12px;">
                      {typeIcons[tt] ?? ""}
                    </span>
                    {String(task.title)}
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )
  }
</Layout>

<style>
  .task-item:hover {
    background: var(--bg-hover);
  }
  .task-item:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
  }
  .task-done .task-item {
    opacity: 0.5;
  }
</style>

<script>
  // Task checkbox completion
  document
    .querySelectorAll<HTMLInputElement>(".task-checkbox")
    .forEach((cb) => {
      cb.addEventListener("change", async () => {
        const id = cb.dataset.id;
        if (!id) return;
        try {
          await fetch(`/api/tasks/${id}`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ status: cb.checked ? "done" : "pending" }),
          });
          const item = cb.closest(".task-item") as HTMLElement | null;
          if (cb.checked && item) {
            item.style.opacity = "0.4";
            item.style.transition = "opacity 0.3s";
            setTimeout(() => item.remove(), 800);
          }
        } catch {
          /* retry silently */
        }
      });
    });

  // Click to open task detail
  document.querySelectorAll<HTMLElement>(".task-item").forEach((item) => {
    item.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).tagName === "INPUT") return;
      const id = item.dataset.id;
      if (id) window.location.href = `/tasks#task-${id}`;
    });
    // Keyboard: Enter/Space to activate
    item.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        const id = (e.target as HTMLElement).dataset?.id;
        if (id) window.location.href = `/tasks#task-${id}`;
      }
    });
  });

  // Quick-add with NL date parsing
  const quickForm = document.getElementById(
    "quick-add-form",
  ) as HTMLFormElement;
  const quickInput = document.getElementById(
    "quick-add-input",
  ) as HTMLInputElement;
  const quickFeedback = document.getElementById(
    "quick-add-feedback",
  ) as HTMLElement;

  quickForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const text = quickInput?.value.trim();
    if (!text) return;

    try {
      const res = await fetch("/api/tasks", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ title: text }),
      });
      if (res.ok) {
        if (quickInput) quickInput.value = "";
        if (quickFeedback) quickFeedback.style.display = "none";
        window.location.reload();
      }
    } catch {
      /* silently retry */
    }
  });

  // Live NL date feedback as user types
  let feedbackTimer: ReturnType<typeof setTimeout> | null = null;
  quickInput?.addEventListener("input", () => {
    if (feedbackTimer) clearTimeout(feedbackTimer);
    const val = quickInput.value.trim().toLowerCase();
    const nlPatterns = [
      { pattern: /\btomorrow\b/i, label: "📅 Due: Tomorrow" },
      { pattern: /\btoday\b/i, label: "📅 Due: Today" },
      { pattern: /\bnext\s+\w+/i, label: "📅 Due: Next week" },
      { pattern: /\bin\s+\d+\s+\w+/i, label: "📅 Due: Relative date" },
      { pattern: /\bevery\s+\w+/i, label: "🔁 Recurring task" },
    ];
    const match = nlPatterns.find((p) => p.pattern.test(val));
    if (match) {
      quickFeedback.textContent = match.label;
      quickFeedback.style.display = "block";
    } else {
      quickFeedback.style.display = "none";
    }
  });
</script>
