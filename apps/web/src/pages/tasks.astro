---
import Layout from "../layouts/Layout.astro";
import { t } from "../i18n/translations";
import type { Locale } from "../lib/locale";
import { formatTicketKey } from "../lib/ticket-key";
import {
  ensureSchema,
  getPersistenceClient,
} from "@domains/tasks/persistence/store";

// i18n: resolve locale from cookie
const cookieLocale = Astro.cookies.get("meitheal-locale")?.value;
const locale: Locale = cookieLocale === "ga" ? "ga" : "en";

let tasks: Record<string, unknown>[] = [];
try {
  await ensureSchema();
  const client = getPersistenceClient();
  const result = await client.execute(
    "SELECT id, title, description, status, priority, due_date, labels, framework_payload, calendar_sync_state, board_id, custom_fields, start_date, end_date, progress, color, is_favorite, task_type, parent_id, ticket_number, created_at, updated_at FROM tasks ORDER BY created_at DESC",
  );
  tasks = result.rows as Record<string, unknown>[];
} catch (e) {
  // DB not available
}

const priorityLabels: Record<number, string> = {
  1: t("priority.critical", locale),
  2: t("priority.high", locale),
  3: t("priority.medium", locale),
  4: t("priority.low", locale),
  5: t("priority.minimal", locale),
};
const priorityColors: Record<number, string> = {
  1: "#ef4444",
  2: "#f59e0b",
  3: "#3b82f6",
  4: "#10b981",
  5: "#6b7280",
};
const statusLabels: Record<string, string> = {
  pending: t("task_status.pending", locale),
  active: t("task_status.active", locale),
  in_progress: t("task_status.active", locale),
  complete: t("task_status.complete", locale),
  done: t("task_status.complete", locale),
  todo: t("task_status.pending", locale),
};
---

<Layout title={`Meitheal — ${t("tasks.title", locale)}`}>
  <span slot="page-title">{t("tasks.title", locale)}</span>
  <div slot="actions" style="display: flex; gap: 8px; align-items: center;">
    <div class="view-switcher" role="group" aria-label="View mode">
      <a
        href="/tasks"
        class="view-btn active"
        title={t("tasks.list_view", locale)}
        aria-label={t("tasks.list_view", locale)}>☰</a
      >
      <a
        href="/kanban"
        class="view-btn"
        title={t("tasks.kanban_board", locale)}
        aria-label={t("tasks.kanban_board", locale)}>▦</a
      >
      <a
        href="/table"
        class="view-btn"
        title={t("tasks.table_view", locale)}
        aria-label={t("tasks.table_view", locale)}>⊞</a
      >
    </div>
    <button class="btn btn-primary" id="create-task-btn"
      >{t("tasks.new_task", locale)}</button
    >
  </div>

  <!-- Filters -->
  <div class="filter-bar" id="filter-bar">
    <input
      type="text"
      class="form-input"
      id="search-input"
      placeholder={t("tasks.search_placeholder", locale)}
      style="max-width: 300px;"
    />
    <select
      class="form-select"
      id="filter-status"
      style="max-width: 150px;"
      aria-label="Filter by status"
    >
      <option value="">{t("tasks.all_statuses", locale)}</option>
      <option value="pending">{t("task_status.pending", locale)}</option>
      <option value="active">{t("task_status.active", locale)}</option>
      <option value="complete">{t("task_status.complete", locale)}</option>
    </select>
    <select
      class="form-select"
      id="filter-priority"
      style="max-width: 150px;"
      aria-label="Filter by priority"
    >
      <option value="">{t("tasks.all_priorities", locale)}</option>
      <option value="1">{t("priority.critical", locale)}</option>
      <option value="2">{t("priority.high", locale)}</option>
      <option value="3">{t("priority.medium", locale)}</option>
      <option value="4">{t("priority.low", locale)}</option>
      <option value="5">{t("priority.minimal", locale)}</option>
    </select>
    <select
      class="form-select"
      id="filter-rice"
      style="max-width: 150px;"
      aria-label="Filter by RICE score"
    >
      <option value="">{t("tasks.all_rice", locale)}</option>
      <option value="high">{t("tasks.rice_high", locale)}</option>
      <option value="medium">{t("tasks.rice_medium", locale)}</option>
      <option value="low">{t("tasks.rice_low", locale)}</option>
    </select>
    <select
      class="form-select"
      id="sort-select"
      style="max-width: 160px;"
      aria-label="Sort tasks"
    >
      <option value="created_at-desc">{t("tasks.newest_first", locale)}</option>
      <option value="created_at-asc">{t("tasks.oldest_first", locale)}</option>
      <option value="priority-asc">{t("tasks.priority_up", locale)}</option>
      <option value="priority-desc">{t("tasks.priority_down", locale)}</option>
      <option value="rice-desc">{t("tasks.rice_down", locale)}</option>
      <option value="rice-asc">{t("tasks.rice_up", locale)}</option>
      <option value="title-asc">{t("tasks.title_az", locale)}</option>
      <option value="due_date-asc">{t("tasks.due_soonest", locale)}</option>
    </select>
  </div>

  <!-- Task List -->
  <div class="task-list" id="task-list">
    {
      tasks.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">☘</div>
          <div class="empty-text">No tasks yet</div>
          <div class="empty-sub">
            Create your first task to start managing your life
          </div>
        </div>
      ) : (
        tasks.map((task) => {
          const p = Number(task.priority ?? 3);
          const s = String(task.status);
          const isDone = s === "complete" || s === "done";
          const fp =
            typeof task.framework_payload === "string"
              ? JSON.parse(String(task.framework_payload))
              : {};
          const rice =
            fp.reach && fp.impact && fp.confidence && fp.effort
              ? Math.round(
                  (Number(fp.reach) *
                    Number(fp.impact) *
                    Number(fp.confidence)) /
                    Number(fp.effort),
                )
              : null;
          return (
            <div
              class={`task-item ${isDone ? "task-done" : ""}`}
              data-id={String(task.id)}
              data-status={s}
              data-priority={String(p)}
              data-rice={rice !== null ? String(rice) : ""}
              data-board={String(task.board_id ?? "default")}
              data-title={String(task.title).toLowerCase()}
            >
              <input
                type="checkbox"
                class="task-checkbox"
                checked={isDone}
                data-id={String(task.id)}
              />
              <div class="task-content">
                <div class={`task-title ${isDone ? "done" : ""}`}>
                  {formatTicketKey(Number(task.ticket_number)) && (
                    <span style="font-size:10px;font-family:'JetBrains Mono',monospace;color:var(--accent);opacity:0.7;margin-right:6px;">
                      {formatTicketKey(Number(task.ticket_number))}
                    </span>
                  )}
                  {String(task.title)}
                </div>
                <div class="task-meta">
                  <span style={`color: ${priorityColors[p] ?? "#6b7280"}`}>
                    {priorityLabels[p] ?? "Medium"}
                  </span>
                  {task.due_date
                    ? ` · Due ${String(task.due_date).split("T")[0]}`
                    : ""}
                  {String(task.calendar_sync_state) === "confirmed"
                    ? " · 📅"
                    : ""}
                  {rice ? ` · RICE: ${rice}` : ""}
                </div>
                {(() => {
                  try {
                    const lbls = JSON.parse(String(task.labels ?? "[]"));
                    if (Array.isArray(lbls) && lbls.length > 0) {
                      return (
                        <div class="task-labels">
                          {lbls.map((l: string) => (
                            <span class="label-chip">{l}</span>
                          ))}
                        </div>
                      );
                    }
                  } catch {
                    /* skip */
                  }
                  return null;
                })()}
                {(() => {
                  try {
                    const cf =
                      typeof task.custom_fields === "string"
                        ? JSON.parse(String(task.custom_fields))
                        : {};
                    const entries = Object.entries(cf).filter(
                      ([, v]) => v !== "" && v !== null && v !== undefined,
                    );
                    if (entries.length > 0) {
                      return (
                        <div
                          class="task-custom-fields"
                          style="display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px;"
                        >
                          {entries.map(([key, val]) => (
                            <span
                              class="custom-field-chip"
                              style="font-size: 11px; padding: 2px 8px; border-radius: 10px; background: rgba(16,185,129,0.1); color: var(--accent); border: 1px solid rgba(16,185,129,0.2);"
                            >
                              {key}: {String(val)}
                            </span>
                          ))}
                        </div>
                      );
                    }
                  } catch {
                    /* skip */
                  }
                  return null;
                })()}
              </div>
              <span class={`task-badge badge-${isDone ? "done" : s}`}>
                {statusLabels[s] ?? s}
              </span>
              <button
                class="task-duplicate"
                data-id={String(task.id)}
                title={t("tasks.duplicate_task", locale)}
                aria-label={t("tasks.duplicate_task", locale)}
              >
                ⧉
              </button>
              <button
                class="task-ask-ai"
                data-title={String(task.title)}
                data-description={
                  task.description ? String(task.description) : ""
                }
                data-status={String(task.status ?? "pending")}
                data-priority={String(task.priority ?? 3)}
                title={t("tasks.ask_ai", locale)}
                aria-label={t("tasks.ask_ai", locale)}
              >
                🤖
              </button>
              <button
                class="task-delete"
                data-id={String(task.id)}
                title={t("tasks.delete", locale)}
                aria-label={t("tasks.delete", locale)}
              >
                ×
              </button>
            </div>
          );
        })
      )
    }
  </div>

  <!-- Create/Edit Modal -->
  <div class="modal-overlay" id="task-modal">
    <div class="modal">
      <div class="modal-title" id="modal-title">
        {t("tasks.new_task_modal", locale)}
      </div>
      <form id="task-form">
        <input type="hidden" id="task-id" />
        <div class="form-group">
          <label class="form-label" for="task-title-input"
            >{t("tasks.title_label", locale)}</label
          >
          <input
            type="text"
            class="form-input"
            id="task-title-input"
            required
            autocomplete="off"
          />
        </div>
        <div class="form-group">
          <label class="form-label" for="task-desc-input"
            >{t("tasks.description", locale)}</label
          >
          <textarea
            class="form-input"
            id="task-desc-input"
            rows="3"
            placeholder={t("tasks.description_placeholder", locale)}></textarea>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
          <div class="form-group">
            <label class="form-label" for="task-priority-input"
              >{t("tasks.priority_label", locale)}</label
            >
            <select class="form-select" id="task-priority-input">
              <option value="1">🔴 Critical</option>
              <option value="2">🟠 High</option>
              <option value="3" selected>🔵 Medium</option>
              <option value="4">🟢 Low</option>
              <option value="5">⚪ Minimal</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label" for="task-status-input"
              >{t("tasks.status_label", locale)}</label
            >
            <select class="form-select" id="task-status-input">
              <option value="pending">{t("task_status.pending", locale)}</option
              >
              <option value="active">{t("task_status.active", locale)}</option>
              <option value="complete"
                >{t("task_status.complete", locale)}</option
              >
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label" for="task-due-input"
            >{t("tasks.due_date", locale)}</label
          >
          <input type="datetime-local" class="form-input" id="task-due-input" />
        </div>
        <div class="form-group">
          <label class="form-label" for="task-labels-input"
            >Labels <span style="color: var(--text-muted); font-weight: 400;"
              >(comma-separated, or use #tag in title)</span
            ></label
          >
          <input
            type="text"
            class="form-input"
            id="task-labels-input"
            placeholder="bug, feature, urgent"
            autocomplete="off"
          />
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
          <div class="form-group">
            <label
              class="form-label"
              for="rice-reach"
              title="How many users/events does this reach per quarter?"
            >
              RICE — Reach <span
                style="cursor: help; color: var(--text-muted);"
                title="# of users or events affected per time period">ⓘ</span
              >
            </label>
            <input
              type="number"
              class="form-input"
              id="rice-reach"
              min="0"
              max="100"
              placeholder="0-100"
            />
          </div>
          <div class="form-group">
            <label
              class="form-label"
              for="rice-impact"
              title="How much does this impact each user? 3=Massive, 2=High, 1=Medium, 0.5=Low, 0.25=Minimal"
            >
              Impact <span
                style="cursor: help; color: var(--text-muted);"
                title="3=Massive, 2=High, 1=Medium, 0.5=Low, 0.25=Minimal"
                >ⓘ</span
              >
            </label>
            <select class="form-select" id="rice-impact">
              <option value="">—</option>
              <option value="3">Massive (3)</option>
              <option value="2">High (2)</option>
              <option value="1">Medium (1)</option>
              <option value="0.5">Low (0.5)</option>
              <option value="0.25">Minimal (0.25)</option>
            </select>
          </div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
          <div class="form-group">
            <label
              class="form-label"
              for="rice-confidence"
              title="How confident are you in these estimates? 100%=High, 80%=Med, 50%=Low"
            >
              Confidence <span
                style="cursor: help; color: var(--text-muted);"
                title="100%=High, 80%=Medium, 50%=Low">ⓘ</span
              >
            </label>
            <select class="form-select" id="rice-confidence">
              <option value="">—</option>
              <option value="100">High (100%)</option>
              <option value="80">Medium (80%)</option>
              <option value="50">Low (50%)</option>
            </select>
          </div>
          <div class="form-group">
            <label
              class="form-label"
              for="rice-effort"
              title="Estimated person-months of work to complete"
            >
              Effort <span
                style="cursor: help; color: var(--text-muted);"
                title="Person-months to complete">ⓘ</span
              >
            </label>
            <input
              type="number"
              class="form-input"
              id="rice-effort"
              min="0.1"
              step="0.1"
              placeholder="0.5"
            />
          </div>
        </div>
        <!-- Custom Fields -->
        <div class="form-group">
          <label class="form-label">{t("tasks.custom_fields", locale)}</label>
          <div
            id="custom-fields-container"
            style="display: flex; flex-direction: column; gap: 6px;"
          >
          </div>
          <button
            type="button"
            class="btn btn-ghost"
            id="add-custom-field-btn"
            style="margin-top: 6px; font-size: 12px; padding: 4px 12px;"
            >{t("tasks.add_field", locale)}</button
          >
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-ghost" id="cancel-modal"
            >{t("tasks.cancel", locale)}</button
          >
          <button type="submit" class="btn btn-primary" id="save-task-btn"
            >{t("tasks.create_task", locale)}</button
          >
        </div>
      </form>
    </div>
  </div>

  <!-- Delete Confirmation -->
  <div class="modal-overlay" id="delete-modal">
    <div class="modal">
      <div class="modal-title">{t("tasks.delete_task", locale)}</div>
      <p style="color: var(--text-secondary); margin-bottom: 16px;">
        {t("tasks.cannot_undo", locale)}
      </p>
      <div class="modal-actions">
        <button class="btn btn-ghost" id="cancel-delete"
          >{t("tasks.cancel", locale)}</button
        >
        <button class="btn btn-danger" id="confirm-delete"
          >{t("tasks.delete", locale)}</button
        >
      </div>
    </div>
  </div>

  <div
    id="toast-container"
    class="toast-container"
    aria-live="polite"
    role="status"
  >
  </div>

  <script>
    import { showToast } from "../lib/toast";

    // Modal controls
    const modal = document.getElementById("task-modal")!;
    const deleteModal = document.getElementById("delete-modal")!;
    let editingId: string | null = null;
    let deletingId: string | null = null;

    document
      .getElementById("create-task-btn")
      ?.addEventListener("click", () => {
        editingId = null;
        (document.getElementById("modal-title") as HTMLElement).textContent =
          "New Task";
        (document.getElementById("save-task-btn") as HTMLElement).textContent =
          "Create Task";
        (document.getElementById("task-form") as HTMLFormElement).reset();
        document.getElementById("custom-fields-container")!.innerHTML = "";
        modal.classList.add("open");
        (
          document.getElementById("task-title-input") as HTMLInputElement
        ).focus();
      });

    document
      .getElementById("cancel-modal")
      ?.addEventListener("click", () => modal.classList.remove("open"));
    modal.addEventListener("click", (e) => {
      if (e.target === modal) modal.classList.remove("open");
    });

    // Edit task on click
    document.querySelectorAll(".task-item").forEach((item) => {
      item.addEventListener("click", async (e) => {
        const target = e.target as HTMLElement;
        if (
          target.classList.contains("task-checkbox") ||
          target.classList.contains("task-delete")
        )
          return;
        const id = (item as HTMLElement).dataset.id;
        if (!id) return;
        try {
          const res = await fetch(`/api/tasks/${id}`);
          if (!res.ok) return;
          const task = await res.json();
          editingId = id;
          (document.getElementById("modal-title") as HTMLElement).textContent =
            "Edit Task";
          (
            document.getElementById("save-task-btn") as HTMLElement
          ).textContent = "Save Changes";
          (
            document.getElementById("task-title-input") as HTMLInputElement
          ).value = task.title ?? "";
          (
            document.getElementById("task-desc-input") as HTMLTextAreaElement
          ).value = task.description ?? "";
          (
            document.getElementById("task-priority-input") as HTMLSelectElement
          ).value = String(task.priority ?? 3);
          (
            document.getElementById("task-status-input") as HTMLSelectElement
          ).value = task.status ?? "pending";
          (
            document.getElementById("task-due-input") as HTMLInputElement
          ).value = task.due_date ?? "";
          // RICE fields
          const fp =
            typeof task.framework_payload === "string"
              ? JSON.parse(task.framework_payload)
              : (task.framework_payload ?? {});
          (document.getElementById("rice-reach") as HTMLInputElement).value =
            fp.reach ?? "";
          (document.getElementById("rice-impact") as HTMLSelectElement).value =
            fp.impact ?? "";
          (
            document.getElementById("rice-confidence") as HTMLSelectElement
          ).value = fp.confidence ?? "";
          (document.getElementById("rice-effort") as HTMLInputElement).value =
            fp.effort ?? "";
          // Populate labels
          try {
            const lbls =
              typeof task.labels === "string" ? JSON.parse(task.labels) : [];
            (
              document.getElementById("task-labels-input") as HTMLInputElement
            ).value = Array.isArray(lbls) ? lbls.join(", ") : "";
          } catch {
            (
              document.getElementById("task-labels-input") as HTMLInputElement
            ).value = "";
          }
          // Populate custom fields
          populateCustomFields(task.custom_fields);
          modal.classList.add("open");
        } catch {
          /* ignore */
        }
      });
    });

    // Save task
    document
      .getElementById("task-form")
      ?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const title = (
          document.getElementById("task-title-input") as HTMLInputElement
        ).value.trim();
        if (!title) return;

        // ✨ Quick Add Magic — parse #labels and date keywords from title
        let parsedTitle = title;
        const extractedLabels: string[] = [];
        let extractedDue: string | null = null;

        // Extract #labels
        parsedTitle = parsedTitle
          .replace(/#(\w+)/g, (_match, label) => {
            extractedLabels.push(label);
            return "";
          })
          .trim();

        // Extract date keywords
        const dateKeywords: Record<string, () => Date> = {
          today: () => new Date(),
          tomorrow: () => {
            const d = new Date();
            d.setDate(d.getDate() + 1);
            return d;
          },
          "next week": () => {
            const d = new Date();
            d.setDate(d.getDate() + 7);
            return d;
          },
          monday: () => nextWeekday(1),
          tuesday: () => nextWeekday(2),
          wednesday: () => nextWeekday(3),
          thursday: () => nextWeekday(4),
          friday: () => nextWeekday(5),
        };

        function nextWeekday(day: number): Date {
          const d = new Date();
          const diff = (day - d.getDay() + 7) % 7 || 7;
          d.setDate(d.getDate() + diff);
          return d;
        }

        for (const [keyword, getDate] of Object.entries(dateKeywords)) {
          const regex = new RegExp(`\\b${keyword}\\b`, "i");
          if (regex.test(parsedTitle)) {
            extractedDue = getDate().toISOString().slice(0, 16);
            parsedTitle = parsedTitle.replace(regex, "").trim();
            break;
          }
        }

        // Merge manual labels with extracted labels
        const manualLabels = (
          document.getElementById("task-labels-input") as HTMLInputElement
        ).value
          .split(",")
          .map((l) => l.trim())
          .filter((l) => l.length > 0);
        const allLabels = [...new Set([...manualLabels, ...extractedLabels])];

        // Use parsed title (without #tags and date keywords)
        const finalTitle = parsedTitle || title;

        const fp: Record<string, unknown> = {};
        const reach = (
          document.getElementById("rice-reach") as HTMLInputElement
        ).value;
        const impact = (
          document.getElementById("rice-impact") as HTMLSelectElement
        ).value;
        const confidence = (
          document.getElementById("rice-confidence") as HTMLSelectElement
        ).value;
        const effort = (
          document.getElementById("rice-effort") as HTMLInputElement
        ).value;
        if (reach) fp.reach = Number(reach);
        if (impact) fp.impact = Number(impact);
        if (confidence) fp.confidence = Number(confidence);
        if (effort) fp.effort = Number(effort);

        const body: Record<string, unknown> = {
          title: finalTitle,
          description: (
            document.getElementById("task-desc-input") as HTMLTextAreaElement
          ).value,
          priority: Number(
            (
              document.getElementById(
                "task-priority-input",
              ) as HTMLSelectElement
            ).value,
          ),
          status: (
            document.getElementById("task-status-input") as HTMLSelectElement
          ).value,
          due_date:
            extractedDue ||
            (document.getElementById("task-due-input") as HTMLInputElement)
              .value ||
            null,
          labels: JSON.stringify(allLabels),
          framework_payload: JSON.stringify(fp),
          custom_fields: JSON.stringify(getCustomFieldsFromUI()),
        };

        const saveBtn = document.getElementById(
          "save-task-btn",
        ) as HTMLButtonElement;
        try {
          saveBtn.classList.add("loading");
          saveBtn.disabled = true;
          const url = editingId ? `/api/tasks/${editingId}` : "/api/tasks";
          const method = editingId ? "PUT" : "POST";
          const res = await fetch(url, {
            method,
            headers: { "content-type": "application/json" },
            body: JSON.stringify(body),
          });
          if (res.ok) {
            showToast(editingId ? "Task updated!" : "Task created!");
            modal.classList.remove("open");
            // Optimistic: reload handled by next navigation; avoid jarring page refresh
          } else {
            const data = await res.json();
            showToast(data.error || "Failed", "error");
          }
        } catch {
          showToast("Network error", "error");
        } finally {
          saveBtn.classList.remove("loading");
          saveBtn.disabled = false;
        }
      });

    // Delete
    document.querySelectorAll(".task-delete").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        deletingId = (btn as HTMLElement).dataset.id ?? null;
        deleteModal.classList.add("open");
      });
    });
    document
      .getElementById("cancel-delete")
      ?.addEventListener("click", () => deleteModal.classList.remove("open"));
    document
      .getElementById("confirm-delete")
      ?.addEventListener("click", async () => {
        if (!deletingId) return;
        try {
          await fetch(`/api/tasks/${deletingId}`, { method: "DELETE" });
          showToast("Task deleted");
          deleteModal.classList.remove("open");
          document
            .querySelector(`.task-item[data-id="${deletingId}"]`)
            ?.remove();
        } catch {
          showToast("Failed to delete", "error");
        }
      });

    // Checkbox toggle
    document.querySelectorAll(".task-checkbox").forEach((cb) => {
      cb.addEventListener("change", async (e) => {
        e.stopPropagation();
        const target = e.target as HTMLInputElement;
        const id = target.dataset.id;
        const taskItem = target.closest(".task-item");
        const titleEl = taskItem?.querySelector(".task-title");
        const badge = taskItem?.querySelector(".task-badge");
        const newStatus = target.checked ? "complete" : "pending";

        // Optimistic UI update
        if (target.checked) {
          taskItem?.classList.add("task-done");
          titleEl?.classList.add("done");
          if (badge) {
            badge.className = "task-badge badge-done";
            badge.textContent = "Complete";
          }
        } else {
          taskItem?.classList.remove("task-done");
          titleEl?.classList.remove("done");
          if (badge) {
            badge.className = "task-badge badge-pending";
            badge.textContent = "Pending";
          }
        }

        try {
          await fetch(`/api/tasks/${id}`, {
            method: "PUT",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ status: newStatus }),
          });
          showToast(target.checked ? "Task completed!" : "Task reopened");
        } catch {
          showToast("Failed to update", "error");
          target.checked = !target.checked; // Revert
        }
      });
    });

    // Duplicate task
    document.querySelectorAll(".task-duplicate").forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        e.stopPropagation();
        const id = (btn as HTMLElement).dataset.id;
        if (!id) return;
        try {
          const res = await fetch(`/api/tasks/${id}`);
          if (!res.ok) return;
          const task = await res.json();
          const dupRes = await fetch("/api/tasks", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({
              title: `${task.title} (Copy)`,
              description: task.description ?? "",
              priority: task.priority ?? 3,
              status: "pending",
              due_date: task.due_date ?? null,
              labels: task.labels ?? "[]",
              framework_payload: task.framework_payload ?? "{}",
            }),
          });
          if (dupRes.ok) {
            showToast("Task duplicated!");
            // Optimistic: clone the card DOM node
            const original = document.querySelector(
              `.task-item[data-id="${id}"]`,
            );
            if (original) {
              const clone = original.cloneNode(true) as HTMLElement;
              const dupTitle = clone.querySelector(".task-title");
              if (dupTitle) dupTitle.textContent = `${task.title} (Copy)`;
              clone.style.animation = "fade-in 300ms ease";
              original.parentElement?.insertBefore(clone, original.nextSibling);
            }
          }
        } catch {
          showToast("Failed to duplicate", "error");
        }
      });
    });

    // Ask AI handler — opens task context as a prompt in AI provider
    document.querySelectorAll(".task-ask-ai").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const el = btn as HTMLElement;
        const title = el.dataset.title ?? "";
        const desc = el.dataset.description ?? "";
        const status = el.dataset.status ?? "pending";
        const priority = el.dataset.priority ?? "3";
        const prompt = `I have a task in my task manager:

Title: ${title}
Status: ${status}
Priority: ${priority}/5
${desc ? `Description: ${desc}` : ""}

Can you help me break this down, suggest next steps, estimate effort, or identify potential blockers?`;
        // Default to ChatGPT — configurable via settings in future
        const encodedPrompt = encodeURIComponent(prompt);
        window.open(`https://chatgpt.com/?q=${encodedPrompt}`, "_blank");
      });
    });

    // Client-side filtering + sorting
    function applyFilters() {
      const search = (
        document.getElementById("search-input") as HTMLInputElement
      ).value.toLowerCase();
      const statusFilter = (
        document.getElementById("filter-status") as HTMLSelectElement
      ).value;
      const priorityFilter = (
        document.getElementById("filter-priority") as HTMLSelectElement
      ).value;

      const riceFilter = (
        document.getElementById("filter-rice") as HTMLSelectElement
      ).value;

      document.querySelectorAll(".task-item").forEach((item) => {
        const el = item as HTMLElement;
        const matchTitle = !search || (el.dataset.title ?? "").includes(search);
        const matchStatus =
          !statusFilter ||
          el.dataset.status === statusFilter ||
          (statusFilter === "complete" &&
            (el.dataset.status === "done" || el.dataset.status === "complete"));
        const matchPriority =
          !priorityFilter || el.dataset.priority === priorityFilter;

        let matchRice = true;
        if (riceFilter && el.dataset.rice) {
          const r = Number(el.dataset.rice);
          if (riceFilter === "high") matchRice = r >= 15;
          else if (riceFilter === "medium") matchRice = r >= 8 && r < 15;
          else if (riceFilter === "low") matchRice = r < 8;
        } else if (riceFilter && !el.dataset.rice) {
          matchRice = false; // No RICE score = doesn't match any RICE filter
        }

        el.style.display =
          matchTitle && matchStatus && matchPriority && matchRice ? "" : "none";
      });
    }

    document
      .getElementById("search-input")
      ?.addEventListener("input", applyFilters);
    document
      .getElementById("filter-status")
      ?.addEventListener("change", applyFilters);
    document
      .getElementById("filter-priority")
      ?.addEventListener("change", applyFilters);

    document
      .getElementById("filter-rice")
      ?.addEventListener("change", applyFilters);

    // OA-611: Persist filter/sort state in localStorage
    function saveFilterState() {
      const state = {
        search:
          (document.getElementById("search-input") as HTMLInputElement)
            ?.value ?? "",
        status:
          (document.getElementById("filter-status") as HTMLSelectElement)
            ?.value ?? "",
        priority:
          (document.getElementById("filter-priority") as HTMLSelectElement)
            ?.value ?? "",
        rice:
          (document.getElementById("filter-rice") as HTMLSelectElement)
            ?.value ?? "",
        sort:
          (document.getElementById("sort-select") as HTMLSelectElement)
            ?.value ?? "created_at-desc",
      };
      localStorage.setItem("meitheal-task-filters", JSON.stringify(state));
    }
    document
      .getElementById("search-input")
      ?.addEventListener("input", saveFilterState);
    document
      .getElementById("filter-status")
      ?.addEventListener("change", saveFilterState);
    document
      .getElementById("filter-priority")
      ?.addEventListener("change", saveFilterState);
    document
      .getElementById("filter-rice")
      ?.addEventListener("change", saveFilterState);
    document
      .getElementById("sort-select")
      ?.addEventListener("change", saveFilterState);

    // Restore filter state on load
    try {
      const saved = localStorage.getItem("meitheal-task-filters");
      if (saved) {
        const state = JSON.parse(saved);
        if (state.search)
          (document.getElementById("search-input") as HTMLInputElement).value =
            state.search;
        if (state.status)
          (
            document.getElementById("filter-status") as HTMLSelectElement
          ).value = state.status;
        if (state.priority)
          (
            document.getElementById("filter-priority") as HTMLSelectElement
          ).value = state.priority;
        if (state.rice)
          (document.getElementById("filter-rice") as HTMLSelectElement).value =
            state.rice;
        if (state.sort)
          (document.getElementById("sort-select") as HTMLSelectElement).value =
            state.sort;
        applyFilters();
      }
    } catch {
      /* ignore */
    }

    // Hash deep-link: #edit-{id} opens task edit
    const hash = window.location.hash;
    if (hash.startsWith("#edit-")) {
      const taskId = hash.slice(6);
      const taskItem = document.querySelector(
        `.task-item[data-id="${taskId}"]`,
      );
      if (taskItem) {
        taskItem.scrollIntoView({ behavior: "smooth", block: "center" });
        const editBtn = taskItem.querySelector(".edit-btn") as HTMLElement;
        if (editBtn) setTimeout(() => editBtn.click(), 300);
      }
    }

    // Keyboard shortcuts — most handled by Layout.astro global handler
    // Only keep task-specific Escape for local modals
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        modal.classList.remove("open");
        deleteModal.classList.remove("open");
      }
    });

    // ───── Custom Fields UI ─────
    const cfContainer = document.getElementById("custom-fields-container")!;
    document
      .getElementById("add-custom-field-btn")
      ?.addEventListener("click", () => {
        addCustomFieldRow("", "");
      });

    function addCustomFieldRow(key: string, value: string) {
      const row = document.createElement("div");
      row.style.cssText = "display:flex;gap:6px;align-items:center;";
      row.innerHTML = `
        <input type="text" class="form-input cf-key" placeholder="Field name" value="${key.replace(/"/g, "&quot;")}" style="flex:1;font-size:13px;padding:6px 10px;" />
        <input type="text" class="form-input cf-value" placeholder="Value" value="${value.replace(/"/g, "&quot;")}" style="flex:1;font-size:13px;padding:6px 10px;" />
        <button type="button" class="btn-icon cf-remove" title="Remove" style="color:var(--danger);font-size:16px;">×</button>
      `;
      row
        .querySelector(".cf-remove")!
        .addEventListener("click", () => row.remove());
      cfContainer.appendChild(row);
    }

    function populateCustomFields(
      raw: string | Record<string, unknown> | null | undefined,
    ) {
      cfContainer.innerHTML = "";
      try {
        const cf = typeof raw === "string" ? JSON.parse(raw) : (raw ?? {});
        for (const [k, v] of Object.entries(cf)) {
          if (v !== null && v !== undefined && v !== "") {
            addCustomFieldRow(k, String(v));
          }
        }
      } catch {
        /* skip */
      }
    }

    function getCustomFieldsFromUI(): Record<string, string> {
      const result: Record<string, string> = {};
      cfContainer.querySelectorAll("div").forEach((row) => {
        const key = (
          row.querySelector(".cf-key") as HTMLInputElement
        )?.value.trim();
        const val = (
          row.querySelector(".cf-value") as HTMLInputElement
        )?.value.trim();
        if (key) result[key] = val;
      });
      return result;
    }
  </script>
</Layout>

<style>
  .filter-bar {
    display: flex;
    gap: 10px;
    margin-bottom: 16px;
    flex-wrap: wrap;
    align-items: center;
  }
  .view-switcher {
    display: flex;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  .view-btn {
    padding: 6px 12px;
    text-decoration: none;
    color: var(--text-secondary);
    font-size: 16px;
    transition: all 200ms;
    border-right: 1px solid var(--border);
  }
  .view-btn:last-child {
    border-right: none;
  }
  .view-btn:hover {
    background: var(--bg-hover);
    color: var(--text-primary);
  }
  .view-btn.active {
    background: var(--accent-light);
    color: var(--accent);
  }
  .task-done {
    opacity: 0.6;
  }
</style>
