---
import Layout from "../layouts/Layout.astro";
import TaskViewTabs from "../components/tasks/TaskViewTabs.astro";
import EmptyState from "../components/ui/EmptyState.astro";
import StatusBadge from "../components/ui/StatusBadge.astro";
import PriorityLabel from "../components/ui/PriorityLabel.astro";
import RiceBadge from "../components/ui/RiceBadge.astro";
import LabelBadges from "../components/ui/LabelBadges.astro";
import { t } from "../i18n/translations";
import type { Locale } from "../lib/locale";
import { formatTicketKey } from "../lib/ticket-key";
import { getTasksForView } from "../lib/task-queries";

// i18n: resolve locale from cookie
const cookieLocale = Astro.cookies.get("meitheal-locale")?.value;
const locale: Locale = cookieLocale === "ga" ? "ga" : "en";

const { tasks, counts, customFieldDefs } = await getTasksForView();
---

<Layout title={`Meitheal — ${t("tasks.title", locale)}`}>
  <span slot="page-title">{t("tasks.title", locale)}</span>
  <div slot="actions" class="page-actions">
    <button type="button" class="btn btn-primary" id="create-task-btn"
      >{t("tasks.new_task", locale)}</button
    >
  </div>

  <script define:vars={{ customFieldDefs }}>
    window.__customFieldDefs = customFieldDefs;
  </script>

  <TaskViewTabs activeView="list" />

  <!-- Task Summary Bar -->
  {
    tasks.length > 0 && (
      <div class="filter-summary-bar" id="task-summary">
        <span class="summary-count">{counts.open}</span> open ·
        <span class="summary-count">{counts.active}</span> active
        {counts.overdue > 0 && (
          <Fragment>
            ·{" "}
            <span class="summary-overdue">
              {counts.overdue} {t("tasks.overdue", locale)}
            </span>
          </Fragment>
        )}
      </div>
    )
  }

  <!-- Filters -->
  <div class="filter-bar" id="filter-bar">
    <input
      type="text"
      class="form-input filter-search"
      id="search-input"
      placeholder={t("tasks.search_placeholder", locale)}
    />
    <select
      class="form-select filter-select"
      id="filter-status"
      aria-label="Filter by status"
    >
      <option value="">{t("tasks.all_statuses", locale)}</option>
      <option value="pending">{t("task_status.pending", locale)}</option>
      <option value="active">{t("task_status.active", locale)}</option>
      <option value="complete">{t("task_status.complete", locale)}</option>
      <option value="overdue">{t("tasks.overdue", locale)}</option>
    </select>
    <select
      class="form-select filter-select"
      id="filter-priority"
      aria-label="Filter by priority"
    >
      <option value="">{t("tasks.all_priorities", locale)}</option>
      <option value="1">{t("priority.critical", locale)}</option>
      <option value="2">{t("priority.high", locale)}</option>
      <option value="3">{t("priority.medium", locale)}</option>
      <option value="4">{t("priority.low", locale)}</option>
      <option value="5">{t("priority.minimal", locale)}</option>
    </select>
    <select
      class="form-select filter-select"
      id="filter-rice"
      aria-label="Filter by RICE score"
    >
      <option value="">{t("tasks.all_rice", locale)}</option>
      <option value="high">{t("tasks.rice_high", locale)}</option>
      <option value="medium">{t("tasks.rice_medium", locale)}</option>
      <option value="low">{t("tasks.rice_low", locale)}</option>
    </select>
    <select
      class="form-select filter-select"
      id="sort-select"
      aria-label="Sort tasks"
    >
      <option value="created_at-desc">{t("tasks.newest_first", locale)}</option>
      <option value="created_at-asc">{t("tasks.oldest_first", locale)}</option>
      <option value="priority-asc">{t("tasks.priority_up", locale)}</option>
      <option value="priority-desc">{t("tasks.priority_down", locale)}</option>
      <option value="rice-desc">{t("tasks.rice_down", locale)}</option>
      <option value="rice-asc">{t("tasks.rice_up", locale)}</option>
      <option value="title-asc">{t("tasks.title_az", locale)}</option>
      <option value="due_date-asc">{t("tasks.due_soonest", locale)}</option>
    </select>
    <button type="button" class="filter-clear-btn" id="clear-filters"
      >{t("tasks.clear_filters", locale)}</button
    >
  </div>

  <!-- Task List -->
  <div class="task-list" id="task-list">
    {
      tasks.length === 0 ? (
        <EmptyState
          title={t("tasks.no_tasks_yet", locale)}
          description={t("tasks.create_first_task", locale)}
          actionText={t("tasks.new_task", locale)}
          actionEvent="meitheal:new-task"
        />
      ) : (
        tasks.map((task) => {
          const searchText = [
            task.title,
            task.description ?? "",
            ...task.labels,
          ]
            .join(" ")
            .toLowerCase();
          return (
            <div
              class={`task-item ${task.is_done ? "task-done" : ""}`}
              data-id={task.id}
              data-status={task.status}
              data-priority={String(task.priority)}
              data-rice={task.rice !== null ? String(task.rice) : ""}
              data-board={task.board_id}
              data-overdue={task.is_overdue ? "true" : "false"}
              data-title={task.title.toLowerCase()}
              data-search={searchText}
              role="button"
              tabindex="0"
            >
              {/* Color indicator */}
              {task.color && (
                <span
                  class="task-color-dot"
                  style={`background: ${task.color}`}
                />
              )}
              {/* Favorite star */}
              <button
                type="button"
                class={`task-fav-btn ${task.is_favorite ? "is-fav" : ""}`}
                data-id={task.id}
                aria-label={
                  task.is_favorite
                    ? "Remove from favorites"
                    : "Add to favorites"
                }
                title={task.is_favorite ? "★ Favorited" : "☆ Favorite"}
              >
                {task.is_favorite ? "★" : "☆"}
              </button>
              <input
                type="checkbox"
                class="task-checkbox"
                checked={task.is_done}
                data-id={task.id}
              />
              <div class="task-content">
                <div class={`task-title ${task.is_done ? "done" : ""}`}>
                  {formatTicketKey(task.ticket_number ?? 0) && (
                    <span class="kanban-ticket-key ticket-key-inline">
                      {formatTicketKey(task.ticket_number ?? 0)}
                    </span>
                  )}
                  <span class="task-title-text">{task.title}</span>
                </div>
                <div class="task-meta">
                  <PriorityLabel priority={task.priority} />
                  {task.due_date && (
                    <span class={task.is_overdue ? "overdue-date" : ""}>
                      · {t("tasks.due_prefix", locale)}{" "}
                      {task.due_date.split("T")[0]}
                      {task.is_overdue && (
                        <span class="overdue-tag">
                          {t("tasks.overdue", locale)}
                        </span>
                      )}
                    </span>
                  )}
                  {task.calendar_sync_state === "confirmed" && (
                    <span>· 📅</span>
                  )}
                  {task.rice !== null && <span>·</span>}
                  <RiceBadge rice={task.rice} />
                </div>
                {/* Progress bar */}
                {task.progress > 0 && (
                  <div class="task-progress">
                    <div class="task-progress-track">
                      <div
                        class="task-progress-fill"
                        style={`width: ${Math.min(task.progress, 100)}%`}
                      />
                    </div>
                    <span class="task-progress-label">{task.progress}%</span>
                  </div>
                )}
                {task.labels.length > 0 && (
                  <LabelBadges labels={task.labels} />
                )}
                {(() => {
                  const entries = Object.entries(task.custom_fields).filter(
                    ([, v]) => v !== "" && v !== null && v !== undefined,
                  );
                  if (entries.length > 0) {
                    return (
                      <div class="task-custom-fields">
                        {entries.map(([key, val]) => (
                          <span class="custom-field-chip">
                            {key}: {String(val)}
                          </span>
                        ))}
                      </div>
                    );
                  }
                  return null;
                })()}
              </div>
              <StatusBadge status={task.status} />
              <div class="task-actions">
                <button
                  type="button"
                  class="task-action-btn task-duplicate"
                  data-id={task.id}
                  title={t("tasks.duplicate_task", locale)}
                  aria-label={t("tasks.duplicate_task", locale)}
                >
                  ⧉
                </button>
                <button
                  type="button"
                  class="task-action-btn task-ask-ai"
                  data-title={task.title}
                  data-description={task.description ?? ""}
                  data-status={task.status}
                  data-priority={String(task.priority)}
                  title={t("tasks.ask_ai", locale)}
                  aria-label={t("tasks.ask_ai", locale)}
                >
                  🤖
                </button>
                <button
                  type="button"
                  class="task-action-btn danger task-delete"
                  data-id={task.id}
                  title={t("tasks.delete", locale)}
                  aria-label={t("tasks.delete", locale)}
                >
                  ×
                </button>
              </div>
            </div>
          );
        })
      )
    }
  </div>
</Layout>

<div
  id="toast-container"
  class="toast-container"
  aria-live="polite"
  role="status"
  data-no-scroll-lock="true"
>
</div>

<script>
  import { showToast } from "@lib/toast";
  import { confirmDialog } from "@lib/confirm-dialog";
  import { taskApi } from "../lib/task-api-client";
  import { onTaskCompleted } from "../lib/gamification-hook";
  import {
    saveFilterState as persistFilters,
    loadFilterState,
    matchesStatusFilter,
    matchesRiceFilter,
  } from "@lib/filter-state";

  // Task clicks are handled by Layout.astro's delegated openTaskDetail handler

  // Delete
  document.querySelectorAll(".task-delete").forEach((btn) => {
    btn.addEventListener("click", async (e) => {
      e.stopPropagation();
      const id = (btn as HTMLElement).dataset.id;
      if (!id) return;

      const ok = await confirmDialog({
        title: "Delete Task?",
        message: "This action cannot be undone.",
        variant: "danger",
        confirmText: "Delete",
      });

      if (!ok) return;

      try {
        await taskApi.deleteTask(id);
        showToast("common.task_deleted");
        setTimeout(() => window.location.reload(), 800);
      } catch {
        showToast("common.failed_delete", "error");
      }
    });
  });

  // Checkbox toggle
  document.querySelectorAll(".task-checkbox").forEach((cb) => {
    cb.addEventListener("change", async (e) => {
      e.stopPropagation();
      const target = e.target as HTMLInputElement;
      const id = target.dataset.id;
      const taskItem = target.closest(".task-item");
      const titleEl = taskItem?.querySelector(".task-title");
      const badge = taskItem?.querySelector(".task-badge");
      const newStatus = target.checked ? "complete" : "pending";

      // Optimistic UI update + celebration animation
      if (target.checked) {
        taskItem?.classList.add("task-done");
        taskItem?.classList.add("task-celebrate");
        setTimeout(() => taskItem?.classList.remove("task-celebrate"), 600);
        titleEl?.classList.add("done");
        if (badge) {
          badge.className = "task-badge badge-complete";
          badge.textContent = "Complete";
        }
      } else {
        taskItem?.classList.remove("task-done");
        titleEl?.classList.remove("done");
        if (badge) {
          badge.className = "task-badge badge-pending";
          badge.textContent = "Pending";
        }
      }

      try {
        await taskApi.updateTask(id!, { status: newStatus });
        showToast(
          target.checked ? "common.task_completed" : "common.task_reopened",
        );
        if (target.checked) onTaskCompleted();
      } catch {
        showToast("common.failed_update", "error");
        target.checked = !target.checked; // Revert optimistic update
      }
    });
  });

  // Duplicate task — reload page to get fresh DOM with proper event listeners
  document.querySelectorAll(".task-duplicate").forEach((btn) => {
    btn.addEventListener("click", async (e) => {
      e.stopPropagation();
      const id = (btn as HTMLElement).dataset.id;
      if (!id) return;
      try {
        await taskApi.duplicateTask(id);
        showToast("common.task_created");
        setTimeout(() => window.location.reload(), 500);
      } catch {
        showToast("common.failed", "error");
      }
    });
  });

  // Ask AI handler — routes through configured AI provider
  document.querySelectorAll(".task-ask-ai").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const el = btn as HTMLElement;
      const title = el.dataset.title ?? "";
      const desc = el.dataset.description ?? "";
      const status = el.dataset.status ?? "pending";
      const priority = el.dataset.priority ?? "3";
      const prompt = `I have a task in my task manager:\n\nTitle: ${title}\nStatus: ${status}\nPriority: ${priority}/5\n${desc ? `Description: ${desc}` : ""}\n\nCan you help me break this down, suggest next steps, estimate effort, or identify potential blockers?`;

      // Check configured provider (default: chatgpt)
      const provider =
        localStorage.getItem("meitheal-ai-provider") || "chatgpt";

      if (provider === "ha_llm") {
        // Open HA Assist modal with pre-filled prompt
        const modal = document.getElementById("ask-ha-modal");
        if (modal) {
          modal.classList.add("active");
          const input = modal.querySelector(
            "#ask-ha-input",
          ) as HTMLInputElement;
          if (input) {
            input.value = prompt;
            input.focus();
            // Auto-submit by dispatching the form
            const form = input.closest("form");
            if (form)
              form.dispatchEvent(
                new Event("submit", { bubbles: true, cancelable: true }),
              );
          }
        }
        return;
      }

      const encodedPrompt = encodeURIComponent(prompt);
      const urls: Record<string, string> = {
        chatgpt: `https://chatgpt.com/?q=${encodedPrompt}`,
        claude: `https://claude.ai/new?q=${encodedPrompt}`,
        gemini: `https://gemini.google.com/app?q=${encodedPrompt}`,
        ollama:
          localStorage.getItem("meitheal-ai-custom-url") ||
          "http://localhost:11434",
        custom: localStorage.getItem("meitheal-ai-custom-url") || "",
      };
      const url = urls[provider] || urls.chatgpt;
      if (url) window.open(url, "_blank");
    });
  });

  // Client-side filtering
  function applyFilters() {
    const search = (
      document.getElementById("search-input") as HTMLInputElement
    ).value.toLowerCase();
    const statusFilter = (
      document.getElementById("filter-status") as HTMLSelectElement
    ).value;
    const priorityFilter = (
      document.getElementById("filter-priority") as HTMLSelectElement
    ).value;
    const riceFilter = (
      document.getElementById("filter-rice") as HTMLSelectElement
    ).value;

    document.querySelectorAll(".task-item").forEach((item) => {
      const el = item as HTMLElement;
      // Full-text search across title, description, and labels (#35)
      const matchTitle =
        !search ||
        (el.dataset.search ?? el.dataset.title ?? "").includes(search);
      const matchStatus = matchesStatusFilter(el, statusFilter);
      const matchPriority =
        !priorityFilter || el.dataset.priority === priorityFilter;
      const matchRice = matchesRiceFilter(el, riceFilter);

      const visible = matchTitle && matchStatus && matchPriority && matchRice;
      if (visible) {
        el.classList.remove("filtered-out");
      } else {
        el.classList.add("filtered-out");
      }
    });

    saveFilterState();
  }

  function saveFilterState() {
    const state = {
      search:
        (document.getElementById("search-input") as HTMLInputElement)?.value ??
        "",
      status:
        (document.getElementById("filter-status") as HTMLSelectElement)
          ?.value ?? "",
      priority:
        (document.getElementById("filter-priority") as HTMLSelectElement)
          ?.value ?? "",
      rice:
        (document.getElementById("filter-rice") as HTMLSelectElement)?.value ??
        "",
      sort:
        (document.getElementById("sort-select") as HTMLSelectElement)?.value ??
        "created_at-desc",
    };
    persistFilters(state);
  }

  // Attach filter listeners
  [
    "search-input",
    "filter-status",
    "filter-priority",
    "filter-rice",
    "sort-select",
  ].forEach((id) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.addEventListener(
      id === "search-input" ? "input" : "change",
      applyFilters,
    );
  });

  // Clear all filters
  document.getElementById("clear-filters")?.addEventListener("click", () => {
    (document.getElementById("search-input") as HTMLInputElement).value = "";
    (document.getElementById("filter-status") as HTMLSelectElement).value = "";
    (document.getElementById("filter-priority") as HTMLSelectElement).value =
      "";
    (document.getElementById("filter-rice") as HTMLSelectElement).value = "";
    (document.getElementById("sort-select") as HTMLSelectElement).value =
      "created_at-desc";
    applyFilters();
  });

  try {
    const source = loadFilterState();

    if (source.search)
      (document.getElementById("search-input") as HTMLInputElement).value =
        source.search;
    if (source.status)
      (document.getElementById("filter-status") as HTMLSelectElement).value =
        source.status;
    if (source.priority)
      (document.getElementById("filter-priority") as HTMLSelectElement).value =
        source.priority;
    if (source.rice)
      (document.getElementById("filter-rice") as HTMLSelectElement).value =
        source.rice;
    if (source.sort)
      (document.getElementById("sort-select") as HTMLSelectElement).value =
        source.sort;
    if (source.search || source.status || source.priority || source.rice)
      applyFilters();
  } catch {
    /* ignore */
  }

  // Hash deep-link: #edit-{id} opens task edit
  const hash = window.location.hash;
  if (hash.startsWith("#edit-")) {
    const taskId = hash.slice(6);
    const taskItem = document.querySelector(`.task-item[data-id="${taskId}"]`);
    if (taskItem) {
      taskItem.scrollIntoView({ behavior: "smooth", block: "center" });
      const editBtn = taskItem.querySelector(".edit-btn") as HTMLElement;
      if (editBtn) setTimeout(() => editBtn.click(), 300);
    }
  }

  // =============================================================================
  // Favorite toggle (#47)
  // =============================================================================

  document.querySelectorAll(".task-fav-btn").forEach((btn) => {
    btn.addEventListener("click", async (e) => {
      e.stopPropagation();
      const el = btn as HTMLElement;
      const id = el.dataset.id;
      if (!id) return;
      const isFav = el.classList.contains("is-fav");
      const newFav = !isFav;
      // Optimistic toggle
      el.classList.toggle("is-fav", newFav);
      el.textContent = newFav ? "★" : "☆";
      el.title = newFav ? "★ Favorited" : "☆ Favorite";
      try {
        await taskApi.updateTask(id, { is_favorite: newFav ? 1 : 0 });
      } catch {
        // Revert on error
        el.classList.toggle("is-fav", isFav);
        el.textContent = isFav ? "★" : "☆";
        showToast("common.failed", "error");
      }
    });
  });

  // =============================================================================
  // Keyboard Navigation (#10)
  // =============================================================================

  let focusedIndex = -1;
  const getVisibleTasks = () =>
    Array.from(
      document.querySelectorAll(".task-item:not(.filtered-out)"),
    ) as HTMLElement[];

  function focusTask(index: number) {
    const items = getVisibleTasks();
    if (items.length === 0) return;
    focusedIndex = Math.max(0, Math.min(index, items.length - 1));
    items.forEach((el, i) =>
      el.classList.toggle("task-focused", i === focusedIndex),
    );
    items[focusedIndex]?.scrollIntoView({
      behavior: "smooth",
      block: "nearest",
    });
  }

  document.addEventListener("keydown", (e) => {
    // Don't capture when typing in inputs/selects
    const tag = (e.target as HTMLElement).tagName;
    if (
      tag === "INPUT" ||
      tag === "SELECT" ||
      tag === "TEXTAREA" ||
      (e.target as HTMLElement).contentEditable === "true"
    )
      return;

    const items = getVisibleTasks();
    switch (e.key) {
      case "j":
      case "ArrowDown":
        e.preventDefault();
        focusTask(focusedIndex + 1);
        break;
      case "k":
      case "ArrowUp":
        e.preventDefault();
        focusTask(focusedIndex - 1);
        break;
      case "x":
        if (focusedIndex >= 0 && focusedIndex < items.length) {
          const cb = items[focusedIndex]?.querySelector(
            ".task-checkbox",
          ) as HTMLInputElement;
          if (cb) {
            cb.checked = !cb.checked;
            cb.dispatchEvent(new Event("change", { bubbles: true }));
          }
        }
        break;
      case "e":
      case "Enter":
        if (focusedIndex >= 0 && focusedIndex < items.length) {
          const id = items[focusedIndex]?.dataset.id;
          if (id)
            document.dispatchEvent(
              new CustomEvent("meitheal:open-task-detail", { detail: { id } }),
            );
        }
        break;
      case "n":
        if (!e.ctrlKey && !e.metaKey) {
          document.dispatchEvent(new CustomEvent("meitheal:new-task"));
        }
        break;
    }
  });
</script>

<style>
  .filter-bar {
    display: flex;
    gap: 10px;
    margin-bottom: 16px;
    flex-wrap: wrap;
    align-items: center;
  }
  .filter-search {
    max-width: 300px;
    flex: 1;
    min-width: 150px;
  }
  .filter-select {
    max-width: 150px;
  }
  .task-done {
    opacity: 0.6;
  }
  .task-title {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .task-title-text {
    font-weight: 500;
  }
  .ticket-key-inline {
    font-size: 11px;
    font-family: "JetBrains Mono", monospace;
    color: var(--text-muted);
    font-weight: 500;
    background: rgba(255, 255, 255, 0.05);
    padding: 2px 6px;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .task-meta {
    display: flex;
    gap: 4px;
    align-items: center;
    flex-wrap: wrap;
  }
  .task-custom-fields {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  .custom-field-chip {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 10px;
    background: rgba(99, 102, 241, 0.1);
    color: var(--accent);
    border: 1px solid rgba(99, 102, 241, 0.2);
  }
  .overdue-tag {
    font-size: 10px;
    padding: 1px 6px;
    border-radius: 8px;
    background: var(--danger);
    color: white;
    margin-left: 4px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .page-actions {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  /* Favorite star button */
  .task-fav-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 16px;
    color: var(--text-muted);
    padding: 2px;
    transition:
      transform 200ms ease,
      color 200ms ease;
    flex-shrink: 0;
  }
  .task-fav-btn:hover {
    transform: scale(1.2);
    color: var(--warning);
  }
  .task-fav-btn.is-fav {
    color: var(--warning);
  }
  /* Color indicator dot */
  .task-color-dot {
    width: 4px;
    border-radius: 4px;
    align-self: stretch;
    flex-shrink: 0;
    min-height: 20px;
  }
  /* Progress bar */
  .task-progress {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
  }
  .task-progress-track {
    flex: 1;
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
    max-width: 120px;
  }
  .task-progress-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 2px;
    transition: width 300ms ease;
  }
  .task-progress-label {
    font-size: 11px;
    color: var(--text-muted);
    font-weight: 500;
  }
  /* Keyboard focus highlight */
  .task-focused {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
