---
import Layout from "../layouts/Layout.astro";
import EmptyState from "../components/ui/EmptyState.astro";
import {
  ensureSchema,
  getPersistenceClient,
} from "@domains/tasks/persistence/store";
interface DayGroup {
  date: string;
  label: string;
  isToday: boolean;
  isTomorrow: boolean;
  tasks: Record<string, unknown>[];
}

const days: DayGroup[] = [];

try {
  await ensureSchema();
  const client = getPersistenceClient();
  const today = new Date();
  const todayStr = today.toISOString().split("T")[0] ?? "";

  // Persona 9: Single query for all 7 days instead of 7 sequential queries
  const endDate = new Date(today);
  endDate.setDate(endDate.getDate() + 6);
  const endStr = endDate.toISOString().split("T")[0] ?? "";

  const result = await client.execute({
    sql: `SELECT * FROM tasks
          WHERE due_date >= ? AND due_date <= ?
            AND status NOT IN ('complete', 'done')
          ORDER BY due_date ASC, priority DESC, created_at ASC`,
    args: [todayStr, endStr],
  });

  const tasksByDate = new Map<string, Record<string, unknown>[]>();
  for (const row of result.rows) {
    const r = row as Record<string, unknown>;
    const d = String(r.due_date);
    if (!tasksByDate.has(d)) tasksByDate.set(d, []);
    tasksByDate.get(d)!.push(r);
  }

  for (let i = 0; i < 7; i++) {
    const d = new Date(today);
    d.setDate(d.getDate() + i);
    const dateStr = d.toISOString().split("T")[0] ?? "";

    const weekday = d.toLocaleDateString("en-US", { weekday: "long" });
    const monthDay = d.toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
    });

    let label = `${weekday}, ${monthDay}`;
    if (i === 0) label = `Today — ${monthDay}`;
    if (i === 1) label = `Tomorrow — ${monthDay}`;

    days.push({
      date: dateStr,
      label,
      isToday: i === 0,
      isTomorrow: i === 1,
      tasks: tasksByDate.get(dateStr) ?? [],
    });
  }
} catch {
  /* DB not available */
}

const priorityLabels: Record<number, string> = {
  1: "Lowest",
  2: "Low",
  3: "Medium",
  4: "High",
  5: "Highest",
};
const priorityColors: Record<number, string> = {
  1: "#6b7280",
  2: "#10b981",
  3: "#3b82f6",
  4: "#f59e0b",
  5: "#ef4444",
};
const typeIcons: Record<string, string> = {
  epic: "🎯",
  story: "📖",
  task: "📌",
};

const totalTasks = days.reduce((sum, d) => sum + d.tasks.length, 0);
---

<Layout title="Meitheal — Upcoming">
  <span slot="page-title">📅 Upcoming</span>
  <div slot="actions">
    <a href="/today" class="btn btn-ghost" style="font-size: 13px;">☀️ Today</a>
    <a href="/calendar" class="btn btn-ghost" style="font-size: 13px;"
      >🗓️ Calendar</a
    >
    <button
      type="button"
      class="btn btn-primary"
      id="create-task-btn"
      style="font-size: 13px;">+ New Task</button
    >
  </div>

  <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 12px;">
    {totalTasks}
    {totalTasks === 1 ? "task" : "tasks"} in the next 7 days
  </div>

  {
    totalTasks === 0 && (
      <EmptyState
        title="No upcoming tasks"
        description="Your schedule is clear for the next 7 days."
        actionText="Plan something"
        actionHref="/tasks"
      />
    )
  }

  <div class="upcoming-grid">
    {
      days.map((day) => (
        <div
          class={`card ${day.tasks.length === 0 ? "day-empty" : ""}`}
          style={`margin-bottom: ${day.tasks.length > 0 ? "12px" : "4px"}; ${day.isToday ? "border-left: 3px solid var(--accent);" : ""}`}
        >
          <div
            style={`padding: ${day.tasks.length > 0 ? "10px 16px" : "8px 16px"}; display: flex; align-items: center; justify-content: space-between;`}
          >
            <div style="display: flex; align-items: center; gap: 8px;">
              <span
                style={`font-size: 13px; font-weight: ${day.isToday || day.isTomorrow ? "600" : "500"}; color: ${day.isToday ? "var(--accent)" : "var(--text-primary)"};`}
              >
                {day.label}
              </span>
            </div>
            {day.tasks.length > 0 && (
              <span style="font-size: 11px; background: var(--accent); color: white; padding: 1px 6px; border-radius: 8px; font-weight: 600;">
                {day.tasks.length}
              </span>
            )}
            {day.tasks.length === 0 && (
              <span style="font-size: 11px; color: var(--text-muted); font-style: italic;">
                —
              </span>
            )}
          </div>
          {day.tasks.length > 0 && (
            <div class="task-list">
              {day.tasks.map((task) => {
                const p = Number(task.priority ?? 3);
                const tt = String(task.task_type ?? "task");
                return (
                  <div
                    class="task-item"
                    data-id={String(task.id)}
                    style="cursor:pointer; padding: 8px 16px; display: flex; align-items: center; gap: 10px; border-top: 1px solid var(--border); transition: background 0.15s;"
                    role="button"
                    tabindex="0"
                    aria-label={`${String(task.title)}, priority ${priorityLabels[p] ?? "Medium"}, due ${day.label}`}
                  >
                    <input
                      type="checkbox"
                      class="task-checkbox"
                      data-id={String(task.id)}
                      aria-label={`Complete ${String(task.title)}`}
                    />
                    <span
                      style={`color: ${priorityColors[p] ?? "#3b82f6"}; font-size: 10px; flex-shrink: 0;`}
                      title={`Priority: ${priorityLabels[p] ?? "Medium"}`}
                    >
                      ●
                    </span>
                    <div style="flex: 1; min-width: 0;">
                      <div style="font-size: 13px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                        <span style="margin-right: 3px; font-size: 11px;">
                          {typeIcons[tt] ?? ""}
                        </span>
                        {String(task.title)}
                      </div>
                    </div>
                    {task.color && (
                      <span
                        style={`width: 4px; height: 20px; border-radius: 2px; background: ${String(task.color)}; flex-shrink: 0;`}
                      />
                    )}
                    {task.recurrence_rule && (
                      <span
                        style="font-size: 10px; color: var(--text-muted);"
                        title="Recurring"
                      >
                        🔁
                      </span>
                    )}
                  </div>
                );
              })}
            </div>
          )}
        </div>
      ))
    }
  </div>
</Layout>

<style>
  .day-empty {
    opacity: 0.6;
  }
  .day-empty:hover {
    opacity: 0.8;
  }
  .task-item:hover {
    background: var(--bg-hover);
  }
  .task-item:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
  }
</style>

<script>
  // Task checkbox completion
  document
    .querySelectorAll<HTMLInputElement>(".task-checkbox")
    .forEach((cb) => {
      cb.addEventListener("change", async () => {
        const id = cb.dataset.id;
        if (!id) return;
        try {
          await fetch(`${window.__ingress_path || ""}/api/tasks/${id}`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ status: cb.checked ? "done" : "pending" }),
          });
          const item = cb.closest(".task-item") as HTMLElement | null;
          if (cb.checked && item) {
            item.style.opacity = "0.4";
            item.style.transition = "opacity 0.3s";
            setTimeout(() => item.remove(), 800);
          }
        } catch {
          /* retry silently */
        }
      });
    });

  // Click to open task detail
  document.querySelectorAll<HTMLElement>(".task-item").forEach((item) => {
    item.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).tagName === "INPUT") return;
      const id = item.dataset.id;
      if (id)
        window.location.href =
          (window.__ingress_path || "") + `/tasks#task-${id}`;
    });
    item.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        const id = (e.target as HTMLElement).dataset?.id;
        if (id)
          window.location.href =
            (window.__ingress_path || "") + `/tasks#task-${id}`;
      }
    });
  });
</script>
