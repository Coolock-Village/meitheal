---
import Layout from "../layouts/Layout.astro";
import {
  ensureSchema,
  getPersistenceClient,
} from "@domains/tasks/persistence/store";

const cookieLocale = Astro.cookies.get("meitheal-locale")?.value;
const locale = cookieLocale === "ga" ? "ga" : "en";

interface DayGroup {
  date: string;
  label: string;
  tasks: Record<string, unknown>[];
}

const days: DayGroup[] = [];

try {
  await ensureSchema();
  const client = getPersistenceClient();
  const today = new Date();

  for (let i = 0; i < 7; i++) {
    const d = new Date(today);
    d.setDate(d.getDate() + i);
    const dateStr = d.toISOString().split("T")[0] ?? "";

    let label = d.toLocaleDateString("en-US", {
      weekday: "long",
      month: "short",
      day: "numeric",
    });
    if (i === 0) label = `Today — ${label}`;
    if (i === 1) label = `Tomorrow — ${label}`;

    const result = await client.execute({
      sql: `SELECT * FROM tasks
            WHERE due_date = ?
              AND status NOT IN ('complete', 'done')
            ORDER BY priority ASC, created_at ASC`,
      args: [dateStr],
    });

    days.push({
      date: dateStr,
      label,
      tasks: result.rows as Record<string, unknown>[],
    });
  }
} catch {
  /* DB not available */
}

const priorityColors: Record<number, string> = {
  1: "#ef4444",
  2: "#f59e0b",
  3: "#3b82f6",
  4: "#10b981",
  5: "#6b7280",
};
const typeIcons: Record<string, string> = {
  epic: "🎯",
  story: "📖",
  task: "✅",
};
---

<Layout title="Meitheal — Upcoming">
  <span slot="page-title">📅 Upcoming</span>
  <div slot="actions">
    <a href="/today" class="btn btn-ghost">☀️ Today</a>
    <a href="/calendar" class="btn btn-ghost">🗓️ Calendar</a>
  </div>

  <div class="upcoming-grid">
    {
      days.map((day) => (
        <div class="card" style="margin-bottom: 16px;">
          <div class="card-header" style="padding: 12px 16px;">
            <div>
              <div class="card-title" style="font-size: 14px;">
                {day.label}
              </div>
              <div class="card-subtitle">
                {day.tasks.length} {day.tasks.length === 1 ? "task" : "tasks"}
              </div>
            </div>
          </div>
          {day.tasks.length === 0 ? (
            <div style="padding: 12px 16px; color: var(--text-muted); font-size: 13px; font-style: italic;">
              Nothing scheduled
            </div>
          ) : (
            <div class="task-list">
              {day.tasks.map((task) => {
                const p = Number(task.priority ?? 3);
                const tt = String(task.task_type ?? "task");
                return (
                  <div
                    class="task-item"
                    data-id={String(task.id)}
                    style="cursor:pointer;"
                  >
                    <input
                      type="checkbox"
                      class="task-checkbox"
                      data-id={String(task.id)}
                    />
                    <div class="task-content">
                      <div class="task-title">
                        <span style="margin-right:4px;">
                          {typeIcons[tt] ?? "✅"}
                        </span>
                        {String(task.title)}
                      </div>
                      <div class="task-meta">
                        <span
                          style={`color: ${priorityColors[p] ?? "#6b7280"}; font-size: 11px;`}
                        >
                          ●
                        </span>
                        {task.recurrence_rule && (
                          <span class="text-xs text-text-muted">🔁</span>
                        )}
                      </div>
                    </div>
                    {task.color && (
                      <span
                        style={`width:4px;height:100%;border-radius:2px;background:${String(task.color)};flex-shrink:0;`}
                      />
                    )}
                  </div>
                );
              })}
            </div>
          )}
        </div>
      ))
    }
  </div>
</Layout>

<script>
  // Task checkbox completion
  document
    .querySelectorAll<HTMLInputElement>(".task-checkbox")
    .forEach((cb) => {
      cb.addEventListener("change", async () => {
        const id = cb.dataset.id;
        if (!id) return;
        try {
          await fetch(`/api/tasks/${id}`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ status: cb.checked ? "done" : "pending" }),
          });
          cb.closest(".task-item")?.classList.toggle("task-done", cb.checked);
        } catch {
          /* retry silently */
        }
      });
    });

  // Click to open task detail
  document.querySelectorAll<HTMLElement>(".task-item").forEach((item) => {
    item.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).tagName === "INPUT") return;
      const id = item.dataset.id;
      if (id) window.location.href = `/tasks#task-${id}`;
    });
  });
</script>
